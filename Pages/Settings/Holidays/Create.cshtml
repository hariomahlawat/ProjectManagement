@page
@model ProjectManagement.Pages.Settings.Holidays.CreateModel
@using ProjectManagement.Areas.Admin.Models
@using ProjectManagement.Models.Scheduling
@{
    ViewData["Title"] = "Add holiday entry";
    var header = new AdminPageHeaderModel { Eyebrow = "Master data · Office calendar", Title = "Add holiday entry", Description = "Record a Gazetted Holiday or add a Restricted Holiday to the shared calendar for information.", Icon = "bi-calendar-plus", Actions = new[] { new AdminPageActionModel { Text = "Back to holidays", Href = Url.Page("./Index", new { year = Model.Input.Date.Year }), Icon = "bi-arrow-left" } } };
}
<partial name="~/Areas/Admin/Pages/Shared/_AdminPageHeader.cshtml" model="header" />
<div class="admin-form-layout">
<form method="post" class="admin-panel admin-form-panel" novalidate>
<header class="admin-form-section__header"><span>01</span><div><h2>Holiday details</h2><p>Classification determines the default office status and schedule effect.</p></div></header>
<div class="admin-form-section__body">
<div asp-validation-summary="ModelOnly" class="admin-validation-summary" role="alert"></div>
<div class="admin-form-grid admin-form-grid--two">
<div class="admin-field"><label asp-for="Input.Date"></label><input asp-for="Input.Date" class="form-control" type="date" /><span asp-validation-for="Input.Date" class="text-danger"></span></div>
<div class="admin-field"><label asp-for="Input.Type"></label><select asp-for="Input.Type" class="form-select" data-holiday-type><option value="@HolidayType.Gazetted">Gazetted Holiday</option><option value="@HolidayType.Restricted">Restricted Holiday</option></select><span asp-validation-for="Input.Type" class="text-danger"></span></div>
<div class="admin-field admin-field--wide"><label asp-for="Input.Name"></label><input asp-for="Input.Name" class="form-control" maxlength="160" autocomplete="off" autofocus /><span asp-validation-for="Input.Name" class="text-danger"></span></div>
<div class="admin-field admin-field--wide"><label asp-for="Input.AuthorityReference"></label><input asp-for="Input.AuthorityReference" class="form-control" maxlength="240" placeholder="Notification, office order or authority reference" /><span asp-validation-for="Input.AuthorityReference" class="text-danger"></span></div>
<div class="admin-field admin-field--wide"><label asp-for="Input.Remarks"></label><textarea asp-for="Input.Remarks" class="form-control" rows="3" maxlength="1200" placeholder="Optional administrative context"></textarea><span asp-validation-for="Input.Remarks" class="text-danger"></span></div>
</div>
<div class="admin-holiday-behaviour" data-holiday-behaviour><i class="bi bi-building-x"></i><div><strong>Gazetted Holiday</strong><span>The office is closed and the date is excluded from future working-day calculations.</span></div></div>
</div>
<footer class="admin-form-actions"><a asp-page="./Index" asp-route-year="@Model.Input.Date.Year" class="btn btn-outline-secondary">Cancel</a><button class="btn btn-primary" type="submit"><i class="bi bi-plus-lg"></i>Add entry</button></footer>
</form>
<aside class="admin-guidance-card"><span class="admin-guidance-card__icon"><i class="bi bi-calendar-week"></i></span><h2>Restricted Holidays</h2><p>A new Restricted Holiday is informational by default: it appears on the calendar while the office remains open. It can later be declared as an office holiday through a controlled action.</p></aside>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script src="~/js/pages/holiday-admin.js" asp-append-version="true"></script> }
