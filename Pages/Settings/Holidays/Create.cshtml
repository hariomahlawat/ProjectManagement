@page
@model ProjectManagement.Pages.Settings.Holidays.CreateModel
@using ProjectManagement.Areas.Admin.Models
@{
    ViewData["Title"] = "Add holiday";
    var header = new AdminPageHeaderModel { Eyebrow = "Master data · Holidays", Title = "Add holiday", Description = "Add an official non-working date to project scheduling and calendar views.", Icon = "bi-calendar-plus", Actions = new[] { new AdminPageActionModel { Text = "Back to holidays", Href = Url.Page("./Index", new { year = Model.Input.Date.Year }), Icon = "bi-arrow-left" } } };
}
<partial name="~/Areas/Admin/Pages/Shared/_AdminPageHeader.cshtml" model="header" />
<div class="admin-form-layout"><form method="post" class="admin-panel admin-form-panel" novalidate><header class="admin-form-section__header"><span>01</span><div><h2>Holiday details</h2><p>Only one holiday can be recorded for a date.</p></div></header><div class="admin-form-section__body"><div asp-validation-summary="ModelOnly" class="admin-validation-summary" role="alert"></div><div class="admin-form-grid admin-form-grid--two"><div class="admin-field"><label asp-for="Input.Date"></label><input asp-for="Input.Date" class="form-control" type="date" /><span asp-validation-for="Input.Date" class="text-danger"></span></div><div class="admin-field admin-field--wide"><label asp-for="Input.Name"></label><input asp-for="Input.Name" class="form-control" maxlength="160" autocomplete="off" autofocus /><span asp-validation-for="Input.Name" class="text-danger"></span></div></div></div><footer class="admin-form-actions"><a asp-page="./Index" asp-route-year="@Model.Input.Date.Year" class="btn btn-outline-secondary">Cancel</a><button class="btn btn-primary" type="submit"><i class="bi bi-plus-lg"></i>Add holiday</button></footer></form><aside class="admin-guidance-card"><span class="admin-guidance-card__icon"><i class="bi bi-calendar-week"></i></span><h2>Scheduling effect</h2><p>The selected date will be excluded from working-day calculations. Review any already approved deadlines separately.</p></aside></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
