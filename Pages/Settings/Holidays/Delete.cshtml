@page "{id:int}"
@model ProjectManagement.Pages.Settings.Holidays.DeleteModel
@{
    ViewData["Title"] = "Delete holiday";
}

@if (Model.Item is null)
{
    <div class="alert alert-warning" role="status">The requested holiday could not be found.</div>
}
else
{
    <div class="card border-danger">
        <div class="card-body">
            <h1 class="h4">Delete holiday</h1>
            <p>This removes the date from project schedule calculations and calendar views.</p>

            <dl class="row mb-4">
                <dt class="col-sm-3">Date</dt>
                <dd class="col-sm-9">@Model.Item.Date.ToString("dd MMM yyyy") (@Model.Item.Date.DayOfWeek)</dd>
                <dt class="col-sm-3">Holiday</dt>
                <dd class="col-sm-9">@Model.Item.Name</dd>
            </dl>

            <form method="post">
                <input asp-for="RowVersion" type="hidden" />
                <button type="submit" class="btn btn-danger">Delete holiday</button>
                <a asp-page="Index" asp-route-year="@Model.Item.Date.Year" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
}
