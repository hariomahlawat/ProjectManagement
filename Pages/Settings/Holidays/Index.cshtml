@page
@model ProjectManagement.Pages.Settings.Holidays.IndexModel
@{
    ViewData["Title"] = "Holidays";
}
<partial name="~/Areas/Admin/Pages/Shared/_AdminPageHeader.cshtml" model="Model.Header" />
<partial name="~/Areas/Admin/Pages/Shared/_AdminFlashMessages.cshtml" />
<section class="admin-master-summary-grid" aria-label="Holiday summary">
    <article class="admin-monitoring-metric admin-monitoring-metric--neutral"><span class="admin-monitoring-metric__icon"><i class="bi bi-calendar-week"></i></span><span class="admin-monitoring-metric__copy"><strong>@Model.Items.Count</strong><span>Holidays</span><small>@Model.Year calendar year</small></span></article>
    <article class="admin-monitoring-metric admin-monitoring-metric--info"><span class="admin-monitoring-metric__icon"><i class="bi bi-calendar-event"></i></span><span class="admin-monitoring-metric__copy"><strong>@Model.UpcomingCount</strong><span>Upcoming</span><small>On or after today</small></span></article>
    <article class="admin-monitoring-metric admin-monitoring-metric--neutral"><span class="admin-monitoring-metric__icon"><i class="bi bi-clock-history"></i></span><span class="admin-monitoring-metric__copy"><strong>@Model.ElapsedCount</strong><span>Elapsed</span><small>Already observed</small></span></article>
    <article class="admin-monitoring-metric admin-monitoring-metric--warning"><span class="admin-monitoring-metric__icon"><i class="bi bi-calendar2-week"></i></span><span class="admin-monitoring-metric__copy"><strong>@Model.WeekendCount</strong><span>Weekend dates</span><small>Review scheduling impact</small></span></article>
</section>
<section class="admin-panel" aria-labelledby="holiday-directory-title">
<header class="admin-panel__header"><div><div class="admin-panel__eyebrow">Calendar year</div><h2 id="holiday-directory-title">Holiday directory</h2></div><span class="admin-panel__meta">@Model.Items.Count record@(Model.Items.Count == 1 ? string.Empty : "s")</span></header>
<form method="get" class="admin-year-toolbar"><a class="btn btn-sm btn-outline-secondary" asp-route-year="@(Model.Year - 1)" aria-label="Previous year"><i class="bi bi-chevron-left"></i></a><div class="admin-filter-toolbar__field"><label asp-for="Year">Year</label><select asp-for="Year" class="form-select">@foreach (var year in Model.AvailableYears){<option value="@year">@year</option>}</select></div><button class="btn btn-primary" type="submit">View year</button><a class="btn btn-sm btn-outline-secondary" asp-route-year="@(Model.Year + 1)" aria-label="Next year"><i class="bi bi-chevron-right"></i></a></form>
@if (Model.Items.Count == 0)
{
<partial name="~/Areas/Admin/Pages/Shared/_AdminEmptyState.cshtml" model="@(new ProjectManagement.Areas.Admin.Models.AdminEmptyStateModel { Icon = "bi-calendar-week", Title = $"No holidays recorded for {Model.Year}", Description = "Add the first official non-working date for this year.", ActionText = "Add holiday", ActionHref = Url.Page("./Create", new { year = Model.Year }) })" />
}
else
{
<div class="admin-data-table-wrap"><table class="admin-data-table"><thead><tr><th>Date</th><th>Day</th><th>Holiday</th><th>Schedule effect</th><th class="admin-data-table__actions">Actions</th></tr></thead><tbody>@foreach (var holiday in Model.Items){var weekend = holiday.Date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;<tr><td><div class="admin-activity-value"><strong>@holiday.Date.ToString("dd MMM yyyy")</strong><span>@holiday.Date.ToString("yyyy-MM-dd")</span></div></td><td>@holiday.Date.DayOfWeek</td><td><div class="admin-lookup-name"><span><i class="bi bi-calendar-event"></i></span><strong>@holiday.Name</strong></div></td><td><span class="admin-status-pill admin-status-pill--@(weekend ? "warning" : "info")">@(weekend ? "Weekend holiday" : "Non-working day")</span></td><td class="admin-data-table__actions"><div class="dropdown"><button class="btn btn-sm btn-icon" type="button" data-bs-toggle="dropdown" aria-label="Actions for @holiday.Name"><i class="bi bi-three-dots"></i></button><ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item" asp-page="./Edit" asp-route-id="@holiday.Id"><i class="bi bi-pencil-square"></i>Edit</a></li><li><a class="dropdown-item text-danger" asp-page="./Delete" asp-route-id="@holiday.Id"><i class="bi bi-trash3"></i>Delete</a></li></ul></div></td></tr>}</tbody></table></div>
}
</section>
<section class="admin-guidance-strip"><span><i class="bi bi-info-circle"></i></span><div><strong>Schedule impact</strong><p>Holiday dates are treated as non-working days by project schedule calculations. Changes apply immediately to future calculations.</p></div></section>
