@page "{id:int}"
@model ProjectManagement.Pages.Settings.Holidays.EditModel
@{
    ViewData["Title"] = "Edit holiday";
}

<div class="mb-3">
    <a asp-page="Index" asp-route-year="@Model.Input.Date.Year" class="text-decoration-none">
        <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to holidays
    </a>
</div>

<div class="card">
    <div class="card-body">
        <h1 class="h4 mb-1">Edit holiday</h1>
        <p class="text-muted">Update the date or official description.</p>

        <form method="post" class="mt-4" novalidate>
            <input asp-for="Input.Id" type="hidden" />
            <input asp-for="Input.RowVersion" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Input.Date" class="form-label"></label>
                    <input asp-for="Input.Date" class="form-control" type="date" />
                    <span asp-validation-for="Input.Date" class="text-danger"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Input.Name" class="form-label"></label>
                    <input asp-for="Input.Name" class="form-control" maxlength="160" autocomplete="off" />
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save changes</button>
                <a asp-page="Index" asp-route-year="@Model.Input.Date.Year" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
