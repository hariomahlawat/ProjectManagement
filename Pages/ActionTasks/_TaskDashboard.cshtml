@model ProjectManagement.Pages.ActionTasks.IndexModel
@using ProjectManagement.Models
@{
    var attention = new List<(ProjectManagement.Pages.ActionTasks.IndexModel.TaskDisplayItem Item, string Label, string Tone, int Rank)>();
    var seen = new HashSet<int>();

    void AddItems(IEnumerable<ProjectManagement.Pages.ActionTasks.IndexModel.TaskDisplayItem> items, string label, string tone, int rank)
    {
        foreach (var item in items)
        {
            if (seen.Add(item.Task.Id))
            {
                attention.Add((item, label, tone, rank));
            }
        }
    }

    AddItems(Model.CommandBlockedTaskDisplays.Where(x => string.Equals(x.Task.Priority, "Critical", StringComparison.OrdinalIgnoreCase)), "Blocked · Critical", "danger", 0);
    AddItems(Model.CommandBlockedTaskDisplays, "Blocked", "warning", 1);
    AddItems(Model.CommandPendingClosureTaskDisplays, "Awaiting closure", "info", 2);
    AddItems(Model.CommandOverdueTaskDisplays.OrderBy(x => x.Task.DueDate), "Overdue", "danger", 3);
    AddItems(Model.CommandCriticalOpenTaskDisplays, "Critical", "neutral", 4);
    var orderedAttention = attention.OrderBy(x => x.Rank).ThenBy(x => x.Item.Task.DueDate).ToList();
    var recentCount = Model.RecentlySubmittedTaskDisplays.Count + Model.RecentlyUpdatedTaskDisplays.Count;
}

<section class="at-overview-headline" aria-label="Task summary">
    <div class="at-overview-strip">
        <a asp-page="/ActionTasks/Index" asp-route-viewMode="Register" asp-route-TaskScope="Open" class="at-overview-metric @(Model.OverdueCount > 0 ? "is-danger" : string.Empty)">
            <span>Overdue</span><strong>@Model.OverdueCount</strong>
        </a>
        <a asp-page="/ActionTasks/Index" asp-route-viewMode="Register" asp-route-TaskScope="Open" asp-route-FilterStatus="Blocked" class="at-overview-metric @(Model.BlockedCount > 0 ? "is-warning" : string.Empty)">
            <span>Blocked</span><strong>@Model.BlockedCount</strong>
        </a>
        <a asp-page="/ActionTasks/Index" asp-route-viewMode="Register" asp-route-TaskScope="Open" asp-route-FilterStatus="Submitted" class="at-overview-metric @(Model.SubmittedPendingClosureCount > 0 ? "is-info" : string.Empty)">
            <span>Awaiting closure</span><strong>@Model.SubmittedPendingClosureCount</strong>
        </a>
        <a asp-page="/ActionTasks/Index" asp-route-viewMode="Register" asp-route-TaskScope="Open" asp-route-FilterPriority="Critical" class="at-overview-metric">
            <span>Critical</span><strong>@Model.CriticalOpenCount</strong>
        </a>
    </div>
    <a asp-page="/ActionTasks/Index" asp-route-viewMode="Register" asp-route-TaskScope="Open" class="at-open-total-link">
        <strong>@Model.OpenTaskCount</strong> open tasks
        <i class="bi bi-arrow-right" aria-hidden="true"></i>
    </a>
</section>

@if (Model.ActiveSprint is not null)
{
    <section class="at-panel at-sprint-glance" aria-label="Active sprint">
        <div class="at-sprint-glance-main">
            <div class="at-sprint-glance-title">
                <span class="at-label">Active sprint</span>
                <h2>@Model.ActiveSprint.StartDate.ToString("dd")–@Model.ActiveSprint.EndDate.ToString("dd MMM yyyy")</h2>
                <span class="at-sprint-status-pill">Active</span>
            </div>
            <div class="at-sprint-glance-counts" aria-label="Active sprint summary">
                <span><strong>@Model.ActiveSprintMetrics.TotalTasks</strong> tasks</span>
                <span><strong>@Model.ActiveSprintMetrics.InProgressTasks</strong> in progress</span>
                <span class="@(Model.ActiveSprintMetrics.OverdueTasks > 0 ? "is-danger" : string.Empty)"><strong>@Model.ActiveSprintMetrics.OverdueTasks</strong> overdue</span>
                <span class="@(Model.ActiveSprintMetrics.BlockedTasks > 0 ? "is-warning" : string.Empty)"><strong>@Model.ActiveSprintMetrics.BlockedTasks</strong> blocked</span>
            </div>
        </div>
        <a asp-page="/ActionTasks/Index" asp-route-viewMode="Planning" asp-route-PlanningTab="Execute" asp-route-SelectedSprintId="@Model.ActiveSprint.Id" class="btn btn-outline-primary btn-sm">Open board</a>
    </section>
}
else if (Model.CanPlanSprints)
{
    <section class="at-panel at-sprint-glance is-empty" aria-label="No active sprint">
        <div><span class="at-label">Active sprint</span><h2>No active sprint</h2></div>
        <a asp-page="/ActionTasks/Index" asp-route-viewMode="Planning" asp-route-PlanningTab="Plan" class="btn btn-outline-primary btn-sm">Plan a sprint</a>
    </section>
}

<section class="at-panel at-attention-feed" aria-label="Needs attention">
    <div class="at-simple-section-heading">
        <h2>Needs attention</h2>
        <span>@orderedAttention.Count</span>
    </div>

    @if (!orderedAttention.Any())
    {
        <div class="at-empty-state at-empty-state-calm">
            <i class="bi bi-check2-circle" aria-hidden="true"></i>
            <strong>Nothing needs command attention.</strong>
        </div>
    }
    else
    {
        <div class="at-unified-attention-list">
            @foreach (var entry in orderedAttention)
            {
                var task = entry.Item.Task;
                <a class="at-unified-attention-row is-@entry.Tone @(Model.IsSelectedTask(task) ? "is-selected" : string.Empty)" asp-page="/ActionTasks/Index" asp-route-taskId="@task.Id" asp-route-viewMode="@Model.ResolvedViewMode">
                    <span class="at-attention-reason">@entry.Label</span>
                    <span class="at-attention-task">AT-@task.Id · @task.Title</span>
                    <span class="at-attention-owner">@entry.Item.AssigneeName</span>
                    <span class="at-attention-date">Due @task.DueDate.ToString("dd MMM yyyy")</span>
                    <i class="bi bi-chevron-right" aria-hidden="true"></i>
                </a>
            }
        </div>
    }
</section>

@if (Model.HasRecentActivityItems)
{
    <details class="at-panel at-quiet-details">
        <summary>Recent activity <span class="at-count-chip">@recentCount updates</span></summary>
        <div class="at-card-grid mt-3">
            @if (Model.RecentlySubmittedTaskDisplays.Any())
            {
                <article class="at-panel at-subpanel">
                    <div class="at-panel-heading"><h3>Recently submitted</h3><span class="at-count-chip">@Model.RecentlySubmittedTaskDisplays.Count</span></div>
                    <partial name="_TaskMiniList" model='@Tuple.Create(Model, Model.RecentlySubmittedTaskDisplays, string.Empty)' />
                </article>
            }
            @if (Model.RecentlyUpdatedTaskDisplays.Any())
            {
                <article class="at-panel at-subpanel">
                    <div class="at-panel-heading"><h3>Recently updated</h3><span class="at-count-chip">@Model.RecentlyUpdatedTaskDisplays.Count</span></div>
                    <partial name="_TaskMiniList" model='@Tuple.Create(Model, Model.RecentlyUpdatedTaskDisplays, string.Empty)' />
                </article>
            }
        </div>
    </details>
}
