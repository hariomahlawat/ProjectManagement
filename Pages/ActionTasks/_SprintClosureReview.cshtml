@model ProjectManagement.Pages.ActionTasks.IndexModel

@if (Model.SelectedSprint is not null && Model.CanReviewSprintClosure)
{
    var review = Model.SprintClosureReview;
    <section id="sprint-closure-review" class="at-panel at-closure-review" data-at-closure-review="true">
        <div class="at-panel-heading">
            <div>
                <h2>Review sprint closure</h2>
                <p class="at-panel-note">Choose what happens to each unfinished task.</p>
            </div>
            <span class="at-count-chip">@review.UnfinishedTasks.Count unfinished</span>
        </div>

        <div class="at-closure-metrics" aria-label="Sprint closure summary">
            <div><span>@review.CompletedTasks.Count</span><small>Completed</small></div>
            <div><span>@review.UnfinishedTasks.Count</span><small>Unfinished</small></div>
            <div><span>@review.BlockedTasks.Count</span><small>Blocked</small></div>
            <div><span>@review.SubmittedPendingClosureTasks.Count</span><small>Awaiting closure</small></div>
        </div>

        <form method="post" asp-page-handler="CloseSprintWithDisposition" class="at-closure-form" data-at-closure-form="true">
            <input type="hidden" asp-for="ClosureInput.SprintId" value="@Model.SelectedSprint.Id" />
            <input type="hidden" asp-for="ClosureInput.RowVersion" value="@Convert.ToBase64String(Model.SelectedSprint.RowVersion)" />

            @if (review.UnfinishedTasks.Any())
            {
                <div class="at-closure-target-tools" data-at-closure-target-tools="true" data-at-force-visible="@(Model.ShowCreateNextSprintPanel ? "true" : "false")" @(Model.ShowCreateNextSprintPanel ? null : "hidden")>
                    <div class="at-closure-target-row">
                        <label class="form-label" asp-for="ClosureInput.TargetSprintId">Carry unfinished work to</label>
                        <select class="form-select" asp-for="ClosureInput.TargetSprintId" data-at-closure-target="true" disabled>
                            <option value="">Select destination sprint</option>
                            @foreach (var sprint in Model.ClosureTargetSprints)
                            {
                                <option value="@sprint.Id">@sprint.StartDate.ToString("dd")–@sprint.EndDate.ToString("dd MMM yyyy") · @sprint.Status</option>
                            }
                        </select>
                    </div>
                    @if (Model.ShouldShowCreateNextSprint)
                    {
                        <details class="at-next-sprint-panel" open="@Model.ShowCreateNextSprintPanel" data-at-create-next-sprint="true">
                            <summary class="btn btn-outline-primary btn-sm">Create next sprint</summary>
                            <div class="at-sprint-command-form">
                                <input type="hidden" asp-for="NextSprintInput.SourceSprintId" value="@Model.SelectedSprint.Id" />
                                <div asp-validation-summary="All" class="text-danger small"></div>
                                <label class="form-label" asp-for="NextSprintInput.Name"></label>
                                <input class="form-control" asp-for="NextSprintInput.Name" maxlength="160" />
                                <label class="form-label" asp-for="NextSprintInput.StartDate"></label>
                                <input class="form-control" asp-for="NextSprintInput.StartDate" type="date" />
                                <label class="form-label" asp-for="NextSprintInput.EndDate"></label>
                                <input class="form-control" asp-for="NextSprintInput.EndDate" type="date" />
                                <label class="form-label" asp-for="NextSprintInput.Goal"></label>
                                <textarea class="form-control" asp-for="NextSprintInput.Goal" rows="2" maxlength="2000"></textarea>
                                <button type="submit" asp-page-handler="CreateNextSprint" class="btn btn-primary btn-sm" formnovalidate>Create next sprint</button>
                            </div>
                        </details>
                    }
                </div>

                <div class="at-disposition-legend" aria-label="Disposition guidance">
                    <span><strong>Carry forward</strong> Move to the selected next sprint and keep the assignee.</span>
                    <span><strong>Keep assigned</strong> Remove from this sprint but keep the assignee and due date.</span>
                    <span><strong>Backlog</strong> Remove the sprint and assignee for replanning.</span>
                </div>

                <div class="at-closure-task-table" role="table" aria-label="Unfinished tasks requiring a decision">
                    <div class="at-closure-task-row at-closure-task-head" role="row">
                        <span>Task</span>
                        <span>Status</span>
                        <span>Decision</span>
                    </div>
                    @foreach (var task in review.UnfinishedTasks)
                    {
                        var mustReturnInvalidTaskToBacklog = Model.MustReturnInvalidTaskToBacklogDuringClosure(task);
                        <div class="at-closure-task-row" role="row">
                            <span>
                                <strong>AT-@task.Id · @task.Title</strong>
                                <small>Due @task.DueDate.ToString("dd MMM yyyy")</small>
                                @if (Model.IsInvalidTaskState(task))
                                {
                                    <small class="at-closure-warning">This task must return to backlog unless its assignee is corrected.</small>
                                }
                            </span>
                            <span>
                                <span class="@Model.GetStatusBadgeClass(task.Status)">@(task.Status == ProjectManagement.Models.ActionTaskStatuses.Submitted ? "Awaiting Closure" : task.Status)</span>
                            </span>
                            <span>
                                <select class="form-select form-select-sm at-disposition-select" name="ClosureInput.Dispositions[@task.Id]" data-at-closure-disposition="true" required disabled="@mustReturnInvalidTaskToBacklog">
                                    <option value="">Choose action</option>
                                    <option value="carry">Carry forward</option>
                                    <option value="outside">Keep assigned</option>
                                    <option value="backlog">Return to backlog</option>
                                </select>
                                @if (mustReturnInvalidTaskToBacklog)
                                {
                                    <input type="hidden" name="ClosureInput.Dispositions[@task.Id]" value="backlog" />
                                    <span class="at-fixed-decision">Return to backlog</span>
                                }
                            </span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="at-empty-state at-empty-state-compact">All tasks are complete. Add closure remarks and close the sprint.</div>
            }

            <label class="form-label" asp-for="ClosureInput.Remarks">Closure remarks</label>
            <textarea class="form-control" asp-for="ClosureInput.Remarks" rows="3" maxlength="2000" required data-at-closure-remarks="true" placeholder="Record the closure decision and any follow-up required."></textarea>

            <div class="at-closure-sticky-bar">
                <div class="at-closure-summary" data-at-closure-summary="true" aria-live="polite"></div>
                <div class="at-closure-actions">
                    <button type="submit" class="btn btn-danger" data-at-closure-submit="true" disabled>Close sprint</button>
                </div>
            </div>
        </form>
    </section>
}
else if (Model.SelectedSprint?.Status == ProjectManagement.Models.ActionSprintStatus.Closed)
{
    <section class="at-panel at-closure-review is-readonly">
        <div class="at-panel-heading">
            <h2>Sprint closure</h2>
            <span class="at-sprint-status-pill">Closed</span>
        </div>
        <p class="at-empty-inline">This sprint is closed and read-only.</p>
    </section>
}
