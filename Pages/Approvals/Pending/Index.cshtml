@page "/Approvals/Pending"
@model ProjectManagement.Pages.Approvals.Pending.IndexModel
@{
    ViewData["Title"] = "Pending approvals";
}
@section Styles {
    <link rel="stylesheet" href="~/css/pages/approvals.css" asp-append-version="true" />
}

<div class="approvals-shell">
    <header class="approvals-page-header">
        <div>
            <div class="approvals-eyebrow">Decision workspace</div>
            <h1>Pending approvals</h1>
            <p>Review and decide approval-gated requests across Projects and Project Office Reports.</p>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="approvals-feedback approvals-feedback--success" role="status"><i class="bi bi-check-circle"></i>@Model.SuccessMessage</div>
    }

    @if (Model.TotalPendingCount == 0 && !Model.HasActiveFilters)
    {
        <section class="approvals-clear-state">
            <div class="approvals-clear-icon"><i class="bi bi-check2"></i></div>
            <div><h2>All caught up</h2><p>There are no pending approvals across Projects or Project Office Reports.</p></div>
        </section>
    }
    else
    {
        <section class="approvals-metrics" aria-label="Approval queue summary">
            <a class="approval-metric approval-metric--primary" asp-page="/Approvals/Pending/Index">
                <span>Total pending</span><strong>@Model.TotalPendingCount</strong><small>Requests in current view</small>
            </a>
            <div class="approval-metric"><span>Oldest request</span><strong>@Model.OldestPendingDisplay</strong><small>Age of oldest pending item</small></div>
            <a class="approval-metric" asp-page="/Approvals/Pending/Index" asp-route-Module="Projects">
                <span>Projects</span><strong>@Model.ProjectsPendingCount</strong><small>Project approvals</small>
            </a>
            <a class="approval-metric" asp-page="/Approvals/Pending/Index" asp-route-Module="ProjectOfficeReports">
                <span>Project Office</span><strong>@Model.ProjectOfficePendingCount</strong><small>Report approvals</small>
            </a>
            <a class="approval-metric @(Model.OverdueCount > 0 ? "approval-metric--alert" : "")" asp-page="/Approvals/Pending/Index" asp-route-Age="over7">
                <span>Over 7 days</span><strong>@Model.OverdueCount</strong><small>Requires attention</small>
            </a>
        </section>
    }

    <section class="approvals-filter-panel">
        <form method="get" class="approvals-filter-form" data-approvals-filter-form>
            <div class="approvals-filter-field approvals-filter-field--search">
                <label asp-for="Search">Search</label>
                <div class="approvals-search-control"><i class="bi bi-search"></i><input asp-for="Search" type="search" placeholder="Project, requester, request ID or summary" /></div>
            </div>
            <div class="approvals-filter-field"><label asp-for="Type">Request type</label><select asp-for="Type" asp-items="Model.TypeOptions"></select></div>
            <div class="approvals-filter-field"><label asp-for="Module">Module</label><select asp-for="Module" asp-items="Model.ModuleOptions"></select></div>
            <div class="approvals-filter-field"><label asp-for="Age">Age</label><select asp-for="Age" asp-items="Model.AgeOptions"></select></div>
            <button type="submit" class="btn btn-primary approvals-apply-button">Apply</button>
            @if (Model.HasActiveFilters)
            {
                <a class="btn btn-link approvals-clear-button" asp-page="/Approvals/Pending/Index">Clear</a>
            }
        </form>
    </section>

    <section class="approvals-results-panel">
        @if (Model.Items.Count == 0)
        {
            <div class="approvals-empty-filtered">
                <i class="bi bi-inbox"></i><h2>No matching approvals</h2><p>Adjust or clear the filters to view other pending requests.</p>
                <a class="btn btn-outline-primary" asp-page="/Approvals/Pending/Index">Clear filters</a>
            </div>
        }
        else
        {
            <div class="approvals-results-header">
                <div><h2>Approval queue</h2><p>Showing @Model.PageStart–@Model.PageEnd of @Model.FilteredCount requests · oldest first</p></div>
                @if (!string.IsNullOrWhiteSpace(Model.TopTypeDisplay) && Model.TopTypeDisplay != "—")
                { <div class="approvals-top-type"><span>Most common</span><strong>@Model.TopTypeDisplay</strong><small>@Model.TopTypeMeta</small></div> }
            </div>

            <div class="approvals-list" role="list">
                @foreach (var item in Model.Items)
                {
                    <a class="approval-request" href="@item.DetailsUrl" role="listitem">
                        <div class="approval-request__type"><span class="approval-type-icon"><i class="bi bi-check2-square"></i></span><div><span>@Model.GetTypeLabel(item.ApprovalType)</span><small>@Model.GetModuleLabel(item.Module)</small></div></div>
                        <div class="approval-request__project"><strong>@(item.ProjectName ?? "Project Office report")</strong>@if (item.ProjectId.HasValue){<small>Project #@item.ProjectId</small>}</div>
                        <div class="approval-request__summary">@item.Summary</div>
                        <div class="approval-request__requester"><span>Requested by</span><strong>@item.RequestedByName</strong></div>
                        <div class="approval-request__age"><span class="approval-age @Model.GetAgeClass(item.RequestedAtUtc)">@Model.GetAgeLabel(item.RequestedAtUtc)</span><small>@item.RequestedAtUtc.ToLocalTime().ToString("dd MMM yyyy, h:mm tt")</small></div>
                        <span class="approval-request__arrow"><i class="bi bi-chevron-right"></i></span>
                    </a>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="approvals-pagination" aria-label="Approval queue pages">
                    <a class="btn btn-outline-secondary @(Model.HasPreviousPage ? "" : "disabled")" asp-route-Type="@Model.Type" asp-route-Module="@Model.Module" asp-route-Age="@Model.Age" asp-route-Search="@Model.Search" asp-route-PageNumber="@(Model.PageNumber - 1)">Previous</a>
                    <span>Page @Model.PageNumber of @Model.TotalPages</span>
                    <a class="btn btn-outline-secondary @(Model.HasNextPage ? "" : "disabled")" asp-route-Type="@Model.Type" asp-route-Module="@Model.Module" asp-route-Age="@Model.Age" asp-route-Search="@Model.Search" asp-route-PageNumber="@(Model.PageNumber + 1)">Next</a>
                </nav>
            }
        }
    </section>
</div>
