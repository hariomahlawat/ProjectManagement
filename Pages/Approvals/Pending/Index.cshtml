@page "/Approvals/Pending"
@model ProjectManagement.Pages.Approvals.Pending.IndexModel
@{
    ViewData["Title"] = "Decision Centre";
}
@section Styles {
    <link rel="stylesheet" href="~/css/pages/approvals.css" asp-append-version="true" />
}

<main class="decision-centre">
    <header class="decision-header">
        <div>
            <div class="decision-eyebrow">Command decision workspace</div>
            <h1>Decision Centre</h1>
            <p>One place to review and decide project, document and institutional requests.</p>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="decision-feedback decision-feedback--success" role="status">
            <i class="bi bi-check-circle-fill" aria-hidden="true"></i>
            <span>@Model.SuccessMessage</span>
        </div>
    }

    <section class="decision-summary" aria-label="Current approval workload">
        <a class="decision-stat @(string.IsNullOrWhiteSpace(Model.Readiness) ? "is-active" : null)"
           asp-page="/Approvals/Pending/Index"
           asp-route-Type="@Model.Type" asp-route-Module="@Model.Module" asp-route-Age="@Model.Age" asp-route-Search="@Model.Search">
            <span>Pending</span><strong>@Model.TotalPendingCount</strong>
        </a>
        <a class="decision-stat decision-stat--ready @(Model.Readiness == "Ready" ? "is-active" : null)"
           asp-page="/Approvals/Pending/Index" asp-route-Readiness="Ready"
           asp-route-Type="@Model.Type" asp-route-Module="@Model.Module" asp-route-Age="@Model.Age" asp-route-Search="@Model.Search">
            <span>Ready</span><strong>@Model.ReadyCount</strong>
        </a>
        <a class="decision-stat decision-stat--waiting @(Model.Readiness == "Waiting" ? "is-active" : null)"
           asp-page="/Approvals/Pending/Index" asp-route-Readiness="Waiting"
           asp-route-Type="@Model.Type" asp-route-Module="@Model.Module" asp-route-Age="@Model.Age" asp-route-Search="@Model.Search">
            <span>Waiting</span><strong>@Model.WaitingCount</strong>
        </a>
        <a class="decision-stat decision-stat--blocked @(Model.Readiness is "Blocked" or "Stale" or "Superseded" ? "is-active" : null)"
           asp-page="/Approvals/Pending/Index" asp-route-Readiness="Blocked"
           asp-route-Type="@Model.Type" asp-route-Module="@Model.Module" asp-route-Age="@Model.Age" asp-route-Search="@Model.Search">
            <span>Blocked</span><strong>@Model.BlockedCount</strong>
        </a>
        <a class="decision-stat decision-stat--attention @(Model.Age == "over7" ? "is-active" : null)"
           asp-page="/Approvals/Pending/Index" asp-route-Age="over7"
           asp-route-Type="@Model.Type" asp-route-Module="@Model.Module" asp-route-Readiness="@Model.Readiness" asp-route-Search="@Model.Search">
            <span>Needs attention</span><strong>@Model.AttentionCount</strong>
        </a>
    </section>

    <section class="decision-toolbar" aria-label="Approval filters">
        <form method="get" class="decision-filter-form" data-decision-filter-form>
            <div class="decision-search">
                <i class="bi bi-search" aria-hidden="true"></i>
                <label class="visually-hidden" asp-for="Search">Search approvals</label>
                <input asp-for="Search" type="search" autocomplete="off"
                       placeholder="Search project, activity, document or requester" />
            </div>
            <label class="visually-hidden" asp-for="Type">Request type</label>
            <select asp-for="Type" asp-items="Model.TypeOptions" data-auto-submit></select>
            <label class="visually-hidden" asp-for="Module">Module</label>
            <select asp-for="Module" asp-items="Model.ModuleOptions" data-auto-submit></select>
            <label class="visually-hidden" asp-for="Age">Request age</label>
            <select asp-for="Age" asp-items="Model.AgeOptions" data-auto-submit></select>
            <input type="hidden" asp-for="Readiness" />
            <button type="submit" class="btn btn-primary decision-filter-button">Search</button>
            @if (Model.HasActiveFilters)
            {
                <a class="btn btn-link decision-clear-filter" asp-page="/Approvals/Pending/Index">Clear</a>
            }
        </form>
    </section>

    @if (!Model.HasResults)
    {
        <section class="decision-empty">
            <div class="decision-empty__icon"><i class="bi bi-check2" aria-hidden="true"></i></div>
            <h2>@(Model.HasActiveFilters ? "No matching requests" : "All caught up")</h2>
            <p>@(Model.HasActiveFilters
                ? "No pending request matches the selected filters."
                : "There are no approval-gated requests awaiting a decision.")</p>
            @if (Model.HasActiveFilters)
            {
                <a class="btn btn-outline-primary" asp-page="/Approvals/Pending/Index">Clear filters</a>
            }
        </section>
    }
    else
    {
        <div class="decision-results-heading">
            <div>
                <h2>Approval queue</h2>
                <p>Showing @Model.PageStart–@Model.PageEnd of @Model.FilteredCount pending requests</p>
            </div>
            <div class="decision-legend" aria-label="Readiness legend">
                <span><i class="decision-dot decision-dot--ready"></i>Ready</span>
                <span><i class="decision-dot decision-dot--waiting"></i>Waiting</span>
                <span><i class="decision-dot decision-dot--blocked"></i>Blocked</span>
            </div>
        </div>

        @if (Model.ProjectGroups.Count > 0)
        {
            <section class="decision-group-list" aria-label="Project approvals">
                @foreach (var group in Model.ProjectGroups)
                {
                    <article class="decision-project-group">
                        <header class="decision-project-header">
                            <div class="decision-project-title">
                                <span class="decision-project-icon"><i class="bi bi-kanban" aria-hidden="true"></i></span>
                                <div>
                                    <h3>@group.Title</h3>
                                    <p>
                                        @group.Subtitle
                                        @if (!string.IsNullOrWhiteSpace(group.WorkflowVersion))
                                        {
                                            <span class="decision-workflow">Workflow @group.WorkflowVersion</span>
                                        }
                                    </p>
                                </div>
                            </div>
                            <div class="decision-project-counts">
                                @if (group.ReadyCount > 0)
                                {
                                    <span class="count-ready">@group.ReadyCount ready</span>
                                }
                                @if (group.WaitingCount > 0)
                                {
                                    <span class="count-waiting">@group.WaitingCount waiting</span>
                                }
                                @if (group.BlockedCount > 0)
                                {
                                    <span class="count-blocked">@group.BlockedCount blocked</span>
                                }
                            </div>
                        </header>
                        <div class="decision-request-list">
                            @foreach (var item in group.Items)
                            {
                                <a class="decision-request decision-request--@item.Readiness.ToString().ToLowerInvariant()"
                                   href="@item.DetailsUrl">
                                    <span class="decision-request__sequence" aria-hidden="true">
                                        @if (item.ApprovalType == ProjectManagement.ViewModels.ApprovalQueueType.StageChange && item.WorkflowOrder.HasValue)
                                        {
                                            @(item.WorkflowOrder.Value + 1)
                                        }
                                        else
                                        {
                                            <i class="bi @Model.GetTypeIcon(item.ApprovalType)"></i>
                                        }
                                    </span>
                                    <span class="decision-request__body">
                                        <span class="decision-request__topline">
                                            <strong>@Model.GetTypeLabel(item.ApprovalType)</strong>
                                            @if (item.RevisionNumber > 1)
                                            {
                                                <span class="decision-revision">Revision @item.RevisionNumber</span>
                                            }
                                        </span>
                                        <span class="decision-request__summary">@item.Summary</span>
                                        @if (!string.IsNullOrWhiteSpace(item.ReadinessMessage))
                                        {
                                            <span class="decision-request__reason">@item.ReadinessMessage</span>
                                        }
                                    </span>
                                    <span class="decision-request__meta">
                                        <span class="decision-readiness decision-readiness--@item.Readiness.ToString().ToLowerInvariant()">
                                            <i class="bi @Model.GetReadinessIcon(item.Readiness)" aria-hidden="true"></i>
                                            @Model.GetReadinessLabel(item.Readiness)
                                        </span>
                                        <span class="decision-request__requester">@item.RequestedByName</span>
                                        <span class="decision-request__time">@Model.GetAgeLabel(item.RequestedAtUtc) · @Model.FormatRequestedAt(item.RequestedAtUtc)</span>
                                    </span>
                                    <i class="bi bi-chevron-right decision-request__arrow" aria-hidden="true"></i>
                                </a>
                            }
                        </div>
                    </article>
                }
            </section>
        }

        @if (Model.StandaloneGroups.Count > 0)
        {
            <section class="decision-standalone">
                <div class="decision-section-label">
                    <h2>Institutional and standalone requests</h2>
                    <p>Requests not tied to an individual project.</p>
                </div>
                @foreach (var group in Model.StandaloneGroups)
                {
                    <article class="decision-project-group">
                        <header class="decision-project-header decision-project-header--compact">
                            <div><h3>@group.Title</h3><p>@group.Subtitle</p></div>
                        </header>
                        <div class="decision-request-list">
                            @foreach (var item in group.Items)
                            {
                                <a class="decision-request decision-request--@item.Readiness.ToString().ToLowerInvariant()"
                                   href="@item.DetailsUrl">
                                    <span class="decision-request__sequence"><i class="bi @Model.GetTypeIcon(item.ApprovalType)"></i></span>
                                    <span class="decision-request__body">
                                        <span class="decision-request__topline"><strong>@Model.GetTypeLabel(item.ApprovalType)</strong></span>
                                        <span class="decision-request__summary">@item.Summary</span>
                                    </span>
                                    <span class="decision-request__meta">
                                        <span class="decision-readiness decision-readiness--@item.Readiness.ToString().ToLowerInvariant()">
                                            <i class="bi @Model.GetReadinessIcon(item.Readiness)"></i>@Model.GetReadinessLabel(item.Readiness)
                                        </span>
                                        <span class="decision-request__requester">@item.RequestedByName</span>
                                        <span class="decision-request__time">@Model.GetAgeLabel(item.RequestedAtUtc)</span>
                                    </span>
                                    <i class="bi bi-chevron-right decision-request__arrow"></i>
                                </a>
                            }
                        </div>
                    </article>
                }
            </section>
        }

        @if (Model.TotalPages > 1)
        {
            <nav class="decision-pagination" aria-label="Decision Centre pages">
                <a class="btn btn-outline-secondary @(Model.HasPreviousPage ? null : "disabled")"
                   asp-route-Type="@Model.Type" asp-route-Module="@Model.Module" asp-route-Readiness="@Model.Readiness"
                   asp-route-Age="@Model.Age" asp-route-Search="@Model.Search" asp-route-PageNumber="@(Model.PageNumber - 1)">Previous</a>
                <span>Page @Model.PageNumber of @Model.TotalPages</span>
                <a class="btn btn-outline-secondary @(Model.HasNextPage ? null : "disabled")"
                   asp-route-Type="@Model.Type" asp-route-Module="@Model.Module" asp-route-Readiness="@Model.Readiness"
                   asp-route-Age="@Model.Age" asp-route-Search="@Model.Search" asp-route-PageNumber="@(Model.PageNumber + 1)">Next</a>
            </nav>
        }
    }
</main>

@section Scripts {
    <script src="~/js/pages/approvals-pending.js" asp-append-version="true" type="module"></script>
}
