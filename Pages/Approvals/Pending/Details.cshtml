@page "/Approvals/Pending/{type}/{id}"
@model ProjectManagement.Pages.Approvals.Pending.DetailsModel
@using ProjectManagement.ViewModels
@{
    ViewData["Title"] = "Approval review";
    var item = Model.Detail.Item;
    var backUrl = !string.IsNullOrWhiteSpace(Model.ReturnUrl) && Url.IsLocalUrl(Model.ReturnUrl)
        ? Model.ReturnUrl
        : Url.Page("/Approvals/Pending/Index");
}
@section Styles {
    <link rel="stylesheet" href="~/css/pages/approvals.css" asp-append-version="true" />
}

<main class="decision-review">
    <nav class="decision-review__back" aria-label="Back navigation">
        <a href="@backUrl"><i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Decision Centre</a>
    </nav>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="decision-feedback decision-feedback--error" role="alert">
            <i class="bi bi-exclamation-octagon-fill" aria-hidden="true"></i>
            <span>@Model.ErrorMessage</span>
        </div>
    }
    @if (Model.AlreadyDecided)
    {
        <div class="decision-feedback decision-feedback--info" role="status">
            <i class="bi bi-info-circle-fill" aria-hidden="true"></i>
            <span>This request was decided while you were reviewing it. The latest state is shown below.</span>
        </div>
    }

    <header class="decision-review-header">
        <div class="decision-review-header__main">
            <div class="decision-eyebrow">@Model.GetModuleLabel(item.Module)</div>
            <h1>@(item.ProjectName ?? Model.GetTypeLabel(item.ApprovalType))</h1>
            <p>@item.Summary</p>
            <div class="decision-review-meta">
                <span><i class="bi bi-person" aria-hidden="true"></i>@item.RequestedByName</span>
                <span><i class="bi bi-clock" aria-hidden="true"></i>@Model.FormatDateTime(item.RequestedAtUtc)</span>
                <span><i class="bi bi-tag" aria-hidden="true"></i>@Model.GetTypeLabel(item.ApprovalType)</span>
                @if (!string.IsNullOrWhiteSpace(item.WorkflowVersion))
                {
                    <span><i class="bi bi-diagram-2" aria-hidden="true"></i>Workflow @item.WorkflowVersion</span>
                }
                @if (item.RevisionNumber > 1)
                {
                    <span><i class="bi bi-files" aria-hidden="true"></i>Revision @item.RevisionNumber</span>
                }
            </div>
        </div>
        <div class="decision-readiness-card decision-readiness-card--@item.Readiness.ToString().ToLowerInvariant()">
            <i class="bi @Model.GetReadinessIcon(item.Readiness)" aria-hidden="true"></i>
            <div>
                <span>Decision status</span>
                <strong>@(Model.IsPending ? Model.GetReadinessLabel(item.Readiness) : Model.FormatStatus(Model.CurrentStatus))</strong>
                @if (Model.IsPending && !string.IsNullOrWhiteSpace(item.ReadinessMessage))
                {
                    <small>@item.ReadinessMessage</small>
                }
            </div>
        </div>
    </header>

    <div class="decision-review-grid">
        <div class="decision-review-content">
            @if (Model.Detail.ReadinessChecks.Count > 0)
            {
                <section class="decision-panel">
                    <header class="decision-panel__header">
                        <div><h2>Approval readiness</h2><p>PRISM checks the current project state immediately before a decision.</p></div>
                    </header>
                    <div class="decision-check-list">
                        @foreach (var check in Model.Detail.ReadinessChecks)
                        {
                            <div class="decision-check decision-check--@check.State.ToString().ToLowerInvariant()">
                                <i class="bi @Model.GetCheckIcon(check.State)" aria-hidden="true"></i>
                                <div><strong>@check.Label</strong>@if (!string.IsNullOrWhiteSpace(check.Detail)){<p>@check.Detail</p>}</div>
                                @if (!string.IsNullOrWhiteSpace(check.ActionUrl))
                                {
                                    <a class="btn btn-sm btn-outline-primary" href="@check.ActionUrl">@(check.ActionLabel ?? "Resolve")</a>
                                }
                            </div>
                        }
                    </div>
                </section>
            }

            @if (Model.Detail.StageChange is { } stage)
            {
                <section class="decision-panel">
                    <header class="decision-panel__header">
                        <div><h2>Stage update</h2><p>Sequence resolved from workflow <strong>@stage.WorkflowVersion</strong> assigned to this project.</p></div>
                        <span class="decision-stage-order">Workflow position @(stage.WorkflowOrder + 1)</span>
                    </header>
                    <div class="decision-comparison-grid">
                        <div><span>Stage</span><strong>@stage.StageName</strong><small>@stage.StageCode</small></div>
                        <div><span>Current status</span><strong>@Model.FormatStatus(stage.CurrentStatus)</strong></div>
                        <div class="is-proposed"><span>Requested status</span><strong>@Model.FormatStatus(stage.RequestedStatus)</strong></div>
                        <div><span>Actual start</span><strong>@Model.FormatDate(stage.CurrentActualStart)</strong></div>
                        <div><span>Recorded completion</span><strong>@Model.FormatDate(stage.CurrentCompletedOn)</strong></div>
                        <div class="is-proposed"><span>Requested date</span><strong>@Model.FormatDate(stage.RequestedDate)</strong></div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(stage.RequestNote))
                    {
                        <div class="decision-note"><span>Project Officer’s note</span><p>@stage.RequestNote</p></div>
                    }
                </section>
            }

            @if (Model.Detail.MetaChange is { } meta)
            {
                var changedFields = new[]
                {
                    ("Project name", meta.Name), ("Description", meta.Description), ("Case file number", meta.CaseFileNumber),
                    ("Category", meta.Category), ("Technical category", meta.TechnicalCategory), ("Project type", meta.ProjectType),
                    ("Repeat build", meta.IsBuild), ("Sponsoring unit", meta.SponsoringUnit),
                    ("Sponsoring line directorate", meta.SponsoringLineDirectorate)
                }.Where(field => field.Item2.HasChanged).ToArray();
                <section class="decision-panel">
                    <header class="decision-panel__header"><div><h2>Proposed project information</h2><p>@changedFields.Length field@(changedFields.Length == 1 ? "" : "s") will change.</p></div></header>
                    <div class="decision-change-table">
                        <div class="decision-change-row decision-change-row--head"><span>Field</span><span>Current</span><span>Proposed</span></div>
                        @foreach (var field in changedFields)
                        {
                            <div class="decision-change-row"><strong>@field.Item1</strong><span>@field.Item2.CurrentValue</span><span class="is-proposed">@field.Item2.ProposedValue</span></div>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(meta.RequestNote))
                    {
                        <div class="decision-note"><span>Reason</span><p>@meta.RequestNote</p></div>
                    }
                </section>
            }

            @if (Model.Detail.PlanApproval is { } plan)
            {
                <section class="decision-panel">
                    <header class="decision-panel__header"><div><h2>Timeline plan version @plan.VersionNumber</h2><p>Review all changed stage dates before activation.</p></div></header>
                    @if (plan.StageDiffs.Count == 0)
                    {
                        <div class="decision-inline-empty">No date differences were detected.</div>
                    }
                    else
                    {
                        <div class="decision-change-table decision-change-table--timeline">
                            <div class="decision-change-row decision-change-row--head"><span>Stage</span><span>Current plan</span><span>Proposed plan</span></div>
                            @foreach (var diff in plan.StageDiffs)
                            {
                                <div class="decision-change-row">
                                    <strong>@diff.StageName</strong>
                                    <span>@Model.FormatDate(diff.CurrentStart) – @Model.FormatDate(diff.CurrentDue)</span>
                                    <span class="is-proposed">@Model.FormatDate(diff.ProposedStart) – @Model.FormatDate(diff.ProposedDue)</span>
                                </div>
                            }
                        </div>
                    }
                </section>
            }

            @if (Model.Detail.DocumentModeration is { } document)
            {
                <section class="decision-panel">
                    <header class="decision-panel__header"><div><h2>Project document request</h2><p>@Model.FormatStatus(document.RequestType.ToString())</p></div></header>
                    <dl class="decision-definition-list">
                        <div><dt>Title</dt><dd>@document.Title</dd></div>
                        <div><dt>Lifecycle stage</dt><dd>@(document.StageDisplayName ?? "General project record")</dd></div>
                        <div><dt>File</dt><dd>@(document.OriginalFileName ?? document.CurrentDocument?.OriginalFileName ?? "—")</dd></div>
                        <div><dt>Description</dt><dd>@(string.IsNullOrWhiteSpace(document.Description) ? "—" : document.Description)</dd></div>
                    </dl>
                    @if (!string.IsNullOrWhiteSpace(document.PreviewUrl) || !string.IsNullOrWhiteSpace(document.DownloadUrl))
                    {
                        <div class="decision-document-actions">
                            @if (!string.IsNullOrWhiteSpace(document.PreviewUrl)){<a class="btn btn-outline-primary" href="@document.PreviewUrl" target="_blank" rel="noopener">Preview document</a>}
                            @if (!string.IsNullOrWhiteSpace(document.DownloadUrl)){<a class="btn btn-outline-secondary" href="@document.DownloadUrl">Download</a>}
                        </div>
                    }
                </section>
            }

            @if (Model.Detail.TotRequest is { } tot)
            {
                <section class="decision-panel">
                    <header class="decision-panel__header"><div><h2>Transfer of Technology update</h2><p>Compare the approved record with the proposed update.</p></div></header>
                    <div class="decision-change-table">
                        <div class="decision-change-row decision-change-row--head"><span>Field</span><span>Current</span><span>Proposed</span></div>
                        <div class="decision-change-row"><strong>Status</strong><span>@Model.FormatStatus(tot.CurrentStatus.ToString())</span><span class="is-proposed">@Model.FormatStatus(tot.ProposedStatus.ToString())</span></div>
                        <div class="decision-change-row"><strong>Started on</strong><span>@Model.FormatDate(tot.CurrentStartedOn)</span><span class="is-proposed">@Model.FormatDate(tot.ProposedStartedOn)</span></div>
                        <div class="decision-change-row"><strong>Completed on</strong><span>@Model.FormatDate(tot.CurrentCompletedOn)</span><span class="is-proposed">@Model.FormatDate(tot.ProposedCompletedOn)</span></div>
                        <div class="decision-change-row"><strong>MET details</strong><span>@(tot.CurrentMetDetails ?? "—")</span><span class="is-proposed">@(tot.ProposedMetDetails ?? "—")</span></div>
                    </div>
                </section>
            }

            @if (Model.Detail.ProliferationYearly is { } yearly)
            {
                <section class="decision-panel">
                    <header class="decision-panel__header"><div><h2>Yearly proliferation record</h2><p>@yearly.Source · @yearly.Year</p></div></header>
                    <dl class="decision-definition-list">
                        <div><dt>Total quantity</dt><dd>@yearly.TotalQuantity</dd></div>
                        <div><dt>Remarks</dt><dd>@(yearly.Remarks ?? "—")</dd></div>
                    </dl>
                </section>
            }

            @if (Model.Detail.ProliferationGranular is { } granular)
            {
                <section class="decision-panel">
                    <header class="decision-panel__header"><div><h2>Unit-wise proliferation record</h2><p>@granular.Source</p></div></header>
                    <dl class="decision-definition-list">
                        <div><dt>Unit</dt><dd>@granular.UnitName</dd></div>
                        <div><dt>Date</dt><dd>@Model.FormatDate(granular.ProliferationDate)</dd></div>
                        <div><dt>Quantity</dt><dd>@granular.Quantity</dd></div>
                        <div><dt>Remarks</dt><dd>@(granular.Remarks ?? "—")</dd></div>
                    </dl>
                </section>
            }

            @if (Model.Detail.ActivityDelete is { } activity)
            {
                <section class="decision-panel decision-panel--destructive">
                    <header class="decision-panel__header"><div><h2>Delete institutional activity</h2><p>This action removes the activity and its associated records.</p></div></header>
                    <dl class="decision-definition-list">
                        <div><dt>Activity</dt><dd>@activity.Title</dd></div>
                        <div><dt>Type</dt><dd>@activity.ActivityType</dd></div>
                        <div><dt>Location</dt><dd>@(activity.Location ?? "—")</dd></div>
                        <div><dt>Scheduled</dt><dd>@Model.FormatDateTime(activity.ScheduledStartUtc)</dd></div>
                        <div><dt>Reason</dt><dd>@(activity.Reason ?? "—")</dd></div>
                    </dl>
                </section>
            }

            @if (Model.Detail.TrainingDelete is { } training)
            {
                <section class="decision-panel decision-panel--destructive">
                    <header class="decision-panel__header"><div><h2>Delete training record</h2><p>This action removes the training, roster, counters and project links.</p></div></header>
                    <dl class="decision-definition-list">
                        <div><dt>Training</dt><dd>@training.TrainingType</dd></div>
                        <div><dt>Period</dt><dd>@training.Period</dd></div>
                        <div><dt>Total trainees</dt><dd>@training.TotalTrainees</dd></div>
                        <div><dt>Reason</dt><dd>@training.Reason</dd></div>
                    </dl>
                </section>
            }

            @if (Model.Detail.RepositoryDocumentDelete is { } repositoryDocument)
            {
                <section class="decision-panel decision-panel--destructive">
                    <header class="decision-panel__header"><div><h2>Move repository document to trash</h2><p>The document will be soft-deleted and remain auditable.</p></div></header>
                    <dl class="decision-definition-list">
                        <div><dt>Subject</dt><dd>@repositoryDocument.Subject</dd></div>
                        <div><dt>Received from</dt><dd>@(repositoryDocument.ReceivedFrom ?? "—")</dd></div>
                        <div><dt>Document date</dt><dd>@Model.FormatDate(repositoryDocument.DocumentDate)</dd></div>
                        <div><dt>File</dt><dd>@repositoryDocument.OriginalFileName</dd></div>
                        <div><dt>Reason</dt><dd>@(repositoryDocument.Reason ?? "—")</dd></div>
                    </dl>
                </section>
            }

            @if (Model.Detail.RelatedRequests.Count > 0)
            {
                <section class="decision-panel">
                    <header class="decision-panel__header"><div><h2>Related stage requests</h2><p>Requests are ordered according to this project’s workflow version.</p></div></header>
                    <div class="decision-related-list">
                        @foreach (var related in Model.Detail.RelatedRequests)
                        {
                            <a href="@related.DetailsUrl" class="decision-related-item">
                                <span><strong>@related.Label</strong><small>@related.Summary · @Model.FormatStatus(related.Status)</small></span>
                                <span class="decision-readiness decision-readiness--@related.Readiness.ToString().ToLowerInvariant()">
                                    @(string.Equals(related.Status, "Pending", StringComparison.OrdinalIgnoreCase)
                                        ? Model.GetReadinessLabel(related.Readiness)
                                        : Model.FormatStatus(related.Status))
                                </span>
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        }
                    </div>
                </section>
            }
        </div>

        <aside class="decision-action-column">
            <section class="decision-action-card">
                <header>
                    <span>Decision</span>
                    <strong>@(Model.IsPending ? "Required" : Model.FormatStatus(Model.CurrentStatus))</strong>
                </header>

                @if (Model.IsPending)
                {
                    <form method="post" asp-page="/Approvals/Pending/Decide" class="approval-decision-form"
                          data-approval-form data-confirm-title="Approve request" data-confirm-message="@Model.GetApproveConfirmation()">
                        <input type="hidden" asp-for="Input.ApprovalType" />
                        <input type="hidden" asp-for="Input.RequestId" />
                        <input type="hidden" asp-for="Input.RowVersion" />
                        <input type="hidden" asp-for="Input.ReturnUrl" />

                        <label asp-for="Input.Remarks">Remarks</label>
                        <textarea asp-for="Input.Remarks" rows="5" maxlength="2000"
                                  placeholder="Optional for approval; required when rejecting"></textarea>
                        <span asp-validation-for="Input.Remarks" class="text-danger"></span>

                        @if (!Model.CanApprove)
                        {
                            <div class="decision-blocked-note">
                                <i class="bi bi-lock-fill" aria-hidden="true"></i>
                                <span>Approval is disabled until the readiness issue is resolved.</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.CorrectionUrl))
                            {
                                <a class="btn btn-outline-primary w-100" href="@item.CorrectionUrl">Resolve blocker</a>
                            }
                        }

                        <div class="decision-action-buttons">
                            <button type="submit" name="Input.Decision" value="Approve"
                                    class="btn btn-success" disabled="@(!Model.CanApprove)" data-decision="approve">
                                <i class="bi bi-check2" aria-hidden="true"></i>Approve
                            </button>
                            <button type="submit" name="Input.Decision" value="Reject"
                                    class="btn btn-outline-danger" data-decision="reject">
                                <i class="bi bi-x-lg" aria-hidden="true"></i>Reject
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <dl class="decision-recorded-result">
                        <div><dt>Status</dt><dd>@Model.FormatStatus(Model.CurrentStatus)</dd></div>
                        <div><dt>Decided by</dt><dd>@(Model.DecidedByName ?? "—")</dd></div>
                        <div><dt>Decided at</dt><dd>@Model.FormatDateTime(Model.DecidedAtUtc)</dd></div>
                        @if (!string.IsNullOrWhiteSpace(Model.DecisionRemarks))
                        {
                            <div><dt>Remarks</dt><dd>@Model.DecisionRemarks</dd></div>
                        }
                    </dl>
                    <a class="btn btn-primary w-100" href="@backUrl">Return to Decision Centre</a>
                }
            </section>
        </aside>
    </div>
</main>

<dialog class="decision-confirm-dialog" id="approval-confirm-dialog" aria-labelledby="approval-confirm-title">
    <form method="dialog">
        <div class="decision-confirm-icon"><i class="bi bi-check2-circle"></i></div>
        <h2 id="approval-confirm-title">Approve request</h2>
        <p data-confirm-message>Approve this request? The change will be applied immediately.</p>
        <div class="decision-confirm-actions">
            <button type="button" class="btn btn-outline-secondary" data-confirm-cancel>Cancel</button>
            <button type="button" class="btn btn-success" data-confirm-approve>Approve request</button>
        </div>
    </form>
</dialog>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/approvals.js" asp-append-version="true"></script>
}
