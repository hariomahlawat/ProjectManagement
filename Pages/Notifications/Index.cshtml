@page
@using System.Text.Json
@model ProjectManagement.Pages.Notifications.IndexModel
@{
    ViewData["Title"] = "Notification Centre";
    ViewData["PageShell"] = "wide";

    var bootstrap = new
    {
        items = Model.ViewModel.Notifications,
        totalCount = Model.ViewModel.TotalCount,
        unreadCount = Model.ViewModel.UnreadCount,
        nextCursor = Model.ViewModel.NextCursor,
        hasMore = Model.ViewModel.HasMore,
        projects = Model.ViewModel.Projects,
        modules = Model.ViewModel.Modules,
        folders = Model.ViewModel.Folders,
    };
    var bootstrapJson = JsonSerializer.Serialize(
        bootstrap,
        new JsonSerializerOptions(JsonSerializerDefaults.Web));
    var folderCounts = Model.ViewModel.Folders.ToDictionary(folder => folder.Key, StringComparer.OrdinalIgnoreCase);

    int FolderTotal(string key)
        => folderCounts.TryGetValue(key, out var folder) ? folder.TotalCount : 0;

    int FolderUnread(string key)
        => folderCounts.TryGetValue(key, out var folder) ? folder.UnreadCount : 0;

    string DisplayCount(int count) => count > 999 ? "999+" : count.ToString();

    var markAllLabel = Model.ViewModel.UnreadCount == 0
        ? "No unread notifications"
        : "Mark all notifications as read";
}
<section class="notification-inbox py-3"
         data-notification-center
         data-active-folder="inbox"
         data-api-base="@Model.ViewModel.ApiBaseUrl"
         data-unread-url="@Model.ViewModel.UnreadCountUrl"
         data-hub-url="@Model.ViewModel.HubUrl"
         data-notification-limit="@Model.ViewModel.PageSize"
         data-unread-count="@Model.ViewModel.UnreadCount"
         data-notification-center-url="@Model.ViewModel.NotificationCenterUrl">
    <script type="application/json" data-notification-bootstrap>@Html.Raw(bootstrapJson)</script>

    <header class="notification-inbox__page-header">
        <div>
            <span class="notification-inbox__kicker">Personal activity inbox</span>
            <h1 class="notification-inbox__title">Notification Centre</h1>
            <p class="notification-inbox__subtitle">Updates, approvals, assignments and project activity in one place.</p>
        </div>
        <div class="notification-inbox__summary" aria-label="Notification summary">
            <span><strong data-notification-unread-count>@Model.ViewModel.UnreadCount</strong> unread</span>
            <span aria-hidden="true">·</span>
            <span><strong data-notification-total-count>@Model.ViewModel.TotalCount</strong> matching</span>
        </div>
    </header>

    <div class="notification-inbox__shell">
        <aside class="notification-inbox__rail" aria-label="Notification folders">
            <nav class="notification-inbox__folders">
                <button type="button" class="notification-folder is-active" data-notification-folder="inbox" aria-current="page">
                    <i class="bi bi-inbox" aria-hidden="true"></i>
                    <span>Inbox</span>
                    <span class="notification-folder__count" data-folder-count data-folder-key="inbox" data-folder-count-mode="unread">@(FolderUnread("inbox") > 0 ? DisplayCount(FolderUnread("inbox")) : string.Empty)</span>
                </button>
                <button type="button" class="notification-folder" data-notification-folder="unread">
                    <i class="bi bi-envelope" aria-hidden="true"></i>
                    <span>Unread</span>
                    <span class="notification-folder__count" data-folder-count data-folder-key="unread" data-folder-count-mode="total">@(FolderTotal("unread") > 0 ? DisplayCount(FolderTotal("unread")) : string.Empty)</span>
                </button>
                <button type="button" class="notification-folder" data-notification-folder="action">
                    <i class="bi bi-exclamation-circle" aria-hidden="true"></i>
                    <span>Action required</span>
                    <span class="notification-folder__count" data-folder-count data-folder-key="action" data-folder-count-mode="unread">@(FolderUnread("action") > 0 ? DisplayCount(FolderUnread("action")) : string.Empty)</span>
                </button>

                <span class="notification-folder__section">Categories</span>
                <button type="button" class="notification-folder" data-notification-folder="approvals">
                    <i class="bi bi-clipboard-check" aria-hidden="true"></i>
                    <span>Approvals</span>
                    <span class="notification-folder__count" data-folder-count data-folder-key="approvals" data-folder-count-mode="unread">@(FolderUnread("approvals") > 0 ? DisplayCount(FolderUnread("approvals")) : string.Empty)</span>
                </button>
                <button type="button" class="notification-folder" data-notification-folder="collaboration">
                    <i class="bi bi-chat-dots" aria-hidden="true"></i>
                    <span>Mentions &amp; remarks</span>
                    <span class="notification-folder__count" data-folder-count data-folder-key="collaboration" data-folder-count-mode="unread">@(FolderUnread("collaboration") > 0 ? DisplayCount(FolderUnread("collaboration")) : string.Empty)</span>
                </button>
                <button type="button" class="notification-folder" data-notification-folder="assignments">
                    <i class="bi bi-person-check" aria-hidden="true"></i>
                    <span>Assignments</span>
                    <span class="notification-folder__count" data-folder-count data-folder-key="assignments" data-folder-count-mode="unread">@(FolderUnread("assignments") > 0 ? DisplayCount(FolderUnread("assignments")) : string.Empty)</span>
                </button>
                <button type="button" class="notification-folder" data-notification-folder="lifecycle">
                    <i class="bi bi-diagram-3" aria-hidden="true"></i>
                    <span>Project updates</span>
                    <span class="notification-folder__count" data-folder-count data-folder-key="lifecycle" data-folder-count-mode="unread">@(FolderUnread("lifecycle") > 0 ? DisplayCount(FolderUnread("lifecycle")) : string.Empty)</span>
                </button>
                <button type="button" class="notification-folder" data-notification-folder="documents">
                    <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
                    <span>Documents</span>
                    <span class="notification-folder__count" data-folder-count data-folder-key="documents" data-folder-count-mode="unread">@(FolderUnread("documents") > 0 ? DisplayCount(FolderUnread("documents")) : string.Empty)</span>
                </button>
                <button type="button" class="notification-folder" data-notification-folder="tasks">
                    <i class="bi bi-list-check" aria-hidden="true"></i>
                    <span>Action tasks</span>
                    <span class="notification-folder__count" data-folder-count data-folder-key="tasks" data-folder-count-mode="unread">@(FolderUnread("tasks") > 0 ? DisplayCount(FolderUnread("tasks")) : string.Empty)</span>
                </button>

                <span class="notification-folder__section">More</span>
                <button type="button" class="notification-folder" data-notification-folder="all">
                    <i class="bi bi-archive" aria-hidden="true"></i>
                    <span>All notifications</span>
                    <span class="notification-folder__count" data-folder-count data-folder-key="all" data-folder-count-mode="total">@(FolderTotal("all") > 0 ? DisplayCount(FolderTotal("all")) : string.Empty)</span>
                </button>
                <button type="button" class="notification-folder" data-notification-folder="muted">
                    <i class="bi bi-bell-slash" aria-hidden="true"></i>
                    <span>Muted projects</span>
                    <span class="notification-folder__count" data-folder-count data-folder-key="muted" data-folder-count-mode="total">@(FolderTotal("muted") > 0 ? DisplayCount(FolderTotal("muted")) : string.Empty)</span>
                </button>
            </nav>
        </aside>

        <main class="notification-inbox__workspace">
            <div class="notification-inbox__sticky-header">
                <div class="notification-inbox__actionbar">
                    <div class="notification-inbox__selection-control">
                        <input class="form-check-input mt-0" type="checkbox" data-select-all aria-label="Select all loaded notifications" />
                    </div>

                    <div class="notification-inbox__default-actions" data-default-actions>
                        <button type="button" class="notification-inbox__icon-button" data-notification-action="refresh" title="Refresh notifications" aria-label="Refresh notifications">
                            <i class="bi bi-arrow-clockwise" aria-hidden="true"></i>
                        </button>
                        <button type="button" class="notification-inbox__icon-button" data-notification-action="mark-all-read"
                                title="@markAllLabel" aria-label="@markAllLabel"
                                @(Model.ViewModel.UnreadCount == 0 ? "disabled" : null)>
                            <i class="bi bi-check2-all" aria-hidden="true"></i>
                        </button>
                    </div>

                    <div class="notification-inbox__selection-actions" data-selection-actions hidden>
                        <span class="notification-inbox__selection-count" data-selection-count>0 selected</span>
                        <button type="button" class="notification-inbox__icon-button" data-notification-bulk="mark-read" title="Mark selected as read" aria-label="Mark selected as read" disabled>
                            <i class="bi bi-envelope-open" aria-hidden="true"></i>
                        </button>
                        <button type="button" class="notification-inbox__icon-button" data-notification-bulk="mark-unread" title="Mark selected as unread" aria-label="Mark selected as unread" disabled>
                            <i class="bi bi-envelope" aria-hidden="true"></i>
                        </button>
                        <button type="button" class="notification-inbox__icon-button" data-notification-bulk="mute-project" title="Mute selected projects" aria-label="Mute selected projects" disabled>
                            <i class="bi bi-bell-slash" aria-hidden="true"></i>
                        </button>
                        <button type="button" class="notification-inbox__icon-button" data-notification-bulk="unmute-project" title="Unmute selected projects" aria-label="Unmute selected projects" disabled>
                            <i class="bi bi-bell" aria-hidden="true"></i>
                        </button>
                    </div>

                    <span class="notification-inbox__range" data-notification-list-summary>
                        Showing @Model.ViewModel.Notifications.Count of @Model.ViewModel.TotalCount
                    </span>
                </div>

                <form class="notification-inbox__filters" data-notification-filters>
                    <div class="notification-inbox__search">
                        <i class="bi bi-search" aria-hidden="true"></i>
                        <label class="visually-hidden" for="notificationSearch">Search notifications</label>
                        <input type="search" id="notificationSearch" class="form-control" data-filter-search
                               placeholder="Search notifications" autocomplete="off" />
                    </div>
                    <label class="visually-hidden" for="notificationStatusFilter">Read status</label>
                    <select id="notificationStatusFilter" class="form-select" data-filter-status>
                        <option value="all" selected>All states</option>
                        <option value="unread">Unread</option>
                        <option value="read">Read</option>
                    </select>
                    <label class="visually-hidden" for="notificationProjectFilter">Project</label>
                    <select id="notificationProjectFilter" class="form-select" data-filter-project>
                        <option value="">All projects</option>
                        @foreach (var project in Model.ViewModel.Projects)
                        {
                            <option value="@project.Id">@project.Label@(project.IsMuted ? " — muted" : string.Empty)</option>
                        }
                    </select>
                    <label class="visually-hidden" for="notificationModuleFilter">Module</label>
                    <select id="notificationModuleFilter" class="form-select" data-filter-module>
                        <option value="">All modules</option>
                        @foreach (var module in Model.ViewModel.Modules)
                        {
                            <option value="@module">@module</option>
                        }
                    </select>
                    <button type="button" class="notification-inbox__clear-button" data-notification-action="clear-filters" title="Clear search and filters">
                        <i class="bi bi-x-lg" aria-hidden="true"></i>
                        <span class="visually-hidden">Clear search and filters</span>
                    </button>
                </form>
            </div>

            <div class="notification-inbox__loading" data-notification-loading hidden>
                <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                <span>Loading notifications…</span>
            </div>

            <div class="notification-inbox__list" data-notification-center-list aria-live="polite">
                <div data-notification-rows>
                    @foreach (var item in Model.ViewModel.Notifications)
                    {
                        <article class="notification-inbox-row @(item.IsRead ? "is-read" : "is-unread") @(item.IsProjectMuted ? "is-muted" : string.Empty)"
                                 data-notification-row
                                 data-notification-id="@item.Id"
                                 data-project-id="@(item.ProjectId?.ToString() ?? string.Empty)"
                                 data-read="@(item.IsRead ? "true" : "false")"
                                 data-muted="@(item.IsProjectMuted ? "true" : "false")"
                                 tabindex="0">
                            <div class="notification-inbox-row__select">
                                <input class="form-check-input" type="checkbox" value="@item.Id" data-notification-select aria-label="Select notification" />
                            </div>
                            <div class="notification-inbox-row__icon" aria-hidden="true"><i class="@item.IconCssClass"></i></div>
                            <div class="notification-inbox-row__source">
                                <span class="notification-inbox-row__unread-dot" data-notification-unread-dot aria-hidden="true"></span>
                                <span class="notification-inbox-row__project" data-notification-project>@(string.IsNullOrWhiteSpace(item.ProjectName) ? item.Category : item.ProjectName)</span>
                                <span class="notification-inbox-row__category" data-notification-category>@item.Category</span>
                            </div>
                            <div class="notification-inbox-row__message">
                                <a class="notification-inbox-row__title"
                                   href="@(string.IsNullOrWhiteSpace(item.Route) ? Model.ViewModel.NotificationCenterUrl : item.Route)"
                                   data-notification-link data-notification-title>@(string.IsNullOrWhiteSpace(item.Title) ? "Notification" : item.Title)</a>
                                @if (!string.IsNullOrWhiteSpace(item.Summary))
                                {
                                    <span class="notification-inbox-row__separator" aria-hidden="true">—</span>
                                    <span class="notification-inbox-row__preview"
                                          title="@(string.IsNullOrWhiteSpace(item.SummaryTooltip) ? item.Summary : item.SummaryTooltip)"
                                          data-notification-summary>@item.Summary</span>
                                }
                                <span class="notification-inbox-row__meta">
                                    @if (!string.IsNullOrWhiteSpace(item.ActorDisplayName))
                                    {
                                        <span data-notification-actor>@item.ActorDisplayName</span>
                                    }
                                    else
                                    {
                                        <span data-notification-actor hidden></span>
                                    }
                                    <span class="notification-inbox-row__action-required" data-notification-action-required @(item.IsActionRequired ? null : "hidden")>
                                        <i class="bi bi-exclamation-circle" aria-hidden="true"></i> Action required
                                    </span>
                                    <span class="notification-inbox-row__muted" data-notification-muted @(item.IsProjectMuted ? null : "hidden")>
                                        <i class="bi bi-bell-slash" aria-hidden="true"></i> Muted
                                    </span>
                                </span>
                            </div>
                            <div class="notification-inbox-row__time">
                                <time datetime="@item.CreatedUtc.ToString("O")" title="@item.CreatedDisplayIst" data-notification-created>@item.CreatedDisplayIst</time>
                            </div>
                            <div class="notification-inbox-row__quick-actions" role="group" aria-label="Notification actions">
                                <button type="button" class="notification-inbox__icon-button" data-notification-row-action="toggle-read" title="@(item.IsRead ? "Mark as unread" : "Mark as read")" aria-label="@(item.IsRead ? "Mark as unread" : "Mark as read")">
                                    <i class="bi @(item.IsRead ? "bi-envelope" : "bi-envelope-open")" aria-hidden="true"></i>
                                </button>
                                @if (item.ProjectId.HasValue)
                                {
                                    <button type="button" class="notification-inbox__icon-button" data-notification-row-action="toggle-mute" title="@(item.IsProjectMuted ? "Unmute project" : "Mute project")" aria-label="@(item.IsProjectMuted ? "Unmute project" : "Mute project")">
                                        <i class="bi @(item.IsProjectMuted ? "bi-bell" : "bi-bell-slash")" aria-hidden="true"></i>
                                    </button>
                                }
                                <a class="notification-inbox__icon-button"
                                   href="@(string.IsNullOrWhiteSpace(item.Route) ? Model.ViewModel.NotificationCenterUrl : item.Route)"
                                   target="_blank" rel="noopener"
                                   data-notification-open-new
                                   title="Open in new tab" aria-label="Open notification in new tab">
                                    <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
                                </a>
                            </div>
                            <span class="visually-hidden" data-notification-state>@(item.IsRead ? "Read" : "Unread")</span>
                        </article>
                    }
                </div>

                <div class="notification-inbox__empty" data-notification-empty @(Model.ViewModel.Notifications.Count == 0 ? null : "hidden")>
                    <i class="bi bi-inbox" aria-hidden="true"></i>
                    <h2>No notifications found</h2>
                    <p>Try another folder or clear the active filters.</p>
                </div>
            </div>

            <footer class="notification-inbox__footer">
                <span class="notification-inbox__status" data-notification-status role="status" aria-live="polite"></span>
                <button type="button" class="btn btn-outline-primary btn-sm" data-notification-load-more @(Model.ViewModel.HasMore ? null : "hidden")>
                    Load more
                </button>
            </footer>
        </main>
    </div>

    <template data-notification-row-template>
        <article class="notification-inbox-row is-unread" data-notification-row tabindex="0">
            <div class="notification-inbox-row__select">
                <input class="form-check-input" type="checkbox" data-notification-select aria-label="Select notification" />
            </div>
            <div class="notification-inbox-row__icon" aria-hidden="true"><i data-notification-icon class="bi bi-bell"></i></div>
            <div class="notification-inbox-row__source">
                <span class="notification-inbox-row__unread-dot" data-notification-unread-dot aria-hidden="true"></span>
                <span class="notification-inbox-row__project" data-notification-project></span>
                <span class="notification-inbox-row__category" data-notification-category></span>
            </div>
            <div class="notification-inbox-row__message">
                <a class="notification-inbox-row__title" href="#" data-notification-link data-notification-title>Notification</a>
                <span class="notification-inbox-row__separator" data-notification-summary-separator aria-hidden="true">—</span>
                <span class="notification-inbox-row__preview" data-notification-summary></span>
                <span class="notification-inbox-row__meta">
                    <span data-notification-actor></span>
                    <span class="notification-inbox-row__action-required" data-notification-action-required hidden>
                        <i class="bi bi-exclamation-circle" aria-hidden="true"></i> Action required
                    </span>
                    <span class="notification-inbox-row__muted" data-notification-muted hidden>
                        <i class="bi bi-bell-slash" aria-hidden="true"></i> Muted
                    </span>
                </span>
            </div>
            <div class="notification-inbox-row__time">
                <time data-notification-created datetime=""></time>
            </div>
            <div class="notification-inbox-row__quick-actions" role="group" aria-label="Notification actions">
                <button type="button" class="notification-inbox__icon-button" data-notification-row-action="toggle-read" title="Mark as read" aria-label="Mark as read">
                    <i class="bi bi-envelope-open" aria-hidden="true"></i>
                </button>
                <button type="button" class="notification-inbox__icon-button" data-notification-row-action="toggle-mute" title="Mute project" aria-label="Mute project">
                    <i class="bi bi-bell-slash" aria-hidden="true"></i>
                </button>
                <a class="notification-inbox__icon-button" href="#" target="_blank" rel="noopener" data-notification-open-new title="Open in new tab" aria-label="Open notification in new tab">
                    <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
                </a>
            </div>
            <span class="visually-hidden" data-notification-state>Unread</span>
        </article>
    </template>
</section>
