@page
@using System.Text.Json
@model ProjectManagement.Pages.Notifications.IndexModel
@{
    ViewData["Title"] = "Notification Centre";
    ViewData["PageShell"] = "wide";
    var bootstrap = new
    {
        items = Model.ViewModel.Notifications,
        totalCount = Model.ViewModel.TotalCount,
        unreadCount = Model.ViewModel.UnreadCount,
        nextCursor = Model.ViewModel.NextCursor,
        hasMore = Model.ViewModel.HasMore,
        projects = Model.ViewModel.Projects,
        modules = Model.ViewModel.Modules,
    };
    var bootstrapJson = JsonSerializer.Serialize(
        bootstrap,
        new JsonSerializerOptions(JsonSerializerDefaults.Web));
}
<section class="notification-centre py-4" data-notification-center
         data-api-base="@Model.ViewModel.ApiBaseUrl"
         data-unread-url="@Model.ViewModel.UnreadCountUrl"
         data-hub-url="@Model.ViewModel.HubUrl"
         data-notification-limit="@Model.ViewModel.PageSize"
         data-unread-count="@Model.ViewModel.UnreadCount"
         data-notification-center-url="@Model.ViewModel.NotificationCenterUrl">
    <script type="application/json" data-notification-bootstrap>@Html.Raw(bootstrapJson)</script>

    <header class="notification-centre__hero">
        <div>
            <span class="notification-centre__kicker">Personal activity inbox</span>
            <h1 class="notification-centre__title">Notification Centre</h1>
            <p class="notification-centre__lead">Review updates, resolve action items and control project-level alerts.</p>
        </div>
        <div class="notification-centre__metrics" aria-label="Notification summary">
            <div class="notification-centre__metric">
                <span class="notification-centre__metric-value" data-notification-unread-count>@Model.ViewModel.UnreadCount</span>
                <span class="notification-centre__metric-label">Unread</span>
            </div>
            <div class="notification-centre__metric">
                <span class="notification-centre__metric-value" data-notification-total-count>@Model.ViewModel.TotalCount</span>
                <span class="notification-centre__metric-label">Matching</span>
            </div>
        </div>
    </header>

    <div class="notification-centre__toolbar" role="region" aria-labelledby="notificationFiltersHeading">
        <div class="notification-centre__toolbar-heading">
            <h2 id="notificationFiltersHeading">Find notifications</h2>
            <button type="button" class="btn btn-sm btn-link" data-notification-action="clear-filters">Clear filters</button>
        </div>
        <form class="notification-centre__filters" data-notification-filters>
            <div class="notification-filter notification-filter--search">
                <label class="visually-hidden" for="notificationSearch">Search notifications</label>
                <i class="bi bi-search" aria-hidden="true"></i>
                <input type="search" id="notificationSearch" class="form-control" data-filter-search
                       placeholder="Search title, details or project" autocomplete="off" />
            </div>
            <div class="notification-filter">
                <label class="form-label" for="notificationStatusFilter">Status</label>
                <select id="notificationStatusFilter" class="form-select" data-filter-status>
                    <option value="all" selected>All</option>
                    <option value="unread">Unread</option>
                    <option value="read">Read</option>
                    <option value="muted">Muted projects</option>
                </select>
            </div>
            <div class="notification-filter">
                <label class="form-label" for="notificationProjectFilter">Project</label>
                <select id="notificationProjectFilter" class="form-select" data-filter-project>
                    <option value="">All projects</option>
                    @foreach (var project in Model.ViewModel.Projects)
                    {
                        <option value="@project.Id">@project.Label@(project.IsMuted ? " — muted" : string.Empty)</option>
                    }
                </select>
            </div>
            <div class="notification-filter">
                <label class="form-label" for="notificationModuleFilter">Module</label>
                <select id="notificationModuleFilter" class="form-select" data-filter-module>
                    <option value="">All modules</option>
                    @foreach (var module in Model.ViewModel.Modules)
                    {
                        <option value="@module">@module</option>
                    }
                </select>
            </div>
        </form>
    </div>

    <div class="notification-centre__panel">
        <div class="notification-centre__actions">
            <div class="d-flex align-items-center gap-2">
                <input class="form-check-input mt-0" type="checkbox" data-select-all aria-label="Select all loaded notifications" />
                <span class="small fw-semibold" data-selection-count>0 selected</span>
            </div>
            <div class="notification-centre__bulk-buttons" role="group" aria-label="Bulk notification actions">
                <button type="button" class="btn btn-sm btn-outline-primary" data-notification-bulk="mark-read" disabled>
                    <i class="bi bi-envelope-open" aria-hidden="true"></i> Mark read
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-notification-bulk="mark-unread" disabled>
                    <i class="bi bi-envelope" aria-hidden="true"></i> Mark unread
                </button>
                <button type="button" class="btn btn-sm btn-outline-primary" data-notification-action="mark-all-read"
                        @(Model.ViewModel.UnreadCount == 0 ? "disabled" : null)>
                    <i class="bi bi-check2-all" aria-hidden="true"></i> Mark all read
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-notification-bulk="mute-project" disabled>
                    <i class="bi bi-bell-slash" aria-hidden="true"></i> Mute project
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-notification-bulk="unmute-project" disabled>
                    <i class="bi bi-bell" aria-hidden="true"></i> Unmute project
                </button>
                <button type="button" class="btn btn-sm btn-outline-dark" data-notification-action="refresh" title="Refresh notifications">
                    <i class="bi bi-arrow-clockwise" aria-hidden="true"></i>
                    <span class="visually-hidden">Refresh notifications</span>
                </button>
            </div>
        </div>

        <div class="notification-centre__loading" data-notification-loading hidden>
            <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
            <span>Loading notifications…</span>
        </div>

        <div class="notification-centre__list" data-notification-center-list aria-live="polite">
            <div data-notification-rows>
                @foreach (var item in Model.ViewModel.Notifications)
                {
                    <article class="notification-card @(item.IsRead ? "is-read" : "is-unread")"
                             data-notification-row
                             data-notification-id="@item.Id"
                             data-project-id="@(item.ProjectId?.ToString() ?? string.Empty)"
                             data-read="@(item.IsRead ? "true" : "false")"
                             data-muted="@(item.IsProjectMuted ? "true" : "false")">
                        <div class="notification-card__select">
                            <input class="form-check-input" type="checkbox" value="@item.Id"
                                   data-notification-select aria-label="Select notification" />
                        </div>
                        <div class="notification-card__icon" aria-hidden="true"><i class="@item.IconCssClass"></i></div>
                        <div class="notification-card__body">
                            <div class="notification-card__context">
                                <span data-notification-category>@item.Category</span>
                                @if (!string.IsNullOrWhiteSpace(item.ProjectName))
                                {
                                    <span aria-hidden="true">•</span>
                                    <span data-notification-project>@item.ProjectName</span>
                                }
                                @if (item.IsActionRequired)
                                {
                                    <span class="notification-card__action-badge" data-notification-action-required>Action required</span>
                                }
                            </div>
                            <a class="notification-card__title" href="@(string.IsNullOrWhiteSpace(item.Route) ? Model.ViewModel.NotificationCenterUrl : item.Route)"
                               data-notification-link data-notification-title>
                                @(string.IsNullOrWhiteSpace(item.Title) ? "Notification" : item.Title)
                            </a>
                            @if (!string.IsNullOrWhiteSpace(item.Summary))
                            {
                                <p class="notification-card__summary" data-notification-summary>@item.Summary</p>
                            }
                            <div class="notification-card__meta">
                                <time datetime="@item.CreatedUtc.ToString("O")" title="@item.CreatedDisplayIst" data-notification-created>@item.CreatedDisplayIst</time>
                                @if (!string.IsNullOrWhiteSpace(item.ActorDisplayName))
                                {
                                    <span aria-hidden="true">•</span>
                                    <span data-notification-actor>@item.ActorDisplayName</span>
                                }
                                <span class="notification-card__muted" data-notification-muted @(item.IsProjectMuted ? null : "hidden")>
                                    <i class="bi bi-bell-slash" aria-hidden="true"></i> Muted
                                </span>
                            </div>
                        </div>
                        <div class="notification-card__state">
                            <span class="notification-state-pill @(item.IsRead ? "is-read" : "is-unread")" data-notification-state>
                                @(item.IsRead ? "Read" : "Unread")
                            </span>
                        </div>
                    </article>
                }
            </div>

            <div class="notification-centre__empty" data-notification-empty @(Model.ViewModel.Notifications.Count == 0 ? null : "hidden")>
                <i class="bi bi-inbox" aria-hidden="true"></i>
                <h3>No notifications found</h3>
                <p>Adjust the filters or check back when new activity occurs.</p>
            </div>
        </div>

        <div class="notification-centre__footer">
            <div>
                <span data-notification-list-summary>
                    Showing @Model.ViewModel.Notifications.Count of @Model.ViewModel.TotalCount notifications
                </span>
                <span class="notification-centre__status" data-notification-status role="status" aria-live="polite"></span>
            </div>
            <button type="button" class="btn btn-outline-primary btn-sm" data-notification-load-more
                    @(Model.ViewModel.HasMore ? null : "hidden")>
                Load more
            </button>
        </div>
    </div>

    <template data-notification-row-template>
        <article class="notification-card is-unread" data-notification-row>
            <div class="notification-card__select">
                <input class="form-check-input" type="checkbox" data-notification-select aria-label="Select notification" />
            </div>
            <div class="notification-card__icon" aria-hidden="true"><i data-notification-icon class="bi bi-bell"></i></div>
            <div class="notification-card__body">
                <div class="notification-card__context">
                    <span data-notification-category>General</span>
                    <span data-notification-project-separator aria-hidden="true">•</span>
                    <span data-notification-project></span>
                    <span class="notification-card__action-badge" data-notification-action-required hidden>Action required</span>
                </div>
                <a class="notification-card__title" href="#" data-notification-link data-notification-title>Notification</a>
                <p class="notification-card__summary" data-notification-summary></p>
                <div class="notification-card__meta">
                    <time data-notification-created datetime=""></time>
                    <span data-notification-actor-separator aria-hidden="true">•</span>
                    <span data-notification-actor></span>
                    <span class="notification-card__muted" data-notification-muted hidden>
                        <i class="bi bi-bell-slash" aria-hidden="true"></i> Muted
                    </span>
                </div>
            </div>
            <div class="notification-card__state">
                <span class="notification-state-pill is-unread" data-notification-state>Unread</span>
            </div>
        </article>
    </template>
</section>
