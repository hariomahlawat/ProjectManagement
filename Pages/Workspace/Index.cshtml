@page "/Workspace"
@model ProjectManagement.Pages.Workspace.IndexModel
@{
    ViewData["Title"] = Model.IsCommandMode
        ? Model.CommandWorkspace.ActiveView switch
        {
            "portfolio" => "Project Portfolio | Comdt / HoD Workspace",
            "adoption" => "ERP Adoption | Comdt / HoD Workspace",
            _ => "Officer Workload | Comdt / HoD Workspace"
        }
        : "My Workspace";
    ViewData["UseFullWidth"] = true;
    ViewData["PageShell"] = "workspace";
}
@section Styles {
    <link rel="stylesheet" href="~/css/command-workspace.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/workspace.css" asp-append-version="true" />
}

@if (Model.IsCommandMode)
{
    @await Html.PartialAsync("_CommandWorkspace", Model)
}
else
{
    @await Html.PartialAsync("_ProjectOfficerWorkspace", Model)
}

@section Scripts {
    @if (Model.IsCommandMode)
    {
        <script src="~/lib/chart.js/chart.umd.js" asp-append-version="true"></script>
        <script src="~/lib/sortable/1.15.2/Sortable.min.js" asp-append-version="true"></script>
        <script type="module" src="~/js/pages/command-workspace.js" asp-append-version="true"></script>
    }
    else
    {
        <script src="~/js/pages/workspace-index.js" asp-append-version="true"></script>
    }
}
