@page "/Workspace"
@using ProjectManagement.ViewModels.Workspace
@using ProjectManagement.Services.Workspace
@model ProjectManagement.Pages.Workspace.IndexModel
@{
    ViewData["Title"] = "My Workspace";
    ViewData["UseFullWidth"] = true;

    var actionCount = Model.Workspace.ActionQueueTotalCount;
    var dailyActionTitle = actionCount == 0
        ? "Your workspace is clear"
        : actionCount == 1
            ? "1 action requires attention"
            : $"{actionCount} actions require attention";
    var visibleProjectCount = Model.Workspace.ProjectMatrix.Count;
    var followUpCount = Model.Workspace.PersonalReminders.Count + Model.Workspace.Ideas.Count;
    var projectAttentionCount = Model.Workspace.ProjectMatrix.Count(row =>
        row.UpdateStatus.Equals("ActionRequired", StringComparison.OrdinalIgnoreCase) ||
        WorkspaceDisplayHelpers.TimelineStatusCss(row) is "danger" or "warning" ||
        row.RecordGapCount > 0);
    var overdueProjectCount = Model.Workspace.ProjectMatrix.Count(row =>
        WorkspaceDisplayHelpers.TimelineStatusCss(row) == "danger");
    var incompleteTimelineCount = Model.Workspace.ProjectMatrix.Count(row =>
        WorkspaceDisplayHelpers.TimelineStatusLabel(row).Contains("missing", StringComparison.OrdinalIgnoreCase));
    var reviewDocumentCount = Model.Workspace.ActionQueue.Count(item =>
        item.Type.Equals("Aots", StringComparison.OrdinalIgnoreCase));
    var operationalSummaryParts = new List<string>();
    if (projectAttentionCount > 0) operationalSummaryParts.Add($"{projectAttentionCount} project{(projectAttentionCount == 1 ? "" : "s")} need attention");
    if (overdueProjectCount > 0) operationalSummaryParts.Add($"{overdueProjectCount} overdue");
    if (incompleteTimelineCount > 0) operationalSummaryParts.Add($"{incompleteTimelineCount} current-stage timeline{(incompleteTimelineCount == 1 ? "" : "s")} incomplete");
    if (reviewDocumentCount > 0) operationalSummaryParts.Add($"{reviewDocumentCount} AOTS document{(reviewDocumentCount == 1 ? "" : "s")} awaiting review");
    var operationalSummary = operationalSummaryParts.Count > 0
        ? string.Join(" · ", operationalSummaryParts)
        : "No overdue project actions or incomplete timelines";
    var recordHealthRows = Model.Workspace.ProjectMatrix
        .Select(row => row.RecordHealth)
        .Concat(Model.Workspace.ImproveProjects.Select(item => item.RecordHealth))
        .Where(health => health.ProjectId > 0)
        .GroupBy(health => health.ProjectId)
        .Select(group => group.First())
        .OrderBy(health => health.HealthPercent)
        .ToList();
}
@section Styles {
    <link rel="stylesheet" href="~/css/workspace.css" asp-append-version="true" />
}

<div class="po-workspace">
    <header class="po-command" id="today">
        <div class="po-command__main">
            <div class="po-command__identity">
                <span class="po-command__mark" aria-hidden="true"><i class="bi bi-grid-1x2-fill"></i></span>
                <div>
                    <div class="po-eyebrow">Project Officer Workspace</div>
                    <h1>@dailyActionTitle</h1>
                    <p>Review priority work, maintain records and keep assigned projects moving.</p>
                    <div class="po-operational-summary"><i class="bi bi-activity"></i><span>@operationalSummary</span></div>
                </div>
            </div>

            <div class="po-command__actions">
                <span class="po-date" title="Workspace data refresh time"><i class="bi bi-arrow-clockwise"></i>Refreshed @Model.Workspace.GeneratedAtUtc.ToLocalTime().ToString("HH:mm")</span>
                <a class="po-btn po-btn--secondary" href="@WorkspaceRouteHelper.ActionTasksMyWork()"><i class="bi bi-list-check"></i><span>View assigned work</span></a>
                <a class="po-btn po-btn--primary" href="@Model.Workspace.MyProjectsUrl"><i class="bi bi-kanban"></i><span>Open my projects</span></a>
            </div>
        </div>

        <div class="po-command__metrics" aria-label="Workspace summary">
            <a class="po-metric @(actionCount > 0 ? "po-metric--attention" : "po-metric--clear")" href="#action-queue">
                <span class="po-metric__icon"><i class="bi bi-lightning-charge-fill"></i></span>
                <span><strong>@actionCount</strong><small>Actions pending</small></span>
                <i class="bi bi-arrow-down-right po-metric__arrow"></i>
            </a>
            <a class="po-metric @(Model.Workspace.AssignedProjectCount > 0 ? "po-metric--primary" : "po-metric--clear")" href="#assigned-projects">
                <span class="po-metric__icon"><i class="bi bi-kanban-fill"></i></span>
                <span><strong>@Model.Workspace.AssignedProjectCount</strong><small>Assigned projects</small></span>
                <i class="bi bi-arrow-down-right po-metric__arrow"></i>
            </a>
            <a class="po-metric @(Model.Workspace.RecordGapCount > 0 ? "po-metric--danger" : "po-metric--clear")" href="#record-gaps">
                <span class="po-metric__icon"><i class="bi bi-clipboard2-pulse-fill"></i></span>
                <span><strong>@Model.Workspace.RecordGapCount</strong><small>Pending fields</small></span>
                <i class="bi bi-arrow-down-right po-metric__arrow"></i>
            </a>
        </div>
    </header>

    <nav class="po-section-nav" aria-label="Workspace sections">
        <a href="#action-queue" class="active"><i class="bi bi-list-check"></i><span>Action queue</span><b>@actionCount</b></a>
        <a href="#assigned-projects"><i class="bi bi-kanban"></i><span>Assigned projects</span><b>@Model.Workspace.AssignedProjectCount</b></a>
        <a href="#record-gaps"><i class="bi bi-clipboard2-pulse"></i><span>Pending fields</span><b>@Model.Workspace.RecordGapCount</b></a>
        <a href="#follow-ups"><i class="bi bi-bell"></i><span>Follow-ups</span><b>@followUpCount</b></a>
    </nav>

    <div class="po-layout">
        <main class="po-main">
            <section id="action-queue" class="po-panel po-actions-panel" data-workspace-section>
                <div class="po-panel__head">
                    <div>
                        <span class="po-panel__kicker">Current workload</span>
                        <h2>Action Queue</h2>
                        <p>Sequenced by operational priority. Start with the highlighted item.</p>
                    </div>
                    <a class="po-link" href="@WorkspaceRouteHelper.ActionTasksMyWork()">Open complete queue<i class="bi bi-arrow-right"></i></a>
                </div>

                @if (!Model.Workspace.ActionQueue.Any())
                {
                    <div class="po-empty po-empty--success">
                        <i class="bi bi-check2-circle"></i>
                        <div><strong>Queue clear</strong><span>New project actions and documents will appear here.</span></div>
                    </div>
                }
                else
                {
                    <div class="po-action-list" role="list">
                        @for (var i = 0; i < Model.Workspace.ActionQueue.Count; i++)
                        {
                            var item = Model.Workspace.ActionQueue[i];
                            var isRecommended = i == 0;
                            var actionSeverityClass = item.Type.Equals("Aots", StringComparison.OrdinalIgnoreCase)
                                ? "routine"
                                : item.Severity.ToLowerInvariant();
                            <article role="listitem" class="po-action @(isRecommended ? "po-action--recommended" : string.Empty) po-action--@actionSeverityClass">
                                <span class="po-action__rail" aria-hidden="true"></span>
                                <div class="po-action__type">
                                    <span class="po-type po-type--@item.Type.ToLowerInvariant()">@item.BadgeText</span>
                                    @if (isRecommended)
                                    {
                                        <span class="po-recommended"><i class="bi bi-stars"></i>Recommended next</span>
                                    }
                                </div>
                                <div class="po-action__content">
                                    <a href="@item.ActionUrl" class="po-action__title" title="@item.Title">@item.Title</a>
                                    <div class="po-action__meta">
                                        <span>@item.Detail</span>
                                        @if (!string.IsNullOrWhiteSpace(item.Meta))
                                        {
                                            <span class="po-action__separator" aria-hidden="true"></span>
                                            <span class="po-action__context">@item.Meta</span>
                                        }
                                    </div>
                                </div>
                                <a class="po-action__button" href="@item.ActionUrl"><span>@item.ActionText</span><i class="bi bi-arrow-right"></i></a>
                            </article>
                        }
                    </div>

                    @if (Model.Workspace.ActionQueueHiddenCount > 0)
                    {
                        <div class="po-panel__footer">
                            <span>@Model.Workspace.ActionQueueHiddenCount additional item@(Model.Workspace.ActionQueueHiddenCount == 1 ? "" : "s") not shown</span>
                            <a href="@WorkspaceRouteHelper.ActionTasksMyWork()">View complete queue</a>
                        </div>
                    }
                }
            </section>

            <section id="assigned-projects" class="po-panel po-projects-panel" data-workspace-section>
                <div class="po-panel__head">
                    <div>
                        <span class="po-panel__kicker">Portfolio control</span>
                        <h2>Assigned Projects</h2>
                        <p>Projects requiring intervention are shown first.</p>
                    </div>
                    <div class="po-head-actions">
                        @if (Model.Workspace.AssignedProjectCount > visibleProjectCount)
                        {
                            <span>Showing @visibleProjectCount of @Model.Workspace.AssignedProjectCount</span>
                        }
                        <a class="po-link" href="@Model.Workspace.MyProjectsUrl">View all projects<i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>

                @if (!Model.Workspace.ProjectMatrix.Any())
                {
                    <div class="po-empty"><i class="bi bi-kanban"></i><div><strong>No assigned projects</strong><span>Your assigned projects will appear here.</span></div></div>
                }
                else
                {
                    <div class="po-table-wrap">
                        <table class="po-project-table">
                            <thead>
                                <tr>
                                    <th>Project</th>
                                    <th>Stage</th>
                                    <th>Update</th>
                                    <th>Timeline</th>
                                    <th>
                                        <span class="po-th-with-help">Record completeness
                                            <button type="button" class="po-help-button" data-bs-toggle="modal" data-bs-target="#recordCompletenessHelp" aria-label="How record completeness is calculated">
                                                <i class="bi bi-info-circle"></i>
                                            </button>
                                        </span>
                                    </th>
                                    <th><span class="visually-hidden">Next action</span></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.Workspace.ProjectMatrix)
                                {
                                    var timelineCss = WorkspaceDisplayHelpers.TimelineStatusCss(row);
                                    var rowCritical = row.UpdateStatus.Equals("ActionRequired", StringComparison.OrdinalIgnoreCase) || timelineCss == "danger";
                                    var rowWarning = !rowCritical && (timelineCss == "warning" || row.RecordHealthPercent < 50);
                                    var rowClass = rowCritical ? "po-project-row--critical" : rowWarning ? "po-project-row--warning" : "po-project-row--normal";
                                    <tr class="@rowClass">
                                        <td>
                                            <div class="po-project-cell">
                                                <span class="po-project-indicator" aria-hidden="true"></span>
                                                <div>
                                                    <a class="po-project-name" href="@row.OpenUrl" title="@row.ProjectName">@row.ProjectName</a>
                                                    <small>@row.RecordGapCount pending field@(row.RecordGapCount == 1 ? "" : "s")</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td><div class="po-stage"><strong>@row.CurrentStageCode</strong>@if (row.DaysInCurrentStage.HasValue){<span>@row.DaysInCurrentStage.Value days</span>}</div></td>
                                        <td><span class="po-status po-status--@row.UpdateStatus.ToLowerInvariant()"><i></i>@WorkspaceDisplayHelpers.CompactStatusLabel(row.UpdateStatus)</span></td>
                                        <td><span class="po-status po-status--@timelineCss"><i></i>@WorkspaceDisplayHelpers.TimelineStatusLabel(row)</span></td>
                                        <td>
                                            <button type="button"
                                                    class="po-record po-record--@WorkspaceDisplayHelpers.HealthCss(row.RecordHealthPercent)"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#recordHealth-@row.ProjectId"
                                                    title="View exact pending fields for @row.ProjectName">
                                                <span class="po-record__top"><strong>@row.RecordHealthPercent% record completeness</strong><small>@row.RecordGapCount pending field@(row.RecordGapCount == 1 ? "" : "s")</small></span>
                                                <span class="po-record__bar"><i style="width:@row.RecordHealthPercent%"></i></span>
                                                <span class="po-record__view">View breakdown</span>
                                            </button>
                                        </td>
                                        <td><a class="po-row-action" href="@row.NextActionUrl"><span>@WorkspaceDisplayHelpers.CompactActionLabel(row.NextActionText)</span><i class="bi bi-arrow-right"></i></a></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            <section id="follow-ups" class="po-panel po-follow-panel" data-workspace-section>
                <div class="po-panel__head">
                    <div>
                        <span class="po-panel__kicker">Personal work</span>
                        <h2>Follow-ups</h2>
                        <p>Reminders and project ideas requiring your attention.</p>
                    </div>
                    <a class="po-link" href="/Notebook?view=today">Open notebook<i class="bi bi-arrow-right"></i></a>
                </div>

                <div class="po-follow-grid">
                    <div class="po-follow-column">
                        <div class="po-follow-column__head">
                            <span><i class="bi bi-bell"></i><strong>Reminders</strong></span>
                            <b>@Model.Workspace.PersonalReminders.Count</b>
                        </div>
                        @if (!Model.Workspace.PersonalReminders.Any())
                        {
                            <div class="po-follow-empty"><i class="bi bi-check2"></i>No reminders due.</div>
                        }
                        else
                        {
                            <div class="po-follow-list">
                                @foreach (var reminder in Model.Workspace.PersonalReminders.Take(4))
                                {
                                    var reminderClass = string.Empty;
                                    if (reminder.DueAtUtc.HasValue)
                                    {
                                        if (reminder.DueAtUtc.Value < DateTimeOffset.UtcNow)
                                        {
                                            reminderClass = "po-follow-item--overdue";
                                        }
                                        else if (reminder.DueAtUtc.Value <= DateTimeOffset.UtcNow.AddDays(7))
                                        {
                                            reminderClass = "po-follow-item--due-soon";
                                        }
                                    }
                                    <a href="@reminder.OpenUrl" class="@reminderClass">
                                        <span><strong>@reminder.Title</strong><small>@reminder.Priority · @WorkspaceDisplayHelpers.FormatReminderDate(reminder.DueAtUtc)</small></span>
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                }
                            </div>
                        }
                    </div>

                    <div class="po-follow-column">
                        <div class="po-follow-column__head">
                            <span><i class="bi bi-lightbulb"></i><strong>Project ideas</strong></span>
                            <a href="/ProjectIdeas?MyIdeas=true">View all</a>
                        </div>
                        @if (!Model.Workspace.Ideas.Any())
                        {
                            <div class="po-follow-empty"><i class="bi bi-check2"></i>No active ideas.</div>
                        }
                        else
                        {
                            <div class="po-follow-list">
                                @foreach (var idea in Model.Workspace.Ideas.Take(4))
                                {
                                    <a href="@idea.OpenUrl">
                                        <span><strong>@idea.Title</strong><small>@idea.Status · @idea.CommentCount comments · @idea.DocumentCount docs</small></span>
                                        @if (idea.NeedsUpdate)
                                        {
                                            <em>Update</em>
                                        }
                                        else
                                        {
                                            <i class="bi bi-chevron-right"></i>
                                        }
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </section>
        </main>

        <aside class="po-sidebar">
            <section id="record-gaps" class="po-readiness" data-workspace-section>
                <div class="po-readiness__head">
                    <div>
                        <span class="po-panel__kicker">Project readiness</span>
                        <h2>Pending Fields</h2>
                        <p>Fields that need to be completed in assigned projects.</p>
                    </div>
                    <span class="po-readiness__count">@Model.Workspace.RecordGapCount</span>
                </div>

                @if (!Model.Workspace.ImproveProjects.Any())
                {
                    <div class="po-readiness__empty"><i class="bi bi-check2-circle"></i><strong>Records complete</strong><span>No applicable project fields are pending.</span></div>
                }
                else
                {
                    <div class="po-gap-list">
                        @foreach (var item in Model.Workspace.ImproveProjects)
                        {
                            var gapSeverity = item.FixCount >= 6 ? "critical" : item.FixCount >= 4 ? "attention" : "standard";
                            <article class="po-gap-item po-gap-item--@gapSeverity">
                                <div class="po-gap-item__top">
                                    <a href="@item.Url" title="@item.ProjectName">@item.ProjectName</a>
                                    <span>@item.FixCount</span>
                                </div>
                                <div class="po-gap-labels">
                                    @foreach (var gap in item.PreviewGapDetails.Take(3))
                                    {
                                        <a href="@gap.ActionUrl">@gap.Label</a>
                                    }
                                    @if (item.HiddenGapCount > 0)
                                    {
                                        <span>+@item.HiddenGapCount more</span>
                                    }
                                </div>
                                <button type="button" class="po-text-action po-text-action--button" data-bs-toggle="modal" data-bs-target="#recordHealth-@item.ProjectId">
                                    View pending fields<i class="bi bi-arrow-right"></i>
                                </button>
                            </article>
                        }
                    </div>
                    <a class="po-readiness__footer" href="@Model.Workspace.MyProjectsUrl">Open all assigned projects<i class="bi bi-arrow-right"></i></a>
                }
            </section>
        </aside>
    </div>
</div>

@foreach (var health in recordHealthRows)
{
    var healthCss = WorkspaceDisplayHelpers.HealthCss(health.HealthPercent);
    <div class="modal fade po-record-modal" id="recordHealth-@health.ProjectId" tabindex="-1" aria-labelledby="recordHealthLabel-@health.ProjectId" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header po-record-modal__header">
                    <div>
                        <span class="po-record-modal__eyebrow">Project record completeness</span>
                        <h2 class="modal-title" id="recordHealthLabel-@health.ProjectId">@health.ProjectName</h2>
                        <p>Only information applicable to the project’s current stage is assessed.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body po-record-modal__body">
                    <div class="po-record-summary po-record-summary--@healthCss">
                        <div class="po-record-summary__score">
                            <strong>@health.HealthPercent%</strong>
                            <span>@health.HealthLabel</span>
                        </div>
                        <div class="po-record-summary__progress" aria-label="@health.HealthPercent percent complete">
                            <i style="width:@health.HealthPercent%"></i>
                        </div>
                        <div class="po-record-summary__meta">
                            <strong>@health.PendingFieldCount pending field@(health.PendingFieldCount == 1 ? "" : "s")</strong>
                            <span>Every deduction below maps to a specific field and correction action.</span>
                        </div>
                    </div>

                    <section class="po-component-section" aria-labelledby="componentScores-@health.ProjectId">
                        <div class="po-record-modal__section-head">
                            <div>
                                <h3 id="componentScores-@health.ProjectId">Score breakdown</h3>
                                <p>Component scores total 100 points.</p>
                            </div>
                        </div>
                        <div class="po-component-grid">
                            @foreach (var component in health.Components)
                            {
                                var componentPercent = component.MaximumPoints <= 0 ? 100 : (int)Math.Round(component.EarnedPoints / component.MaximumPoints * 100m);
                                var componentCss = component.Status.ToLowerInvariant();
                                <article class="po-component-card po-component-card--@componentCss">
                                    <div class="po-component-card__top">
                                        <span>@component.Label</span>
                                        <strong>@component.EarnedPoints.ToString("0.##")/@component.MaximumPoints.ToString("0.##")</strong>
                                    </div>
                                    <div class="po-component-card__bar"><i style="width:@componentPercent%"></i></div>
                                    <div class="po-component-card__foot">
                                        <span class="po-component-status">@component.Status</span>
                                        @if (component.Gaps.Count > 0)
                                        {
                                            <span>@component.Gaps.Count pending</span>
                                        }
                                    </div>
                                </article>
                            }
                        </div>
                    </section>

                    <section class="po-pending-section" aria-labelledby="pendingFields-@health.ProjectId">
                        <div class="po-record-modal__section-head">
                            <div>
                                <h3 id="pendingFields-@health.ProjectId">Exact pending fields</h3>
                                <p>Complete these items to improve the score.</p>
                            </div>
                        </div>
                        @if (!health.GapDetails.Any())
                        {
                            <div class="po-record-complete-state">
                                <i class="bi bi-check2-circle"></i>
                                <div><strong>Record complete</strong><span>No applicable fields are pending.</span></div>
                            </div>
                        }
                        else
                        {
                            <div class="po-pending-groups">
                                @foreach (var group in health.GapDetails.GroupBy(gap => gap.Component))
                                {
                                    <div class="po-pending-group">
                                        <h4>@group.Key <span>@group.Count()</span></h4>
                                        <div class="po-pending-list">
                                            @foreach (var gap in group)
                                            {
                                                <article class="po-pending-field">
                                                    <span class="po-pending-field__icon"><i class="bi @gap.Icon"></i></span>
                                                    <div class="po-pending-field__content">
                                                        <div class="po-pending-field__title">
                                                            <strong>@gap.FieldLabel</strong>
                                                            <span class="po-field-status po-field-status--@gap.Status.ToLowerInvariant()">@gap.Status</span>
                                                        </div>
                                                        <p>@gap.Reason</p>
                                                        <small>@gap.MaximumPoints.ToString("0.##") point@(gap.MaximumPoints == 1 ? "" : "s") affected</small>
                                                    </div>
                                                    <a class="po-pending-field__action" href="@gap.ActionUrl">@gap.ActionText<i class="bi bi-arrow-right"></i></a>
                                                </article>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </section>
                </div>
                <div class="modal-footer po-record-modal__footer">
                    <span><i class="bi bi-shield-check"></i>Not-applicable and not-yet-applicable fields do not reduce the score.</span>
                    <a class="po-btn po-btn--secondary" href="@health.OpenUrl">Open project overview</a>
                    <button type="button" class="po-btn po-btn--primary" data-bs-dismiss="modal">Done</button>
                </div>
            </div>
        </div>
    </div>
}

<div class="modal fade po-record-help-modal" id="recordCompletenessHelp" tabindex="-1" aria-labelledby="recordCompletenessHelpLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <span class="po-record-modal__eyebrow">How the score works</span>
                    <h2 class="modal-title" id="recordCompletenessHelpLabel">Record completeness</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body po-record-help">
                <p class="po-record-help__lead">The score measures how much of the project information that should exist at the present stage has actually been recorded.</p>
                <div class="po-record-help__principles">
                    <div><i class="bi bi-diagram-3"></i><strong>Stage-aware</strong><span>Only fields enabled by completed or current stages are assessed.</span></div>
                    <div><i class="bi bi-percent"></i><strong>Proportional</strong><span>Partially completed categories receive proportionate marks.</span></div>
                    <div><i class="bi bi-clock-history"></i><strong>Historical dates</strong><span>Completed historical stages assess Actual Start and Actual Completion only.</span></div>
                    <div><i class="bi bi-calendar2-week"></i><strong>Current-stage PDC</strong><span>The active stage assesses its start date and PDC. An overdue date affects schedule health, not completeness.</span></div>
                </div>
                <div class="po-record-help__weights">
                    <div><span>Core project profile</span><strong>15</strong></div>
                    <div><span>Procurement at a glance</span><strong>25</strong></div>
                    <div><span>Historical stage actual dates</span><strong>20</strong></div>
                    <div><span>Current-stage timeline (PDC)</span><strong>15</strong></div>
                    <div><span>Published project documents</span><strong>15</strong></div>
                    <div><span>Supporting media</span><strong>10</strong></div>
                </div>
                <p class="po-record-help__note"><i class="bi bi-info-circle"></i>Not-applicable and not-yet-applicable fields are excluded. Select any project percentage to see its exact pending fields and direct correction links.</p>
            </div>
            <div class="modal-footer"><button type="button" class="po-btn po-btn--primary" data-bs-dismiss="modal">Understood</button></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/workspace-index.js" asp-append-version="true"></script>
}
