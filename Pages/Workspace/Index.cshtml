@page "/Workspace"
@using ProjectManagement.ViewModels.Workspace
@using ProjectManagement.Services.Workspace
@model ProjectManagement.Pages.Workspace.IndexModel
@{
    ViewData["Title"] = "My Workspace";
    ViewData["UseFullWidth"] = true;

    var actionCount = Model.Workspace.ActionQueueTotalCount;
    var dailyActionTitle = actionCount == 0
        ? "No immediate action is pending"
        : actionCount == 1
            ? "1 action requires attention"
            : $"{actionCount} actions require attention";
    var visibleProjectCount = Model.Workspace.ProjectMatrix.Count;
    var followUpCount = Model.Workspace.PersonalReminders.Count + Model.Workspace.Ideas.Count;
}
@section Styles {
    <link rel="stylesheet" href="~/css/workspace.css" asp-append-version="true" />
}

<div class="po-workspace">
    <header class="po-command" id="today">
        <div class="po-command__identity">
            <div class="po-command__mark" aria-hidden="true"><i class="bi bi-command"></i></div>
            <div>
                <div class="po-eyebrow">PRISM · Project Officer Workspace</div>
                <h1>@dailyActionTitle</h1>
                <p>Prioritise current work, maintain project records and keep assigned projects moving.</p>
            </div>
        </div>

        <div class="po-command__actions">
            <span class="po-date"><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dd MMM yyyy")</span>
            <a class="po-btn po-btn--secondary" href="@WorkspaceRouteHelper.ActionTasksMyWork()"><i class="bi bi-list-check"></i> My work</a>
            <a class="po-btn po-btn--primary" href="@Model.Workspace.MyProjectsUrl"><i class="bi bi-kanban"></i> Open projects</a>
        </div>

        <div class="po-command__metrics" aria-label="Workspace summary">
            @foreach (var chip in Model.Workspace.CommandChips)
            {
                var chipState = chip.State?.ToLowerInvariant() ?? "neutral";
                <div class="po-metric po-metric--@chipState">
                    <span class="po-metric__icon"><i class="bi @chip.Icon"></i></span>
                    <span class="po-metric__value">@chip.Count</span>
                    <span class="po-metric__label">@chip.Label</span>
                </div>
            }
            <div class="po-metric @(Model.Workspace.RecordGapCount > 0 ? "po-metric--attention" : "po-metric--clear")">
                <span class="po-metric__icon"><i class="bi bi-clipboard-data"></i></span>
                <span class="po-metric__value">@Model.Workspace.RecordGapCount</span>
                <span class="po-metric__label">Record gaps</span>
            </div>
        </div>
    </header>

    <nav class="po-section-nav" aria-label="Workspace sections">
        <a href="#action-queue" class="active"><i class="bi bi-list-check"></i><span>Action queue</span><b>@actionCount</b></a>
        <a href="#assigned-projects"><i class="bi bi-kanban"></i><span>Assigned projects</span><b>@Model.Workspace.AssignedProjectCount</b></a>
        <a href="#record-gaps"><i class="bi bi-clipboard2-pulse"></i><span>Record gaps</span><b>@Model.Workspace.ImproveProjectsTotalCount</b></a>
        <a href="#follow-ups"><i class="bi bi-bell"></i><span>Follow-ups</span><b>@followUpCount</b></a>
    </nav>

    <div class="po-layout">
        <main class="po-main">
            <section id="action-queue" class="po-panel po-actions-panel">
                <div class="po-panel__head">
                    <div>
                        <span class="po-panel__kicker">Current workload</span>
                        <h2>Action Queue</h2>
                        <p>Items are sequenced by operational priority.</p>
                    </div>
                    <a class="po-link" href="@WorkspaceRouteHelper.ActionTasksMyWork()">Open complete queue <i class="bi bi-arrow-right"></i></a>
                </div>

                @if (!Model.Workspace.ActionQueue.Any())
                {
                    <div class="po-empty po-empty--success">
                        <i class="bi bi-check2-circle"></i>
                        <div><strong>Queue clear</strong><span>New project actions and documents will appear here.</span></div>
                    </div>
                }
                else
                {
                    <div class="po-action-list">
                        @for (var i = 0; i < Model.Workspace.ActionQueue.Count; i++)
                        {
                            var item = Model.Workspace.ActionQueue[i];
                            var isRecommended = i == 0;
                            <article class="po-action @(isRecommended ? "po-action--recommended" : string.Empty) po-action--@item.Severity.ToLowerInvariant()">
                                <div class="po-action__rail" aria-hidden="true"></div>
                                <div class="po-action__priority">
                                    <span class="po-type po-type--@item.Type.ToLowerInvariant()">@item.BadgeText</span>
                                    @if (isRecommended)
                                    {
                                        <span class="po-recommended"><i class="bi bi-stars"></i> Recommended</span>
                                    }
                                </div>
                                <div class="po-action__body">
                                    <strong title="@item.Title">@item.Title</strong>
                                    <span>@item.Detail</span>
                                </div>
                                <div class="po-action__context">
                                    <small>Context</small>
                                    <span>@item.Meta</span>
                                </div>
                                <a class="po-action__button" href="@item.ActionUrl"><span>@item.ActionText</span><i class="bi bi-arrow-right"></i></a>
                            </article>
                        }
                    </div>

                    @if (Model.Workspace.ActionQueueHiddenCount > 0)
                    {
                        <div class="po-panel__footer">
                            <span>@Model.Workspace.ActionQueueHiddenCount additional item@(Model.Workspace.ActionQueueHiddenCount == 1 ? "" : "s") not shown</span>
                            <a href="@WorkspaceRouteHelper.ActionTasksMyWork()">View complete queue</a>
                        </div>
                    }
                }
            </section>

            <section id="assigned-projects" class="po-panel po-projects-panel">
                <div class="po-panel__head">
                    <div>
                        <span class="po-panel__kicker">Portfolio control</span>
                        <h2>Assigned Projects</h2>
                        <p>Projects requiring intervention are shown first.</p>
                    </div>
                    <div class="po-head-actions">
                        @if (Model.Workspace.AssignedProjectCount > visibleProjectCount)
                        {
                            <span>Showing @visibleProjectCount of @Model.Workspace.AssignedProjectCount</span>
                        }
                        <a class="po-link" href="@Model.Workspace.MyProjectsUrl">View all projects <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>

                @if (!Model.Workspace.ProjectMatrix.Any())
                {
                    <div class="po-empty"><i class="bi bi-kanban"></i><div><strong>No assigned projects</strong><span>Your assigned projects will appear here.</span></div></div>
                }
                else
                {
                    <div class="po-table-wrap">
                        <table class="po-project-table">
                            <thead>
                                <tr>
                                    <th>Project</th>
                                    <th>Stage</th>
                                    <th>Update</th>
                                    <th>Timeline</th>
                                    <th>Record health</th>
                                    <th><span class="visually-hidden">Next action</span></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.Workspace.ProjectMatrix)
                                {
                                    var timelineCss = WorkspaceDisplayHelpers.TimelineStatusCss(row);
                                    var rowAttention = row.UpdateStatus.Equals("ActionRequired", StringComparison.OrdinalIgnoreCase) || timelineCss == "danger";
                                    <tr class="@(rowAttention ? "po-project-row--critical" : string.Empty)">
                                        <td>
                                            <div class="po-project-cell">
                                                <span class="po-project-indicator" aria-hidden="true"></span>
                                                <div>
                                                    <a class="po-project-name" href="@row.OpenUrl" title="@row.ProjectName">@row.ProjectName</a>
                                                    <small>@row.RecordGapCount record gap@(row.RecordGapCount == 1 ? "" : "s")</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="po-stage"><strong>@row.CurrentStageCode</strong>@if (row.DaysInCurrentStage.HasValue){<span>@row.DaysInCurrentStage.Value days</span>}</div>
                                        </td>
                                        <td>
                                            <span class="po-status po-status--@row.UpdateStatus.ToLowerInvariant()">
                                                <i></i>@WorkspaceDisplayHelpers.CompactStatusLabel(row.UpdateStatus)
                                            </span>
                                        </td>
                                        <td>
                                            <span class="po-status po-status--@timelineCss">
                                                <i></i>@WorkspaceDisplayHelpers.TimelineStatusLabel(row)
                                            </span>
                                        </td>
                                        <td>
                                            <a class="po-record po-record--@WorkspaceDisplayHelpers.HealthCss(row.RecordHealthPercent)" href="@row.OpenUrl" title="@row.RecordHealthPercent% complete">
                                                <span class="po-record__top"><strong>@row.RecordHealthPercent%</strong><small>@row.RecordGapCount gap@(row.RecordGapCount == 1 ? "" : "s")</small></span>
                                                <span class="po-record__bar"><i style="width:@row.RecordHealthPercent%"></i></span>
                                            </a>
                                        </td>
                                        <td>
                                            <a class="po-row-action" href="@row.NextActionUrl">@WorkspaceDisplayHelpers.CompactActionLabel(row.NextActionText)<i class="bi bi-arrow-right"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </main>

        <aside class="po-sidebar">
            <section class="po-attention-panel">
                <div class="po-attention-panel__head">
                    <div>
                        <span class="po-panel__kicker">Attention panel</span>
                        <h2>Project Readiness</h2>
                    </div>
                    <span class="po-attention-count">@Model.Workspace.RecordGapCount open</span>
                </div>

                <div id="record-gaps" class="po-attention-section">
                    <div class="po-section-title">
                        <div><i class="bi bi-clipboard2-pulse"></i><span><strong>Records to Complete</strong><small>Highest-impact data gaps</small></span></div>
                        <a href="@Model.Workspace.MyProjectsUrl">View all</a>
                    </div>

                    @if (!Model.Workspace.ImproveProjects.Any())
                    {
                        <div class="po-side-empty"><i class="bi bi-check2-circle"></i><span>All project records are complete.</span></div>
                    }
                    else
                    {
                        <div class="po-gap-list">
                            @foreach (var item in Model.Workspace.ImproveProjects.Take(2))
                            {
                                <article class="po-gap-item">
                                    <div class="po-gap-item__top">
                                        <a href="@item.Url" title="@item.ProjectName">@item.ProjectName</a>
                                        <span>@item.FixCount</span>
                                    </div>
                                    <div class="po-gap-labels">
                                        @foreach (var gap in item.PreviewGapDetails.Take(3))
                                        {
                                            <a href="@gap.ActionUrl">@WorkspaceDisplayHelpers.ShortGapLabel(gap.Label)</a>
                                        }
                                        @if (item.HiddenGapCount > 0)
                                        {
                                            <span>+@item.HiddenGapCount</span>
                                        }
                                    </div>
                                    <a class="po-text-action" href="@item.Url">Complete record <i class="bi bi-arrow-right"></i></a>
                                </article>
                            }
                        </div>
                    }
                </div>

                <div id="follow-ups" class="po-attention-section">
                    <div class="po-section-title">
                        <div><i class="bi bi-bell"></i><span><strong>Personal Follow-ups</strong><small>Reminders and active ideas</small></span></div>
                        <a href="/Notebook?view=today">Notebook</a>
                    </div>

                    <div class="po-follow-group">
                        <div class="po-follow-group__head"><strong>Reminders</strong><span>@Model.Workspace.PersonalReminders.Count</span></div>
                        @if (!Model.Workspace.PersonalReminders.Any())
                        {
                            <p class="po-muted-line">No reminders due.</p>
                        }
                        else
                        {
                            <div class="po-follow-list">
                                @foreach (var reminder in Model.Workspace.PersonalReminders.Take(3))
                                {
                                    <a href="@reminder.OpenUrl">
                                        <span><strong>@reminder.Title</strong><small>@reminder.Priority · @WorkspaceDisplayHelpers.FormatReminderDate(reminder.DueAtUtc)</small></span>
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                }
                            </div>
                        }
                    </div>

                    <div class="po-follow-group po-follow-group--last">
                        <div class="po-follow-group__head"><strong>Project ideas</strong><a href="/ProjectIdeas?MyIdeas=true">View all</a></div>
                        @if (!Model.Workspace.Ideas.Any())
                        {
                            <p class="po-muted-line">No active ideas.</p>
                        }
                        else
                        {
                            <div class="po-follow-list">
                                @foreach (var idea in Model.Workspace.Ideas.Take(3))
                                {
                                    <a href="@idea.OpenUrl">
                                        <span><strong>@idea.Title</strong><small>@idea.Status · @idea.CommentCount comments · @idea.DocumentCount docs</small></span>
                                        @if (idea.NeedsUpdate)
                                        {
                                            <em>Update</em>
                                        }
                                        else
                                        {
                                            <i class="bi bi-chevron-right"></i>
                                        }
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </section>
        </aside>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/workspace-index.js" asp-append-version="true"></script>
}
