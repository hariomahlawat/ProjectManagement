@using ProjectManagement.ViewModels.Workspace
@model ProjectManagement.Pages.Workspace.IndexModel
@{
    var activityYear = Model.Workspace.ActivityYear;
    var year = activityYear.Year;
    var recent = activityYear.Recent;
}
<div class="po-workspace po-workspace--embedded po-dedicated-page">
    <header class="po-dedicated-hero">
        <div>
            <span class="po-eyebrow">My resources</span>
            <h1>My ERP activity</h1>
            <p>Review your recorded ERP adoption pattern. This is not an attendance or productivity measure.</p>
        </div>
        <div class="po-dedicated-hero__metric po-dedicated-hero__metric--activity">
            <strong>@year.MonitoredWorkingDays</strong>
            <span>monitored working day@(year.MonitoredWorkingDays == 1 ? string.Empty : "s") available</span>
            <small>@year.MonitoringAvailabilityLabel</small>
        </div>
    </header>

    <section class="po-personal-activity-kpis po-personal-activity-kpis--year" aria-label="ERP activity summary">
        <article>
            <span><i class="bi bi-calendar-check" aria-hidden="true"></i></span>
            <div>
                <strong>@recent.ActiveWorkingDays of @recent.MonitoredWorkingDays</strong>
                <b>Active working days</b>
                <small>Last 30 calendar days</small>
            </div>
        </article>
        <article>
            <span><i class="bi bi-clock-history" aria-hidden="true"></i></span>
            <div>
                <strong>@year.LastActivityTypeLabel</strong>
                <b>Last recorded activity</b>
                <small>@year.LastActiveLabel</small>
            </div>
        </article>
        <article>
            <span><i class="bi bi-pencil-square" aria-hidden="true"></i></span>
            <div>
                <strong>@year.OperationalActionDays</strong>
                <b>Operational-action day@(year.OperationalActionDays == 1 ? string.Empty : "s")</b>
                <small>Rolling 12-month period</small>
            </div>
        </article>
    </section>

    <section class="po-panel po-year-activity-panel" aria-labelledby="po-year-activity-title">
        <header class="po-year-activity-panel__header">
            <div>
                <span class="po-panel__kicker">Rolling 12 months</span>
                <h2 id="po-year-activity-title">Activity over the last year</h2>
                <p>The shade represents the highest ERP activity level recorded on each calendar day.</p>
            </div>
            <span class="po-period-chip">@activityYear.RollingPeriodLabel</span>
        </header>

        <div class="po-year-activity-panel__body">
            @await Html.PartialAsync("_ErpActivityYearHeatmap", activityYear)

            <div class="po-activity-privacy-note" role="note">
                <i class="bi bi-shield-check" aria-hidden="true"></i>
                <span><strong>Private self-view.</strong> No peer ranking or productivity comparison is performed.</span>
            </div>
        </div>
    </section>

    <details class="po-panel po-recent-activity-details">
        <summary>
            <span>
                <span class="po-panel__kicker">Daily detail</span>
                <strong>Recent 30 days</strong>
                <small>@recent.DateRangeLabel</small>
            </span>
            <span class="po-recent-activity-details__summary">
                @recent.ActivitySummary
                <i class="bi bi-chevron-down" aria-hidden="true"></i>
            </span>
        </summary>

        <div class="po-activity-day-list" aria-label="Recent daily ERP activity">
            @foreach (var day in recent.Days.Reverse())
            {
                <div class="po-activity-day-row">
                    <time datetime="@(day.Date.ToString("yyyy-MM-dd"))">@day.Date.ToString("ddd, dd MMM")</time>
                    <span class="po-activity-day-cell @day.CellStateClass @(day.IsToday ? "is-today" : string.Empty)"
                          title="@day.Tooltip"
                          aria-hidden="true"></span>
                    <strong>@day.StateLabel</strong>
                </div>
            }
        </div>
    </details>
</div>
