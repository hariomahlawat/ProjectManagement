@using ProjectManagement.ViewModels.Workspace
@model ProjectManagement.Pages.Workspace.IndexModel
@{
    var activityYear = Model.Workspace.ActivityYear;
    var year = activityYear.Year;
    var recent = activityYear.Recent;
    var monitoringStart = year.MonitoringStartedOn ?? recent.MonitoringStartedOn ?? year.MonitoringAvailableFrom;
}
<div class="po-workspace po-workspace--embedded po-dedicated-page">
    <header class="po-dedicated-hero">
        <div>
            <span class="po-eyebrow">My resources</span>
            <h1>My ERP activity</h1>
            <p>Review your recorded ERP adoption pattern. This is not an attendance or productivity measure.</p>
        </div>
        <div class="po-dedicated-hero__metric po-dedicated-hero__metric--date">
            <strong>@(monitoringStart?.ToString("dd MMM yyyy") ?? "Not started")</strong>
            <span>Monitoring since</span>
        </div>
    </header>

    <section class="po-personal-activity-kpis po-personal-activity-kpis--year" aria-label="ERP activity summary">
        <article>
            <span><i class="bi bi-calendar-check" aria-hidden="true"></i></span>
            <div>
                <strong>@recent.ActiveWorkingDays of @recent.MonitoredWorkingDays</strong>
                <b>Active monitored working days</b>
                <small>Last 30 calendar days</small>
            </div>
        </article>
        <article>
            <span><i class="bi bi-clock-history" aria-hidden="true"></i></span>
            <div>
                <strong>@recent.LastActivityTypeLabel</strong>
                <b>Last recorded activity</b>
                <small>@recent.LastActiveLabel</small>
            </div>
        </article>
        <article>
            <span><i class="bi bi-pencil-square" aria-hidden="true"></i></span>
            <div>
                <strong>@year.OperationalActionDays</strong>
                <b>Recognised-action day@(year.OperationalActionDays == 1 ? string.Empty : "s")</b>
                <small>@activityYear.OperationalActionPeriodLabel</small>
            </div>
        </article>
    </section>

    <section class="po-panel po-year-activity-panel" aria-labelledby="po-year-activity-title">
        <header class="po-year-activity-panel__header">
            <div>
                <span class="po-panel__kicker">@activityYear.PeriodKicker</span>
                <h2 id="po-year-activity-title">@activityYear.PeriodTitle</h2>
                <p>@activityYear.PeriodDescription</p>
            </div>
            <div class="po-year-activity-panel__context">
                <span class="po-period-chip">@activityYear.PeriodLabel</span>
                <nav class="po-activity-periods" aria-label="ERP activity period">
                    @foreach (var option in activityYear.PrimaryPeriodOptions)
                    {
                        <a asp-page="/Workspace/Index"
                           asp-route-mode="project-officer"
                           asp-route-view="activity"
                           asp-route-activityPeriod="@option.Key"
                           class="@(option.IsSelected ? "is-active" : string.Empty)"
                           aria-current="@(option.IsSelected ? "page" : null)">@option.Label</a>
                    }
                    @if (activityYear.OlderPeriodOptions.Any())
                    {
                        <form method="get" class="po-activity-periods__older">
                            <input type="hidden" name="mode" value="project-officer" />
                            <input type="hidden" name="view" value="activity" />
                            <label for="po-activity-older-year" class="visually-hidden">Older calendar year</label>
                            <select id="po-activity-older-year" name="activityPeriod" onchange="this.form.submit()">
                                <option value="">Older years</option>
                                @foreach (var option in activityYear.OlderPeriodOptions)
                                {
                                    if (option.IsSelected)
                                    {
                                        <option value="@option.Key" selected>@option.Label</option>
                                    }
                                    else
                                    {
                                        <option value="@option.Key">@option.Label</option>
                                    }
                                }
                            </select>
                        </form>
                    }
                </nav>
            </div>
        </header>

        <div class="po-year-activity-panel__body">
            @await Html.PartialAsync("_ErpActivityYearHeatmap", activityYear)

            @if (activityYear.HasHistoricalAudits)
            {
                <div class="po-activity-history-note" role="note">
                    <i class="bi bi-info-circle" aria-hidden="true"></i>
                    <span><strong>Historical records excluded.</strong> @activityYear.HistoricalAuditSummary</span>
                </div>
            }

            <div class="po-activity-privacy-note" role="note">
                <i class="bi bi-shield-check" aria-hidden="true"></i>
                <span><strong>Private self-view.</strong> Daily summaries are retained to preserve your year-on-year activity history; no peer ranking or productivity comparison is performed.</span>
            </div>
        </div>
    </section>

    <details class="po-panel po-recent-activity-details">
        <summary>
            <span>
                <span class="po-panel__kicker">Daily detail</span>
                <strong>Recent 30 days</strong>
                <small>@recent.DateRangeLabel</small>
            </span>
            <span class="po-recent-activity-details__summary">
                @recent.ActivitySummary
                <i class="bi bi-chevron-down" aria-hidden="true"></i>
            </span>
        </summary>

        <div class="po-activity-day-list" aria-label="Recent daily ERP activity">
            @foreach (var day in recent.Days.Reverse())
            {
                <div class="po-activity-day-row">
                    <time datetime="@(day.Date.ToString("yyyy-MM-dd"))">@day.Date.ToString("ddd, dd MMM")</time>
                    <span class="po-activity-day-cell @day.CellStateClass @(day.IsToday ? "is-today" : string.Empty)"
                          title="@day.Tooltip"
                          aria-hidden="true"></span>
                    <strong>@day.StateLabel</strong>
                </div>
            }
        </div>
    </details>
</div>
