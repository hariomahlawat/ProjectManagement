@using System.Text.Json
@using ProjectManagement.Infrastructure
@using ProjectManagement.ViewModels.Workspace
@model ProjectManagement.Pages.Workspace.IndexModel
@{
    var vm = Model.CommandWorkspace;
    var adoption = vm.UsageSummary;
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var isPortfolio = vm.ActiveView == "portfolio";
    var isAdoption = vm.ActiveView == "adoption";
    var selectedCategoryCount = vm.SelectedParentCategoryIds.Count;
    var categoryTriggerText = selectedCategoryCount switch
    {
        0 => "All categories",
        1 => "1 category",
        _ => $"{selectedCategoryCount} categories"
    };
    var filteredProjectCount = vm.StageColumns.Sum(x => x.ProjectCount);
    var completedMaturityDays = Math.Min(adoption.TrackingWorkingDays, adoption.RequiredWorkingDays);
    var hasAdoptionPeriod = adoption.PeriodStart != default && adoption.PeriodEnd != default;
    var adoptionPeriodLabel = !hasAdoptionPeriod
        ? "Current monitored period"
        : adoption.PeriodStart == adoption.PeriodEnd
            ? adoption.PeriodEnd.ToString("dd MMM yyyy")
            : $"{adoption.PeriodStart:dd MMM} – {adoption.PeriodEnd:dd MMM yyyy}";
    var trendJson = JsonSerializer.Serialize(adoption.Trend, jsonOptions);
    var population = Math.Max(1, adoption.TotalUsers);
    var signInReach = Math.Clamp((int)Math.Round(adoption.SignedInUsers * 100d / population), 0, 100);
    var usageReach = Math.Clamp((int)Math.Round(adoption.UsedErpUsers * 100d / population), 0, 100);
    var contributionReach = Math.Clamp((int)Math.Round(adoption.OperationalContributors * 100d / population), 0, 100);
}

<div class="command-workspace is-nav-expanded" data-command-workspace>
    <aside class="cw-local-rail is-expanded" data-workspace-rail aria-label="Comdt and HoD workspace navigation">
        <div class="cw-local-rail__identity">
            <span class="cw-local-rail__mark" aria-hidden="true"><i class="bi bi-grid-1x2-fill"></i></span>
            <div>
                <small>PRISM ERP</small>
                <strong>Command workspace</strong>
            </div>
            <button type="button"
                    class="cw-local-rail__toggle"
                    data-workspace-rail-toggle
                    aria-expanded="true"
                    aria-controls="workspace-local-navigation"
                    aria-label="Collapse workspace navigation"
                    title="Collapse workspace navigation">
                <i class="bi bi-layout-sidebar-inset" aria-hidden="true"></i>
            </button>
        </div>

        <nav id="workspace-local-navigation">
            @if (Model.CanSwitchWorkspace)
            {
                <div class="cw-local-rail__group">
                    <span class="cw-local-rail__group-label">Workspace</span>
                    <a asp-page="/Workspace/Index"
                       asp-route-mode="command"
                       asp-route-view="officers"
                       class="is-context-active"
                       data-tooltip="Comdt / HoD workspace">
                        <i class="bi bi-building" aria-hidden="true"></i><span>Comdt / HoD</span>
                    </a>
                    <a asp-page="/Workspace/Index"
                       asp-route-mode="project-officer"
                       data-tooltip="Project Officer workspace">
                        <i class="bi bi-person-workspace" aria-hidden="true"></i><span>Project Officer</span>
                    </a>
                </div>
            }

            <div class="cw-local-rail__group">
                <span class="cw-local-rail__group-label">Project control</span>
                <a asp-page="/Workspace/Index"
                   asp-route-mode="command"
                   asp-route-view="officers"
                   class="@(!isPortfolio && !isAdoption ? "is-active" : null)"
                   aria-current="@(!isPortfolio && !isAdoption ? "page" : null)"
                   data-tooltip="Officer workload">
                    <i class="bi bi-people" aria-hidden="true"></i><span>Officer workload</span><b>@vm.ProjectOfficerCount</b>
                </a>
                <a asp-page="/Workspace/Index"
                   asp-route-mode="command"
                   asp-route-view="portfolio"
                   class="@(isPortfolio ? "is-active" : null)"
                   aria-current="@(isPortfolio ? "page" : null)"
                   data-tooltip="Project portfolio">
                    <i class="bi bi-diagram-3" aria-hidden="true"></i><span>Project portfolio</span><b>@vm.TotalOngoingProjects</b>
                </a>
            </div>

            <div class="cw-local-rail__group">
                <span class="cw-local-rail__group-label">Monitoring</span>
                <a asp-page="/Workspace/Index"
                   asp-route-mode="command"
                   asp-route-view="adoption"
                   class="@(isAdoption ? "is-active" : null)"
                   aria-current="@(isAdoption ? "page" : null)"
                   data-tooltip="ERP adoption">
                    <i class="bi bi-person-check" aria-hidden="true"></i><span>ERP adoption</span><b>@adoption.ActiveToday</b>
                </a>
            </div>
        </nav>
    </aside>

    <main class="cw-workspace-content">
        @if (!isAdoption)
        {
            <section class="cw-usage-summary" aria-label="ERP adoption summary">
                <div class="cw-usage-summary__heading">
                    <span><i class="bi bi-person-check"></i></span>
                    <div>
                        <small>ERP adoption</small>
                        <strong>Login and actual use</strong>
                        <em>@(adoption.ReviewAvailable ? $"Last {adoption.RequiredWorkingDays} monitored working days" : $"Initial collection · {completedMaturityDays} of {adoption.RequiredWorkingDays} working days")</em>
                    </div>
                </div>
                <div class="cw-usage-summary__metrics">
                    <div><strong>@adoption.SignedInUsers</strong><span>Signed in</span><small>unique users</small></div>
                    <div><strong>@adoption.UsedErpUsers</strong><span>Used ERP</span><small>monitored use</small></div>
                    <div><strong>@adoption.OperationalContributors</strong><span>Contributed</span><small>operational actions</small></div>
                    <div class="@(adoption.AdoptionGap > 0 ? "is-warning" : null)"><strong>@adoption.AdoptionGap</strong><span>Adoption gap</span><small>signed in, no monitored use</small></div>
                </div>
                <a asp-page="/Workspace/Index" asp-route-mode="command" asp-route-view="adoption" class="cw-usage-summary__action">Review adoption <i class="bi bi-arrow-right"></i></a>
            </section>
        }

        @if (isAdoption)
        {
            <section class="cw-adoption-hero" aria-labelledby="cw-adoption-title">
                <div>
                    <span class="cw-adoption-hero__eyebrow">Command monitoring</span>
                    <h1 id="cw-adoption-title">ERP adoption</h1>
                    <p>Compare successful sign-ins with monitored use and recognised operational contribution. This is an adoption indicator, not attendance.</p>
                </div>
                <div class="cw-adoption-hero__actions">
                    <span class="cw-adoption-maturity @(adoption.ReviewAvailable ? "is-ready" : null)">
                        <i class="bi @(adoption.ReviewAvailable ? "bi-check-circle" : "bi-hourglass-split")"></i>
                        @(adoption.ReviewAvailable
                            ? $"Baseline available · {adoption.RequiredWorkingDays} monitored working days"
                            : $"Initial collection · {completedMaturityDays} of {adoption.RequiredWorkingDays} monitored working days")
                    </span>
                    <a asp-page="/Usage/Index" class="cw-header-action"><i class="bi bi-bar-chart-line"></i><span>Open detailed ERP usage</span></a>
                </div>
            </section>

            <section class="cw-adoption-kpis" aria-label="ERP adoption measures">
                <article><span><i class="bi bi-activity"></i></span><div><strong>@adoption.ActiveToday</strong><b>Active today</b><small>of @adoption.TotalUsers users in scope</small></div></article>
                <article><span><i class="bi bi-box-arrow-in-right"></i></span><div><strong>@adoption.SignedInUsers</strong><b>Signed in</b><small>unique users · @adoptionPeriodLabel</small></div></article>
                <article><span><i class="bi bi-window"></i></span><div><strong>@adoption.UsedErpUsers</strong><b>Used ERP</b><small>navigation, interaction or action</small></div></article>
                <article><span><i class="bi bi-pencil-square"></i></span><div><strong>@adoption.OperationalContributors</strong><b>Operational contributors</b><small>recognised recorded actions</small></div></article>
                <article class="@(adoption.AdoptionGap > 0 ? "is-attention" : null)"><span><i class="bi bi-arrow-left-right"></i></span><div><strong>@adoption.AdoptionGap</strong><b>Adoption gap</b><small>signed in without monitored use</small></div></article>
            </section>

            <div class="cw-adoption-analysis-grid">
                <section class="cw-panel cw-adoption-trend-panel" aria-labelledby="cw-adoption-trend-title">
                    <header class="cw-panel__header">
                        <div><span class="cw-panel__eyebrow">Daily pattern</span><h2 id="cw-adoption-trend-title">Login versus ERP use</h2></div>
                        <span class="cw-result-count">@adoptionPeriodLabel</span>
                    </header>
                    @if (adoption.Trend.Count == 0)
                    {
                        <div class="cw-empty"><i class="bi bi-graph-up"></i><strong>No monitored trend yet</strong><span>Trend data will appear after usage monitoring begins.</span></div>
                    }
                    else
                    {
                        <div class="cw-adoption-chart-wrap">
                            <canvas id="command-adoption-chart"
                                    role="img"
                                    aria-label="Unique users signed in and using ERP by day"
                                    data-series='@Html.Raw(trendJson)'></canvas>
                        </div>
                        <div class="cw-adoption-chart-note"><i class="bi bi-info-circle"></i>Counts are unique users per day. A user may continue an existing session without a fresh login.</div>
                    }
                </section>

                <section class="cw-panel cw-adoption-reach" aria-labelledby="cw-adoption-reach-title">
                    <header class="cw-panel__header">
                        <div><span class="cw-panel__eyebrow">Population reach</span><h2 id="cw-adoption-reach-title">Adoption reach</h2></div>
                    </header>
                    <div class="cw-adoption-reach__body">
                        <div class="cw-reach-row">
                            <div><span>Accounts in scope</span><strong>@adoption.TotalUsers</strong></div>
                            <progress class="cw-reach-progress" max="100" value="100" aria-label="Accounts in scope: 100 percent">100%</progress>
                            <small>100%</small>
                        </div>
                        <div class="cw-reach-row">
                            <div><span>Signed in</span><strong>@adoption.SignedInUsers</strong></div>
                            <progress class="cw-reach-progress" max="100" value="@signInReach" aria-label="Signed-in reach: @signInReach percent">@signInReach%</progress>
                            <small>@signInReach%</small>
                        </div>
                        <div class="cw-reach-row is-use">
                            <div><span>Used ERP</span><strong>@adoption.UsedErpUsers</strong></div>
                            <progress class="cw-reach-progress" max="100" value="@usageReach" aria-label="ERP-use reach: @usageReach percent">@usageReach%</progress>
                            <small>@usageReach%</small>
                        </div>
                        <div class="cw-reach-row is-contribution">
                            <div><span>Operational contributors</span><strong>@adoption.OperationalContributors</strong></div>
                            <progress class="cw-reach-progress" max="100" value="@contributionReach" aria-label="Operational-contribution reach: @contributionReach percent">@contributionReach%</progress>
                            <small>@contributionReach%</small>
                        </div>
                    </div>
                    <p class="cw-adoption-reach__note">Sign-in and monitored use are independent signals measured against the same effective population.</p>
                </section>
            </div>

            <section class="cw-panel cw-adoption-attention" aria-labelledby="cw-adoption-attention-title">
                <header class="cw-panel__header">
                    <div><span class="cw-panel__eyebrow">Command review</span><h2 id="cw-adoption-attention-title">Attention required</h2></div>
                    @if (adoption.ReviewAvailable)
                    {
                        <span class="cw-result-count">@adoption.ReviewCaseCount user@(adoption.ReviewCaseCount == 1 ? "" : "s")</span>
                    }
                </header>
                @if (!adoption.ReviewAvailable)
                {
                    <div class="cw-adoption-pending">
                        <i class="bi bi-hourglass-split"></i>
                        <div><strong>Review classifications are withheld during initial collection.</strong><span>They become available after @adoption.RequiredWorkingDays monitored working days. Current login and usage counts remain available above.</span></div>
                    </div>
                }
                else if (adoption.Attention.Count == 0)
                {
                    <div class="cw-adoption-pending is-clear"><i class="bi bi-check2-circle"></i><div><strong>No adoption exceptions require review.</strong><span>All users in scope have monitored use in the current review window.</span></div></div>
                }
                else
                {
                    <div class="cw-adoption-table-wrap">
                        <table class="cw-adoption-table">
                            <thead><tr><th>User</th><th>Observation</th><th>Last recorded use</th></tr></thead>
                            <tbody>
                                @foreach (var row in adoption.Attention)
                                {
                                    <tr>
                                        <td><strong>@row.DisplayName</strong><span>@string.Join(" · ", new[] { row.Rank, row.UserName }.Where(x => !string.IsNullOrWhiteSpace(x)))</span></td>
                                        <td><span class="cw-adoption-observation @(row.SignedInDuringPeriod ? "is-gap" : null)">@row.Observation</span></td>
                                        <td>@(row.LastRecordedUseUtc.HasValue ? IstClock.ToIst(row.LastRecordedUseUtc.Value).ToString("dd MMM yyyy, HH:mm") + " IST" : "No monitored use recorded")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (adoption.ReviewCaseCount > adoption.Attention.Count)
                    {
                        <footer class="cw-adoption-attention__footer">Showing the first @adoption.Attention.Count of @adoption.ReviewCaseCount review cases. Open detailed ERP usage for the complete directory.</footer>
                    }
                }
            </section>
        }
        else if (isPortfolio)
        {
        <section class="cw-panel cw-panel--chart">
            <header class="cw-panel__header cw-panel__header--compact">
                <h2>Projects by current stage</h2>
                <div class="cw-panel__actions">
                    <a href="/Projects/Ongoing" class="cw-header-action"><i class="bi bi-kanban"></i><span>Open ongoing projects</span></a>
                    <button type="button" class="cw-icon-button" data-chart-download aria-label="Download chart" title="Download chart"><i class="bi bi-download"></i></button>
                </div>
            </header>

            <form method="get" class="cw-filter-grid" data-cw-auto-filter aria-label="Portfolio filters">
                <input type="hidden" name="mode" value="command" />
                <input type="hidden" name="view" value="portfolio" />
                <label class="cw-field cw-field--search">
                    <span class="visually-hidden">Project search</span>
                    <div><i class="bi bi-search"></i><input type="search" name="ProjectSearch" value="@vm.ProjectSearch" placeholder="Search projects" aria-label="Search projects" autocomplete="off" /></div>
                </label>
                <div class="cw-field cw-field--categories">
                    <span class="visually-hidden">Project categories</span>
                    <button type="button" class="cw-multi-trigger" data-cw-filter-trigger aria-expanded="false" aria-haspopup="true">
                        <span>@categoryTriggerText</span><i class="bi bi-chevron-down"></i>
                    </button>
                    <div class="cw-multi-popover" data-cw-filter-popover hidden>
                        <div class="cw-multi-popover__header">
                            <strong>Project categories</strong>
                            @if (selectedCategoryCount > 0)
                            {
                                <a asp-page="/Workspace/Index" asp-route-mode="command" asp-route-view="portfolio">Clear</a>
                            }
                        </div>
                        <div class="cw-multi-popover__options">
                            @foreach (var option in vm.ParentCategoryOptions)
                            {
                                <label><input type="checkbox" name="ParentCategoryIds" value="@option.Id" checked="@vm.SelectedParentCategoryIds.Contains(option.Id)" /> <span>@option.Name</span></label>
                            }
                        </div>
                    </div>
                </div>
                <input type="hidden" name="PopulatedStagesOnly" value="true" />
                @if (!string.IsNullOrWhiteSpace(vm.ProjectSearch) || selectedCategoryCount > 0)
                {
                    <a asp-page="/Workspace/Index" asp-route-mode="command" asp-route-view="portfolio" class="cw-reset-link">Reset</a>
                }
                <span class="cw-filter-result">@(filteredProjectCount == vm.TotalOngoingProjects ? $"{vm.TotalOngoingProjects} projects" : $"{filteredProjectCount} of {vm.TotalOngoingProjects} projects")</span>
                <span class="cw-filter-status" data-cw-filter-status aria-live="polite"></span>
            </form>

            <div class="cw-chart-wrap">
                <canvas id="command-stage-chart" role="img" aria-label="Ongoing projects by current stage" data-series='@Html.Raw(JsonSerializer.Serialize(vm.StageSeries, jsonOptions))'></canvas>
            </div>
        </section>

        <section class="cw-panel cw-stage-board-panel">
            <header class="cw-panel__header cw-panel__header--compact">
                <h2>Stage-wise project register</h2>
                <div class="cw-panel__actions">
                    <span class="cw-result-count">@filteredProjectCount projects</span>
                    <div class="cw-scroll-controls" aria-label="Stage navigation">
                        <button type="button" data-scroll-target="stage-board" data-scroll-direction="previous" aria-label="Previous stages" title="Previous stages"><i class="bi bi-chevron-left"></i></button>
                        <button type="button" data-scroll-target="stage-board" data-scroll-direction="next" aria-label="Next stages" title="Next stages"><i class="bi bi-chevron-right"></i></button>
                    </div>
                </div>
            </header>
            @if (vm.StageColumns.Count == 0 || vm.StageColumns.All(x => x.ProjectCount == 0))
            {
                <div class="cw-empty"><i class="bi bi-inbox"></i><strong>No matching projects</strong><span>Change or reset the current filters.</span></div>
            }
            else
            {
                <div class="cw-stage-board-shell">
                    <div class="cw-edge-fade cw-edge-fade--left" aria-hidden="true"></div>
                    <div class="cw-stage-board" id="stage-board" data-horizontal-board tabindex="0" aria-label="Horizontally scrollable stage-wise project list. Press and drag to move horizontally.">
                        @foreach (var stage in vm.StageColumns)
                        {
                            <article class="cw-stage-column @(stage.ProjectCount == 0 ? "is-empty" : null)" data-stage-code="@stage.StageCode">
                                <header>
                                    <div class="cw-stage-heading"><strong>@stage.StageCode</strong><h3>@stage.StageName</h3></div>
                                    <b>@stage.ProjectCount</b>
                                </header>
                                <div class="cw-stage-column__body">
                                    @if (stage.ProjectCount == 0)
                                    {
                                        <p class="cw-stage-empty">No projects</p>
                                    }
                                    else
                                    {
                                        @foreach (var category in stage.Categories)
                                        {
                                            <section class="cw-stage-category">
                                                <h4><span data-category="@category.CategoryName"></span><span class="cw-category-name">@category.CategoryName</span><b>@category.ProjectCount</b></h4>
                                                <ol>
                                                    @foreach (var project in category.Projects)
                                                    {
                                                        <li>
                                                            <a href="@project.OpenUrl" title="@project.ProjectName">@project.ProjectName</a>
                                                            <span>@project.OfficerName</span>
                                                        </li>
                                                    }
                                                </ol>
                                            </section>
                                        }
                                    }
                                </div>
                            </article>
                        }
                    </div>
                    <div class="cw-edge-fade cw-edge-fade--right" aria-hidden="true"></div>
                </div>
            }
        </section>
        }
        else
        {
        <section class="cw-panel cw-officer-panel">
            <header class="cw-panel__header cw-panel__header--compact">
                <h2>Officer workload</h2>
                <div class="cw-panel__actions">
                    <span class="cw-result-count">@vm.Officers.Count officers</span>
                </div>
            </header>

            <form class="cw-order-preference" data-officer-order-form data-save-url="?handler=SaveOfficerOrder" hidden>
                @Html.AntiForgeryToken()
            </form>

            @if (vm.Officers.Count == 0)
            {
                <div class="cw-empty"><i class="bi bi-people"></i><strong>No assigned workload</strong><span>No Project Officer currently has projects, ideas or other tasks assigned.</span></div>
            }
            else
            {
                <div class="cw-officer-grid" data-officer-grid aria-label="Project Officer workload cards">
                    @foreach (var officer in vm.Officers)
                    {
                        @await Html.PartialAsync(
                            "_OfficerWorkloadCard",
                            new OfficerWorkloadCardRenderVm
                            {
                                Officer = officer,
                                CanReorder = true,
                                ShowConferenceAction = true
                            })
                    }
                </div>
                <div class="cw-order-feedback" data-officer-order-feedback aria-live="polite"></div>
            }
        </section>
        }
    </main>
</div>
