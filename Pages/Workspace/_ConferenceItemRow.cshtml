@using ProjectManagement.Infrastructure
@using ProjectManagement.ViewModels.Workspace
@model OfficerConferenceItemRenderVm
@{
    var item = Model.Item;
    var direction = item.LatestDirection;
    var kindLabel = item.Kind switch
    {
        ConferenceItemKind.Project => "project",
        ConferenceItemKind.ProjectIdea => "idea",
        ConferenceItemKind.ActionTask => "task",
        _ => "item"
    };
    var openLabel = $"Open {kindLabel}";
    var directionActionLabel = direction is null ? "Issue direction" : "Issue further direction";
    var directionDate = direction is null
        ? null
        : IstClock.ToIst(direction.CreatedAtUtc).ToString("dd MMM yyyy, hh:mm tt");
    var directionDateIso = direction?.CreatedAtUtc.ToString("O");
    var editorId = $"oc-editor-{(int)item.Kind}-{item.ItemId}";
    var feedbackId = $"{editorId}-feedback";
    var directionBodyId = $"oc-direction-body-{(int)item.Kind}-{item.ItemId}";
    var directionCellClass = direction is null
        ? "oc-item__direction oc-item__direction--empty"
        : "oc-item__direction";
    var directionCount = Math.Max(item.DirectionCount, direction is null ? 0 : 1);
}

<article class="oc-item @(item.RequiresAttention ? "oc-item--attention" : string.Empty)"
         data-oc-item
         data-officer-id="@Model.OfficerUserId"
         data-item-kind="@((int)item.Kind)"
         data-item-id="@item.ItemId"
         data-direction-count="@directionCount"
         data-latest-direction-id="@(direction?.Id.ToString() ?? string.Empty)">
    <div class="oc-item__main">
        <div class="oc-item__title-row">
            <a href="@item.OpenUrl" target="_blank" rel="noopener" title="@openLabel">
                @item.Title
            </a>
        </div>
        <div class="oc-state">
            @if (!string.IsNullOrWhiteSpace(item.CurrentStateCode)
                 && !string.Equals(item.CurrentStateCode, item.CurrentStateName, StringComparison.OrdinalIgnoreCase))
            {
                <strong>@item.CurrentStateCode</strong>
                <span>@item.CurrentStateName</span>
            }
            else
            {
                <strong>@item.CurrentStateName</strong>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(item.CurrentContext))
        {
            <p class="oc-current-context">@item.CurrentContext</p>
        }
        @if (item.Kind == ConferenceItemKind.Project && item.RecordHealth is not null)
        {
            var recordHealth = item.RecordHealth;
            var recordHealthCss = WorkspaceDisplayHelpers.HealthCss(recordHealth.HealthPercent);
            var recordGapLabel = $"{recordHealth.RecordGapCount} gap{(recordHealth.RecordGapCount == 1 ? string.Empty : "s")}";
            <a class="oc-record-health oc-record-health--@recordHealthCss"
               href="@recordHealth.OpenUrl"
               target="_blank"
               rel="noopener"
               title="Open project record for @item.Title"
               aria-label="@item.Title: @recordHealth.HealthPercent percent record complete with @recordGapLabel">
                <span class="oc-record-health__top">
                    <strong>Records</strong>
                    <span>@recordHealth.HealthPercent% complete · @recordGapLabel</span>
                </span>
                <progress class="oc-record-health__track"
                          value="@recordHealth.HealthPercent"
                          max="100"
                          aria-label="Record completeness: @recordHealth.HealthPercent percent">@recordHealth.HealthPercent%</progress>
            </a>
        }
        @if (!string.IsNullOrWhiteSpace(item.AttentionText))
        {
            <span class="oc-attention"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i>@item.AttentionText</span>
        }
    </div>

    <div class="@directionCellClass" data-oc-direction>
        @if (direction is null)
        {
            <div class="oc-no-direction" data-oc-empty-direction>
                <i class="bi bi-file-earmark" aria-hidden="true"></i>
                <span>No conference direction recorded</span>
            </div>
            <button type="button"
                    class="oc-add-direction oc-add-direction--issue"
                    data-oc-add
                    data-oc-direction-action
                    aria-controls="@editorId"
                    aria-expanded="false">
                <i class="bi bi-plus-circle" aria-hidden="true"></i>
                <span>Issue direction</span>
            </button>
        }
        else
        {
            <div class="oc-direction"
                 data-oc-direction-content
                 data-direction-sequence="@directionCount"
                 data-direction-total="@directionCount"
                 data-direction-latest="true"
                 aria-label="Latest conference direction, @directionCount of @directionCount">
                @if (directionCount > 1)
                {
                    <div class="oc-direction-history"
                         data-oc-direction-history
                         aria-label="Conference direction history navigation">
                        <button type="button"
                                class="oc-direction-history__button"
                                data-oc-direction-older
                                aria-label="Show older conference direction"
                                title="Show older conference direction">
                            <i class="bi bi-chevron-left" aria-hidden="true"></i>
                        </button>
                        <span class="oc-direction-history__position"
                              data-oc-direction-position
                              aria-live="polite">Latest · @directionCount of @directionCount</span>
                        <button type="button"
                                class="oc-direction-history__button"
                                data-oc-direction-newer
                                aria-label="Show newer conference direction"
                                title="Show newer conference direction"
                                disabled>
                            <i class="bi bi-chevron-right" aria-hidden="true"></i>
                        </button>
                    </div>
                }
                <div class="oc-direction__instruction">
                    <p id="@directionBodyId" class="oc-direction__body" data-oc-direction-body>@direction.Body</p>
                    <button type="button"
                            class="oc-direction-toggle"
                            data-oc-direction-toggle
                            aria-controls="@directionBodyId"
                            aria-expanded="false"
                            hidden>More</button>
                </div>
                <time class="oc-direction__timestamp" datetime="@directionDateIso">Issued @directionDate</time>
            </div>
        }
    </div>

    <div class="oc-item__progress">
        <div data-oc-progress-content>
            @if (direction is not null)
            {
                @if (item.ProgressEntries.Count > 0)
                {
                    <div class="oc-progress-list">
                        @for (var index = 0; index < item.ProgressEntries.Count; index++)
                        {
                            var entry = item.ProgressEntries[index];
                            var progressBodyId = $"oc-progress-body-{(int)item.Kind}-{item.ItemId}-{index}";
                            var activityDate = entry.ActivityAtUtc.HasValue
                                ? IstClock.ToIst(entry.ActivityAtUtc.Value).ToString("dd MMM yyyy, hh:mm tt")
                                : null;
                            var activityDateIso = entry.ActivityAtUtc?.ToString("O");

                            <section class="oc-progress-entry @(string.IsNullOrWhiteSpace(entry.Body) ? "oc-progress-entry--empty" : string.Empty)"
                                     data-oc-progress-entry>
                                <span class="oc-progress-entry__label">@entry.Label</span>
                                @if (!string.IsNullOrWhiteSpace(entry.Title))
                                {
                                    <strong class="oc-progress-entry__title">@entry.Title</strong>
                                }
                                @if (!string.IsNullOrWhiteSpace(entry.Body))
                                {
                                    <p id="@progressBodyId"
                                       class="oc-progress-entry__body"
                                       data-oc-progress-body>@entry.Body</p>
                                    <button type="button"
                                            class="oc-progress-toggle"
                                            data-oc-progress-toggle
                                            aria-controls="@progressBodyId"
                                            aria-expanded="false"
                                            hidden>More</button>
                                }
                                else if (!string.IsNullOrWhiteSpace(entry.EmptyText))
                                {
                                    <p class="oc-progress-entry__empty">@entry.EmptyText</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(entry.AuthorName) || activityDate is not null)
                                {
                                    <small class="oc-progress-entry__meta">
                                        @if (!string.IsNullOrWhiteSpace(entry.AuthorName))
                                        {
                                            <span>@entry.AuthorName</span>
                                        }
                                        @if (activityDate is not null)
                                        {
                                            <time datetime="@activityDateIso">@activityDate</time>
                                        }
                                    </small>
                                }
                            </section>
                        }
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(item.EmptyProgressText))
                {
                    <p class="oc-progress-empty">@item.EmptyProgressText</p>
                }
            }
            else
            {
                <p class="oc-progress-empty oc-progress-empty--awaiting"
                   aria-label="Awaiting initial direction. Progress tracking begins after a direction is issued."
                   title="Progress tracking begins after a direction is issued.">
                    Awaiting initial direction
                </p>
            }
        </div>

        <div class="oc-item__actions @(direction is null ? "oc-item__actions--empty" : string.Empty)">
            @if (direction is not null)
            {
                <button type="button"
                        class="oc-add-direction"
                        data-oc-add
                        data-oc-direction-action
                        aria-controls="@editorId"
                        aria-expanded="false">
                    <i class="bi bi-plus-circle" aria-hidden="true"></i>
                    <span>Issue further direction</span>
                </button>
            }
            <a href="@item.OpenUrl" target="_blank" rel="noopener" class="oc-open-item">
                @openLabel <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
            </a>
            <span class="oc-row-status" data-oc-row-status aria-live="polite"></span>
        </div>
    </div>

    <form method="post"
          id="@editorId"
          class="oc-inline-editor"
          data-oc-editor
          aria-busy="false"
          hidden>
        <input type="hidden" name="officerUserId" value="@Model.OfficerUserId" />
        <input type="hidden" name="kind" value="@((int)item.Kind)" />
        <input type="hidden" name="itemId" value="@item.ItemId" />
        <label class="oc-inline-editor__field">
            <span>Conference direction</span>
            <textarea name="body"
                      rows="2"
                      maxlength="4000"
                      placeholder="Record the direction or observation..."
                      aria-describedby="@feedbackId"
                      data-oc-input></textarea>
        </label>
        <div class="oc-inline-editor__footer">
            <span id="@feedbackId" class="oc-editor-feedback" data-oc-feedback aria-live="polite"></span>
            <div>
                <button type="button" class="oc-editor-cancel" data-oc-cancel>Cancel</button>
                <button type="submit" class="oc-editor-save" data-oc-save disabled>
                    <span data-oc-save-label>@directionActionLabel</span>
                    <i class="bi bi-arrow-right" aria-hidden="true"></i>
                </button>
            </div>
        </div>
    </form>
</article>
