@model ProjectManagement.ViewModels.Notebook.NotebookCardActionsVm
@using ProjectManagement.Models

@* SECTION: API-only notebook card actions *@
<div class="notebook-actions" data-note-actions aria-label="Note actions">
@if (string.Equals(Model.View, "trash", StringComparison.OrdinalIgnoreCase))
{
    <button type="button" class="notebook-action-button" data-action="restore-trash-note"><i class="bi bi-arrow-counterclockwise"></i><span>Restore</span></button>
    <details class="notebook-card-more">
        <summary class="notebook-action-button" aria-label="More actions" aria-expanded="false"><i class="bi bi-three-dots"></i></summary>
        <div class="notebook-card-more__menu" role="menu">
            <button type="button" role="menuitem" data-action="restore-trash-note">Restore</button>
            <button class="text-danger" type="button" role="menuitem" data-action="delete-permanently">Delete permanently</button>
        </div>
    </details>
}
else
{
    @if (Model.Item.CanManageMetadata)
    {
        <button title="@(Model.Item.IsPinned ? "Unpin" : "Pin")" aria-label="@(Model.Item.IsPinned ? "Unpin note" : "Pin note")" type="button" class="notebook-action-icon notebook-action-pin" data-action="pin-note" data-is-pinned="@Model.Item.IsPinned.ToString().ToLowerInvariant()"><i class="bi @(Model.Item.IsPinned ? "bi-pin-angle-fill" : "bi-pin-angle")"></i></button>
    }
    @if (Model.Item.CanManageLifecycle && Model.Item.Status != NotebookItemStatus.Completed && (Model.Item.Type == NotebookItemType.Reminder || Model.Item.ReminderAtUtc is not null))
    {
        <button type="button" data-action="complete-note" class="notebook-action-done">Done</button>
    }
    @if (Model.Item.CanManageMetadata)
    {
        <partial name="~/Pages/Notebook/_NotebookColourPicker.cshtml" model="Model.Item.ColorKey ?? string.Empty" />
    }
    <button type="button"
            class="notebook-action-icon"
            data-action="share-note"
            title="@(Model.Item.CanManageCollaborators ? "Manage collaborators" : "View collaborators")"
            aria-label="@(Model.Item.CanManageCollaborators ? "Manage collaborators" : "View collaborators")">
        <i class="bi @(Model.Item.CanManageCollaborators ? "bi-person-plus" : "bi-people")"></i>
    </button>
    <details class="notebook-card-more">
        <summary class="notebook-action-button" aria-label="More actions" aria-expanded="false"><i class="bi bi-three-dots"></i></summary>
        <div class="notebook-card-more__menu" role="menu">
            @if (Model.Item.CanManageMetadata)
            {
                <button type="button" role="menuitem" data-action="label-note"><i class="bi bi-tag"></i><span>Add label</span></button>
            }
            @if (Model.Item.CanDuplicate)
            {
                <button type="button" role="menuitem" data-action="duplicate-note">Make a copy</button>
            }
            @if (Model.Item.CanManageLifecycle && Model.Item.Status != NotebookItemStatus.Completed && (Model.Item.Type == NotebookItemType.Note || Model.Item.Type == NotebookItemType.Checklist))
            {
                <button type="button" role="menuitem" data-action="convert-note" data-convert-to="@(Model.Item.Type == NotebookItemType.Checklist ? NotebookItemType.Note : NotebookItemType.Checklist)">@(Model.Item.Type == NotebookItemType.Checklist ? "Hide checkboxes" : "Show checkboxes")</button>
            }
            @if (Model.Item.CanManageLifecycle)
            {
                @if (Model.Item.Status == NotebookItemStatus.Archived) { <button type="button" role="menuitem" data-action="restore-note">Restore</button> }
                else if (Model.Item.Status == NotebookItemStatus.Completed) { <button type="button" role="menuitem" data-action="reopen-note">Reopen</button> }
                else { <button type="button" role="menuitem" data-action="archive-note">Archive</button> }
                <span class="notebook-menu-separator" aria-hidden="true"></span>
                <button class="text-danger" type="button" role="menuitem" data-action="delete-note">Move to trash</button>
            }
            else if (Model.Item.CanLeave)
            {
                <span class="notebook-menu-separator" aria-hidden="true"></span>
                <button type="button" role="menuitem" data-action="leave-note">Leave shared note</button>
            }
        </div>
    </details>
}
</div>
