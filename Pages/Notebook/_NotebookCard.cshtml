@model ProjectManagement.ViewModels.Notebook.NotebookCardRenderVm
@using ProjectManagement.Models
@using ProjectManagement.ViewModels.Notebook
@{
    var item = Model.Item;
    var isSelected = Model.SelectedId == item.Id;
    var fallbackColor = "white";
    var colorClass = $"notebook-card-color-{(string.IsNullOrWhiteSpace(item.ColorKey) ? fallbackColor : item.ColorKey)}";
    var tags = item.Tags.Take(3).ToArray();
    var extraTags = Math.Max(0, item.Tags.Count - tags.Length);
    var isTrash = string.Equals(Model.View, "trash", StringComparison.OrdinalIgnoreCase);

    static string FriendlyFirstName(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName)) return "Unknown";
        var parts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 1) return parts[0];
        return parts.Length >= 3 ? string.Join(" ", parts.Take(parts.Length - 1)) : parts[0];
    }

    var owner = item.Collaborators.FirstOrDefault(c => c.IsOwner);
    var otherCollaborators = item.Collaborators.Where(c => !c.IsOwner).ToArray();
    var sharingText = string.Empty;
    var sharingTitle = string.Empty;

    if (item.IsShared)
    {
        if (item.AccessLevel == NotebookAccessLevel.Owner)
        {
            var names = otherCollaborators.Select(c => FriendlyFirstName(c.DisplayName)).ToArray();
            sharingText = names.Length switch
            {
                0 => "Shared note",
                1 => $"Shared with {names[0]}",
                2 => $"Shared with {names[0]}, {names[1]}",
                _ => $"Shared with {names[0]}, {names[1]} +{names.Length - 2}"
            };
            sharingTitle = otherCollaborators.Length == 0
                ? "Shared note"
                : $"Shared with {string.Join(", ", otherCollaborators.Select(c => c.DisplayName))}";
        }
        else
        {
            var ownerName = FriendlyFirstName(owner?.DisplayName ?? item.OwnerDisplayName);
            var accessLabel = item.AccessLevel == NotebookAccessLevel.Viewer ? "View only" : "Can edit";
            sharingText = $"Shared by {ownerName} · {accessLabel}";
            sharingTitle = $"Shared by {owner?.DisplayName ?? item.OwnerDisplayName}. Permission: {accessLabel}.";
        }
    }
}

@* SECTION: Notebook board card *@
<article data-note-id="@item.Id" data-notebook-card-id="@item.Id" data-version="@item.Version" data-labels="@System.Text.Json.JsonSerializer.Serialize(item.Tags)" data-is-pinned="@item.IsPinned.ToString().ToLowerInvariant()" data-access-level="@item.AccessLevel" data-owner-id="@item.OwnerId" data-can-edit-content="@item.CanEditContent.ToString().ToLowerInvariant()" data-can-manage-metadata="@item.CanManageMetadata.ToString().ToLowerInvariant()" class="notebook-card @colorClass @(isSelected ? "is-selected" : string.Empty) @(item.ReminderAtUtc is not null ? "has-due-action" : string.Empty) @(item.Status == NotebookItemStatus.Completed ? "is-completed" : string.Empty)">
    @if (!isTrash && item.Status == NotebookItemStatus.Active && item.AccessLevel == NotebookAccessLevel.Owner)
    {
        <button type="button" class="notebook-card-drag-handle" data-notebook-drag-handle hidden aria-label="Rearrange @item.Title" aria-grabbed="false" title="Drag to rearrange"><i class="bi bi-grip-vertical" aria-hidden="true"></i></button>
    }
    <div class="notebook-card-body">
        <a href="@(isTrash ? "#" : Model.OpenUrl)" class="notebook-card-link notebook-card__open-area @(isTrash ? "is-disabled" : "")" data-action="@(isTrash ? null : "open-note")" aria-label="@(isTrash ? item.Title : $"Open {item.Title}")" aria-disabled="@isTrash.ToString().ToLowerInvariant()">
            <div class="notebook-card-topline">
                <span class="notebook-card-indicators">
                    @if (item.Status == NotebookItemStatus.Completed) { <i class="bi bi-check2-circle notebook-card-completed-indicator" title="Completed" aria-label="Completed"></i> }
                    @if (item.IsFavorite) { <i class="bi bi-star-fill" title="Favourite"></i> }
                    @if (item.ReminderAtUtc is not null) { <i class="bi bi-bell" title="Reminder"></i> }
                </span>
                @if (item.IsPinned)
                {
                    <span class="notebook-card-pin-indicator" title="Pinned" aria-label="Pinned"><i class="bi bi-pin-angle-fill"></i></span>
                }
            </div>
            <h3 class="notebook-card-title">@item.Title</h3>
            @if (!string.IsNullOrWhiteSpace(item.Preview))
            {
                <p class="notebook-card-preview">@item.Preview</p>
            }
        </a>

        @if (item.Type == NotebookItemType.Checklist)
        {
            <div class="notebook-checklist-preview">
                @if (item.ChecklistTotal == 0)
                {
                    <div class="notebook-checklist-empty">No checklist items yet</div>
                }
                else
                {
                    foreach (var checklistItem in item.ChecklistPreviewItems)
                    {
                        <div class="notebook-check-row">
                            @if (!isTrash && item.CanToggleChecklist)
                            {
                                <button type="button"
                                        class="notebook-check-toggle @(checklistItem.IsDone ? "is-done" : string.Empty)"
                                        data-action="toggle-checklist"
                                        data-item-id="@item.Id"
                                        data-row-id="@checklistItem.Id"
                                        data-is-done="@checklistItem.IsDone.ToString().ToLowerInvariant()"
                                        aria-label="@(checklistItem.IsDone ? "Mark item incomplete" : "Mark item complete")">
                                    <i class="bi @(checklistItem.IsDone ? "bi-check-square" : "bi-square")" aria-hidden="true"></i><span>@checklistItem.Text</span>
                                </button>
                            }
                            else
                            {
                                <span class="notebook-check-toggle notebook-check-toggle--readonly @(checklistItem.IsDone ? "is-done" : string.Empty)" aria-label="@(checklistItem.IsDone ? "Completed checklist item" : "Incomplete checklist item")">
                                    <i class="bi @(checklistItem.IsDone ? "bi-check-square" : "bi-square")" aria-hidden="true"></i><span>@checklistItem.Text</span>
                                </span>
                            }
                        </div>
                    }
                    <strong>@item.ChecklistDone/@item.ChecklistTotal complete</strong>
                }
            </div>
        }

        <div class="notebook-card-meta">
            @if (item.ReminderAtUtc is not null)
            {
                <span class="@(item.IsOverdue ? "text-danger" : string.Empty)"><i class="bi bi-bell"></i> @item.ReminderDisplay</span>
            }
            @if (item.ChecklistTotal > 0 && item.Type != NotebookItemType.Checklist)
            {
                <span>@item.ChecklistDone/@item.ChecklistTotal done</span>
            }
        </div>

        @if (tags.Any())
        {
            <div class="notebook-card-tags" aria-label="Labels">
                @foreach (var tag in tags)
                {
                    <a class="notebook-tag-chip" asp-page="/Notebook/Index" asp-route-view="labels" asp-route-tag="@tag" aria-label="Open label @tag">@tag</a>
                }
                @if (extraTags > 0)
                {
                    <span class="notebook-tag-chip">+@extraTags</span>
                }
            </div>
        }
    </div>
    @if (item.IsShared)
    {
        <div class="notebook-sharing-summary" title="@sharingTitle" aria-label="@sharingTitle">
            <i class="bi bi-people" aria-hidden="true"></i>
            <span>@sharingText</span>
        </div>
    }
    <div class="notebook-card-actions">
        <partial name="~/Pages/Notebook/_NotebookActions.cshtml" model="Model.Actions" />
    </div>
</article>
