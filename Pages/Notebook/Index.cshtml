@page
@model ProjectManagement.Pages.Notebook.IndexModel
@using ProjectManagement.Models
@using ProjectManagement.ViewModels.Notebook
@inject ProjectManagement.Services.Notebook.INotebookCardModelFactory CardModelFactory
@{
    ViewData["Title"] = "My Notebook";
    ViewData["UseFullWidth"] = true;
    var selected = Model.Notebook.SelectedItem;
    var selectedType = Model.Input.Type;
    var isCreateMode = string.Equals(Model.Mode, "new", StringComparison.OrdinalIgnoreCase);
    var emptyTitle = Model.Notebook.View switch
    {
        "labels" => "No labels yet.",
        "today" or "reminders" => "No reminders due.",
        "archive" or "archived" => "No archived items.",
        "completed" => "No completed items.",
        _ => "No notebook items yet."
    };
    var emptyText = Model.Notebook.View switch
    {
        "labels" => "Add tags to notebook items, then browse by label here.",
        "today" or "reminders" => "Add a reminder to any note, checklist or sticky item.",
        "archive" or "archived" => "Archived notes will appear here.",
        "completed" => "Completed notes will appear here.",
        _ => "Use quick capture or create a structured notebook item."
    };
    var viewTitle = Model.Notebook.View switch
    {
        "archive" or "archived" => "Archive",
        "completed" => "Completed",
        "today" => "Today",
        "reminders" => "Reminders",
        "labels" when !string.IsNullOrWhiteSpace(Model.Notebook.Tag) => Model.Notebook.Tag,
        "labels" => "Labels",
        _ => "My Notebook"
    };
    var viewSubtitle = Model.Notebook.View switch
    {
        "archive" or "archived" => "Archived notes and checklists.",
        "completed" => "Completed reminders and notebook items.",
        "today" => "Items due today.",
        "reminders" => "Upcoming reminders across your notebook.",
        "labels" when !string.IsNullOrWhiteSpace(Model.Notebook.Tag) => $"Items labelled {Model.Notebook.Tag}.",
        "labels" => "Browse and organise notebook labels.",
        _ => "Notes, reminders, checklists, ideas and drafts."
    };
}
@section Styles { <link rel="stylesheet" href="~/css/notebook.css" asp-append-version="true" /> }

<div class="notebook-shell @(Model.UseLegacyEditor ? "has-editor" : "editor-collapsed")" data-board-view="grid">
    @* SECTION: Dedicated anti-forgery token for Notebook API mutations *@
    <div id="notebook-antiforgery-token" hidden>
        @Html.AntiForgeryToken()
    </div>
    <script id="notebook-label-catalog" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Notebook.Tags.Select(tag => new { id = tag.Id, name = tag.Name, count = tag.Count })))</script>
    <aside class="notebook-rail" aria-label="Notebook views">
        <div class="notebook-rail__brand"><i class="bi bi-journal-bookmark"></i><span>My Notebook</span></div>
        @foreach (var item in Model.Notebook.RailItems)
        {
            <a class="notebook-rail__item @(item.IsActive ? "is-active" : "")" href="@item.Url"><i class="bi @item.Icon"></i><span>@item.Label</span><b data-notebook-count="@item.Key">@item.Count</b></a>
            @if (item.Key == "labels" && Model.Notebook.Tags.Any())
            {
                <div class="notebook-rail-labels" aria-label="Notebook labels">
                    @foreach (var label in Model.Notebook.Tags.Take(8))
                    {
                        <a asp-page="/Notebook/Index" asp-route-view="labels" asp-route-tag="@label.Name" class="@(string.Equals(Model.Notebook.Tag, label.Name.ToUpperInvariant(), StringComparison.OrdinalIgnoreCase) ? "is-active" : "")"><i class="bi bi-tag"></i><span>@label.Name</span><b>@label.Count</b></a>
                    }
                </div>
            }
        }
    </aside>

    <main class="notebook-main">
        <section class="notebook-commandbar">
            <div class="notebook-commandbar__heading"><h1>@viewTitle</h1><p>@viewSubtitle</p></div>
            <div class="notebook-command-actions">
                @if (Model.Notebook.View == "labels")
                {
                    <button type="button" class="notebook-manage-labels-button" data-open-label-manager><i class="bi bi-pencil"></i><span>Manage labels</span></button>
                }
                <form method="get" class="notebook-search" aria-label="Search this notebook"><input type="hidden" name="view" value="@Model.Notebook.View" /><input type="hidden" name="filter" value="@Model.Notebook.Filter" /><input type="hidden" name="tag" value="@Model.Notebook.Tag" /><i class="bi bi-search"></i><input name="Query" value="@Model.Query" placeholder="Search this notebook" aria-label="Search this notebook" /></form>
                <div class="notebook-view-toggle" role="group" aria-label="Board layout">
                    <button type="button" data-notebook-view="grid" aria-label="Grid view"><i class="bi bi-grid-3x3-gap"></i></button>
                    <button type="button" data-notebook-view="list" aria-label="List view"><i class="bi bi-list-ul"></i></button>
                </div>
            </div>
        </section>

        @* SECTION: Expandable async notebook composer *@
        @if (string.Equals(Model.Notebook.View, "home", StringComparison.OrdinalIgnoreCase) && string.IsNullOrWhiteSpace(Model.Query) && string.IsNullOrWhiteSpace(Model.Tag))
        {
                    <section class="notebook-composer" aria-label="Create a notebook item" data-notebook-composer data-state="collapsed">
                        <div class="notebook-composer__collapsed" data-composer-collapsed>
                            <button type="button" class="notebook-composer__trigger" data-composer-open-note>Take a note…</button>
                            <div class="notebook-composer__quick-actions">
                                <button type="button" class="notebook-composer__checklist-trigger" data-composer-open-checklist aria-label="Create checklist"><i class="bi bi-check2-square"></i></button>
                                <button type="button" class="notebook-composer__reminder-trigger" data-notebook-create-type="Reminder" aria-label="Create reminder"><i class="bi bi-bell"></i></button>
                            </div>
                        </div>
                        <div class="notebook-composer__expanded" data-composer-expanded hidden>
                            <div class="notebook-composer__top">
                                <input type="text" data-composer-title maxlength="220" placeholder="Title" aria-label="Note title" />
                                <button type="button" data-composer-pin aria-label="Pin note"><i class="bi bi-pin-angle"></i></button>
                            </div>
                            <textarea data-composer-body maxlength="20000" placeholder="Take a note…" aria-label="Note body"></textarea>
                            <div data-composer-checklist hidden></div>
                            <div class="notebook-composer__footer">
                                <span data-composer-status aria-live="polite"></span>
                                <button type="button" data-composer-close>Close</button>
                            </div>
                        </div>
                    </section>
        }

        @* SECTION: Visible async operation errors *@
        <div class="notebook-global-error" data-notebook-global-error role="alert" hidden>
            <span data-notebook-global-error-text></span>
            <button type="button" data-notebook-global-error-close aria-label="Dismiss error">×</button>
        </div>

        @* SECTION: Card-first notebook board *@
        @if (Model.Notebook.View == "labels")
        {
            <section class="notebook-labels-panel" aria-label="Notebook labels">
                <div class="notebook-section-header"><h2>Labels</h2><span>@Model.Notebook.Tags.Count</span></div>
                <div class="notebook-label-chips">
                    @foreach (var tag in Model.Notebook.Tags)
                    {
                        <a asp-page="/Notebook/Index" asp-route-view="labels" asp-route-tag="@tag.Name" class="@(Model.Notebook.Tag == tag.Name.ToUpperInvariant() ? "is-active" : "")">#@tag.Name <span>@tag.Count</span></a>
                    }
                </div>
            </section>
        }
        @if (Model.Notebook.View == "home")
        {

            var hasAnyHomeItems = Model.Notebook.PinnedItems.Any() || Model.Notebook.OtherItems.Any();

            @* SECTION: Manual-order friendly home board sections *@
            <section class="notebook-board-section" data-notebook-section="pinned" hidden="@(!Model.Notebook.PinnedItems.Any())">
                <div class="notebook-section-header"><h2>Pinned</h2><span data-notebook-count="pinned">@Model.Notebook.PinnedItems.Count</span></div>
                <div class="notebook-board" data-notebook-board="pinned" data-layout-policy="fixed-grid" data-layout="grid" data-item-count="@Model.Notebook.PinnedItems.Count">
                    @foreach (var item in Model.Notebook.PinnedItems)
                    {
                        <partial name="_NotebookCard" model="@(CardModelFactory.Create(item, new ProjectManagement.Services.Notebook.NotebookCardContext { View = Model.Notebook.View, Query = Model.Notebook.Query, Filter = Model.Notebook.Filter, Tag = Model.Notebook.Tag, SelectedId = selected?.Id }))" />
                    }
                </div>
            </section>
            <section class="notebook-board-section" data-notebook-section="others">
                <div class="notebook-section-header"><h2>Others</h2><span data-notebook-count="others">@Model.Notebook.OtherItems.Count</span></div>
                <div class="notebook-board" data-notebook-board="others" data-layout-policy="masonry-threshold" data-layout="@(Model.Notebook.OtherItems.Count > 4 ? "masonry" : "grid")" data-item-count="@Model.Notebook.OtherItems.Count">
                    @foreach (var item in Model.Notebook.OtherItems)
                    {
                        <partial name="_NotebookCard" model="@(CardModelFactory.Create(item, new ProjectManagement.Services.Notebook.NotebookCardContext { View = Model.Notebook.View, Query = Model.Notebook.Query, Filter = Model.Notebook.Filter, Tag = Model.Notebook.Tag, SelectedId = selected?.Id }))" />
                    }
                </div>
                @if (!hasAnyHomeItems)
                {
                    <div class="notebook-empty notebook-empty-compact" data-notebook-empty-state><h3>@emptyTitle</h3><p>@emptyText</p></div>
                }
            </section>
        }
        else
        {
            <section class="notebook-board-section">
                <div class="notebook-board" data-notebook-board data-layout-policy="fixed-grid" data-layout="grid" data-item-count="@Model.Notebook.Items.Count">
                    @foreach (var item in Model.Notebook.Items)
                    {
                        <partial name="_NotebookCard" model="@(CardModelFactory.Create(item, new ProjectManagement.Services.Notebook.NotebookCardContext { View = Model.Notebook.View, Query = Model.Notebook.Query, Filter = Model.Notebook.Filter, Tag = Model.Notebook.Tag, SelectedId = selected?.Id }))" />
                    }
                </div>
                @if (!Model.Notebook.Items.Any())
                {
                    var emptyType = Model.Notebook.View switch
                    {
                        "reminders" or "today" => "Reminder",
                        _ => "Note"
                    };
                    var cta = Model.Notebook.View is "archive" or "archived" or "completed" ? null : $"New {emptyType}";
                    <div class="notebook-empty" data-notebook-empty-state><h3>@emptyTitle</h3><p>@emptyText</p>@if (cta is not null) { <a asp-page="/Notebook/Index" asp-route-view="@Model.Notebook.View" asp-route-mode="new" asp-route-type="@emptyType" data-notebook-create-type="@emptyType" class="btn btn-sm btn-primary">@cta</a> }</div>
                }
            </section>
        }
    </main>

    @if (Model.UseLegacyEditor)
    {
    <aside class="notebook-editor-drawer">
        <div class="notebook-editor-header"><h2>@(isCreateMode || selected is null ? $"New {Model.Input.Type.ToString().ToLowerInvariant()}" : "Edit item")</h2><a asp-page="/Notebook/Index" asp-route-view="@Model.Notebook.View" asp-route-query="@Model.Notebook.Query" asp-route-filter="@Model.Notebook.Filter" asp-route-tag="@Model.Notebook.Tag" class="notebook-editor-close" aria-label="Close editor"><i class="bi bi-x-lg"></i></a></div>
        <form method="post" asp-page-handler="@(selected is null ? "Create" : "Update")" asp-route-id="@selected?.Id" class="notebook-editor-form">
            <input type="hidden" asp-for="View" />
            <input type="hidden" asp-for="Query" />
            <input type="hidden" asp-for="Filter" />
            <input type="hidden" asp-for="Tag" />
            @* SECTION: Preserve optimistic concurrency version for legacy form edits *@
            @if (selected is not null)
            {
                <input type="hidden" name="expectedVersion" value="@selected.Version" />
            }
            <label class="notebook-title-field">Title<input asp-for="Input.Title" class="notebook-editor-title-input" required maxlength="220" /></label>
            <section class="notebook-editor-primary">
            <div class="notebook-editor-fields" data-notebook-type-fields="Note,Idea,Draft">
                <label>Body<textarea asp-for="Input.BodyMarkdown" data-autoresize></textarea></label>
            </div>
            <div class="notebook-editor-fields" data-notebook-type-fields="Sticky">
                <label>Quick note<textarea asp-for="Input.BodyMarkdown" class="notebook-sticky-editor" data-autoresize></textarea></label>

            </div>
            <div class="notebook-editor-fields" data-notebook-type-fields="Checklist">
                <div class="notebook-field-prominent notebook-checklist-edit-list">
                    <span>Checklist items</span>
                    @if (selected?.ChecklistItems.Any() == true)
                    {
                        var rowIndex = 0;
                        foreach (var row in selected.ChecklistItems)
                        {
                            <label class="notebook-checklist-edit-row">
                                <input type="hidden" name="ChecklistRows[@rowIndex].Id" value="@row.Id" />
                                <input type="hidden" name="ChecklistRows[@rowIndex].SortOrder" value="@row.SortOrder" />
                                <input type="hidden" name="ChecklistRows[@rowIndex].IsDone" value="@(row.IsDone ? "true" : "false")" />
                                <input name="ChecklistRows[@rowIndex].Text" value="@row.Text" maxlength="500" />
                            </label>
                            rowIndex++;
                        }

                        @* SECTION: Blank checklist append row for existing checklists *@
                        <label class="notebook-checklist-edit-row notebook-checklist-add-row">
                            <input type="hidden" name="ChecklistRows[@rowIndex].SortOrder" value="@rowIndex" />
                            <input type="hidden" name="ChecklistRows[@rowIndex].IsDone" value="false" />
                            <input name="ChecklistRows[@rowIndex].Text" value="" maxlength="500" placeholder="Add another checklist item" />
                        </label>
                    }
                    else
                    {
                        <textarea asp-for="ChecklistText" placeholder="One checklist item per line"></textarea>
                    }
                </div>
                <label data-notebook-checklist-reminder>Reminder (IST)<input asp-for="Input.ReminderLocal" type="datetime-local" /></label>
                <label>Priority<select asp-for="Input.Priority" asp-items="Html.GetEnumSelectList<NotebookPriority>()"></select></label>
                <label>Optional notes<textarea asp-for="Input.BodyMarkdown" data-autoresize></textarea></label>
            </div>
            <div class="notebook-editor-fields" data-notebook-type-fields="Reminder">
                <label class="notebook-field-prominent">Reminder (IST)<input asp-for="Input.ReminderLocal" type="datetime-local" /></label>
                <label>Priority<select asp-for="Input.Priority" asp-items="Html.GetEnumSelectList<NotebookPriority>()"></select></label>
                <label>Notes<textarea asp-for="Input.BodyMarkdown" data-autoresize></textarea></label>
            </div>
            </section>
            <section class="notebook-editor-details"><div class="notebook-editor-section-title">Details</div>
            <label>Type<select asp-for="Input.Type" asp-items="Html.GetEnumSelectList<NotebookItemType>()" data-notebook-type-select></select></label>
            <label>Tags<input asp-for="TagsText" placeholder="procurement, docs" /></label>
            <label data-notebook-shared-reminder>Reminder (IST)<input asp-for="Input.ReminderLocal" type="datetime-local" /></label>
            <label data-notebook-shared-priority>Priority<select asp-for="Input.Priority" asp-items="Html.GetEnumSelectList<NotebookPriority>()"></select></label>
            <label>Colour<select asp-for="Input.ColorKey"><option>white</option><option>blue</option><option>amber</option><option>green</option><option>rose</option><option>slate</option></select></label>
            <div class="notebook-checks"><label><input asp-for="Input.IsPinned" /> Pin</label><label><input asp-for="Input.IsFavorite" /> Favourite</label></div>
            </section>
            <div class="notebook-editor-footer"><button class="btn btn-primary w-100" type="submit">@(isCreateMode || selected is null ? "Create" : "Save")</button></div>
        </form>
        @if (selected is not null && (selected.Type == NotebookItemType.Reminder || selected.ReminderAtUtc is not null))
        {
            <form method="post" asp-page-handler="Complete" asp-route-id="@selected.Id" class="notebook-editor-complete">
                <input type="hidden" asp-for="View" />
                <input type="hidden" asp-for="Query" />
                <input type="hidden" name="isComplete" value="true" />
                <input type="hidden" name="expectedVersion" value="@selected.Version" />
                <button class="btn btn-success w-100" type="submit"><i class="bi bi-check2-circle"></i> Mark done</button>
            </form>
        }
        @if (selected?.ChecklistItems.Any() == true)
        {
            <div class="notebook-checklist-toggle">@foreach (var c in selected.ChecklistItems) { <form method="post" asp-page-handler="ToggleChecklistItem"><input type="hidden" name="checklistItemId" value="@c.Id" /><input type="hidden" name="selectedId" value="@selected.Id" /><input type="hidden" name="expectedVersion" value="@selected.Version" /><input type="hidden" asp-for="View" /><input type="hidden" asp-for="Query" /><label><input type="checkbox" name="isDone" value="true" checked="@c.IsDone" data-submit-on-change /> @c.Text</label></form> }</div>
        }
    </aside>
    }
</div>


<partial name="_NotebookLabelManager" model="Model.Notebook.Tags" />
<partial name="_NotebookEditorTemplate" />

@section Scripts { <script type="module" src="~/dist/notebook-index.bundle.js" asp-append-version="true"></script> }
