<template id="notebook-editor-template">
    <div class="notebook-modal"
         data-notebook-editor
         hidden
         role="dialog"
         aria-modal="true"
         aria-labelledby="notebook-modal-title">
        <div class="notebook-modal__backdrop" data-close></div>
        <section class="notebook-modal__dialog" tabindex="-1">
            <header class="notebook-modal__header">
                <input id="notebook-modal-title"
                       data-modal-title
                       class="notebook-modal__title"
                       maxlength="220"
                       aria-label="Note title" />
                <div class="notebook-modal__header-actions">
                    <button type="button"
                            class="notebook-action-icon"
                            data-action="share-note-editor"
                            aria-label="Collaborators"
                            title="Collaborators">
                        <i class="bi bi-person-plus"></i>
                    </button>
                    <button type="button"
                            class="notebook-action-icon"
                            data-modal-pin
                            aria-label="Pin note">
                        <i class="bi bi-pin-angle"></i>
                    </button>
                    <button type="button"
                            class="notebook-action-icon notebook-modal__close"
                            data-close
                            aria-label="Close note editor">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </header>

            <div class="notebook-access-banner" data-notebook-access-banner hidden role="status">
                <i class="bi bi-eye" data-notebook-access-icon aria-hidden="true"></i>
                <span data-notebook-access-text></span>
            </div>

            <textarea data-modal-body
                      class="notebook-modal__body"
                      maxlength="20000"
                      placeholder="Take a note…"
                      aria-label="Note body"></textarea>

            <div class="notebook-editor__validation"
                 data-notebook-validation-summary
                 role="alert"
                 hidden></div>

            <div data-modal-checklist
                 class="notebook-checklist-editor"
                 hidden></div>



            <button type="button"
                    class="notebook-create-details-toggle"
                    data-notebook-create-details-toggle
                    aria-expanded="false"
                    hidden>
                <span><i class="bi bi-sliders"></i> Details</span>
                <i class="bi bi-chevron-down" aria-hidden="true"></i>
            </button>

            <section class="notebook-create-details"
                     data-notebook-create-details
                     hidden>
                <section class="notebook-reminder-scheduler"
                         data-reminder-scheduler
                         aria-labelledby="notebook-reminder-when-title"
                         hidden>
                    <div class="notebook-reminder-scheduler__heading">
                        <div>
                            <strong id="notebook-reminder-when-title">When</strong>
                            <span>Choose a quick option or set a precise time.</span>
                        </div>
                        <span class="notebook-reminder-scheduler__zone">IST</span>
                    </div>
                    <div class="notebook-reminder-presets" aria-label="Quick reminder times">
                        <button type="button" data-reminder-preset="later-today">Later today</button>
                        <button type="button" data-reminder-preset="tomorrow-morning">Tomorrow 09:00</button>
                        <button type="button" data-reminder-preset="next-monday">Next Monday 09:00</button>
                    </div>
                    <div class="notebook-reminder-date-time">
                        <label>
                            <span>Date</span>
                            <input type="date" data-reminder-date autocomplete="off" />
                        </label>
                        <label>
                            <span>Time</span>
                            <input type="time" data-reminder-time step="900" autocomplete="off" />
                        </label>
                    </div>
                    <p class="notebook-reminder-summary" data-reminder-summary hidden></p>
                    <p class="notebook-reminder-error" data-reminder-error role="alert" hidden></p>
                </section>

                <div class="notebook-create-details__grid">
                    <label data-create-type-field>
                        <span>Type</span>
                        <select data-create-type>
                            <option value="Note">Note</option>
                            <option value="Checklist">Checklist</option>
                            <option value="Reminder">Reminder</option>
                        </select>
                    </label>
                    <label>
                        <span>Priority</span>
                        <select data-create-priority>
                            <option value="Low">Low</option>
                            <option value="Normal" selected>Normal</option>
                            <option value="High">High</option>
                            <option value="Critical">Critical</option>
                        </select>
                    </label>
                </div>
            </section>

            <div class="notebook-create-feedback"
                 data-notebook-create-feedback
                 role="alert"
                 aria-live="polite"
                 hidden></div>

            <div class="notebook-editor-toolbar" data-notebook-editor-toolbar>
                <partial name="_NotebookColourPicker" model="string.Empty" />
                <partial name="_NotebookLabelPicker" />
            </div>

            <div class="notebook-save-feedback">
                <span class="notebook-modal__save-state"
                      data-notebook-save-state
                      aria-live="polite"></span>
                <button type="button" data-notebook-retry hidden>Retry</button>
                <button type="button" data-notebook-reload-application hidden>Reload application</button>
                <button type="button" data-notebook-sign-in hidden>Sign in again</button>
                <button type="button" data-notebook-copy-unsaved hidden>Copy note text</button>
                <button type="button" data-modal-discard hidden>Discard changes</button>
            </div>

            <section class="notebook-conflict"
                     data-notebook-conflict
                     hidden
                     role="status"
                     aria-live="polite">
                <div class="notebook-conflict__message"
                     data-notebook-conflict-message></div>
                <div class="notebook-conflict__actions">
                    <button type="button"
                            class="notebook-conflict__action"
                            data-notebook-use-local>
                        Use my changes
                    </button>
                    <button type="button"
                            class="notebook-conflict__action"
                            data-notebook-reload-latest>
                        Reload latest
                    </button>
                    <button type="button"
                            class="notebook-conflict__action notebook-conflict__action--secondary"
                            data-notebook-copy-local>
                        Copy my changes
                    </button>
                </div>
            </section>

            <footer>
                <button type="button"
                        class="btn btn-sm notebook-create-discard"
                        data-notebook-create-discard
                        hidden>
                    Discard draft
                </button>
                <span class="notebook-create-draft-status" data-notebook-create-draft-status aria-live="polite"></span>
                <button type="button"
                        class="btn btn-sm btn-primary notebook-create-submit"
                        data-notebook-create-submit
                        hidden>
                    Create
                </button>
                <button type="button"
                        class="btn btn-sm notebook-editor-close-button"
                        data-close
                        aria-label="Close note editor">
                    Close
                </button>
            </footer>
        </section>
    </div>
</template>
