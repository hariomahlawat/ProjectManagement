@page "/Admin/MediaSources"
@model ProjectManagement.Pages.Admin.MediaSources.IndexModel
@{
    ViewData["Title"] = "Media Sources";
}

<div class="container-xxl py-4">
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <div class="text-uppercase small fw-semibold text-primary mb-1">Photos administration</div>
            <h1 class="h3 mb-1">Media sources</h1>
            <p class="text-muted mb-0">Monitor PRISM media indexing, NAS connectivity and background processing.</p>
        </div>
        <a asp-page="/Photos/Index" class="btn btn-outline-primary">
            <i class="bi bi-images me-1" aria-hidden="true"></i> Open Photos
        </a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status">@Model.StatusMessage</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-3">
            <div class="border rounded-3 p-3 h-100">
                <div class="text-muted small">Configured sources</div>
                <div class="fs-3 fw-semibold">@Model.Sources.Count</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="border rounded-3 p-3 h-100">
                <div class="text-muted small">Queued / processing</div>
                <div class="fs-3 fw-semibold">@Model.PendingJobs</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="border rounded-3 p-3 h-100">
                <div class="text-muted small">Failed jobs</div>
                <div class="fs-3 fw-semibold text-danger">@Model.FailedJobs</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3 d-flex align-items-stretch">
            <form method="post" asp-page-handler="RetryFailed" class="w-100">
                <button type="submit" class="btn btn-outline-danger w-100 h-100" disabled="@(Model.FailedJobs == 0)">
                    <i class="bi bi-arrow-repeat me-1" aria-hidden="true"></i> Retry failed jobs
                </button>
            </form>
        </div>
    </div>

    <div class="table-responsive border rounded-3">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Source</th>
                    <th>Status</th>
                    <th class="text-end">Assets</th>
                    <th>Last successful scan</th>
                    <th>Location</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var source in Model.Sources)
                {
                    var statusClass = source.Status == "Healthy" ? "text-bg-success"
                        : source.Status is "Scanning" or "Queued" ? "text-bg-primary"
                        : source.Status == "Failed" ? "text-bg-danger"
                        : "text-bg-secondary";
                    <tr>
                        <td>
                            <div class="fw-semibold">@source.Name</div>
                            <div class="small text-muted">@source.Type · @(source.IsReadOnly ? "Read only" : "Managed")</div>
                            @if (!string.IsNullOrWhiteSpace(source.LastError))
                            {
                                <div class="small text-danger mt-1">@source.LastError</div>
                            }
                        </td>
                        <td><span class="badge @statusClass">@source.Status</span></td>
                        <td class="text-end">@source.AssetCount.ToString("N0")</td>
                        <td>@(source.LastSuccessfulScanAtUtc?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "Never")</td>
                        <td><code class="small">@(source.RootPath ?? "PRISM database")</code></td>
                        <td class="text-end">
                            <form method="post" asp-page-handler="Scan">
                                <input type="hidden" name="id" value="@source.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-primary" disabled="@(!source.IsEnabled)">
                                    Scan now
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
