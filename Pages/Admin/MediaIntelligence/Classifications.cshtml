@page
@model ProjectManagement.Pages.Admin.MediaIntelligence.ClassificationsModel
@using ProjectManagement.Features.MediaLibrary.Domain
@{
    ViewData["Title"] = "Classification review";
}

<link rel="stylesheet" href="~/css/pages/media-intelligence.css" asp-append-version="true" />

<div class="container-fluid py-4 media-intelligence-page">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <div>
            <div class="text-primary small text-uppercase fw-semibold mb-1">Media intelligence</div>
            <h1 class="h3 mb-1">Classification review</h1>
            <p class="text-muted mb-0">Validate automatic decisions before an image is allowed into face processing.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <form method="post" asp-page-handler="ReclassifyStale">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-repeat"></i> Reclassify stale assets
                </button>
            </form>
            <a class="btn btn-outline-secondary" asp-page="/Admin/MediaIntelligence/Index">Overview</a>
        </div>
    </div>

    <nav class="intel-tabs mb-4">
        <a asp-page="/Admin/MediaIntelligence/Index">Overview</a>
        <a class="active" asp-page="/Admin/MediaIntelligence/Classifications">Classification</a>
        <a asp-page="/Photos/People/Review">People review</a>
        <a asp-page="/Photos/People/Index">People</a>
    </nav>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage)) { <div class="alert alert-success" role="status">@Model.StatusMessage</div> }
    @if (!string.IsNullOrWhiteSpace(Model.WarningMessage)) { <div class="alert alert-warning" role="alert">@Model.WarningMessage</div> }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) { <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div> }

    <form method="get" class="card card-body shadow-sm border-0 mb-4">
        <div class="row g-3">
            <div class="col-lg-5">
                <label class="form-label" asp-for="Q">Search</label>
                <input class="form-control" asp-for="Q" placeholder="Title, collection or filename" />
            </div>
            <div class="col-lg-3">
                <label class="form-label" asp-for="Classification">Classification</label>
                <select class="form-select" asp-for="Classification">
                    <option value="">All classifications</option>
                    @foreach (var value in Enum.GetValues<MediaClassification>())
                    {
                        <option value="@value">@value</option>
                    }
                </select>
            </div>
            <div class="col-lg-2">
                <label class="form-label" asp-for="Mode">Review set</label>
                <select class="form-select" asp-for="Mode">
                    <option value="all">All</option>
                    <option value="low">Low confidence</option>
                    <option value="unknown">Unknown / needs review</option>
                    <option value="nonphoto">Confirmed non-photographs</option>
                    <option value="stale">Stale classifier</option>
                    <option value="manual">Manual overrides</option>
                    <option value="eligible">Face eligible</option>
                </select>
            </div>
            <div class="col-lg-2 d-flex align-items-end">
                <button class="btn btn-primary w-100">Apply</button>
            </div>
        </div>
    </form>

    <div class="classification-review-toolbar mb-3">
        <div>
            <span class="text-muted">@Model.Total image(s)</span>
            <span class="small text-muted ms-2">Page @Model.P of @Model.TotalPages</span>
        </div>
        <form id="bulk-classification-form" method="post" asp-page-handler="SetBatch" class="classification-bulk-form">
            <label class="form-check mb-0 me-2">
                <input id="select-page" class="form-check-input" type="checkbox" />
                <span class="form-check-label">Select page</span>
            </label>
            <select id="bulk-classification" class="form-select form-select-sm" name="classification" aria-label="Bulk classification" required>
                <option value="">Choose classification…</option>
                @foreach (var value in Enum.GetValues<MediaClassification>().Where(x => x != MediaClassification.Unknown))
                {
                    <option value="@value">@value</option>
                }
            </select>
            <input class="form-control form-control-sm" name="reason" placeholder="Bulk reason (required)" required />
            <span id="selected-count" class="small text-muted">0 selected</span>
            <button id="bulk-apply" class="btn btn-sm btn-primary" type="submit" disabled>Apply to selected</button>
        </form>
    </div>

    <div class="classification-grid classification-grid--review">
        @foreach (var item in Model.Rows)
        {
            <article class="classification-card classification-card--review">
                <label class="classification-card__selector">
                    <input class="form-check-input js-classification-select"
                           type="checkbox"
                           name="assetIds"
                           value="@item.Id"
                           form="bulk-classification-form" />
                    <input type="hidden" name="expectedConcurrencyTokens" value="@item.ConcurrencyToken" form="bulk-classification-form" disabled class="js-classification-token" />
                    <span>Select</span>
                </label>
                <a class="classification-card__preview"
                   href="@Url.Page("/Photos/Media", new { id = item.Id, variant = "preview" })"
                   target="_blank"
                   rel="noopener"
                   aria-label="Open @item.Title">
                    <img src="@Url.Page("/Photos/Media", new { id = item.Id, variant = "thumb" })"
                         alt=""
                         loading="lazy" />
                    <span><i class="bi bi-arrows-fullscreen"></i> Open preview</span>
                </a>

                <div class="classification-card__header">
                    <div class="classification-card__title">
                        <strong>@item.Title</strong>
                        <div class="small text-muted text-truncate">@item.ContextTitle · @item.OriginalFileName</div>
                    </div>
                    <span class="badge @item.ReviewStatusCss">@item.ReviewStatusLabel</span>
                </div>

                <div class="classification-card__body">
                    <dl class="row small mb-2">
                        <dt class="col-5">Prediction</dt>
                        <dd class="col-7">@item.PredictedClassification — @item.PredictedScore.ToString("P0")</dd>
                        <dt class="col-5">Final decision</dt>
                        <dd class="col-7">@item.DecisionStatus</dd>
                        <dt class="col-5">Classification</dt>
                        <dd class="col-7">@item.Classification</dd>
                        <dt class="col-5">Analysis</dt>
                        <dd class="col-7">@item.AnalysisStatus</dd>
                        <dt class="col-5">Source</dt>
                        <dd class="col-7 text-break">@(item.IsManual ? "Manual override" : item.ClassifierVersion ?? "Not classified")</dd>
                    </dl>

                    <div class="classification-eligibility @(item.FaceEligible ? "classification-eligibility--eligible" : null)">
                        <i class="bi @(item.FaceEligible ? "bi-check-circle" : "bi-info-circle")"></i>
                        <span>@item.FaceEligibilityReason</span>
                    </div>

                    @if (item.Signals.Count > 0)
                    {
                        <details class="small mb-3">
                            <summary>Decision signals</summary>
                            <ul class="mt-2 mb-0">
                                @foreach (var signal in item.Signals.Take(5))
                                {
                                    <li>@signal</li>
                                }
                            </ul>
                        </details>
                    }

                    <form method="post" asp-page-handler="Set" class="row g-2">
                        <input type="hidden" name="assetId" value="@item.Id" />
                        <input type="hidden" name="expectedConcurrencyToken" value="@item.ConcurrencyToken" />
                        <div class="col-7">
                            <select class="form-select form-select-sm" name="classification">
                                @foreach (var value in Enum.GetValues<MediaClassification>().Where(x => x != MediaClassification.Unknown))
                                {
                                    @if (value == item.Classification) { <option value="@value" selected>@value</option> } else { <option value="@value">@value</option> }
                                }
                            </select>
                        </div>
                        <div class="col-5">
                            <button class="btn btn-sm btn-primary w-100">Set manually</button>
                        </div>
                        <div class="col-12">
                            <input class="form-control form-control-sm" name="reason" placeholder="Reason (optional)" />
                        </div>
                    </form>

                    @if (item.IsManual)
                    {
                        <form method="post" asp-page-handler="Reset" class="mt-2">
                            <input type="hidden" name="assetId" value="@item.Id" />
                            <input type="hidden" name="expectedConcurrencyToken" value="@item.ConcurrencyToken" />
                            <button class="btn btn-sm btn-outline-secondary">Reset to automatic</button>
                        </form>
                    }
                </div>
            </article>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="d-flex justify-content-end gap-2 mt-4" aria-label="Classification pages">
            <a class="btn btn-outline-secondary btn-sm @(Model.P <= 1 ? "disabled" : null)"
               asp-route-p="@(Model.P - 1)"
               asp-route-q="@Model.Q"
               asp-route-classification="@Model.Classification"
               asp-route-mode="@Model.Mode">Previous</a>
            <a class="btn btn-outline-primary btn-sm @(Model.P >= Model.TotalPages ? "disabled" : null)"
               asp-route-p="@(Model.P + 1)"
               asp-route-q="@Model.Q"
               asp-route-classification="@Model.Classification"
               asp-route-mode="@Model.Mode">Next</a>
        </nav>
    }
</div>

@section Scripts {
<script>
(() => {
 const page=document.getElementById('select-page'), boxes=[...document.querySelectorAll('.js-classification-select')], button=document.getElementById('bulk-apply'), count=document.getElementById('selected-count'), form=document.getElementById('bulk-classification-form');
 const sync=()=>{const selected=boxes.filter(x=>x.checked); boxes.forEach((box,i)=>{const token=box.parentElement.querySelector('.js-classification-token'); if(token) token.disabled=!box.checked;}); if(count) count.textContent=`${selected.length} selected`; if(button) button.disabled=selected.length===0; if(page){page.checked=boxes.length>0&&selected.length===boxes.length;page.indeterminate=selected.length>0&&selected.length<boxes.length;}};
 page?.addEventListener('change',()=>{boxes.forEach(x=>x.checked=page.checked);sync();}); boxes.forEach(x=>x.addEventListener('change',sync));
 form?.addEventListener('submit',e=>{const selected=boxes.filter(x=>x.checked).length;if(!selected){e.preventDefault();alert('Select at least one image.');return;} if(selected>10&&!confirm(`Apply this classification to ${selected} images?`))e.preventDefault();}); sync();
})();
</script>
}
