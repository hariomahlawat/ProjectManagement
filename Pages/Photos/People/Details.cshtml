@page
@model ProjectManagement.Pages.Photos.People.DetailsModel
@{ViewData["Title"]=Model.PersonName;}
<div class="container-fluid py-4"><div class="d-flex justify-content-between align-items-start mb-4"><div><h1 class="h3 mb-1">@Model.PersonName</h1><p class="text-muted mb-0">Human-confirmed photographs only.</p></div><a class="btn btn-outline-secondary" asp-page="./Index">Back to People</a></div><div class="row g-3">@foreach(var photo in Model.Photos){<div class="col-6 col-md-4 col-xl-3"><a class="card h-100 text-decoration-none" href="/Photos#media-@photo.AssetId"><img class="card-img-top object-fit-cover" style="height:220px" src="/Photos/Media?id=@photo.AssetId&variant=thumb" alt="" loading="lazy"/><div class="card-body"><div class="fw-semibold text-body">@photo.ContextTitle</div><small class="text-muted">@photo.MediaDateUtc.ToLocalTime().ToString("dd MMM yyyy")</small></div></a></div>}@if(Model.Photos.Count==0){<div class="col-12"><div class="alert alert-light border">No confirmed photographs are available.</div></div>}</div></div>
