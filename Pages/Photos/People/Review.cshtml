@page
@model ProjectManagement.Pages.Photos.People.ReviewModel
@{ViewData["Title"]="Face review";}
<div class="container-fluid py-4"><div class="d-flex justify-content-between mb-4"><div><h1 class="h3">Face review</h1><p class="text-muted">Every identity suggestion requires a human decision.</p></div><a class="btn btn-outline-secondary" asp-page="/Admin/MediaIntelligence/Index">Intelligence dashboard</a></div>
@foreach(var item in Model.Items){<div class="card mb-3"><div class="card-body d-flex flex-wrap gap-3 align-items-center"><img class="rounded object-fit-cover" width="96" height="96" src="/Photos/FaceThumbnail?id=@item.FaceId" alt="Detected face"/><div class="flex-grow-1"><strong>@item.ContextTitle</strong><div class="text-muted">Suggested: @(item.PersonName??"No existing person") · Similarity: @(item.Similarity?.ToString("0.000")??"—")</div></div>@if(item.PersonId.HasValue){<form method="post" asp-page-handler="Confirm"><input type="hidden" name="faceId" value="@item.FaceId"/><input type="hidden" name="personId" value="@item.PersonId"/><input type="hidden" name="confidence" value="@item.Similarity"/><button class="btn btn-success">Confirm</button></form><form method="post" asp-page-handler="Reject"><input type="hidden" name="faceId" value="@item.FaceId"/><input type="hidden" name="personId" value="@item.PersonId"/><button class="btn btn-outline-danger">Not this person</button></form>}<form method="post" asp-page-handler="Create" class="d-flex gap-2"><input type="hidden" name="faceId" value="@item.FaceId"/><input class="form-control" name="displayName" placeholder="Create person" required/><button class="btn btn-primary">Create & assign</button></form></div></div>}@if(Model.Items.Count==0){<div class="alert alert-light border">No face suggestions are awaiting review.</div>}</div>
