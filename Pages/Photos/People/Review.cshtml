@page
@model ProjectManagement.Pages.Photos.People.ReviewModel
@{
    ViewData["Title"] = "People classification";
    ViewData["PageShell"] = "wide";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/photos-people.css" asp-append-version="true" />
}

<div class="people-workspace">
    <header class="people-header">
        <div>
            <span class="people-eyebrow">Human-confirmed identity intelligence</span>
            <h1>People classification</h1>
            <p>Review suggested appearances of the same person, then confirm the identity once. PRISM never names a person automatically.</p>
        </div>
        <nav class="people-header__actions">
            @if (Model.FeatureEnabled)
            {
                <form method="post" asp-page-handler="RefreshCandidates">
                    <input type="hidden" name="Mode" value="@Model.Mode" />
                    <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-arrow-repeat"></i> Refresh matches
                    </button>
                </form>
            }
            <a class="btn btn-outline-secondary" asp-page="./Index"><i class="bi bi-people"></i> People</a>
            <a class="btn btn-outline-secondary" asp-page="/Admin/MediaIntelligence/Index"><i class="bi bi-cpu"></i> Readiness</a>
        </nav>
    </header>

    @if (!Model.FeatureEnabled)
    {
        <section class="people-empty">
            <i class="bi bi-shield-lock" aria-hidden="true"></i>
            <h2>People intelligence is disabled</h2>
            <p>The approved local detector and embedding models must pass readiness before face grouping and identity review can run.</p>
            <a class="btn btn-primary" asp-page="/Admin/MediaIntelligence/Index">Open readiness dashboard</a>
        </section>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert alert-success" role="status">@Model.StatusMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }

        <nav class="identity-review-tabs" aria-label="People review mode">
            @if (Model.GroupingEnabled)
            {
                <a class="identity-review-tab @(Model.IsGroupsMode ? "is-active" : null)"
                   asp-page="./Review" asp-route-Mode="groups">
                    <i class="bi bi-collection"></i>
                    <span>Identity groups</span>
                    @if (Model.IsGroupsMode)
                    {
                        <strong>@Model.GroupResult.TotalGroups</strong>
                    }
                </a>
            }
            <a class="identity-review-tab @(!Model.IsGroupsMode ? "is-active" : null)"
               asp-page="./Review" asp-route-Mode="faces">
                <i class="bi bi-person-bounding-box"></i>
                <span>Individual faces</span>
                @if (!Model.IsGroupsMode)
                {
                    <strong>@Model.Result.TotalFaces</strong>
                }
            </a>
        </nav>

        @if (Model.IsGroupsMode)
        {
            <section class="review-summary review-summary--people">
                <div><strong>@Model.GroupResult.TotalGroups</strong><span>suggested people groups</span></div>
                <div><strong>@Model.GroupResult.GroupedFaceCount</strong><span>appearances grouped</span></div>
                <div><strong>@Model.GroupResult.RemainingIndividualFaceCount</strong><span>faces needing individual review</span></div>
                <p><i class="bi bi-shield-check"></i> A group is only a similarity suggestion. An authorised reviewer must select the correct appearances and confirm a name.</p>
            </section>

            @if (Model.GroupResult.Groups.Count == 0)
            {
                <section class="people-empty">
                    <i class="bi bi-person-check"></i>
                    <h2>No repeated unnamed people found</h2>
                    <p>There are no strict multi-photo groups awaiting confirmation. Continue with individual face review.</p>
                    <a class="btn btn-primary" asp-page="./Review" asp-route-Mode="faces">Review individual faces</a>
                </section>
            }
            else
            {
                <div class="identity-group-list">
                    @foreach (var group in Model.GroupResult.Groups)
                    {
                        <article class="identity-group-card" data-identity-group="@group.GroupKey">
                            <header class="identity-group-card__header">
                                <div>
                                    <span class="identity-group-card__kicker">Suggested same person</span>
                                    <h2>@group.Members.Count appearances across @group.PhotoCount photographs</h2>
                                    <p>@group.FirstSeenUtc.ToLocalTime().ToString("dd MMM yyyy") – @group.LastSeenUtc.ToLocalTime().ToString("dd MMM yyyy")</p>
                                </div>
                                <div class="identity-group-card__cohesion" title="Average similarity to the representative face">
                                    <span>Group cohesion</span>
                                    <strong>@group.CohesionScore.ToString("0.000")</strong>
                                </div>
                            </header>

                            <div class="identity-group-mosaic" role="list" aria-label="Suggested appearances">
                                @foreach (var member in group.Members)
                                {
                                    <a class="identity-group-face @(member.FaceId == group.RepresentativeFaceId ? "is-representative" : null)"
                                       href="@Url.Page("/Photos/Media", new { id = member.AssetId, variant = "preview" })"
                                       target="_blank" rel="noopener" role="listitem"
                                       title="@member.ContextTitle · similarity @member.SimilarityToRepresentative.ToString("0.000")">
                                        <img src="@Url.Page("/Photos/FaceThumbnail", new { id = member.FaceId })"
                                             alt="Face appearance from @member.ContextTitle" loading="lazy" />
                                        <span>@member.SimilarityToRepresentative.ToString("0.000")</span>
                                    </a>
                                }
                            </div>

                            @if (group.Candidates.Count > 0)
                            {
                                <section class="identity-group-candidates" aria-label="Known-person matches">
                                    <h3>Possible existing person</h3>
                                    @foreach (var candidate in group.Candidates.Take(3))
                                    {
                                        var isStrong = candidate.Similarity >= Model.CandidateStrongSimilarityThreshold;
                                        <div class="identity-group-candidate">
                                            <span>
                                                <strong>@candidate.DisplayName</strong>
                                                <small>Match @candidate.Similarity.ToString("0.000") · @candidate.ReferenceCount @(candidate.ReferenceCount == 1 ? "reference face" : "reference faces")</small>
                                            </span>
                                            <div class="identity-group-candidate__actions">
                                                <form method="post" asp-page-handler="AssignGroup">
                                                    <input type="hidden" name="Mode" value="groups" />
                                                    @foreach (var faceId in group.FaceIds)
                                                    {
                                                        <input type="hidden" name="faceIds" value="@faceId" />
                                                    }
                                                    <input type="hidden" name="personId" value="@candidate.PersonId" />
                                                    <input type="hidden" name="confidence" value="@candidate.Similarity" />
                                                    <button type="submit" class="btn btn-sm @(isStrong ? "btn-success" : "btn-outline-primary")">
                                                        Confirm all as @candidate.DisplayName
                                                    </button>
                                                </form>
                                                <form method="post" asp-page-handler="RejectGroupCandidate">
                                                    <input type="hidden" name="Mode" value="groups" />
                                                    @foreach (var faceId in group.FaceIds)
                                                    {
                                                        <input type="hidden" name="faceIds" value="@faceId" />
                                                    }
                                                    <input type="hidden" name="personId" value="@candidate.PersonId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Not this person</button>
                                                </form>
                                            </div>
                                        </div>
                                    }
                                </section>
                            }

                            <form method="post" class="identity-group-decision" data-group-decision>
                                <input type="hidden" name="Mode" value="groups" />
                                <div class="identity-group-selection">
                                    <div>
                                        <strong>Select appearances that are the same person</strong>
                                        <span data-selected-count>@group.FaceIds.Count selected</span>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-link" data-toggle-group-selection>Select/clear all</button>
                                </div>
                                <div class="identity-group-checkboxes">
                                    @foreach (var member in group.Members)
                                    {
                                        <label>
                                            <input class="form-check-input" type="checkbox" name="faceIds" value="@member.FaceId" checked />
                                            <span>@member.ContextTitle</span>
                                        </label>
                                    }
                                </div>
                                <div class="identity-group-actions">
                                    <div>
                                        <label for="existing-@group.GroupKey">Assign to an existing person</label>
                                        <select id="existing-@group.GroupKey" class="form-select" name="personId">
                                            <option value="">Select a person</option>
                                            @foreach (var person in Model.AvailablePeople)
                                            {
                                                <option value="@person.Id">@person.DisplayName</option>
                                            }
                                        </select>
                                        <button type="submit" asp-page-handler="AssignGroup" class="btn btn-outline-primary">Assign selected</button>
                                    </div>
                                    <div>
                                        <label for="new-@group.GroupKey">Or create a new person</label>
                                        <input id="new-@group.GroupKey" class="form-control" name="displayName" maxlength="200" placeholder="Enter the correct name" />
                                        <button type="submit" asp-page-handler="CreateGroup" class="btn btn-primary">Create and confirm selected</button>
                                    </div>
                                </div>
                            </form>
                        </article>
                    }
                </div>
            }
        }
        else
        {
            <section class="review-summary">
                <strong>@Model.Result.TotalFaces</strong>
                <span>face@(Model.Result.TotalFaces == 1 ? string.Empty : "s") awaiting an individual human decision</span>
            </section>

            @if (Model.Result.Items.Count == 0)
            {
                <section class="people-empty">
                    <i class="bi bi-check2-circle"></i>
                    <h2>Individual review queue clear</h2>
                    <p>No detected faces currently require an individual decision.</p>
                </section>
            }
            else
            {
                <div class="face-review-list">
                    @foreach (var item in Model.Result.Items)
                    {
                        <article class="face-review-card">
                            <div class="face-review-card__face">
                                <img src="@Url.Page("/Photos/FaceThumbnail", new { id = item.FaceId })" alt="Detected face" loading="lazy" />
                                <span>Quality @item.QualityScore.ToString("0.00")</span>
                            </div>
                            <div class="face-review-card__content">
                                <header>
                                    <div>
                                        <h2>@item.ContextTitle</h2>
                                        <p>@item.ContextSubtitle · @item.MediaDateUtc.ToLocalTime().ToString("dd MMM yyyy")</p>
                                    </div>
                                    <a class="btn btn-sm btn-outline-secondary"
                                       href="@Url.Page("/Photos/Media", new { id = item.AssetId, variant = "preview" })"
                                       target="_blank" rel="noopener">View photograph <i class="bi bi-arrow-up-right"></i></a>
                                </header>

                                <div class="face-candidates" aria-label="Suggested people">
                                    @if (item.Candidates.Count == 0)
                                    {
                                        <div class="face-candidates__empty">
                                            <i class="bi bi-person-question" aria-hidden="true"></i>
                                            <span>No reliable known-person match was found.</span>
                                        </div>
                                    }
                                    @foreach (var candidate in item.Candidates)
                                    {
                                        <div class="face-candidate">
                                            <span class="face-candidate__identity">
                                                <strong>@candidate.DisplayName</strong>
                                                <small>
                                                    Match @(candidate.Similarity?.ToString("0.000") ?? "—")
                                                    @if (candidate.IsStrong)
                                                    {
                                                        <em class="candidate-strength is-strong">Strong</em>
                                                    }
                                                    else if (candidate.IsAmbiguous)
                                                    {
                                                        <em class="candidate-strength is-ambiguous">Ambiguous</em>
                                                    }
                                                </small>
                                            </span>
                                            <form method="post" asp-page-handler="Confirm">
                                                <input type="hidden" name="Mode" value="faces" />
                                                <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                                <input type="hidden" name="faceId" value="@item.FaceId" />
                                                <input type="hidden" name="personId" value="@candidate.PersonId" />
                                                <input type="hidden" name="confidence" value="@candidate.Similarity" />
                                                <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Confirm</button>
                                            </form>
                                            <form method="post" asp-page-handler="Reject">
                                                <input type="hidden" name="Mode" value="faces" />
                                                <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                                <input type="hidden" name="faceId" value="@item.FaceId" />
                                                <input type="hidden" name="personId" value="@candidate.PersonId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-lg"></i> Not this person</button>
                                            </form>
                                        </div>
                                    }
                                </div>

                                <div class="face-review-card__alternatives">
                                    @if (Model.AvailablePeople.Count > 0)
                                    {
                                        <button type="button"
                                                class="btn btn-outline-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#assignExistingModal"
                                                data-face-id="@item.FaceId"
                                                data-face-context="@item.ContextTitle">
                                            <i class="bi bi-person-check"></i> Assign an existing person
                                        </button>
                                    }
                                    <form method="post" asp-page-handler="Create" class="face-create-person">
                                        <input type="hidden" name="Mode" value="faces" />
                                        <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                        <input type="hidden" name="faceId" value="@item.FaceId" />
                                        <label for="new-person-@item.FaceId">Create a new person</label>
                                        <input id="new-person-@item.FaceId" class="form-control" name="displayName" maxlength="200" placeholder="Enter the correct name" required />
                                        <button type="submit" class="btn btn-primary">Create and confirm</button>
                                    </form>
                                    <div class="face-review-card__secondary-actions">
                                        @if (item.Candidates.Count > 0)
                                        {
                                            <form method="post" asp-page-handler="RejectAll">
                                                <input type="hidden" name="Mode" value="faces" />
                                                <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                                <input type="hidden" name="faceId" value="@item.FaceId" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary">Reject all suggestions</button>
                                            </form>
                                        }
                                        <form method="post" asp-page-handler="Ignore">
                                            <input type="hidden" name="Mode" value="faces" />
                                            <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                            <input type="hidden" name="faceId" value="@item.FaceId" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">Leave unidentified</button>
                                        </form>
                                        <form method="post" asp-page-handler="Suppress">
                                            <input type="hidden" name="Mode" value="faces" />
                                            <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                            <input type="hidden" name="faceId" value="@item.FaceId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Not a face</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </article>
                    }
                </div>

                <nav class="people-pagination" aria-label="Review pages">
                    @if (Model.Result.HasPreviousPage)
                    {
                        <a class="btn btn-outline-secondary" asp-page="./Review" asp-route-Mode="faces" asp-route-PageNumber="@(Model.Result.PageNumber - 1)">
                            <i class="bi bi-arrow-left"></i> Previous
                        </a>
                    }
                    <span>Page @Model.Result.PageNumber</span>
                    @if (Model.Result.HasNextPage)
                    {
                        <a class="btn btn-outline-secondary" asp-page="./Review" asp-route-Mode="faces" asp-route-PageNumber="@(Model.Result.PageNumber + 1)">
                            Next <i class="bi bi-arrow-right"></i>
                        </a>
                    }
                </nav>
            }
        }

        @if (Model.AvailablePeople.Count > 0 && !Model.IsGroupsMode)
        {
            <div class="modal fade" id="assignExistingModal" tabindex="-1" aria-labelledby="assignExistingModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <form method="post" asp-page-handler="AssignExisting">
                            <div class="modal-header">
                                <div>
                                    <h2 class="modal-title fs-5" id="assignExistingModalLabel">Assign an existing person</h2>
                                    <p class="mb-0 small text-body-secondary" data-face-context>Choose the confirmed identity for this face.</p>
                                </div>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" name="Mode" value="faces" />
                                <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                <input type="hidden" name="faceId" value="" />
                                <label for="existingPersonId" class="form-label">Person</label>
                                <select id="existingPersonId" class="form-select" name="personId" required>
                                    <option value="">Select a person</option>
                                    @foreach (var person in Model.AvailablePeople)
                                    {
                                        <option value="@person.Id">@person.DisplayName</option>
                                    }
                                </select>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Assign person</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script src="~/js/pages/photos-people-review.js" asp-append-version="true"></script>
}
