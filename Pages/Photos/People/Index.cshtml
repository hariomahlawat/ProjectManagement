@page
@model ProjectManagement.Pages.Photos.People.IndexModel
@{ViewData["Title"]="People";}
<div class="container-fluid py-4"><div class="d-flex justify-content-between mb-4"><div><h1 class="h3">People</h1><p class="text-muted">Only human-confirmed identities are shown.</p></div><a class="btn btn-outline-secondary" asp-page="/Photos/Index">Back to Photos</a></div><div class="row g-3">@foreach(var p in Model.People){<div class="col-6 col-md-3 col-xl-2"><a class="card h-100 text-decoration-none text-body" asp-page="./Details" asp-route-id="@p.Id"><div class="card-body">@if(p.RepresentativeFaceId.HasValue){<img class="rounded-circle object-fit-cover mb-3" width="72" height="72" src="/Photos/FaceThumbnail?id=@p.RepresentativeFaceId" alt=""/>}else{<div class="rounded-circle bg-light d-flex align-items-center justify-content-center mb-3" style="width:72px;height:72px"><i class="bi bi-person fs-2"></i></div>}<h2 class="h6 mb-1">@p.Name</h2><small class="text-muted">@p.FaceCount confirmed face(s)</small></div></a></div>}@if(Model.People.Count==0){<div class="col-12"><div class="alert alert-light border">No people have been confirmed yet.</div></div>}</div></div>
