@page "/Photos"
@model ProjectManagement.Pages.Photos.IndexModel
@using ProjectManagement.Pages.Photos
@{
    ViewData["Title"] = "Photos";
    ViewData["PageShell"] = "wide";
    var hasFilters = !string.IsNullOrWhiteSpace(Model.Q)
        || Model.Source != "all"
        || Model.Kind != "all"
        || Model.ProjectId.HasValue
        || Model.Year.HasValue;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/photos-library.css" asp-append-version="true" />
}

<div class="photos-library" data-photos-library>
    <header class="photos-library__header">
        <div>
            <span class="photos-library__eyebrow">Unified organisational media</span>
            <h1>Photos</h1>
            <p>Browse project photographs, videos, visits and events in one professional media library.</p>
        </div>
        <button class="btn btn-primary photos-library__filter-toggle" type="button" data-bs-toggle="offcanvas" data-bs-target="#photosFilters" aria-controls="photosFilters">
            <i class="bi bi-sliders2" aria-hidden="true"></i>
            Filters
            @if (hasFilters)
            {
                <span class="photos-library__filter-dot" aria-label="Filters are active"></span>
            }
        </button>
    </header>

    <section class="photos-library__toolbar" aria-label="Media library controls">
        <form method="get" class="photos-search" role="search">
            <i class="bi bi-search" aria-hidden="true"></i>
            <input type="search" name="Q" value="@Model.Q" placeholder="Search projects, visits, events and captions" autocomplete="off" />
            <input type="hidden" name="Source" value="@Model.Source" />
            <input type="hidden" name="Kind" value="@Model.Kind" />
            @if (Model.ProjectId.HasValue)
            {
                <input type="hidden" name="ProjectId" value="@Model.ProjectId" />
            }
            @if (Model.Year.HasValue)
            {
                <input type="hidden" name="Year" value="@Model.Year" />
            }
            @if (!string.IsNullOrWhiteSpace(Model.Q))
            {
                <a asp-page="./Index" asp-route-Source="@Model.Source" asp-route-Kind="@Model.Kind" asp-route-ProjectId="@Model.ProjectId" asp-route-Year="@Model.Year" class="photos-search__clear" aria-label="Clear search">
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </a>
            }
        </form>

        <nav class="photos-segments" aria-label="Media type">
            <a class="@(Model.Kind == "all" ? "is-active" : null)" asp-page="./Index" asp-route-Q="@Model.Q" asp-route-Source="@Model.Source" asp-route-Kind="all" asp-route-ProjectId="@Model.ProjectId" asp-route-Year="@Model.Year">All</a>
            <a class="@(Model.Kind == "photo" ? "is-active" : null)" asp-page="./Index" asp-route-Q="@Model.Q" asp-route-Source="@Model.Source" asp-route-Kind="photo" asp-route-ProjectId="@Model.ProjectId" asp-route-Year="@Model.Year">Photos</a>
            <a class="@(Model.Kind == "video" ? "is-active" : null)" asp-page="./Index" asp-route-Q="@Model.Q" asp-route-Source="@Model.Source" asp-route-Kind="video" asp-route-ProjectId="@Model.ProjectId" asp-route-Year="@Model.Year">Videos</a>
        </nav>
    </section>

    <section class="photos-library__stats" aria-label="Library summary">
        <div><strong>@Model.Stats.Total</strong><span>items</span></div>
        <div><strong>@Model.Stats.Collections</strong><span>collections</span></div>
        <div><strong>@Model.Stats.Photos</strong><span>photos</span></div>
        <div><strong>@Model.Stats.Videos</strong><span>videos</span></div>
    </section>

    @if (hasFilters)
    {
        <div class="photos-active-filters" aria-label="Active filters">
            @if (!string.IsNullOrWhiteSpace(Model.Q))
            {
                <span><i class="bi bi-search"></i>@Model.Q</span>
            }
            @if (Model.Source != "all")
            {
                <span><i class="bi bi-folder2"></i>@Model.Source</span>
            }
            @if (Model.Kind != "all")
            {
                <span><i class="bi bi-images"></i>@Model.Kind</span>
            }
            @if (Model.ProjectId.HasValue)
            {
                var projectName = Model.Projects.FirstOrDefault(project => project.Id == Model.ProjectId.Value)?.Name ?? "Project";
                <span><i class="bi bi-kanban"></i>@projectName</span>
            }
            @if (Model.Year.HasValue)
            {
                <span><i class="bi bi-calendar3"></i>@Model.Year</span>
            }
            <a asp-page="./Index">Clear all</a>
        </div>
    }

    @if (Model.Groups.Count == 0)
    {
        <section class="photos-empty">
            <div class="photos-empty__icon"><i class="bi bi-images" aria-hidden="true"></i></div>
            <h2>No media found</h2>
            <p>@(hasFilters ? "Try removing one or more filters." : "Photos and videos uploaded in supported PRISM modules will appear here automatically.")</p>
            @if (hasFilters)
            {
                <a asp-page="./Index" class="btn btn-outline-primary">Clear filters</a>
            }
        </section>
    }
    else
    {
        <div class="photos-timeline">
            @foreach (var group in Model.Groups)
            {
                <section class="photos-group" aria-labelledby="group-@group.Key.Replace(':', '-')">
                    <header class="photos-group__header">
                        <div>
                            <div class="photos-group__date">@group.Date.ToString("dd MMMM yyyy")</div>
                            <h2 id="group-@group.Key.Replace(':', '-')">@group.Title</h2>
                            <p>@group.Subtitle · @group.Items.Count item@(group.Items.Count == 1 ? string.Empty : "s")</p>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(group.Items[0].SourceUrl))
                        {
                            <a href="@group.Items[0].SourceUrl" class="photos-group__source">Open source <i class="bi bi-arrow-up-right"></i></a>
                        }
                    </header>

                    <div class="photos-grid" role="list">
                        @foreach (var item in group.Items)
                        {
                            <button type="button"
                                    class="photos-tile"
                                    role="listitem"
                                    style="--media-ratio:@item.AspectRatio.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)"
                                    data-media-item
                                    data-kind="@item.Kind.ToString().ToLowerInvariant()"
                                    data-title="@item.Title"
                                    data-caption="@item.Caption"
                                    data-context="@item.ContextTitle"
                                    data-subtitle="@item.ContextSubtitle"
                                    data-date="@item.MediaDate.ToString("dd MMMM yyyy")"
                                    data-source-label="@item.SourceLabel"
                                    data-display-url="@item.DisplayUrl"
                                    data-original-url="@item.OriginalUrl"
                                    data-download-url="@item.DownloadUrl"
                                    data-source-url="@item.SourceUrl"
                                    data-duration="@IndexModel.FormatDuration(item.DurationSeconds)"
                                    data-width="@item.Width"
                                    data-height="@item.Height"
                                    aria-label="Open @item.Title">
                                <img src="@item.ThumbnailUrl" alt="" loading="lazy" decoding="async" />
                                <span class="photos-tile__shade"></span>
                                @if (item.Kind == IndexModel.MediaKind.Video)
                                {
                                    <span class="photos-tile__play"><i class="bi bi-play-fill" aria-hidden="true"></i></span>
                                    <span class="photos-tile__duration">@IndexModel.FormatDuration(item.DurationSeconds)</span>
                                }
                                @if (item.IsCover)
                                {
                                    <span class="photos-tile__cover" title="Cover media"><i class="bi bi-star-fill" aria-hidden="true"></i></span>
                                }
                                <span class="photos-tile__meta">
                                    <strong>@item.Title</strong>
                                    <span>@item.SourceLabel</span>
                                </span>
                            </button>
                        }
                    </div>
                </section>
            }
        </div>

        <nav class="photos-pagination" aria-label="Photos pages">
            @if (Model.HasPreviousPage)
            {
                <a class="btn btn-outline-secondary" asp-page="./Index" asp-route-Q="@Model.Q" asp-route-Source="@Model.Source" asp-route-Kind="@Model.Kind" asp-route-ProjectId="@Model.ProjectId" asp-route-Year="@Model.Year" asp-route-PageNumber="@(Model.CurrentPage - 1)">
                    <i class="bi bi-arrow-left"></i> Previous
                </a>
            }
            <span>Page @Model.CurrentPage</span>
            @if (Model.HasNextPage)
            {
                <a class="btn btn-outline-secondary" asp-page="./Index" asp-route-Q="@Model.Q" asp-route-Source="@Model.Source" asp-route-Kind="@Model.Kind" asp-route-ProjectId="@Model.ProjectId" asp-route-Year="@Model.Year" asp-route-PageNumber="@(Model.CurrentPage + 1)">
                    Next <i class="bi bi-arrow-right"></i>
                </a>
            }
        </nav>
    }
</div>

<div class="offcanvas offcanvas-end photos-filters" tabindex="-1" id="photosFilters" aria-labelledby="photosFiltersTitle">
    <div class="offcanvas-header">
        <div>
            <span class="photos-library__eyebrow">Refine library</span>
            <h2 class="offcanvas-title" id="photosFiltersTitle">Filters</h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <form method="get" class="photos-filter-form">
            <input type="hidden" name="Q" value="@Model.Q" />
            <div>
                <label for="sourceFilter">Source</label>
                <select id="sourceFilter" name="Source" class="form-select">
                    <option value="all" selected="@(Model.Source == "all")">All sources</option>
                    <option value="projects" selected="@(Model.Source == "projects")">Projects</option>
                    <option value="visits" selected="@(Model.Source == "visits")">Visits to SDD</option>
                    <option value="events" selected="@(Model.Source == "events")">Events</option>
                </select>
            </div>
            <div>
                <label for="kindFilter">Media type</label>
                <select id="kindFilter" name="Kind" class="form-select">
                    <option value="all" selected="@(Model.Kind == "all")">Photos and videos</option>
                    <option value="photo" selected="@(Model.Kind == "photo")">Photos only</option>
                    <option value="video" selected="@(Model.Kind == "video")">Videos only</option>
                </select>
            </div>
            <div>
                <label for="projectFilter">Project</label>
                <select id="projectFilter" name="ProjectId" class="form-select">
                    <option value="">All projects</option>
                    @foreach (var project in Model.Projects)
                    {
                        <option value="@project.Id" selected="@(Model.ProjectId == project.Id)">@project.Name</option>
                    }
                </select>
                <small>Selecting a project limits the library to project media.</small>
            </div>
            <div>
                <label for="yearFilter">Year</label>
                <select id="yearFilter" name="Year" class="form-select">
                    <option value="">All years</option>
                    @foreach (var year in Model.Years)
                    {
                        <option value="@year" selected="@(Model.Year == year)">@year</option>
                    }
                </select>
            </div>
            <div class="photos-filter-form__actions">
                <a asp-page="./Index" class="btn btn-outline-secondary">Reset</a>
                <button type="submit" class="btn btn-primary">Apply filters</button>
            </div>
        </form>
    </div>
</div>

<div class="photos-viewer" data-photos-viewer hidden aria-hidden="true">
    <div class="photos-viewer__backdrop" data-viewer-close></div>
    <div class="photos-viewer__dialog" role="dialog" aria-modal="true" aria-labelledby="photosViewerTitle">
        <header class="photos-viewer__header">
            <div class="photos-viewer__heading">
                <span data-viewer-context></span>
                <strong id="photosViewerTitle" data-viewer-title></strong>
            </div>
            <div class="photos-viewer__actions">
                <a href="#" data-viewer-original target="_blank" rel="noopener" title="Open original"><i class="bi bi-arrows-fullscreen"></i></a>
                <a href="#" data-viewer-download title="Download"><i class="bi bi-download"></i></a>
                <button type="button" data-viewer-info aria-pressed="false" title="Show information"><i class="bi bi-info-circle"></i></button>
                <button type="button" data-viewer-close title="Close"><i class="bi bi-x-lg"></i></button>
            </div>
        </header>
        <main class="photos-viewer__stage">
            <button type="button" class="photos-viewer__nav photos-viewer__nav--prev" data-viewer-prev aria-label="Previous item"><i class="bi bi-chevron-left"></i></button>
            <div class="photos-viewer__media" data-viewer-media></div>
            <button type="button" class="photos-viewer__nav photos-viewer__nav--next" data-viewer-next aria-label="Next item"><i class="bi bi-chevron-right"></i></button>
        </main>
        <aside class="photos-viewer__info" data-viewer-info-panel aria-hidden="true">
            <h2>Information</h2>
            <dl>
                <div><dt>Collection</dt><dd data-info-context></dd></div>
                <div><dt>Date</dt><dd data-info-date></dd></div>
                <div><dt>Source</dt><dd data-info-source></dd></div>
                <div data-info-dimensions-row><dt>Dimensions</dt><dd data-info-dimensions></dd></div>
                <div data-info-duration-row><dt>Duration</dt><dd data-info-duration></dd></div>
            </dl>
            <p data-info-caption></p>
            <a href="#" data-info-source-link class="btn btn-outline-light">Open source record <i class="bi bi-arrow-up-right"></i></a>
        </aside>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/photos-library.js" asp-append-version="true"></script>
}
