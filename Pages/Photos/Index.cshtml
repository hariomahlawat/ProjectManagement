@page "/Photos"
@model ProjectManagement.Pages.Photos.IndexModel
@using ProjectManagement.Pages.Photos
@{
    ViewData["Title"] = "Photos";
    ViewData["PageShell"] = "wide";

    var hasFilters = !string.IsNullOrWhiteSpace(Model.Q)
        || Model.Source != "all"
        || Model.Kind != "all"
        || Model.Classification != "all"
        || Model.ProjectId.HasValue
        || Model.Year.HasValue;

    var activeFilterCount = 0;
    if (!string.IsNullOrWhiteSpace(Model.Q)) activeFilterCount++;
    if (Model.Source != "all") activeFilterCount++;
    if (Model.Kind != "all") activeFilterCount++;
    if (Model.Classification != "all") activeFilterCount++;
    if (Model.ProjectId.HasValue) activeFilterCount++;
    if (Model.Year.HasValue) activeFilterCount++;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/photos-library.css" asp-append-version="true" />
}

<div class="photos-library" data-photos-library>
    <header class="photos-library__header">
        <div class="photos-library__title-block">
            <span class="photos-library__eyebrow">Unified organisational media</span>
            <div class="photos-library__title-row">
                <h1>Photos</h1>
            </div>
            <p>Project photographs, videos, visits and events in one library.</p>
        </div>

        <div class="d-flex align-items-center gap-2">
            @if (User.IsInRole("Admin") || User.IsInRole("HoD"))
            {
                <a asp-page="/Photos/People/Index" class="btn btn-outline-secondary">
                    <i class="bi bi-people" aria-hidden="true"></i> People
                </a>
                <a asp-page="/Admin/MediaIntelligence/Index" class="btn btn-outline-secondary">
                    <i class="bi bi-cpu" aria-hidden="true"></i> Intelligence
                </a>
                <a asp-page="/Admin/MediaSources/Index" class="btn btn-outline-secondary">
                    <i class="bi bi-hdd-network" aria-hidden="true"></i> Sources
                </a>
            }
            <button class="btn btn-primary photos-library__filter-toggle"
                    type="button"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#photosFilters"
                    aria-controls="photosFilters">
                <i class="bi bi-sliders2" aria-hidden="true"></i>
                Filters
                @if (activeFilterCount > 0)
                {
                    <span class="photos-library__filter-count" aria-label="@activeFilterCount active filters">@activeFilterCount</span>
                }
            </button>
        </div>
    </header>

    <section class="photos-library__toolbar" aria-label="Media library controls">
        <form method="get" class="photos-search" role="search">
            <i class="bi bi-search" aria-hidden="true"></i>
            <input type="search"
                   name="Q"
                   value="@Model.Q"
                   placeholder="Search photos, videos, projects, visits, events and external folders"
                   autocomplete="off" />
            <input type="hidden" name="Source" value="@Model.Source" />
            <input type="hidden" name="Kind" value="@Model.Kind" />
            <input type="hidden" name="Classification" value="@Model.Classification" />
            @if (Model.ProjectId.HasValue)
            {
                <input type="hidden" name="ProjectId" value="@Model.ProjectId" />
            }
            @if (Model.Year.HasValue)
            {
                <input type="hidden" name="Year" value="@Model.Year" />
            }
            @if (!string.IsNullOrWhiteSpace(Model.Q))
            {
                <a asp-page="./Index"
                   asp-route-Source="@Model.Source"
                   asp-route-Kind="@Model.Kind"
                   asp-route-Classification="@Model.Classification"
                   asp-route-ProjectId="@Model.ProjectId"
                   asp-route-Year="@Model.Year"
                   class="photos-search__clear"
                   aria-label="Clear search">
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </a>
            }
        </form>

        <nav class="photos-segments" aria-label="Media type">
            <a class="@(Model.Kind == "all" ? "is-active" : null)"
               asp-page="./Index"
               asp-route-Q="@Model.Q"
               asp-route-Source="@Model.Source"
               asp-route-Kind="all"
               asp-route-Classification="@Model.Classification"
               asp-route-ProjectId="@Model.ProjectId"
               asp-route-Year="@Model.Year">All</a>
            <a class="@(Model.Kind == "photo" ? "is-active" : null)"
               asp-page="./Index"
               asp-route-Q="@Model.Q"
               asp-route-Source="@Model.Source"
               asp-route-Kind="photo"
               asp-route-Classification="@Model.Classification"
               asp-route-ProjectId="@Model.ProjectId"
               asp-route-Year="@Model.Year">Photos</a>
            <a class="@(Model.Kind == "video" ? "is-active" : null)"
               asp-page="./Index"
               asp-route-Q="@Model.Q"
               asp-route-Source="@Model.Source"
               asp-route-Kind="video"
               asp-route-Classification="@Model.Classification"
               asp-route-ProjectId="@Model.ProjectId"
               asp-route-Year="@Model.Year">Videos</a>
        </nav>
    </section>

    <section class="photos-library__stats" aria-label="Library summary">
        <div><strong>@Model.Stats.Photos</strong><span>photos</span></div>
        <div><strong>@Model.Stats.Videos</strong><span>videos</span></div>
        <div><strong>@Model.Stats.Collections</strong><span>collections</span></div>
    </section>

    @if (!Model.ExternalLibraryAvailable
         && !string.IsNullOrWhiteSpace(Model.ExternalLibraryWarning)
         && (Model.Source == "external" || User.IsInRole("Admin") || User.IsInRole("HoD")))
    {
        <div class="alert alert-warning py-2" role="status">
            <i class="bi bi-hdd-network me-1" aria-hidden="true"></i>
            @Model.ExternalLibraryWarning
        </div>
    }

    @if (hasFilters)
    {
        <div class="photos-active-filters" aria-label="Active filters">
            @if (!string.IsNullOrWhiteSpace(Model.Q))
            {
                <a asp-page="./Index"
                   asp-route-Source="@Model.Source"
                   asp-route-Kind="@Model.Kind"
                   asp-route-Classification="@Model.Classification"
                   asp-route-ProjectId="@Model.ProjectId"
                   asp-route-Year="@Model.Year"
                   class="photos-filter-chip">
                    <i class="bi bi-search" aria-hidden="true"></i>
                    <span>@Model.Q</span>
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </a>
            }
            @if (Model.Source != "all")
            {
                <a asp-page="./Index"
                   asp-route-Q="@Model.Q"
                   asp-route-Source="all"
                   asp-route-Kind="@Model.Kind"
                   asp-route-Classification="@Model.Classification"
                   asp-route-ProjectId="@Model.ProjectId"
                   asp-route-Year="@Model.Year"
                   class="photos-filter-chip">
                    <i class="bi bi-folder2" aria-hidden="true"></i>
                    <span>@(Model.Source == "external" ? "External folders" : System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(Model.Source))</span>
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </a>
            }
            @if (Model.Kind != "all")
            {
                <a asp-page="./Index"
                   asp-route-Q="@Model.Q"
                   asp-route-Source="@Model.Source"
                   asp-route-Kind="all"
                   asp-route-Classification="@Model.Classification"
                   asp-route-ProjectId="@Model.ProjectId"
                   asp-route-Year="@Model.Year"
                   class="photos-filter-chip">
                    <i class="bi bi-images" aria-hidden="true"></i>
                    <span>@Model.Kind</span>
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </a>
            }
            @if (Model.Classification != "all")
            {
                <a asp-page="./Index"
                   asp-route-Q="@Model.Q"
                   asp-route-Source="@Model.Source"
                   asp-route-Kind="@Model.Kind"
                   asp-route-Classification="all"
                   asp-route-ProjectId="@Model.ProjectId"
                   asp-route-Year="@Model.Year"
                   class="photos-filter-chip">
                    <i class="bi bi-stars" aria-hidden="true"></i>
                    <span>@Model.Classification</span>
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </a>
            }
            @if (Model.ProjectId.HasValue)
            {
                var projectName = Model.Projects.FirstOrDefault(project => project.Id == Model.ProjectId.Value)?.Name ?? "Project";
                <a asp-page="./Index"
                   asp-route-Q="@Model.Q"
                   asp-route-Source="@Model.Source"
                   asp-route-Kind="@Model.Kind"
                   asp-route-Classification="@Model.Classification"
                   asp-route-Year="@Model.Year"
                   class="photos-filter-chip">
                    <i class="bi bi-kanban" aria-hidden="true"></i>
                    <span>@projectName</span>
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </a>
            }
            @if (Model.Year.HasValue)
            {
                <a asp-page="./Index"
                   asp-route-Q="@Model.Q"
                   asp-route-Source="@Model.Source"
                   asp-route-Kind="@Model.Kind"
                   asp-route-Classification="@Model.Classification"
                   asp-route-ProjectId="@Model.ProjectId"
                   class="photos-filter-chip">
                    <i class="bi bi-calendar3" aria-hidden="true"></i>
                    <span>@Model.Year</span>
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </a>
            }
            <a asp-page="./Index" class="photos-active-filters__clear">Clear all</a>
        </div>
    }

    @if (Model.Groups.Count == 0)
    {
        <section class="photos-empty">
            <div class="photos-empty__icon"><i class="bi bi-images" aria-hidden="true"></i></div>
            <h2>No media found</h2>
            <p>@(hasFilters ? "Try removing one or more filters." : "Photos and videos uploaded in supported PRISM modules will appear here automatically.")</p>
            @if (hasFilters)
            {
                <a asp-page="./Index" class="btn btn-outline-primary">Clear filters</a>
            }
        </section>
    }
    else
    {
        var collectionIndex = 0;

        <div class="photos-timeline">
            @foreach (var dateGroup in Model.Groups.GroupBy(group => group.Date.Date).OrderByDescending(group => group.Key))
            {
                <section class="photos-day" aria-labelledby="day-@dateGroup.Key.ToString("yyyyMMdd")">
                    @{
                        var dayItemCount = dateGroup.Sum(group => group.Items.Count);
                    }
                    <header class="photos-day__header">
                        <h2 id="day-@dateGroup.Key.ToString("yyyyMMdd")">
                            @dateGroup.Key.ToString("dd MMMM yyyy")
                            <span>· @dayItemCount item@(dayItemCount == 1 ? string.Empty : "s")</span>
                        </h2>
                    </header>

                    <div class="photos-day__collections">
                        @foreach (var group in dateGroup)
                        {
                            collectionIndex++;
                            var groupId = $"photos-group-{collectionIndex}";
                            var itemCountClass = group.Items.Count >= 6 ? "photos-grid--many" : $"photos-grid--count-{group.Items.Count}";
                            if (group.Items.Count == 1)
                            {
                                itemCountClass += group.Items[0].AspectRatio >= 1.15
                                    ? " photos-grid--single-landscape"
                                    : group.Items[0].AspectRatio <= 0.85
                                        ? " photos-grid--single-portrait"
                                        : " photos-grid--single-square";
                            }

                            var sourceLabel = group.Items[0].SourceLabel ?? string.Empty;
                            var sourceAction = group.Items[0].Source == IndexModel.MediaSource.ExternalFolder
                                ? "Open folder collection"
                                : sourceLabel.Contains("project", StringComparison.OrdinalIgnoreCase)
                                ? "Open project"
                                : sourceLabel.Contains("visit", StringComparison.OrdinalIgnoreCase)
                                    ? "Open visit"
                                    : sourceLabel.Contains("event", StringComparison.OrdinalIgnoreCase)
                                        ? "Open event"
                                        : sourceLabel.Contains("activ", StringComparison.OrdinalIgnoreCase)
                                            || sourceLabel.Contains("misc", StringComparison.OrdinalIgnoreCase)
                                                ? "Open activity"
                                                : "Open source";

                            <section class="photos-group" aria-labelledby="@groupId">
                                <header class="photos-group__header">
                                    <div class="photos-group__identity">
                                        <h3 id="@groupId">@group.Title</h3>
                                        <p>@group.Subtitle · @group.Items.Count item@(group.Items.Count == 1 ? string.Empty : "s")</p>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(group.Items[0].SourceUrl))
                                    {
                                        <a href="@group.Items[0].SourceUrl" class="photos-group__source">
                                            @sourceAction <i class="bi bi-arrow-up-right" aria-hidden="true"></i>
                                        </a>
                                    }
                                </header>

                                <div class="photos-grid @itemCountClass" role="list">
                                    @foreach (var item in group.Items)
                                    {
                                        <button type="button"
                                                class="photos-tile"
                                                role="listitem"
                                                style="--media-ratio:@item.AspectRatio.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)"
                                                data-aspect-ratio="@item.AspectRatio.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)"
                                                data-media-item
                                                data-kind="@item.Kind.ToString().ToLowerInvariant()"
                                                data-title="@item.Title"
                                                data-caption="@item.Caption"
                                                data-context="@item.ContextTitle"
                                                data-subtitle="@item.ContextSubtitle"
                                                data-date="@item.MediaDate.ToString("dd MMMM yyyy")"
                                                data-source-label="@item.SourceLabel"
                                                data-display-url="@item.DisplayUrl"
                                                data-original-url="@item.OriginalUrl"
                                                data-download-url="@item.DownloadUrl"
                                                data-source-url="@item.SourceUrl"
                                                data-duration="@IndexModel.FormatDuration(item.DurationSeconds)"
                                                data-width="@item.Width"
                                                data-height="@item.Height"
                                                aria-label="Open @item.Title">
                                            <span class="photos-tile__placeholder" aria-hidden="true"></span>
                                            <img src="@item.ThumbnailUrl" alt="" loading="lazy" decoding="async" data-media-image />
                                            <span class="photos-tile__unavailable" aria-hidden="true">
                                                <i class="bi bi-image" aria-hidden="true"></i>
                                                <strong>Media unavailable</strong>
                                                <small>Source file could not be opened</small>
                                            </span>
                                            <span class="photos-tile__shade"></span>
                                            @if (item.Kind == IndexModel.MediaKind.Video)
                                            {
                                                <span class="photos-tile__play"><i class="bi bi-play-fill" aria-hidden="true"></i></span>
                                                <span class="photos-tile__duration">@IndexModel.FormatDuration(item.DurationSeconds)</span>
                                            }
                                            @if (item.IsCover)
                                            {
                                                <span class="photos-tile__cover" title="Cover media">
                                                    <i class="bi bi-bookmark-star-fill" aria-hidden="true"></i>
                                                    Cover
                                                </span>
                                            }
                                            <span class="photos-tile__meta">
                                                <strong>@item.Title</strong>
                                                <span>@item.SourceLabel</span>
                                            </span>
                                        </button>
                                    }
                                </div>
                            </section>
                        }
                    </div>
                </section>
            }
        </div>

        <nav class="photos-pagination" aria-label="Photos pages">
            @if (Model.HasPreviousPage)
            {
                <a class="btn btn-outline-secondary"
                   asp-page="./Index"
                   asp-route-Q="@Model.Q"
                   asp-route-Source="@Model.Source"
                   asp-route-Kind="@Model.Kind"
                   asp-route-Classification="@Model.Classification"
                   asp-route-ProjectId="@Model.ProjectId"
                   asp-route-Year="@Model.Year"
                   asp-route-PageNumber="@(Model.CurrentPage - 1)">
                    <i class="bi bi-arrow-left" aria-hidden="true"></i> Previous
                </a>
            }
            <span>Page @Model.CurrentPage</span>
            @if (Model.HasNextPage)
            {
                <a class="btn btn-outline-secondary"
                   asp-page="./Index"
                   asp-route-Q="@Model.Q"
                   asp-route-Source="@Model.Source"
                   asp-route-Kind="@Model.Kind"
                   asp-route-Classification="@Model.Classification"
                   asp-route-ProjectId="@Model.ProjectId"
                   asp-route-Year="@Model.Year"
                   asp-route-PageNumber="@(Model.CurrentPage + 1)">
                    Next <i class="bi bi-arrow-right" aria-hidden="true"></i>
                </a>
            }
        </nav>
    }
</div>

<div class="offcanvas offcanvas-end photos-filters" tabindex="-1" id="photosFilters" aria-labelledby="photosFiltersTitle">
    <div class="offcanvas-header">
        <div>
            <span class="photos-library__eyebrow">Refine library</span>
            <h2 class="offcanvas-title" id="photosFiltersTitle">Filters</h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <form method="get" class="photos-filter-form" data-photos-filter-form>
            <input type="hidden" name="Q" value="@Model.Q" />
            <div>
                <label for="sourceFilter">Source</label>
                <select id="sourceFilter" name="Source" class="form-select">
                    <option value="all" selected="@(Model.Source == "all")">All sources</option>
                    <option value="projects" selected="@(Model.Source == "projects")">Projects</option>
                    <option value="visits" selected="@(Model.Source == "visits")">Visits to SDD</option>
                    <option value="events" selected="@(Model.Source == "events")">Events</option>
                    @if (Model.ExternalSourcesEnabled)
                    {
                        <option value="external" selected="@(Model.Source == "external")">External folders</option>
                    }
                </select>
            </div>
            <div>
                <label for="kindFilter">Media type</label>
                <select id="kindFilter" name="Kind" class="form-select">
                    <option value="all" selected="@(Model.Kind == "all")">Photos and videos</option>
                    <option value="photo" selected="@(Model.Kind == "photo")">Photos only</option>
                    <option value="video" selected="@(Model.Kind == "video")">Videos only</option>
                </select>
            </div>
            <div>
                <label for="classificationFilter">Automatic classification</label>
                <select id="classificationFilter" name="Classification" class="form-select">
                    <option value="all" selected="@(Model.Classification == "all")">All classifications</option>
                    <option value="photograph" selected="@(Model.Classification == "photograph")">Photographs</option>
                    <option value="screenshot" selected="@(Model.Classification == "screenshot")">Screenshots</option>
                    <option value="unknown" selected="@(Model.Classification == "unknown")">Not yet classified</option>
                </select>
                <small>Screenshot detection is applied to indexed external-folder images.</small>
            </div>
            <div>
                <label for="projectFilter">Project</label>
                <select id="projectFilter" name="ProjectId" class="form-select">
                    <option value="">All projects</option>
                    @foreach (var project in Model.Projects)
                    {
                        <option value="@project.Id" selected="@(Model.ProjectId == project.Id)">@project.Name</option>
                    }
                </select>
                <small>Selecting a project limits the library to project media.</small>
            </div>
            <div>
                <label for="yearFilter">Year</label>
                <select id="yearFilter" name="Year" class="form-select">
                    <option value="">All years</option>
                    @foreach (var year in Model.Years)
                    {
                        <option value="@year" selected="@(Model.Year == year)">@year</option>
                    }
                </select>
            </div>
            <div class="photos-filter-form__actions">
                <a asp-page="./Index" class="btn btn-outline-secondary">Reset</a>
                <button type="submit" class="btn btn-primary" data-photos-filter-submit disabled>Apply filters</button>
            </div>
        </form>
    </div>
</div>

<div class="photos-viewer" data-photos-viewer hidden aria-hidden="true">
    <div class="photos-viewer__backdrop" data-viewer-close></div>
    <div class="photos-viewer__dialog" role="dialog" aria-modal="true" aria-labelledby="photosViewerTitle">
        <header class="photos-viewer__header">
            <div class="photos-viewer__heading">
                <span data-viewer-context></span>
                <div class="photos-viewer__title-line">
                    <strong id="photosViewerTitle" data-viewer-title></strong>
                    <span class="photos-viewer__position" data-viewer-position></span>
                </div>
            </div>
            <div class="photos-viewer__actions">
                <button type="button" data-viewer-zoom-out title="Zoom out" aria-label="Zoom out"><i class="bi bi-dash-lg"></i></button>
                <button type="button" data-viewer-zoom-reset title="Reset zoom" aria-label="Reset zoom"><span data-viewer-zoom-label>100%</span></button>
                <button type="button" data-viewer-zoom-in title="Zoom in" aria-label="Zoom in"><i class="bi bi-plus-lg"></i></button>
                <a href="#" data-viewer-original target="_blank" rel="noopener" title="Open original" aria-label="Open original"><i class="bi bi-arrows-fullscreen"></i></a>
                <a href="#" data-viewer-download title="Download" aria-label="Download"><i class="bi bi-download"></i></a>
                <button type="button" data-viewer-info aria-pressed="false" title="Show information" aria-label="Show information"><i class="bi bi-info-circle"></i></button>
                <button type="button" data-viewer-close title="Close" aria-label="Close"><i class="bi bi-x-lg"></i></button>
            </div>
        </header>
        <main class="photos-viewer__stage">
            <button type="button" class="photos-viewer__nav photos-viewer__nav--prev" data-viewer-prev aria-label="Previous item"><i class="bi bi-chevron-left"></i></button>
            <div class="photos-viewer__media" data-viewer-media></div>
            <button type="button" class="photos-viewer__nav photos-viewer__nav--next" data-viewer-next aria-label="Next item"><i class="bi bi-chevron-right"></i></button>
        </main>
        <aside class="photos-viewer__info" data-viewer-info-panel aria-hidden="true">
            <h2>Information</h2>
            <dl>
                <div><dt>Collection</dt><dd data-info-context></dd></div>
                <div><dt>Date</dt><dd data-info-date></dd></div>
                <div><dt>Source</dt><dd data-info-source></dd></div>
                <div data-info-dimensions-row><dt>Dimensions</dt><dd data-info-dimensions></dd></div>
                <div data-info-duration-row><dt>Duration</dt><dd data-info-duration></dd></div>
            </dl>
            <p data-info-caption></p>
            <a href="#" data-info-source-link class="btn btn-outline-light">Open source record <i class="bi bi-arrow-up-right"></i></a>
        </aside>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/photos-library.js" asp-append-version="true"></script>
}
