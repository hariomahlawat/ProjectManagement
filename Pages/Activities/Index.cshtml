@page
@model ProjectManagement.Pages.Activities.IndexModel
@using ProjectManagement.Contracts.Activities
@using ProjectManagement.Infrastructure
@{
    ViewData["Title"] = "Institutional Activities";
    ViewData["UseFullWidth"] = true;
    var vm = Model.ViewModel;
    var hasRows = vm is not null && vm.Rows.Count > 0;
    var currentPage = vm?.Page ?? Model.Page;
    var hasActiveFilters = !string.IsNullOrWhiteSpace(Model.Search)
        || Model.FromDate.HasValue
        || Model.ToDate.HasValue
        || Model.ActivityTypeId.HasValue
        || Model.MediaFilter != ActivityMediaFilter.Any;
    string FormatEventDate(DateTimeOffset? value) => value.HasValue
        ? IstClock.ToIst(value.Value).ToString("dd MMM yyyy", System.Globalization.CultureInfo.CurrentCulture)
        : "Date pending";
}

@section Styles { <link rel="stylesheet" href="~/css/activities/index.css" asp-append-version="true" /> }
@section Scripts { <script src="~/js/pages/activities-index.js" asp-append-version="true"></script> }

<div class="container-fluid activities-page" data-module="activities-index">
    <header class="activities-page-header">
        <div class="activities-page-header__copy">
            <span class="activities-page-header__eyebrow">PROJECT OFFICE</span>
            <h1>Institutional Activities</h1>
            <p>Review engagements, visits, demonstrations and their supporting records.</p>
        </div>
        <div class="activities-actions">
            @if (Model.CanCreateActivities)
            {
                <a class="btn btn-primary" asp-page="./Edit"><i class="bi bi-plus-lg" aria-hidden="true"></i> Add activity</a>
            }
            <form method="post" asp-page-handler="Export" class="d-inline" data-activities-export-form>
                @Html.AntiForgeryToken()
                <input type="hidden" name="Search" value="@Model.Search" />
                <input type="hidden" name="FromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
                <input type="hidden" name="ToDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
                <input type="hidden" name="ActivityTypeId" value="@(Model.ActivityTypeId?.ToString())" />
                <input type="hidden" name="MediaFilter" value="@Model.MediaFilter" />
                <input type="hidden" name="SortBy" value="@Model.SortBy" />
                <input type="hidden" name="SortDir" value="@Model.SortDirection" />
                <button type="submit" class="btn btn-outline-secondary" @(Model.CanExportActivities ? null : "disabled")>
                    <i class="bi bi-download" aria-hidden="true"></i> Export
                </button>
            </form>
            @if (Model.IsDeleteApprover)
            {
                <a class="btn btn-outline-secondary" asp-page="./Approvals"><i class="bi bi-trash3" aria-hidden="true"></i> Deletion requests</a>
            }
        </div>
    </header>

    <section class="activities-workbench" aria-label="Activity register controls">
        <form method="get" id="activitiesFilterForm" class="activities-toolbar" aria-label="Activity filters">
            <input type="hidden" name="Page" value="1" />
            <input type="hidden" asp-for="SortDir" />
            <input type="hidden" asp-for="View" />

            <div class="activities-search">
                <i class="bi bi-search" aria-hidden="true"></i>
                <input asp-for="Search" class="form-control" placeholder="Search title, brief or location" autocomplete="off" />
            </div>

            <select asp-for="ActivityTypeId" class="form-select" asp-items="Model.ActivityTypeOptions" aria-label="Activity type" data-activities-autosubmit></select>

            <select asp-for="SortBy" class="form-select" aria-label="Sort activities" data-activities-autosubmit>
                <option value="ScheduledStart">Event date</option>
                <option value="CreatedAt">Recently added</option>
                <option value="Title">Title</option>
                <option value="ActivityType">Activity type</option>
            </select>

            <details class="activities-more-filters" @(Model.FromDate.HasValue || Model.ToDate.HasValue || Model.MediaFilter != ActivityMediaFilter.Any ? "open" : null)>
                <summary><i class="bi bi-sliders" aria-hidden="true"></i> More filters</summary>
                <div class="activities-more-filters__panel">
                    <label>
                        <span>From date</span>
                        <input asp-for="FromDate" class="form-control" type="date" />
                    </label>
                    <label>
                        <span>To date</span>
                        <input asp-for="ToDate" class="form-control" type="date" />
                    </label>
                    <label>
                        <span>Supporting records</span>
                        <select asp-for="MediaFilter" class="form-select">
                            <option value="Any">Any</option>
                            <option value="WithMedia">With supporting records</option>
                            <option value="WithoutMedia">Without supporting records</option>
                            <option value="Photos">With photos</option>
                            <option value="Videos">With videos</option>
                            <option value="Documents">With documents</option>
                        </select>
                    </label>
                    <button type="submit" class="btn btn-primary">Apply filters</button>
                </div>
            </details>

            <div class="activities-view-toggle" role="group" aria-label="Activity view">
                <a asp-page="./Index" asp-all-route-data="Model.BuildRoute(page: 1)" asp-route-View="cards" class="activities-view-toggle__button @(Model.View == "cards" ? "is-active" : null)" aria-label="Timeline view" title="Timeline view"><i class="bi bi-layout-text-window-reverse" aria-hidden="true"></i></a>
                <a asp-page="./Index" asp-all-route-data="Model.BuildRoute(page: 1)" asp-route-View="table" class="activities-view-toggle__button @(Model.View == "table" ? "is-active" : null)" aria-label="Table view" title="Table view"><i class="bi bi-table" aria-hidden="true"></i></a>
            </div>
        </form>

        <div class="activities-resultbar">
            <div>
                <strong>@(vm?.TotalCount ?? 0) activities</strong>
                <span>@(vm?.Summary.WithMedia ?? 0) with supporting records</span>
            </div>
            @if (hasActiveFilters)
            {
                <a asp-page="./Index" class="activities-clear"><i class="bi bi-x-circle" aria-hidden="true"></i> Clear filters</a>
            }
        </div>
    </section>

    @if (!hasRows)
    {
        <div class="activities-empty">
            <div class="activities-empty__icon"><i class="bi bi-calendar2-event" aria-hidden="true"></i></div>
            <h2>No activities found</h2>
            <p>Adjust the filters or add a new institutional activity.</p>
        </div>
    }
    else if (Model.View == "table")
    {
        <section class="activities-table-card" aria-label="Activity table">
            <div class="table-responsive">
                <table class="table align-middle activities-table">
                    <thead>
                        <tr>
                            <th scope="col">Activity</th>
                            <th scope="col">Type</th>
                            <th scope="col">Event date</th>
                            <th scope="col">Supporting records</th>
                            <th scope="col" class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in vm!.Rows)
                    {
                        <tr>
                            <td>
                                <a class="activities-table__title" asp-page="./Details" asp-route-id="@row.Id">@row.Title</a>
                                <div class="activities-table__brief">@(string.IsNullOrWhiteSpace(row.RemarksPreview) ? "No brief recorded." : row.RemarksPreview)</div>
                                @if (!string.IsNullOrWhiteSpace(row.Location))
                                {
                                    <div class="activities-table__meta"><i class="bi bi-geo-alt" aria-hidden="true"></i> @row.Location</div>
                                }
                            </td>
                            <td><span class="activities-type-badge">@row.ActivityType</span></td>
                            <td class="text-nowrap">@FormatEventDate(row.ScheduledStartUtc)</td>
                            <td>
                                @if (row.HasMedia)
                                {
                                    <div class="activities-table__media">
                                        @if (row.PhotoAttachmentCount > 0){<span><i class="bi bi-image" aria-hidden="true"></i> @row.PhotoAttachmentCount</span>}
                                        @if (row.VideoAttachmentCount > 0){<span><i class="bi bi-camera-video" aria-hidden="true"></i> @row.VideoAttachmentCount</span>}
                                        @if (row.DocumentAttachmentCount > 0){<span><i class="bi bi-file-earmark-text" aria-hidden="true"></i> @row.DocumentAttachmentCount</span>}
                                    </div>
                                }
                                else
                                {
                                    <span class="activities-table__none">None</span>
                                }
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-page="./Details" asp-route-id="@row.Id">Open</a>
                                @if (row.CanEdit)
                                {
                                    <a class="btn btn-sm btn-light" asp-page="./Edit" asp-route-id="@row.Id" title="Edit"><i class="bi bi-pencil" aria-hidden="true"></i></a>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
    else
    {
        <div class="activities-timeline">
            @foreach (var group in vm!.Groups)
            {
                var groupId = $"month-{group.Label.Replace(" ", "-")}";
                <section class="activities-month-group" aria-labelledby="@groupId">
                    <h2 id="@groupId">@group.Label</h2>
                    <div class="activities-month-group__items">
                        @foreach (var row in group.Items)
                        {
                            <partial name="_ActivityCard" model="row" />
                        }
                    </div>
                </section>
            }
        </div>
    }

    @if (vm is not null && vm.TotalPages > 1)
    {
        <nav aria-label="Activity pagination" class="activities-pagination">
            <span>Showing @(((currentPage - 1) * vm.PageSize) + 1)–@(Math.Min(currentPage * vm.PageSize, vm.TotalCount)) of @vm.TotalCount</span>
            <ul class="pagination mb-0">
                <li class="page-item @(currentPage <= 1 ? "disabled" : null)"><a class="page-link" asp-page="./Index" asp-all-route-data="Model.BuildRoute(page: Math.Max(1, currentPage - 1))">Previous</a></li>
                <li class="page-item disabled"><span class="page-link">@currentPage / @vm.TotalPages</span></li>
                <li class="page-item @(currentPage >= vm.TotalPages ? "disabled" : null)"><a class="page-link" asp-page="./Index" asp-all-route-data="Model.BuildRoute(page: Math.Min(vm.TotalPages, currentPage + 1))">Next</a></li>
            </ul>
        </nav>
    }
</div>

@await Html.PartialAsync("_DeleteConfirmModal")
