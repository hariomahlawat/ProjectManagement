@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using ProjectManagement.Models
@using ProjectManagement.Services.Navigation.ModuleNav
@using ProjectManagement.Configuration
@using ProjectManagement.Services.Usage
@inject IAntiforgery Antiforgery
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IErpUsageModuleCatalog ErpUsageModules
@inject IOptions<ErpUsageOptions> ErpUsageConfiguration
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#10213f" />
    <meta name="color-scheme" content="light" />
    @{
        var renderAntiforgeryToken = SignInManager.IsSignedIn(User);
        var antiforgeryRequestToken = renderAntiforgeryToken
            ? Antiforgery.GetAndStoreTokens(Context).RequestToken
            : null;
        var pageTitle = ViewData["Title"]?.ToString();
        var documentTitle = string.Equals(pageTitle, "PRISM ERP", StringComparison.OrdinalIgnoreCase)
            ? "PRISM ERP | Simulator Development Division"
            : $"{pageTitle} | PRISM ERP";
    }
    <title>@documentTitle</title>
    @if (!string.IsNullOrWhiteSpace(antiforgeryRequestToken))
    {
        <meta name="csrf-token" content="@antiforgeryRequestToken" />
    }
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/fonts/mulish.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navigation-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" href="~/css/social-media.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/print.css" asp-append-version="true" media="print" />

    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/icons/favicon-32x32.png" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="16x16" href="~/icons/favicon-16x16.png" asp-append-version="true" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/icons/apple-touch-icon.png" asp-append-version="true" />
    <link rel="mask-icon" href="~/icons/safari-pinned-tab.svg" color="#10213f" />
    <link rel="manifest" href="~/site.webmanifest" asp-append-version="true" />
    <meta name="msapplication-TileColor" content="#10213f" />
    <meta name="msapplication-config" content="@Url.Content("~/browserconfig.xml")" />
</head>
<body class="d-flex flex-column min-vh-100">
    @{
        var signedIn = SignInManager.IsSignedIn(User);
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
        var currentArea = ViewContext.RouteData.Values["area"]?.ToString();
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        var hasCurrentPage = !string.IsNullOrWhiteSpace(currentPage);

        var isDashboardPage = string.Equals(currentPage, "/Dashboard/Index", StringComparison.OrdinalIgnoreCase);
        var isWorkspacePage = hasCurrentPage && currentPage!.StartsWith("/Workspace/", StringComparison.OrdinalIgnoreCase);
        var isCalendarPage = hasCurrentPage
            && (currentPage!.StartsWith("/Calendar/", StringComparison.OrdinalIgnoreCase)
                || currentPage.StartsWith("/Celebrations/", StringComparison.OrdinalIgnoreCase));
        var isNotebookPage = hasCurrentPage && currentPage!.StartsWith("/Notebook/", StringComparison.OrdinalIgnoreCase);
        var isPhotosPage = hasCurrentPage && currentPage!.StartsWith("/Photos/", StringComparison.OrdinalIgnoreCase);
        var isDocumentRepositoryPage = string.Equals(currentArea, "DocumentRepository", StringComparison.OrdinalIgnoreCase);
        var isFfcPage = string.Equals(currentArea, "ProjectOfficeReports", StringComparison.OrdinalIgnoreCase)
            && hasCurrentPage
            && currentPage!.StartsWith("/FFC", StringComparison.OrdinalIgnoreCase);

        var isAdminModulePage = signedIn && AdminNavigationCatalog.IsInScope(
            currentArea,
            currentPage,
            currentController,
            currentAction,
            Context.Request.Query);
        var isUsagePage = string.Equals(currentPage, "/Usage/Index", StringComparison.OrdinalIgnoreCase);
        var useAdminModuleShell = isAdminModulePage && (!isUsagePage || User.IsInRole(RoleNames.Admin));
        var usageModuleKey = signedIn ? ErpUsageModules.ResolvePath(Context.Request.Path) : null;
        var isCalendarPrimaryPage = isCalendarPage && !useAdminModuleShell;

        // Keep the Projects primary tab active throughout the complete module,
        // not only on the Ongoing page. Admin-area routes with similar page names
        // are deliberately excluded.
        var isProjectsModulePage = !isAdminModulePage
            && string.IsNullOrWhiteSpace(currentArea)
            && hasCurrentPage
            && (currentPage!.StartsWith("/Projects/", StringComparison.OrdinalIgnoreCase)
                || currentPage.StartsWith("/Process/", StringComparison.OrdinalIgnoreCase)
                || currentPage.StartsWith("/Analytics/", StringComparison.OrdinalIgnoreCase)
                || currentPage.StartsWith("/IndustryPartners/", StringComparison.OrdinalIgnoreCase)
                || currentPage.StartsWith("/Approvals/Pending/", StringComparison.OrdinalIgnoreCase));
        var useFullWidth = (ViewData["UseFullWidth"] as bool?) == true;
        var requestedShell = ViewData["PageShell"]?.ToString()?.Trim().ToLowerInvariant();
        var shellVariant = requestedShell switch
        {
            "focused" => "focused",
            "standard" => "standard",
            "wide" => "wide",
            "analytics" => "analytics",
            "landing" => "landing",
            _ when !signedIn && string.Equals(currentPage, "/Index", StringComparison.OrdinalIgnoreCase) => "landing",
            _ when string.Equals(currentPage, "/Dashboard/Index", StringComparison.OrdinalIgnoreCase) => "wide",
            _ when string.Equals(currentPage, "/Analytics/Index", StringComparison.OrdinalIgnoreCase) => "analytics",
            _ when string.Equals(currentPage, "/ActionTasks/Index", StringComparison.OrdinalIgnoreCase) => "wide",
            _ when string.Equals(currentPage, "/Workspace/Index", StringComparison.OrdinalIgnoreCase) => "wide",
            _ when string.Equals(currentPage, "/Usage/Index", StringComparison.OrdinalIgnoreCase) => "analytics",
            _ when string.Equals(currentPage, "/Projects/Ongoing/Index", StringComparison.OrdinalIgnoreCase) => "analytics",
            _ when isPhotosPage => "wide",
            _ when string.Equals(currentArea, "DocumentRepository", StringComparison.OrdinalIgnoreCase) => "analytics",
            _ when useFullWidth => "wide",
            _ => "standard"
        };
        var mainContainerClass = $"pm-page-shell pm-page-shell--{shellVariant}";
        var breadcrumbModel = ViewData["Breadcrumb"] as BreadcrumbModel;
        var publicHeaderMode = ViewData["PublicHeaderMode"]?.ToString();
        var isPublicAuthPage = !signedIn && string.Equals(publicHeaderMode, "Auth", StringComparison.OrdinalIgnoreCase);
    }
    @if (signedIn && !string.IsNullOrWhiteSpace(usageModuleKey))
    {
        <div hidden data-erp-usage-context
             data-erp-usage-module="@usageModuleKey"
             data-erp-usage-heartbeat-seconds="@ErpUsageConfiguration.Value.HeartbeatIntervalSeconds"
             data-erp-usage-idle-minutes="@ErpUsageConfiguration.Value.InteractiveIdleMinutes"></div>
    }

    <!-- ===========================
         HEADER / TOP BAR
         =========================== -->
    @if (signedIn)
    {
        <header class="pm-topbar">
            <div class="pm-chrome-shell pm-topbar__inner">
                <div class="pm-topbar__left">
                    @await Component.InvokeAsync("NavigationDrawer")

                    <a class="pm-brand" asp-area="" asp-page="/Index" aria-label="PRISM ERP Home">
                        <img src="~/img/logos/artrac.png"
                             class="pm-nav-logo"
                             alt="ARTRAC crest" />
                        <span class="pm-brand__text">PRISM ERP</span>
                    </a>

                    <nav class="pm-top-tabs" aria-label="Primary navigation">
                        <a asp-page="/Dashboard/Index"
                           class="pm-top-tabs__item @(isDashboardPage ? "is-active" : string.Empty)"
                           aria-current="@(isDashboardPage ? "page" : null)">
                            Dashboard
                        </a>
                        <a asp-page="/Workspace/Index"
                           class="pm-top-tabs__item @(isWorkspacePage ? "is-active" : string.Empty)"
                           aria-current="@(isWorkspacePage ? "page" : null)">
                            My Workspace
                        </a>
                        <a asp-page="/Calendar/Index"
                           class="pm-top-tabs__item @(isCalendarPrimaryPage ? "is-active" : string.Empty)"
                           aria-current="@(isCalendarPrimaryPage ? "page" : null)">
                            Calendar
                        </a>
                        <a asp-page="/Notebook/Index"
                           class="pm-top-tabs__item @(isNotebookPage ? "is-active" : string.Empty)"
                           aria-current="@(isNotebookPage ? "page" : null)">
                            Notebook
                        </a>
                        <a asp-page="/Photos/Index"
                           class="pm-top-tabs__item @(isPhotosPage ? "is-active" : string.Empty)"
                           aria-current="@(isPhotosPage ? "page" : null)">
                            Photos
                        </a>
                        <a asp-page="/Projects/Ongoing/Index"
                           class="pm-top-tabs__item @(isProjectsModulePage ? "is-active" : string.Empty)"
                           aria-current="@(isProjectsModulePage ? "page" : null)">
                            Projects
                        </a>
                        <a asp-area="ProjectOfficeReports"
                           asp-page="/FFC/MapTableDetailed"
                           class="pm-top-tabs__item @(isFfcPage ? "is-active" : string.Empty)"
                           aria-current="@(isFfcPage ? "page" : null)">
                            FFC
                        </a>
                        <a asp-area="DocumentRepository"
                           asp-page="/Documents/Index"
                           class="pm-top-tabs__item @(isDocumentRepositoryPage ? "is-active" : string.Empty)"
                           aria-current="@(isDocumentRepositoryPage ? "page" : null)">
                            <span>Documents</span>
                            @await Component.InvokeAsync("AotsUnreadBadge", new { variant = "topnav" })
                        </a>
                    </nav>
                </div>

                <div class="pm-topbar__right">
                    <form method="get"
                          asp-area="Common"
                          asp-page="/Search/Index"
                          class="pm-top-search d-none d-md-flex"
                          role="search"
                          data-global-search>
                        <label class="visually-hidden" for="pmGlobalSearch">Search PRISM</label>
                        <i class="bi bi-search pm-top-search__icon" aria-hidden="true"></i>
                        <input type="search"
                               id="pmGlobalSearch"
                               name="q"
                               class="pm-top-search__input"
                               placeholder="Search PRISM"
                               autocomplete="off"
                               aria-keyshortcuts="Control+K Meta+K" />
                        <kbd class="pm-top-search__shortcut" aria-hidden="true">Ctrl K</kbd>
                    </form>

                    <a asp-area="Common"
                       asp-page="/Search/Index"
                       class="pm-topbar__icon-button d-inline-flex d-md-none"
                       aria-label="Search PRISM"
                       title="Search PRISM">
                        <i class="bi bi-search" aria-hidden="true"></i>
                    </a>

                    @await Component.InvokeAsync("NotificationBell")
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </header>
    }
    else
    {
        <header class="public-topbar">
            <div class="public-topbar__inner">
                <a class="public-brand" asp-area="" asp-page="/Index" aria-label="PRISM ERP home">
                    <img src="~/img/logos/artrac.png" alt="ARTRAC crest" />
                    <span>PRISM ERP</span>
                </a>
                @if (isPublicAuthPage)
                {
                    <nav class="public-topbar__nav" aria-label="Authentication navigation">
                        <a class="public-topbar__home" asp-area="" asp-page="/Index">
                            <i class="bi bi-arrow-left" aria-hidden="true"></i>
                            Back to home
                        </a>
                    </nav>
                }
                else
                {
                    <nav class="public-topbar__nav" aria-label="Public navigation">
                        <a class="public-topbar__desktop-link" href="/#capabilities">Capabilities</a>
                        <a class="public-topbar__desktop-link" href="/#roles-title">Role-based experience</a>
                        <a class="public-topbar__signin" asp-area="Identity" asp-page="/Account/Login">Sign in</a>
                        <div class="dropdown public-topbar__mobile-menu">
                            <button class="public-topbar__menu-button"
                                    type="button"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    aria-label="Open public navigation">
                                <i class="bi bi-list" aria-hidden="true"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end public-topbar__menu">
                                <li><a class="dropdown-item" href="/#capabilities">Capabilities</a></li>
                                <li><a class="dropdown-item" href="/#roles-title">Role-based experience</a></li>
                            </ul>
                        </div>
                    </nav>
                }
            </div>
        </header>
    }

    <!-- ===========================
         MODULE SUB-NAV
         =========================== -->
    @if (signedIn && !useAdminModuleShell && !isUsagePage)
    {
        <div class="pm-module-subnav-wrap">
            <div class="pm-chrome-shell">
                @await Component.InvokeAsync("ModuleSubNav")
            </div>
        </div>
    }

    <!-- ===========================
         MAIN CONTENT
         =========================== -->
    @if (useAdminModuleShell)
    {
        <main role="main" class="pm-admin-main">
            <div class="admin-shell">
                @await Component.InvokeAsync("AdminSidebar")

                <section class="admin-shell__workspace" aria-label="Administration workspace">
                    <div class="admin-shell__content">
                        @await Html.PartialAsync("_Toasts")
                        @if (breadcrumbModel is not null)
                        {
                            @await Html.PartialAsync("~/Views/Shared/_Breadcrumbs.cshtml", breadcrumbModel)
                        }
                        @RenderBody()
                    </div>
                </section>
            </div>
        </main>
    }
    else
    {
        <main role="main" class="pb-2@(useFullWidth ? " analytics-main" : string.Empty)">
            <div class="@mainContainerClass">
                @await Html.PartialAsync("_Toasts")
                @if (breadcrumbModel is not null)
                {
                    @await Html.PartialAsync("~/Views/Shared/_Breadcrumbs.cshtml", breadcrumbModel)
                }
                @RenderBody()
            </div>
        </main>
    }

    <!-- ===========================
         FOOTER
         =========================== -->
    @if (signedIn)
    {
        <footer class="pm-footer border-top py-2 mt-auto">
            <div class="pm-chrome-shell">
                <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-2 small">
                    <div class="text-muted">© @DateTime.UtcNow.Year — PRISM ERP</div>
                    <div class="d-flex align-items-center gap-2 fw-semibold">
                        <img src="~/img/logos/sdd.png" alt="Simulator Development Division logo" class="pm-util-logo-compact" />
                        <span>Simulator Development Division</span>
                    </div>
                    <div>
                        <a asp-page="/Developer" class="text-decoration-none">Designed and developed by @@hariomahlawat</a>
                    </div>
                </div>
            </div>
        </footer>
    }
    else
    {
        <footer class="public-footer">
            <div class="public-footer__inner">
                <span>© @DateTime.UtcNow.Year PRISM ERP</span>
                <span>Simulator Development Division</span>
                <a asp-area="Identity" asp-page="/Account/Login">Authorised access only</a>
            </div>
        </footer>
    }

    <!-- ===========================
         SHARED MODALS
         =========================== -->
    <!-- Shared small confirm modal (reused for complete/delete/etc.) -->
    <div class="modal fade" id="appConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-body" id="appConfirmText">Are you sure?</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">No</button>
                    <button type="button" class="btn btn-sm btn-primary" id="appConfirmYes">Yes</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===========================
         SCRIPTS
         =========================== -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/microsoft/signalr/signalr.min.js" asp-append-version="true"></script>
    <script src="~/js/theme-colors.js" asp-append-version="true"></script>
    <script type="module" src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/admin/admin-shell.js" asp-append-version="true" defer></script>
    @if (signedIn)
    {
        <script src="~/js/core/erp-usage-heartbeat.js" asp-append-version="true" defer></script>
    }
    <script src="~/js/comments.js" asp-append-version="true" defer></script>
    <script src="~/js/notifications.js" asp-append-version="true" defer></script>
    <script src="~/js/project-media-tabs.js" asp-append-version="true" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/init.js" data-todo-src="@Url.Content("~/js/todo.js")" asp-append-version="true" defer></script>
</body>
</html>
