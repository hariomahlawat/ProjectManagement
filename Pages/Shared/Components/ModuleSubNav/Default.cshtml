@model ProjectManagement.ViewComponents.ModuleSubNavViewModel

@if ((Model.Tabs?.Any() ?? false) || (Model.Actions?.Any() ?? false))
{
    <!-- ===========================
         MODULE SUB-NAV
         =========================== -->
    <div class="pm-module-subnav-row">
        <!-- Keeps module tabs aligned with the primary navigation start. -->
        <div class="pm-module-subnav-spacer" aria-hidden="true">
            <span class="pm-drawer-toggle">
                <span class="navbar-toggler pm-drawer-toggle__button">
                    <span class="pm-drawer-toggle__icon" aria-hidden="true"><i class="bi bi-list"></i></span>
                    <span class="pm-drawer-toggle__label">Menu</span>
                </span>
            </span>

            <span class="pm-brand">
                <img src="~/img/logos/artrac.png" class="pm-nav-logo" alt="" />
                <span class="pm-brand__text">PRISM ERP</span>
            </span>
        </div>

        <div class="pm-module-subnav__content">
            @if (Model.Tabs?.Any() ?? false)
            {
                <nav class="pm-module-subnav" aria-label="@Model.AriaLabel">
                    @foreach (var tab in Model.Tabs)
                    {
                        var classes = "pm-module-subnav__item" + (tab.IsActive ? " is-active" : string.Empty);

                        if (!string.IsNullOrEmpty(tab.Url))
                        {
                            <a class="@classes"
                               href="@tab.Url"
                               aria-current="@(tab.IsActive ? "page" : null)">
                                @if (!string.IsNullOrEmpty(tab.Icon))
                                {
                                    <i class="bi @tab.Icon pm-module-subnav__icon" aria-hidden="true"></i>
                                }
                                <span>@tab.Text</span>

                                @if (!string.IsNullOrEmpty(tab.BadgeViewComponentName))
                                {
                                    <span class="pm-module-subnav__badge">
                                        @await Component.InvokeAsync(tab.BadgeViewComponentName!, tab.BadgeViewComponentParameters ?? new { })
                                    </span>
                                }
                            </a>
                        }
                        else
                        {
                            <span class="@classes">
                                @if (!string.IsNullOrEmpty(tab.Icon))
                                {
                                    <i class="bi @tab.Icon pm-module-subnav__icon" aria-hidden="true"></i>
                                }
                                <span>@tab.Text</span>
                            </span>
                        }
                    }
                </nav>
            }

            @if (Model.OverflowTabs?.Any() ?? false)
            {
                <div class="dropdown pm-module-subnav__dropdown pm-subnav__overflow">
                    <button class="pm-module-subnav__item dropdown-toggle@(Model.IsOverflowActive ? " is-active" : string.Empty)"
                            type="button"
                            data-bs-toggle="dropdown"
                            aria-expanded="false">
                        <i class="bi bi-three-dots" aria-hidden="true"></i>
                        <span>@Model.OverflowLabel</span>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end pm-module-subnav__menu">
                        @foreach (var overflowTab in Model.OverflowTabs)
                        {
                            <li>
                                @if (!string.IsNullOrEmpty(overflowTab.Url))
                                {
                                    <a class="dropdown-item d-flex align-items-center gap-2@(overflowTab.IsActive ? " active" : string.Empty)"
                                       href="@overflowTab.Url"
                                       aria-current="@(overflowTab.IsActive ? "page" : null)">
                                        @if (!string.IsNullOrEmpty(overflowTab.Icon))
                                        {
                                            <i class="bi @overflowTab.Icon" aria-hidden="true"></i>
                                        }
                                        <span>@overflowTab.Text</span>

                                        @if (!string.IsNullOrEmpty(overflowTab.BadgeViewComponentName))
                                        {
                                            <span class="ms-auto">
                                                @await Component.InvokeAsync(
                                                    overflowTab.BadgeViewComponentName!,
                                                    overflowTab.BadgeViewComponentParameters ?? new { })
                                            </span>
                                        }
                                    </a>
                                }
                                else
                                {
                                    <span class="dropdown-item d-flex align-items-center gap-2@(overflowTab.IsActive ? " active" : string.Empty)">
                                        @if (!string.IsNullOrEmpty(overflowTab.Icon))
                                        {
                                            <i class="bi @overflowTab.Icon" aria-hidden="true"></i>
                                        }
                                        <span>@overflowTab.Text</span>
                                    </span>
                                }
                            </li>
                        }
                    </ul>
                </div>
            }

            @if (Model.Actions?.Any() ?? false)
            {
                <div class="pm-module-subnav__actions" aria-label="Module actions">
                    @foreach (var action in Model.Actions)
                    {
                        if (!string.IsNullOrEmpty(action.Url))
                        {
                            <a class="pm-module-subnav__action@(action.IsActive ? " is-active" : string.Empty)"
                               href="@action.Url"
                               aria-current="@(action.IsActive ? "page" : null)">
                                @if (!string.IsNullOrEmpty(action.Icon))
                                {
                                    <i class="bi @action.Icon" aria-hidden="true"></i>
                                }
                                <span>@action.Text</span>
                            </a>
                        }
                    }
                </div>
            }
        </div>
    </div>
}
