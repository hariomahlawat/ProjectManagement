@model ProjectManagement.ViewModels.ProjectTimelinePanelVm
@using System.Globalization
@using ProjectManagement.Models.Execution
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var timeline = Model.Timeline;
    var access = Model.Access;
    var isHod = access.CanApplyStageChangeDirectly;
    var canRequestChange = access.CanRequestStageChange;
    var canEditTimeline = access.CanEditTimeline;
    var futureSectionStarted = false;
}
@functions {
    string D(DateOnly? d) => d.HasValue ? d.Value.ToString("dd MMM yyyy", CultureInfo.CurrentCulture) : "—";

    // SECTION: Stage pill rendering helpers
    string StatusPillClass(StageStatus s) => s switch
    {
        StageStatus.Completed  => "pm-pill pm-pill-success",
        StageStatus.InProgress => "pm-pill pm-pill-primary",
        StageStatus.Blocked    => "pm-pill pm-pill-warning",
        StageStatus.Skipped    => "pm-pill pm-pill-muted",
        _                      => "pm-pill pm-pill-muted"
    };

    string StatusLabel(StageStatus status) => status switch
    {
        StageStatus.Completed  => "Completed",
        StageStatus.InProgress => "In progress",
        StageStatus.Blocked    => "Blocked",
        StageStatus.Skipped    => "Skipped",
        StageStatus.NotStarted => "Not started",
        _                      => "Unknown"
    };

    (string text, string description, string cssClass) VarianceToken(string name, int value)
    {
        var magnitude = Math.Abs(value);

        var cssClass = value < 0
            ? "pm-chip pm-chip-early"
            : value > 0
                ? "pm-chip pm-chip-late"
                : "pm-chip pm-chip-on-time";

        if (value == 0)
        {
            return ($"{name} on time", $"{name} on time", cssClass);
        }

        var text = value > 0
            ? $"{name} +{magnitude}d"
            : $"{name} −{magnitude}d";

        var description = value > 0
            ? $"{name} {magnitude} day{(magnitude == 1 ? string.Empty : "s")} late"
            : $"{name} {magnitude} day{(magnitude == 1 ? string.Empty : "s")} early";

        return (text, description, cssClass);
    }
}
<div class="pm-timeline-grid">
  <div class="pm-rail" aria-hidden="true">
    <div class="pm-rail-line"></div>
  </div>
  <div class="pm-items">
    @foreach (var s in timeline.Items.OrderBy(i => i.SortOrder))
    {
      if (!futureSectionStarted && s.Status == StageStatus.NotStarted)
      {
        futureSectionStarted = true;
        <div class="pm-future-stage-heading" role="separator" aria-label="Future stages">
          <span>Future stages</span>
          <small>Planned dates may be added when available.</small>
        </div>
      }

      var itemClass = s.Status switch
      {
        StageStatus.Completed  => "pm-item is-complete",
        StageStatus.InProgress => "pm-item is-active",
        _                      => "pm-item"
      };
      <div id="timeline-stage-@s.Code" class="@itemClass" data-stage-row="@s.Code" data-timeline-stage data-stage-status-value="@s.Status" data-requires-backfill="@(s.RequiresBackfill ? "true" : "false")">
        <div class="pm-item-card" data-timeline-stage-card>
          <div class="pm-item-header">
            <div class="pm-item-heading">
              <span class="@StatusPillClass(s.Status)"
                    data-stage-status
                    data-stage-status-pill
                    aria-label="Stage status: @StatusLabel(s.Status)">
                @StatusLabel(s.Status)
              </span>
              <button type="button"
                      class="pm-pill pm-pill-warning@(s.RequiresBackfill ? string.Empty : " d-none")"
                      data-action="open-backfill"
                      data-stage-backfill-pill
                      aria-label="Backfill required for @s.Name">
                Backfill required
              </button>
              @if (s.ShowPlanWarning)
              {
                @if (canEditTimeline)
                {
                  <button type="button"
                          class="badge border-0 bg-warning-subtle text-warning-emphasis pm-stage-plan-action"
                          data-bs-toggle="offcanvas"
                          data-bs-target="#offcanvasPlanEdit"
                          aria-controls="offcanvasPlanEdit"
                          aria-label="Set the planned completion date for @s.Name">
                    Planned completion missing
                  </button>
                }
                else
                {
                  <span class="badge bg-warning-subtle text-warning-emphasis"
                        aria-label="Planned completion date is not set for the current stage">
                    Planned completion missing
                  </span>
                }
              }
              <span class="pm-item-title text-truncate"
                    title="@s.Name"
                    data-stage-name>
                @s.Name
              </span>
              @if (s.Status == StageStatus.Completed)
              {
                var completionText = s.CompletedOn.HasValue ? D(s.CompletedOn) : "Completion date required";
                var durationText = s.ActualDurationDays.HasValue
                    ? $"{s.ActualDurationDays.Value} day{(s.ActualDurationDays.Value == 1 ? string.Empty : "s")}" 
                    : "Duration unavailable";
                <span class="pm-item-compact-meta" aria-label="Completed @completionText; duration @durationText">
                  <span><i class="bi bi-calendar-check" aria-hidden="true"></i> @completionText</span>
                  <span class="pm-item-compact-meta__separator" aria-hidden="true">·</span>
                  <span><i class="bi bi-stopwatch" aria-hidden="true"></i> @durationText</span>
                </span>
                <button type="button"
                        class="pm-item-expand-toggle"
                        data-timeline-toggle
                        aria-expanded="false"
                        aria-label="Expand details for @s.Name">
                  <i class="bi bi-chevron-down" aria-hidden="true"></i>
                </button>
              }
            </div>
            <div class="pm-item-actions">
              <div class="dropdown">
                <button class="btn pm-kebab" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Stage actions for @s.Name">
                  <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end" data-stage-action-menu>
                  @if (isHod && s.HasPendingRequest && s.PendingRequestId is int requestId)
                  {
                    <li>
                      <button class="dropdown-item"
                              type="button"
                              data-stage-decision-inline
                              data-stage="@s.Code"
                              data-stage-name="@s.Name"
                              data-request-id="@requestId"
                              data-decision="Approve">
                        Approve
                      </button>
                    </li>
                    <li>
                      <button class="dropdown-item"
                              type="button"
                              data-stage-decision-inline
                              data-stage="@s.Code"
                              data-stage-name="@s.Name"
                              data-request-id="@requestId"
                              data-decision="Reject">
                        Reject
                      </button>
                    </li>
                    <li><hr class="dropdown-divider" /></li>
                  }
                  @if (isHod)
                  {
                    <li class="dropdown-header">Mark as…</li>
                    <li>
                      <button class="dropdown-item"
                              type="button"
                              data-direct-apply
                              data-project="@timeline.ProjectId"
                              data-stage="@s.Code"
                              data-stage-name="@s.Name"
                              data-status="InProgress"
                              data-default-date="@s.ActualStart?.ToString("yyyy-MM-dd")">
                        In progress
                      </button>
                    </li>
                    <li>
                      <button class="dropdown-item"
                              type="button"
                              data-direct-apply
                              data-project="@timeline.ProjectId"
                              data-stage="@s.Code"
                              data-stage-name="@s.Name"
                              data-status="Completed"
                              data-default-date="@s.CompletedOn?.ToString("yyyy-MM-dd")">
                        Completed
                      </button>
                    </li>
                    <li>
                      <button class="dropdown-item"
                              type="button"
                              data-direct-apply
                              data-project="@timeline.ProjectId"
                              data-stage="@s.Code"
                              data-stage-name="@s.Name"
                              data-status="Blocked">
                        Blocked
                      </button>
                    </li>
                    <li>
                      <button class="dropdown-item"
                              type="button"
                              data-direct-apply
                              data-project="@timeline.ProjectId"
                              data-stage="@s.Code"
                              data-stage-name="@s.Name"
                              data-status="Skipped">
                        Skipped
                      </button>
                    </li>
                    <li>
                      <button class="dropdown-item"
                              type="button"
                              data-direct-apply
                              data-project="@timeline.ProjectId"
                              data-stage="@s.Code"
                              data-stage-name="@s.Name"
                              data-status="Reopen">
                        Reopen
                      </button>
                    </li>
                    @if (canRequestChange)
                    {
                      <li><hr class="dropdown-divider" /></li>
                    }
                  }
                  @if (canRequestChange)
                  {
                    <li>
                      <button class="dropdown-item"
                              type="button"
                              data-stage-request
                              data-stage-request-button
                              data-project="@timeline.ProjectId"
                              data-stage="@s.Code"
                              data-stage-name="@s.Name"
                              data-current-status="@s.Status"
                              @(s.HasPendingRequest ? "disabled" : null)>
                        Request change
                      </button>
                    </li>
                  }
                </ul>
              </div>
            </div>
          </div>
          <div class="pm-item-flags">
            @if (s.IsAutoCompleted)
            {
              <span class="pm-flag" title="Auto-completed when a later stage finished." data-stage-autocomplete>Inferred</span>
            }
            <span class="pm-flag pm-flag-danger@(s.IsOverdue ? string.Empty : " d-none")" data-stage-overdue>Overdue</span>
            <span class="pm-flag pm-flag-warning@(s.HasPendingRequest ? string.Empty : " d-none")" data-stage-pending>
              @if (s.HasPendingRequest)
              {
                  <text>Pending: @s.PendingStatus</text>
                  @if (s.PendingDate.HasValue)
                  {
                      <text> · @D(s.PendingDate)</text>
                  }
              }
            </span>
          </div>
          @if (s.Status == StageStatus.Completed)
          {
            <div class="pm-stage-outcome">
              <div class="pm-stage-outcome__primary">
                <span class="pm-date-label">Completed on</span>
                <strong data-stage-completed>@D(s.CompletedOn)</strong>
              </div>
              @if (s.ActualDurationDays.HasValue)
              {
                <div class="pm-stage-outcome__metric">
                  <span class="pm-date-label">Time taken</span>
                  <strong data-stage-duration>@($"{s.ActualDurationDays.Value} day{(s.ActualDurationDays.Value == 1 ? string.Empty : "s")}")</strong>
                </div>
              }
              @if (s.EffectiveActualStart.HasValue)
              {
                <div class="pm-stage-outcome__metric">
                  <span class="pm-date-label">Actual start</span>
                  <strong data-stage-actual-start>@D(s.EffectiveActualStart)</strong>
                  @if (s.IsActualStartInferred)
                  {
                    <span class="small text-muted">Inferred from preceding completion</span>
                  }
                </div>
              }
              @if (s.PlannedEnd.HasValue)
              {
                <div class="pm-stage-outcome__metric">
                  <span class="pm-date-label">Planned completion</span>
                  <strong>@D(s.PlannedEnd)</strong>
                </div>
              }
            </div>
            @if (s.ShowFinishVariance && s.FinishVarianceDays is int finishVar)
            {
              var variance = VarianceToken("Finish", finishVar);
              <div class="pm-item-variance">
                <span class="@variance.cssClass" aria-label="@variance.description" title="@variance.description">@variance.text</span>
              </div>
            }
          }
          else if (s.Status == StageStatus.InProgress)
          {
            <div class="pm-current-stage-dates">
              <div class="pm-current-stage-dates__item">
                <span class="pm-date-label">Started on</span>
                <strong>@D(s.ActualStart)</strong>
                @if (s.NeedsStart)
                {
                  <span class="small text-warning-emphasis">Actual start required</span>
                }
              </div>
              <div class="pm-current-stage-dates__item @(s.NeedsPlannedCompletion ? "is-attention" : string.Empty)">
                <span class="pm-date-label">Planned completion</span>
                <strong>@D(s.PlannedEnd)</strong>
                @if (s.DaysRemaining is int remaining)
                {
                  <span class="small @(remaining < 0 ? "text-danger" : remaining <= 7 ? "text-warning-emphasis" : "text-muted")">
                    @(remaining < 0 ? $"{Math.Abs(remaining)} day{(Math.Abs(remaining) == 1 ? string.Empty : "s")} overdue" : remaining == 0 ? "Due today" : $"{remaining} day{(remaining == 1 ? string.Empty : "s")} remaining")
                  </span>
                }
                else if (canEditTimeline)
                {
                  <button type="button"
                          class="btn btn-sm btn-link p-0 text-warning-emphasis fw-semibold pm-stage-plan-link"
                          data-bs-toggle="offcanvas"
                          data-bs-target="#offcanvasPlanEdit"
                          aria-controls="offcanvasPlanEdit">
                    Set planned completion
                  </button>
                }
                else
                {
                  <span class="small text-warning-emphasis">Planned completion not set</span>
                }
              </div>
            </div>
          }
          else if (s.Status == StageStatus.NotStarted && s.HasPlanDates)
          {
            <div class="pm-future-stage-plan">
              <i class="bi bi-calendar3" aria-hidden="true"></i>
              <span>Planned @D(s.PlannedStart) – @D(s.PlannedEnd)</span>
            </div>
          }
        </div>
      </div>
    }
  </div>
</div>
