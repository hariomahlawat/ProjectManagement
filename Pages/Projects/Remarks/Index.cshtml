@page "{projectId:int}"
@model ProjectManagement.Pages.Projects.Remarks.IndexModel
@using System
@using System.Text.Json

@{
    var projectName = Model.Project?.Name ?? "Project";
    ViewData["Title"] = $"Remarks - {projectName}";
    ViewData["UseFullWidth"] = true;
    var remarksConfigJson = JsonSerializer.Serialize(Model.RemarksPanel, new JsonSerializerOptions(JsonSerializerDefaults.Web));
}

<div class="project-remarks-page">
    <nav aria-label="breadcrumb" class="project-remarks-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-page="/Projects/Index">Projects</a></li>
            <li class="breadcrumb-item"><a asp-page="/Projects/Overview" asp-route-id="@Model.Project!.Id">@projectName</a></li>
            <li class="breadcrumb-item active" aria-current="page">Remarks</li>
        </ol>
    </nav>

    <header class="project-remarks-hero">
        <div class="project-remarks-hero__identity">
            <span class="project-remarks-hero__icon" aria-hidden="true"><i class="bi bi-chat-square-text"></i></span>
            <div>
                <span class="project-remarks-hero__eyebrow">Project communication</span>
                <h1>Remarks</h1>
                <p>Review decisions, progress updates and the complete project conversation.</p>
                <div class="project-remarks-hero__meta">
                    <strong>@projectName</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.Project?.CaseFileNumber))
                    {
                        <span>Case file @Model.Project!.CaseFileNumber</span>
                    }
                </div>
            </div>
        </div>
        <a class="btn btn-outline-secondary project-remarks-back" asp-page="/Projects/Overview" asp-route-id="@Model.Project!.Id">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to overview
        </a>
    </header>

    <div data-panel-project-id="@Model.Project!.Id" class="project-remarks-workspace">
        <section class="project-remarks-toolbar" aria-label="Remark filters">
            <div class="project-remarks-toolbar__title">
                <strong>Remark history</strong>
                <span>Use filters to focus on the updates that matter.</span>
            </div>
            <div class="project-remarks-toolbar__controls" role="toolbar" aria-label="Filter remarks">
                @if (Model.RemarksPanel.ScopeOptions.Count > 1)
                {
                    <div class="project-remarks-filter">
                        <span class="project-remarks-filter__label">Scope</span>
                        <div class="btn-group btn-group-sm" role="group" aria-label="Filter remarks by scope" data-remarks-scope-group>
                            <button type="button" class="btn btn-outline-primary active" data-remarks-scope="all" aria-pressed="true">All</button>
                            @foreach (var scope in Model.RemarksPanel.ScopeOptions)
                            {
                                <button type="button" class="btn btn-outline-primary" data-remarks-scope="@scope.Canonical" aria-pressed="false">@scope.Label</button>
                            }
                        </div>
                    </div>
                }
                <div class="project-remarks-filter">
                    <span class="project-remarks-filter__label">Audience</span>
                    <div class="btn-group btn-group-sm" role="group" aria-label="Filter remarks by audience" data-remarks-type-group>
                        <button type="button" class="btn btn-outline-primary active" data-remarks-type="all" aria-pressed="true">All</button>
                        <button type="button" class="btn btn-outline-primary" data-remarks-type="Internal" aria-pressed="false">Internal</button>
                        <button type="button" class="btn btn-outline-primary" data-remarks-type="External" aria-pressed="false">External</button>
                    </div>
                </div>
                <div class="project-remarks-filter">
                    <span class="project-remarks-filter__label">Period</span>
                    <div class="btn-group btn-group-sm" role="group" aria-label="Filter remarks by period" data-remarks-time-group>
                        <button type="button" class="btn btn-outline-primary active" data-remarks-time="all" aria-pressed="true">All time</button>
                        <button type="button" class="btn btn-outline-primary" data-remarks-time="last-month" aria-pressed="false">Last month</button>
                    </div>
                </div>
                @if (Model.RemarksPanel.ShowDeletedToggle)
                {
                    <label class="project-remarks-deleted-toggle" for="remarks-include-deleted">
                        <input class="form-check-input" type="checkbox" role="switch" id="remarks-include-deleted" data-remarks-include-deleted>
                        <span>Show deleted</span>
                    </label>
                }
            </div>
        </section>

        <div class="remarks-panel project-remarks-panel" data-remarks-panel data-config='@remarksConfigJson' data-initial-page="@Model.InitialPage">
            @if (Model.RemarksPanel.ShowComposer)
            {
                <form class="remarks-composer project-remarks-composer" data-remarks-composer>
                    @Html.AntiForgeryToken()
                    <div class="project-remarks-composer__header">
                        <div>
                            <span class="project-remarks-composer__eyebrow">New update</span>
                            <h2>Add a remark</h2>
                            @if (!string.IsNullOrWhiteSpace(Model.RemarksPanel.ActorDisplayName))
                            {
                                <p>Posting as <strong>@Model.RemarksPanel.ActorDisplayName</strong></p>
                            }
                        </div>
                        <span class="project-remarks-composer__privacy"><i class="bi bi-shield-check"></i> Project record</span>
                    </div>
                    <label for="remark-body" class="visually-hidden">Remark</label>
                    <textarea id="remark-body" class="form-control project-remarks-composer__textarea" rows="4" maxlength="4000" data-remarks-body required placeholder="Share a decision, progress update, issue or next action…"></textarea>
                    <div class="project-remarks-composer__footer">
                        <div class="project-remarks-composer__options">
                            @if (Model.RemarksPanel.ScopeOptions.Count > 1)
                            {
                                <div class="project-remarks-option-group">
                                    <span>Scope</span>
                                    <div class="btn-group btn-group-sm" role="group" aria-label="Remark scope" data-remarks-composer-scope>
                                        @foreach (var scope in Model.RemarksPanel.ScopeOptions)
                                        {
                                            var isDefaultScope = string.Equals(scope.Canonical, Model.RemarksPanel.DefaultScope, StringComparison.OrdinalIgnoreCase);
                                            <button type="button" class="btn btn-outline-secondary@(isDefaultScope ? " active" : string.Empty)" data-remarks-composer-scope-option="@scope.Canonical" aria-pressed="@(isDefaultScope ? "true" : "false")">@scope.Label</button>
                                        }
                                    </div>
                                </div>
                            }
                            <div class="project-remarks-option-group">
                                <span>Audience</span>
                                <div class="btn-group btn-group-sm" role="group" aria-label="Remark audience" data-remarks-composer-type>
                                    <button type="button" class="btn btn-outline-secondary active" data-remarks-composer-option="Internal" aria-pressed="true">Internal</button>
                                    @if (Model.RemarksPanel.AllowExternal)
                                    {
                                        <button type="button" class="btn btn-outline-secondary" data-remarks-composer-option="External" aria-pressed="false">External</button>
                                    }
                                </div>
                            </div>
                            <div class="remarks-composer-external project-remarks-external d-none" data-remarks-external-fields>
                                <div>
                                    <label for="remark-event-date">Event date</label>
                                    <input type="date" id="remark-event-date" class="form-control form-control-sm" data-remarks-event-date value="@Model.RemarksPanel.Today" max="@Model.RemarksPanel.Today" />
                                </div>
                                <div>
                                    <label for="remark-stage">Stage <span>(optional)</span></label>
                                    <select id="remark-stage" class="form-select form-select-sm" data-remarks-stage>
                                        <option value="">Not linked</option>
                                        @foreach (var stage in Model.RemarksPanel.StageOptions)
                                        {
                                            var isDefaultStage = string.Equals(stage.Value, Model.RemarksPanel.DefaultStage, StringComparison.OrdinalIgnoreCase);
                                            <option value="@stage.Value" selected="@(isDefaultStage ? "selected" : null)">@stage.Label</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="project-remarks-composer__actions">
                            <span class="project-remarks-character-note">Up to 4,000 characters</span>
                            <span class="small" data-remarks-feedback></span>
                            <button type="reset" class="btn btn-outline-secondary" data-remarks-reset>Clear</button>
                            <button type="submit" class="btn btn-primary" data-remarks-submit><i class="bi bi-send"></i> Post remark</button>
                        </div>
                    </div>
                </form>
            }
            else
            {
                <div class="project-remarks-readonly" role="status">
                    <i class="bi bi-eye"></i>
                    <span>You can review the complete remark history. Posting is limited to the project team and leadership.</span>
                </div>
            }

            <section class="project-remarks-feed" aria-labelledby="remarks-feed-title">
                <div class="project-remarks-feed__header">
                    <div>
                        <span class="project-remarks-feed__eyebrow">Chronological record</span>
                        <h2 id="remarks-feed-title">Project updates</h2>
                    </div>
                </div>
                <div class="remarks-list" data-remarks-list>
                    <div class="project-remarks-loading" data-remarks-empty><span class="spinner-border spinner-border-sm" aria-hidden="true"></span> Loading remarks…</div>
                    <div class="vstack gap-3" data-remarks-items></div>
                </div>
                <nav class="d-flex justify-content-center mt-4" aria-label="Remarks pagination" data-remarks-pagination></nav>
            </section>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/project-remarks.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/projects/remarks-panel.js" asp-append-version="true"></script>
    <script src="~/js/projects/remarks-index.js" asp-append-version="true"></script>
}
