@page
@model ProjectManagement.Pages.Projects.Documents.UploadRequestModel
@using System
@using System.Linq
@{
    ViewData["Title"] = $"Upload documents – {Model.Project?.Name}";
    var maxSizeMb = Math.Max(1, Model.MaxFileSizeBytes / (1024 * 1024));
    const string friendlyTypes = "Word, PDF, PowerPoint and Excel files";
    var allowedTypesAttribute = string.Join(',', Model.AllowedContentTypes);
    var allowedExtensionsAttribute = string.Join(',', Model.AllowedExtensions);
    var showOptionalDetails = Model.Input.StageId.HasValue ||
                              Model.Input.LinkToTot ||
                              ViewData.ModelState.Keys.Any(key => key is "Input.StageId" or "Input.LinkToTot");
}

<div class="container-xl project-document-upload-page">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Projects/Index">Projects</a></li>
            <li class="breadcrumb-item"><a asp-page="/Projects/Overview" asp-route-id="@Model.Input.ProjectId">@Model.Project?.Name</a></li>
            <li class="breadcrumb-item"><a asp-page="./Index" asp-route-id="@Model.Input.ProjectId">Documents</a></li>
            <li class="breadcrumb-item active" aria-current="page">Upload</li>
        </ol>
    </nav>

    <header class="project-document-upload-header">
        <a asp-page="./Index" asp-route-id="@Model.Input.ProjectId" class="project-document-upload-back">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to documents
        </a>
        <h1>Upload project documents</h1>
        <p class="project-document-upload-project">@Model.Project?.Name</p>
        <p class="text-muted mb-0">Choose one or more files. They will appear in the project after approval.</p>
    </header>

    <form method="post"
          enctype="multipart/form-data"
          novalidate
          data-document-upload-form
          data-max-file-size="@Model.MaxFileSizeBytes"
          data-allowed-types="@allowedTypesAttribute"
          data-allowed-extensions="@allowedExtensionsAttribute">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
        <input type="hidden" asp-for="Input.ProjectId" />

        <section class="card pm-card project-document-upload-section">
            <div class="card-header project-document-upload-section__header">
                <div>
                    <h2>Choose files</h2>
                    <p>Select all related documents together. You can remove or rename them before submitting.</p>
                </div>
                <span class="project-document-upload-step">1</span>
            </div>
            <div class="card-body">
                <div class="project-document-dropzone"
                     data-document-dropzone
                     role="button"
                     tabindex="0"
                     aria-controls="Input_Files"
                     aria-describedby="document-file-help">
                    <span class="project-document-dropzone__icon" aria-hidden="true"><i class="bi bi-cloud-arrow-up"></i></span>
                    <strong>Drag and drop files here</strong>
                    <span>or choose files from this device</span>
                    <small id="document-file-help">@friendlyTypes · up to @maxSizeMb MB each</small>
                </div>
                <input asp-for="Input.Files"
                       id="Input_Files"
                       class="visually-hidden"
                       type="file"
                       multiple
                       accept="@allowedExtensionsAttribute"
                       data-document-file-input />
                <span asp-validation-for="Input.Files" class="text-danger d-block mt-2"></span>
                <div class="alert alert-danger mt-3 mb-0" data-document-file-error hidden></div>

                <div class="project-document-selected" data-document-selected hidden>
                    <div class="project-document-selected__heading">
                        <strong data-document-selected-count>Selected files</strong>
                        <button type="button" class="btn btn-sm btn-link" data-document-add-more>Add more</button>
                    </div>
                    <div class="project-document-selected__list" data-document-selected-list></div>
                </div>

                <noscript>
                    <style>
                        #Input_Files { position: static !important; width: 100% !important; height: auto !important; clip: auto !important; white-space: normal !important; overflow: visible !important; }
                        [data-document-dropzone] { display: none !important; }
                    </style>
                    <p class="form-text">Select the files above. Their file names will be used as document titles.</p>
                </noscript>
            </div>
        </section>

        <section class="card pm-card project-document-upload-section project-document-upload-section--optional">
            <details class="project-document-optional" open="@showOptionalDetails">
                <summary>
                    <span>
                        <strong>Optional details</strong>
                        <small>Add a project stage or Transfer of Technology link only when useful.</small>
                    </span>
                    <i class="bi bi-chevron-down" aria-hidden="true"></i>
                </summary>
                <div class="card-body project-document-upload-fields">
                    <div>
                        <label asp-for="Input.StageId" class="form-label">Project stage</label>
                        @if (Model.HasStageOptions)
                        {
                            <select asp-for="Input.StageId" asp-items="Model.StageOptions" class="form-select">
                                <option value="">Not linked to a specific stage</option>
                            </select>
                        }
                        else
                        {
                            <select asp-for="Input.StageId" class="form-select" disabled>
                                <option value="">No stages available</option>
                            </select>
                        }
                        <span asp-validation-for="Input.StageId" class="text-danger"></span>
                    </div>

                    @if (Model.Project?.Tot is not null)
                    {
                        <div class="project-document-use-option @(Model.AllowTotLinking ? string.Empty : "is-disabled")">
                            @if (Model.AllowTotLinking)
                            {
                                <div class="form-check form-switch">
                                    <input asp-for="Input.LinkToTot" class="form-check-input" />
                                    <label asp-for="Input.LinkToTot" class="form-check-label">
                                        <strong>Also show with Transfer of Technology records</strong>
                                        <span>Turn this on only when the files support the project's ToT work.</span>
                                    </label>
                                </div>
                                <span asp-validation-for="Input.LinkToTot" class="text-danger"></span>
                            }
                            else
                            {
                                <div class="text-muted">Transfer of Technology is @Model.TotStatusDisplay.ToLowerInvariant() for this project.</div>
                            }
                        </div>
                    }
                </div>
            </details>
        </section>

        <div class="project-document-upload-actions">
            <a asp-page="./Index" asp-route-id="@Model.Input.ProjectId" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary" data-document-submit>
                <i class="bi bi-send" aria-hidden="true"></i> Submit for approval
            </button>
        </div>
    </form>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/project-document-upload.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/project-document-upload.js" asp-append-version="true"></script>
}
