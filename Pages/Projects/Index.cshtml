@page
@model ProjectManagement.Pages.Projects.IndexModel
@using System
@using System.Linq
@using System.Globalization
@using ProjectManagement.Models
@using ProjectManagement.Models.Execution
@using ProjectManagement.Models.Stages
@using ProjectManagement.Services.Projects
@{
    ViewData["Title"] = "Projects";

    var activeLifecycle = Model.LifecycleTabs.FirstOrDefault(t => t.IsActive);
    var activeLifecycleLabel = string.IsNullOrWhiteSpace(activeLifecycle?.Label) ? "All" : activeLifecycle!.Label;
    var projectTypeChips = Model.ProjectTypeChips
        .OrderByDescending(chip => chip.Count)
        .ThenBy(chip => chip.Name, StringComparer.OrdinalIgnoreCase)
        .ToList();

    IDictionary<string, string?> BaseRouteValues()
    {
        var values = new Dictionary<string, string?>();
        void AddValue(string key, object? value)
        {
            if (value is null) return;
            var text = value.ToString();
            if (!string.IsNullOrWhiteSpace(text)) values[key] = text;
        }

        AddValue("Query", Model.Query);
        AddValue("CategoryId", Model.CategoryId);
        AddValue("TechnicalCategoryId", Model.TechnicalCategoryId);
        AddValue("LeadPoUserId", Model.LeadPoUserId);
        AddValue("HodUserId", Model.HodUserId);
        AddValue("Lifecycle", Model.Lifecycle == ProjectLifecycleFilter.All ? null : Model.Lifecycle.ToString());
        AddValue("CompletedYear", Model.CompletedYear);
        AddValue("TotStatus", Model.TotStatus?.ToString());
        AddValue("IncludeArchived", Model.IncludeArchived ? "true" : null);
        AddValue("StageCode", Model.StageCode);
        AddValue("StageCompletedMonth", Model.StageCompletedMonth);
        AddValue("SlipBucket", Model.SlipBucket);
        AddValue("IncludeCategoryDescendants", Model.IncludeCategoryDescendants ? "true" : null);
        AddValue("Build", Model.Build);
        AddValue("ProjectTypeId", Model.ProjectTypeId);
        AddValue("ProjectTypeUnclassified", Model.ProjectTypeUnclassified ? "true" : null);
        AddValue("PageSize", Model.PageSize);
        return values;
    }

    var activeFilters = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.Query)) activeFilters.Add($"Search: {Model.Query}");
    var selectedCategory = Model.CategoryOptions.FirstOrDefault(o => o.Selected && !string.IsNullOrEmpty(o.Value))?.Text;
    if (!string.IsNullOrWhiteSpace(selectedCategory)) activeFilters.Add($"Category: {selectedCategory}");
    var selectedTechnicalCategory = Model.TechnicalCategoryOptions.FirstOrDefault(o => o.Selected && !string.IsNullOrEmpty(o.Value))?.Text;
    if (!string.IsNullOrWhiteSpace(selectedTechnicalCategory)) activeFilters.Add($"Technical category: {selectedTechnicalCategory}");
    var selectedHod = Model.HodOptions.FirstOrDefault(o => o.Selected && !string.IsNullOrEmpty(o.Value))?.Text;
    if (!string.IsNullOrWhiteSpace(selectedHod)) activeFilters.Add($"HoD: {selectedHod}");
    var selectedLeadPo = Model.LeadPoOptions.FirstOrDefault(o => o.Selected && !string.IsNullOrEmpty(o.Value))?.Text;
    if (!string.IsNullOrWhiteSpace(selectedLeadPo)) activeFilters.Add($"Project Officer: {selectedLeadPo}");
    var selectedCompletionYear = Model.CompletionYearOptions.FirstOrDefault(o => o.Selected && !string.IsNullOrEmpty(o.Value))?.Text;
    if (!string.IsNullOrWhiteSpace(selectedCompletionYear)) activeFilters.Add($"Completion year: {selectedCompletionYear}");
    var selectedTotStatus = Model.TotStatusOptions.FirstOrDefault(o => o.Selected && !string.IsNullOrEmpty(o.Value))?.Text;
    if (!string.IsNullOrWhiteSpace(selectedTotStatus)) activeFilters.Add($"ToT: {selectedTotStatus}");
    if (Model.ProjectTypeUnclassified) activeFilters.Add("Project type: Unclassified");
    else if (Model.ProjectTypeId.HasValue)
    {
        var selectedTypeName = projectTypeChips.FirstOrDefault(chip => chip.Id == Model.ProjectTypeId.Value)?.Name;
        if (!string.IsNullOrWhiteSpace(selectedTypeName)) activeFilters.Add($"Project type: {selectedTypeName}");
    }
    if (!string.IsNullOrWhiteSpace(Model.Build)) activeFilters.Add(Model.Build == "Repeat" ? "Repeat build" : "New development");
    if (Model.IncludeArchived) activeFilters.Add("Archived included");

    var isAdminOrHod = User.IsInRole("Admin") || User.IsInRole("HoD");
}

@section Styles {
    <link rel="stylesheet" href="~/css/projects/index.css" asp-append-version="true" />
}

<div class="projects-repository" data-projects-page>
    <div class="container-xxl projects-repository__container">
        <header class="projects-header">
            <div class="projects-header__identity">
                <div>
                    <h1 class="projects-header__title">Projects</h1>
                    <p class="projects-header__summary">
                        <strong>@Model.FilteredTotal</strong> projects
                        <span aria-hidden="true">·</span>
                        <span>@activeLifecycleLabel</span>
                    </p>
                </div>
            </div>
            <div class="projects-header__actions">
                <div class="projects-view-toggle" role="group" aria-label="Project result view">
                    <button type="button" class="projects-view-toggle__button is-active" data-project-view="cards" aria-pressed="true" title="Card view">
                        <i class="bi bi-grid-3x3-gap" aria-hidden="true"></i><span class="visually-hidden">Card view</span>
                    </button>
                    <button type="button" class="projects-view-toggle__button" data-project-view="table" aria-pressed="false" title="Table view">
                        <i class="bi bi-list-ul" aria-hidden="true"></i><span class="visually-hidden">Table view</span>
                    </button>
                </div>
                @if (isAdminOrHod)
                {
                    <a asp-page="/Projects/Create" class="btn btn-primary projects-header__create">
                        <i class="bi bi-plus-lg" aria-hidden="true"></i>
                        <span>Create project</span>
                    </a>
                }
            </div>
        </header>

        <nav class="projects-lifecycle" aria-label="Project lifecycle filters">
            @foreach (var lifecycle in Model.LifecycleTabs)
            {
                var routeValues = BaseRouteValues();
                routeValues["Lifecycle"] = lifecycle.Filter == ProjectLifecycleFilter.All ? null : lifecycle.RouteValue;
                routeValues["p"] = "1";
                <a class="projects-lifecycle__tab @(lifecycle.IsActive ? "is-active" : null)"
                   asp-page="./Index"
                   asp-all-route-data="routeValues"
                   aria-current="@(lifecycle.IsActive ? "page" : null)">
                    <span title="@(lifecycle.Filter == ProjectLifecycleFilter.Legacy ? "Older completed projects retained as institutional record" : null)">@(lifecycle.Filter == ProjectLifecycleFilter.Legacy ? "Legacy archive" : lifecycle.Label)</span>
                    <span class="projects-lifecycle__count">@lifecycle.Count</span>
                </a>
            }
        </nav>

        <form method="get" class="projects-toolbar" data-project-filter-form>
            <input type="hidden" name="p" value="1" />
            <input type="hidden" name="Lifecycle" value="@(Model.Lifecycle == ProjectLifecycleFilter.All ? null : Model.Lifecycle.ToString())" />
            @if (!string.IsNullOrWhiteSpace(Model.StageCode)) { <input type="hidden" name="StageCode" value="@Model.StageCode" /> }
            @if (!string.IsNullOrWhiteSpace(Model.StageCompletedMonth)) { <input type="hidden" name="StageCompletedMonth" value="@Model.StageCompletedMonth" /> }
            @if (!string.IsNullOrWhiteSpace(Model.SlipBucket)) { <input type="hidden" name="SlipBucket" value="@Model.SlipBucket" /> }
            @if (Model.IncludeCategoryDescendants) { <input type="hidden" name="IncludeCategoryDescendants" value="true" /> }

            <div class="projects-toolbar__main">
                <label class="projects-search" for="Query">
                    <i class="bi bi-search" aria-hidden="true"></i>
                    <input asp-for="Query" class="form-control" placeholder="Search by project, case file, officer or keyword" autocomplete="off" data-project-search />
                    <span class="visually-hidden">Search projects</span>
                </label>

                <button class="btn btn-outline-secondary projects-toolbar__filter-button" type="button" data-bs-toggle="offcanvas" data-bs-target="#projectFilters" aria-controls="projectFilters">
                    <i class="bi bi-sliders" aria-hidden="true"></i>
                    <span>Filters</span>
                    @if (activeFilters.Count > 0)
                    {
                        <span class="projects-toolbar__filter-count">@activeFilters.Count</span>
                    }
                </button>

                <label class="projects-toolbar__page-size">
                    <span class="visually-hidden">Projects per page</span>
                    <select asp-for="PageSize" class="form-select" data-project-auto-submit title="Projects per page">
                        <option value="25">25 per page</option>
                        <option value="50">50 per page</option>
                        <option value="100">100 per page</option>
                        <option value="0">Show all</option>
                    </select>
                </label>
            </div>

            <div class="offcanvas offcanvas-end projects-filter-drawer" tabindex="-1" id="projectFilters" aria-labelledby="projectFiltersLabel">
                <div class="offcanvas-header">
                    <div>
                        <h2 class="offcanvas-title" id="projectFiltersLabel">Filter projects</h2>
                        <p class="projects-filter-drawer__subtitle">Narrow the repository by classification, responsibility and lifecycle.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body">
                    <section class="projects-filter-section">
                        <h3 class="projects-filter-section__title">Classification</h3>
                        <div class="projects-filter-grid">
                            <div>
                                <label asp-for="CategoryId" class="form-label">Category</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="Model.CategoryOptions"></select>
                            </div>
                            <div>
                                <label asp-for="TechnicalCategoryId" class="form-label">Technical category</label>
                                <select asp-for="TechnicalCategoryId" class="form-select" asp-items="Model.TechnicalCategoryOptions"></select>
                            </div>
                        </div>

                        <div class="projects-filter-choice-group">
                            <span class="form-label">Build type</span>
                            <div class="projects-filter-choice-list">
                                <label class="projects-filter-choice">
                                    <input type="radio" name="Build" value="" checked="@(string.IsNullOrWhiteSpace(Model.Build))" />
                                    <span>All builds</span>
                                </label>
                                <label class="projects-filter-choice">
                                    <input type="radio" name="Build" value="New" checked="@(Model.Build == "New")" />
                                    <span>New development <small>@Model.NewBuildCount</small></span>
                                </label>
                                <label class="projects-filter-choice">
                                    <input type="radio" name="Build" value="Repeat" checked="@(Model.Build == "Repeat")" />
                                    <span>Repeat build <small>@Model.RepeatBuildCount</small></span>
                                </label>
                            </div>
                        </div>

                        <div class="projects-filter-choice-group">
                            <span class="form-label">Project type</span>
                            <div class="projects-filter-choice-list projects-filter-choice-list--wrap">
                                <label class="projects-filter-choice">
                                    <input type="radio" name="ProjectTypeId" value="" checked="@(!Model.ProjectTypeId.HasValue && !Model.ProjectTypeUnclassified)" data-clear-unclassified />
                                    <span>All types</span>
                                </label>
                                @if (Model.ProjectTypeUnclassifiedCount > 0 || Model.ProjectTypeUnclassified)
                                {
                                    <label class="projects-filter-choice">
                                        <input type="radio" name="ProjectTypeUnclassified" value="true" checked="@Model.ProjectTypeUnclassified" data-project-type-unclassified />
                                        <span>Unclassified <small>@Model.ProjectTypeUnclassifiedCount</small></span>
                                    </label>
                                }
                                @foreach (var chip in projectTypeChips)
                                {
                                    <label class="projects-filter-choice">
                                        <input type="radio" name="ProjectTypeId" value="@chip.Id" checked="@(Model.ProjectTypeId == chip.Id)" data-project-type />
                                        <span>@chip.Name <small>@chip.Count</small></span>
                                    </label>
                                }
                            </div>
                        </div>
                    </section>

                    <section class="projects-filter-section">
                        <h3 class="projects-filter-section__title">Responsibility</h3>
                        <div class="projects-filter-grid">
                            <div>
                                <label asp-for="LeadPoUserId" class="form-label">Project Officer</label>
                                <select asp-for="LeadPoUserId" class="form-select" asp-items="Model.LeadPoOptions"></select>
                            </div>
                            <div>
                                <label asp-for="HodUserId" class="form-label">Head of Department</label>
                                <select asp-for="HodUserId" class="form-select" asp-items="Model.HodOptions"></select>
                            </div>
                        </div>
                    </section>

                    <section class="projects-filter-section">
                        <h3 class="projects-filter-section__title">Completion and records</h3>
                        <div class="projects-filter-grid">
                            <div>
                                <label asp-for="CompletedYear" class="form-label">Completion year</label>
                                <select asp-for="CompletedYear" class="form-select" asp-items="Model.CompletionYearOptions"></select>
                            </div>
                            <div>
                                <label asp-for="TotStatus" class="form-label">ToT status</label>
                                <select asp-for="TotStatus" class="form-select" asp-items="Model.TotStatusOptions"></select>
                            </div>
                        </div>
                        <label class="projects-filter-check">
                            <input class="form-check-input" type="checkbox" asp-for="IncludeArchived" />
                            <span>Include archived projects</span>
                        </label>
                    </section>
                </div>
                <div class="projects-filter-drawer__footer">
                    <a asp-page="./Index" asp-route-Lifecycle="@((Model.Lifecycle == ProjectLifecycleFilter.All) ? null : Model.Lifecycle.ToString())" class="btn btn-outline-secondary">Reset</a>
                    <button type="submit" class="btn btn-primary" data-project-filter-apply>
                        <i class="bi bi-funnel" aria-hidden="true"></i>
                        Show results
                    </button>
                </div>
            </div>
        </form>

        @if (activeFilters.Count > 0)
        {
            <div class="projects-filter-summary" aria-label="Active filters">
                <div class="projects-filter-summary__chips">
                    @foreach (var filter in activeFilters)
                    {
                        <span class="projects-filter-chip">@filter</span>
                    }
                </div>
                <a asp-page="./Index" asp-route-Lifecycle="@((Model.Lifecycle == ProjectLifecycleFilter.All) ? null : Model.Lifecycle.ToString())" class="projects-filter-summary__clear">Clear filters</a>
            </div>
        }

        <div class="projects-results-header">
            <div>
                <strong>@Model.FilteredTotal @((Model.FilteredTotal == 1) ? "project" : "projects")</strong>
                @if (Model.TotalPages > 1)
                {
                    <span>Showing @Model.ResultsStart–@Model.ResultsEnd</span>
                }
            </div>
        </div>

        @if (!Model.Projects.Any())
        {
            <section class="projects-empty-state">
                <div class="projects-empty-state__icon"><i class="bi bi-inboxes" aria-hidden="true"></i></div>
                <h2>No projects found</h2>
                <p>Try a different search, remove a filter or select another lifecycle.</p>
                <a asp-page="./Index" class="btn btn-outline-primary">View all projects</a>
            </section>
        }
        else
        {
            <div class="projects-results-view is-active" data-project-results="cards">
                <div class="projects-grid">
                    @foreach (var project in Model.Projects)
                    {
                        var stageDisplay = FormatStageDisplay(project);
                        var totStatus = FormatTotStatusShort(project);
                        string? coverPhotoUrl = null;
                        if (project.CoverPhotoId.HasValue)
                        {
                            coverPhotoUrl = Url.Page("/Projects/Photos/View", new { id = project.Id, photoId = project.CoverPhotoId, size = "sm", v = project.CurrentCoverPhotoVersion ?? project.CoverPhotoVersion });
                        }
                        var officerName = project.LeadPoUser?.FullName ?? project.LeadPoUser?.UserName ?? "Not assigned";
                        var categoryName = project.Category?.Name ?? "Uncategorised";
                        var caseFile = string.IsNullOrWhiteSpace(project.CaseFileNumber) ? "Not recorded" : project.CaseFileNumber;
                        <article class="project-card @(project.IsLegacy ? "project-card--legacy" : null) @(project.IsArchived ? "project-card--archived" : null)">
                            <a asp-page="/Projects/Overview" asp-route-id="@project.Id" asp-route-TechnicalCategoryId="@Model.TechnicalCategoryId" class="project-card__link" aria-label="Open @project.Name"></a>
                            <div class="project-card__topline">
                                <div class="project-card__visual @(string.IsNullOrEmpty(coverPhotoUrl) ? "project-card__visual--icon" : null)">
                                    @if (!string.IsNullOrEmpty(coverPhotoUrl))
                                    {
                                        <img src="@coverPhotoUrl" alt="" loading="lazy" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-kanban" aria-hidden="true"></i>
                                    }
                                </div>
                                <div class="project-card__heading">
                                    <h2>@project.Name</h2>
                                    <div class="project-card__badges">
                                        <span class="badge rounded-pill @GetLifecycleBadgeClass(project.LifecycleStatus)">@FormatLifecycleStatus(project.LifecycleStatus)@if (project.LifecycleStatus == ProjectLifecycleStatus.Completed && project.CompletedYear.HasValue){<text> @project.CompletedYear</text>}</span>
                                        @if (project.IsLegacy) { <span class="badge rounded-pill project-badge--legacy">Legacy archive</span> }
                                        @if (project.IsArchived) { <span class="badge rounded-pill text-bg-secondary">Archived</span> }
                                    </div>
                                </div>
                                <i class="bi bi-chevron-right project-card__open-icon" aria-hidden="true"></i>
                            </div>
                            <dl class="project-card__metadata">
                                <div><dt>Category</dt><dd>@categoryName</dd></div>
                                <div class="@(string.IsNullOrWhiteSpace(project.CaseFileNumber) ? "is-missing" : null)"><dt>Case file</dt><dd>@caseFile</dd></div>
                                <div class="@((project.LeadPoUser is null) ? "is-missing" : null)"><dt>Project Officer</dt><dd>@officerName</dd></div>
                            </dl>
                            <div class="project-card__stage @(stageDisplay.IsMissing ? "is-missing" : null)">
                                <i class="bi bi-signpost-split" aria-hidden="true"></i>
                                <span>
                                    <strong>@stageDisplay.Primary</strong>
                                    @if (!string.IsNullOrWhiteSpace(stageDisplay.Secondary))
                                    {
                                        <small>@stageDisplay.Secondary</small>
                                    }
                                </span>
                            </div>
                            @if (project.LifecycleStatus == ProjectLifecycleStatus.Completed && !string.IsNullOrWhiteSpace(totStatus))
                            {
                                <div class="project-card__tot"><i class="bi bi-arrow-left-right" aria-hidden="true"></i><span>@totStatus</span></div>
                            }
                        </article>
                    }
                </div>
            </div>

            <div class="projects-results-view" data-project-results="table" hidden>
                <div class="projects-table-wrap">
                    <table class="table projects-table align-middle" data-project-sort-table>
                        <thead>
                            <tr>
                                <th scope="col"><button type="button" class="projects-sort" data-sort="project">Project <i class="bi bi-arrow-down-up" aria-hidden="true"></i></button></th>
                                <th scope="col"><button type="button" class="projects-sort" data-sort="status">Status <i class="bi bi-arrow-down-up" aria-hidden="true"></i></button></th>
                                <th scope="col">Current position</th>
                                <th scope="col"><button type="button" class="projects-sort" data-sort="officer">Project Officer <i class="bi bi-arrow-down-up" aria-hidden="true"></i></button></th>
                                <th scope="col"><button type="button" class="projects-sort" data-sort="category">Category <i class="bi bi-arrow-down-up" aria-hidden="true"></i></button></th>
                                <th scope="col"><button type="button" class="projects-sort" data-sort="casefile">Case file <i class="bi bi-arrow-down-up" aria-hidden="true"></i></button></th>
                                <th scope="col" class="projects-table__action"><span class="visually-hidden">Open</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var project in Model.Projects)
                            {
                                var stageDisplay = FormatStageDisplay(project);
                                var rowHref = Url.Page("/Projects/Overview", new { id = project.Id });
                                <tr class="projects-table__row @(project.IsLegacy ? "is-legacy" : null)" data-project-row data-href="@rowHref" tabindex="0">
                                    <td data-sort-value="@project.Name"><a asp-page="/Projects/Overview" asp-route-id="@project.Id" class="projects-table__project">@project.Name</a></td>
                                    <td data-sort-value="@FormatLifecycleStatus(project.LifecycleStatus)"><span class="badge rounded-pill @GetLifecycleBadgeClass(project.LifecycleStatus)">@FormatLifecycleStatus(project.LifecycleStatus)</span></td>
                                    <td class="projects-table__stage">
                                        <strong>@stageDisplay.Primary</strong>
                                        @if (!string.IsNullOrWhiteSpace(stageDisplay.Secondary)) { <small>@stageDisplay.Secondary</small> }
                                    </td>
                                    <td data-sort-value="@(project.LeadPoUser?.FullName ?? project.LeadPoUser?.UserName ?? "Not assigned")">@(project.LeadPoUser?.FullName ?? project.LeadPoUser?.UserName ?? "Not assigned")</td>
                                    <td data-sort-value="@(project.Category?.Name ?? "Uncategorised")">@(project.Category?.Name ?? "Uncategorised")</td>
                                    <td data-sort-value="@(project.CaseFileNumber ?? string.Empty)" class="@(string.IsNullOrWhiteSpace(project.CaseFileNumber) ? "projects-table__missing" : null)">@(string.IsNullOrWhiteSpace(project.CaseFileNumber) ? "Not recorded" : project.CaseFileNumber)</td>
                                    <td class="projects-table__action"><a asp-page="/Projects/Overview" asp-route-id="@project.Id" class="btn btn-sm btn-link" aria-label="Open @project.Name"><i class="bi bi-chevron-right" aria-hidden="true"></i></a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="projects-pagination" aria-label="Project pagination">
                    <div class="projects-pagination__summary">Page @Model.CurrentPage of @Model.TotalPages</div>
                    <ul class="pagination pagination-sm mb-0">
                        @{ var prevRoute = BaseRouteValues(); prevRoute["p"] = Math.Max(1, Model.CurrentPage - 1).ToString(CultureInfo.InvariantCulture); }
                        <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : null)"><a class="page-link" asp-page="./Index" asp-all-route-data="prevRoute" aria-label="Previous page"><i class="bi bi-chevron-left" aria-hidden="true"></i></a></li>
                        @for (var i = 1; i <= Model.TotalPages; i++)
                        {
                            if (i == 1 || i == Model.TotalPages || Math.Abs(i - Model.CurrentPage) <= 2)
                            {
                                var pageRoute = BaseRouteValues(); pageRoute["p"] = i.ToString(CultureInfo.InvariantCulture);
                                <li class="page-item @(i == Model.CurrentPage ? "active" : null)"><a class="page-link" asp-page="./Index" asp-all-route-data="pageRoute">@i</a></li>
                            }
                            else if (i == Model.CurrentPage - 3 || i == Model.CurrentPage + 3)
                            {
                                <li class="page-item disabled"><span class="page-link">…</span></li>
                            }
                        }
                        @{ var nextRoute = BaseRouteValues(); nextRoute["p"] = Math.Min(Model.TotalPages, Model.CurrentPage + 1).ToString(CultureInfo.InvariantCulture); }
                        <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : null)"><a class="page-link" asp-page="./Index" asp-all-route-data="nextRoute" aria-label="Next page"><i class="bi bi-chevron-right" aria-hidden="true"></i></a></li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/projects-index.js" asp-append-version="true"></script>
}

@functions
{
    private readonly record struct StageDisplay(string Primary, string? Secondary, bool IsMissing = false);

    private static StageDisplay FormatStageDisplay(Project project)
    {
        static string FmtDate(DateOnly? d) => d.HasValue ? d.Value.ToString("d MMM yyyy", CultureInfo.InvariantCulture) : string.Empty;

        if (project.ProjectStages is not { Count: > 0 })
            return new StageDisplay("Lifecycle not recorded", "No stage activity is available for this project.", true);

        var stages = project.ProjectStages
            .Where(s => !IsTotStage(s.StageCode))
            .OrderBy(s => s.SortOrder)
            .ToList();

        if (stages.Count == 0)
            return new StageDisplay("Lifecycle not recorded", "No stage activity is available for this project.", true);

        var paymentStage = stages.FirstOrDefault(s => IsPaymentStage(s.StageCode));
        if (paymentStage is not null)
            stages = stages.Where(s => s.SortOrder <= paymentStage.SortOrder).ToList();

        var topCompleted = stages
            .Where(s => s.Status == StageStatus.Completed)
            .OrderByDescending(s => s.SortOrder)
            .ThenByDescending(s => s.CompletedOn ?? DateOnly.MinValue)
            .FirstOrDefault();

        var started = stages.FirstOrDefault(s => s.Status is StageStatus.InProgress or StageStatus.Blocked);

        if (started is not null)
        {
            var currentLabel = StageCodes.DisplayNameOf(started.StageCode);
            var currentState = started.Status == StageStatus.Blocked ? "Blocked" : "In progress";
            var previous = stages.LastOrDefault(s => s.SortOrder < started.SortOrder && s.Status == StageStatus.Completed);
            var secondary = previous is null
                ? "Current project stage"
                : $"Previous: {StageCodes.DisplayNameOf(previous.StageCode)}{(previous.CompletedOn.HasValue ? $" · {FmtDate(previous.CompletedOn)}" : string.Empty)}";
            return new StageDisplay($"{currentLabel} · {currentState}", secondary);
        }

        if (topCompleted is not null)
        {
            var completedLabel = StageCodes.DisplayNameOf(topCompleted.StageCode);
            var next = stages.FirstOrDefault(s => s.SortOrder > topCompleted.SortOrder);
            var primary = next is null ? $"{completedLabel} completed" : $"{completedLabel} → {StageCodes.DisplayNameOf(next.StageCode)}";
            var secondary = topCompleted.CompletedOn.HasValue
                ? $"Completed {FmtDate(topCompleted.CompletedOn)}{(next is null ? string.Empty : " · Next stage not started")}"
                : next is null ? "Latest recorded stage completed" : "Next stage not started";
            return new StageDisplay(primary, secondary);
        }

        var first = stages.FirstOrDefault();
        return first is null
            ? new StageDisplay("Lifecycle not recorded", "No stage activity is available for this project.", true)
            : new StageDisplay($"Next: {StageCodes.DisplayNameOf(first.StageCode)}", "Project lifecycle has not started.");
    }

    private static bool IsTotStage(string code) => StageCodes.IsTot(code);
    private static bool IsPaymentStage(string code) => StageCodes.IsPayment(code);

    private static string? FormatTotStatusShort(Project project)
    {
        if (project.Tot is not { } tot)
        {
            return null;
        }

        return tot.Status switch
        {
            ProjectTotStatus.NotRequired => "ToT not required",
            ProjectTotStatus.NotStarted => "ToT not started",
            ProjectTotStatus.InProgress => "ToT in progress",
            ProjectTotStatus.Completed => "ToT completed",
            _ => null
        };
    }

    private static string FormatLifecycleStatus(ProjectLifecycleStatus status)
    {
        return status switch
        {
            ProjectLifecycleStatus.Active => "Active",
            ProjectLifecycleStatus.Completed => "Completed",
            ProjectLifecycleStatus.Cancelled => "Cancelled",
            _ => status.ToString()
        };
    }

    private static string GetLifecycleBadgeClass(ProjectLifecycleStatus status) => status switch
    {
        ProjectLifecycleStatus.Active => "text-bg-primary",
        ProjectLifecycleStatus.Completed => "text-bg-success",
        ProjectLifecycleStatus.Cancelled => "text-bg-secondary",
        _ => "text-bg-secondary"
    };

    private static string FormatTotStatus(ProjectTotStatus status)
    {
        return status switch
        {
            ProjectTotStatus.NotRequired => "ToT not required",
            ProjectTotStatus.NotStarted => "ToT not started",
            ProjectTotStatus.InProgress => "ToT in progress",
            ProjectTotStatus.Completed => "ToT completed",
            _ => status.ToString()
        };
    }

}
