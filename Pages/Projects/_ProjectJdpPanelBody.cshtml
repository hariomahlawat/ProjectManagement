@model ProjectManagement.Pages.Projects.OverviewModel

@{
    // SECTION: JDP partner list presentation
    var partnerCount = Model.JdpPartners.Count;
}

@if (partnerCount == 0)
{
    <!-- SECTION: JDP nil / not-linked state -->
    <div class="project-exploitation-empty">
        <strong>No partner linked</strong>
        <span>The project currently has no Joint Development Partner association.</span>
    </div>
}
else
{
    <!-- SECTION: JDP linked partner rows -->
    <div class="pm-summary-row-list">
        @foreach (var partner in Model.JdpPartners)
        {
            <a class="pm-summary-row-link pm-summary-row-link--stacked"
               href="/IndustryPartners?id=@partner.Id&amp;projectId=@Model.Project.Id&amp;tab=projects"
               title="Open industry partner details">
                <span class="pm-summary-row-main">
                    <span class="pm-summary-row-title">@partner.Name</span>
                    @if (!string.IsNullOrWhiteSpace(partner.Location))
                    {
                        <span class="pm-summary-row-meta">@partner.Location</span>
                    }
                </span>
                <i class="bi bi-chevron-right" aria-hidden="true"></i>
            </a>
        }
    </div>
}
