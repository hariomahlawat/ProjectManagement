@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    Layout = null;
    var isHod = User.IsInRole("HoD");
    var directApplyTokens = Antiforgery.GetAndStoreTokens(Context);
}

<div class="modal fade" id="stageDirectApplyModal" tabindex="-1" aria-labelledby="stageDirectApplyLabel" aria-hidden="true" data-authorised-override="@isHod.ToString().ToLowerInvariant()">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" data-direct-apply-form novalidate>
                <div class="modal-header">
                    <h5 class="modal-title" id="stageDirectApplyLabel" data-direct-apply-title>Update stage</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="projectId" />
                    <input type="hidden" name="stageCode" />
                    <input type="hidden" name="status" />
                    <input type="hidden" name="__RequestVerificationToken" value="@directApplyTokens.RequestToken" />

                    <div class="alert alert-warning d-none" role="alert" data-direct-apply-missing></div>

                    <div class="mb-3">
                        <div class="fw-semibold" data-direct-apply-stage></div>
                        <div class="text-muted" data-direct-apply-status></div>
                    </div>

                    <div class="alert alert-danger d-none" role="alert" data-direct-apply-errors></div>

                    <div class="alert alert-info d-none" role="status" data-direct-apply-completion-note>
                        This stage will be completed without a separate start action. Review or edit the prefilled start date before saving.
                    </div>

                    <div class="mb-3 d-none" data-direct-apply-start-group>
                        <label class="form-label" for="directApplyStartDate">Start date <span class="text-muted">(optional)</span></label>
                        <input type="date" class="form-control" id="directApplyStartDate" name="startDate" />
                        <div class="form-text" data-direct-apply-start-hint>
                            Enter the actual start date. Where available, the day after the effective predecessor's completion is suggested.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="directApplyDate" data-direct-apply-date-label>Effective date</label>
                        <input type="date" class="form-control" id="directApplyDate" name="date" />
                        <div class="form-text" data-direct-apply-date-hint>Optional</div>
                        <div class="alert alert-warning d-none mt-2 mb-0 py-2 px-3" role="status" data-direct-apply-no-date-warning>
                            <div class="d-flex gap-2 align-items-start">
                                <i class="bi bi-shield-check mt-1" aria-hidden="true"></i>
                                <div>
                                    <div class="fw-semibold">Authorised completion override</div>
                                    <div class="small">The workflow will advance without a completion date. Mandatory backfill will be created and the stage will remain administratively incomplete until the date is recorded.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-check mb-3 d-none" data-direct-apply-force-group>
                        <input class="form-check-input" type="checkbox" value="true" id="directApplyForce" name="forceBackfillPredecessors" data-direct-apply-force />
                        <label class="form-check-label" for="directApplyForce">Also complete unresolved predecessor stages</label>
                        <div class="form-text" data-direct-apply-force-hint>Any predecessor completed without a date will be flagged for mandatory backfill.</div>
                    </div>

                    <div class="mb-0">
                        <label class="form-label" for="directApplyNote">Note <span class="text-muted">(optional)</span></label>
                        <textarea class="form-control" id="directApplyNote" name="note" rows="3" maxlength="1024"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" data-direct-apply-submit>Apply change</button>
                </div>
            </form>
        </div>
    </div>
</div>
