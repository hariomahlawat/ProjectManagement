@using System
@using ProjectManagement.Models
@model ProjectManagement.Pages.Projects.OverviewModel

@{
    var project = Model.Project;
    var roles = Model.Roles;
    var isAdmin = roles.IsAdmin;
    var isHoD = roles.IsHoD;
    var isThisProjectsPo = roles.IsAssignedProjectOfficer;
    var isThisProjectsHod = roles.IsAssignedHoD;
    var canManagePhotos = isAdmin || isThisProjectsPo || isThisProjectsHod;
    var canEditDetails = isAdmin || isHoD;
    var canRequestDetails = isThisProjectsPo;
    var projectTypeName = project?.ProjectType?.Name;
    var sponsoringUnitName = project?.SponsoringUnit?.Name;
    var sponsoringDirectorateName = project?.SponsoringLineDirectorate?.Name;
    var coverPhoto = Model.MediaSummary.CoverPhoto ?? Model.CoverPhoto;
    var coverVersion = Model.MediaSummary.CoverPhotoVersion ?? Model.CoverPhotoVersion ?? coverPhoto?.Version;
    Func<ProjectPhoto, string, int?, string> photoUrl = (photo, size, version) =>
        Url.Page("/Projects/Photos/View", new { id = Model.Project!.Id, photoId = photo.Id, size, v = version ?? photo.Version })!;
    var coverXs = coverPhoto != null ? photoUrl(coverPhoto, "xs", coverVersion) : null;
    var coverSm = coverPhoto != null ? photoUrl(coverPhoto, "sm", coverVersion) : null;
    var coverMd = coverPhoto != null ? photoUrl(coverPhoto, "md", coverVersion) : null;
    var coverXl = coverPhoto != null ? photoUrl(coverPhoto, "xl", coverVersion) : null;
    var coverSrcSet = coverPhoto != null
        ? string.Join(", ", new[]
        {
            $"{coverXs} 400w",
            $"{coverSm} 800w",
            $"{coverMd} 1200w",
            $"{coverXl} 1600w"
        })
        : null;

    var missingDetails = Model.Portfolio.MissingProfileFacts;
}

<div class="card pm-card project-profile-card" id="project-profile-details">
    <div class="card-header pm-card-header">
        <div class="pm-card-heading">
            <span class="pm-card-icon" aria-hidden="true">
                <i class="bi bi-layout-text-window"></i>
            </span>
            <div>
                <h2 class="pm-card-title h5 mb-0">Project overview</h2>
                <p class="pm-card-subtitle mb-0">Description and key project facts</p>
            </div>
        </div>
        @if (canManagePhotos || isThisProjectsPo || isAdmin || isHoD)
        {
            <div class="pm-card-menu dropdown">
                <button class="btn pm-card-menu-toggle"
                        type="button"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        aria-label="Project overview actions">
                    <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    @if (canManagePhotos)
                    {
                        <li>
                            <a class="dropdown-item d-flex align-items-center gap-2"
                               asp-page="/Projects/Photos/Index"
                               asp-route-id="@Model.Project!.Id">
                                <i class="bi bi-images" aria-hidden="true"></i>
                                <span>Manage photos</span>
                            </a>
                        </li>
                    }
                    @if (isThisProjectsPo)
                    {
                        <li>
                            <a class="dropdown-item"
                               asp-page="/Projects/Meta/Request"
                               asp-route-id="@Model.Project!.Id">Update details</a>
                        </li>
                    }
                    @if (isAdmin || isHoD)
                    {
                        <li>
                            <a class="dropdown-item"
                               asp-page="/Projects/Meta/Edit"
                               asp-route-id="@Model.Project!.Id">Edit details</a>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
    <div class="card-body pm-card-body">
        <div class="project-profile-flow">
            <figure class="project-cover-float mb-0">
                <div class="project-photo-cover-frame w-100">
                    @if (coverPhoto != null)
                    {
                        <picture>
                            <source type="image/webp"
                                    srcset="@coverSrcSet"
                                    sizes="(min-width: 1400px) 250px, (min-width: 768px) 220px, 100vw" />
                            <img class="w-100 h-100 object-fit-cover rounded border"
                                 src="@coverXs"
                                 srcset="@coverSrcSet"
                                 sizes="(min-width: 1400px) 250px, (min-width: 768px) 220px, 100vw"
                                 alt="@(string.IsNullOrWhiteSpace(coverPhoto.Caption) ? $"{project?.Name} cover photo" : coverPhoto.Caption)" />
                        </picture>
                    }
                    else
                    {
                        <div class="project-photo-cover-empty text-center">
                            <div class="project-photo-cover-empty__icon" aria-hidden="true">
                                <i class="bi bi-image"></i>
                            </div>
                            <div class="project-photo-cover-empty__title">No cover photo</div>
                            @if (canManagePhotos)
                            {
                                <a class="btn btn-sm btn-primary mt-2"
                                   asp-page="/Projects/Photos/Upload"
                                   asp-route-id="@Model.Project!.Id"
                                   asp-route-cover="true">Upload cover</a>
                            }
                        </div>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(coverPhoto?.Caption))
                {
                    <figcaption class="mt-2 text-muted small">@coverPhoto.Caption</figcaption>
                }
            </figure>

            <dl class="project-facts mb-0">
                <dt class="project-facts__label">Category</dt>
                <dd class="project-facts__value">
                    @(Model.CategoryPath.Any() ? string.Join(" › ", Model.CategoryPath.Select(c => c.Name)) : "—")
                </dd>
                @if (Model.TechnicalCategoryPath.Any())
                {
                    <dt class="project-facts__label">Technical category</dt>
                    <dd class="project-facts__value">@string.Join(" › ", Model.TechnicalCategoryPath.Select(c => c.Name))</dd>
                }
                @if (!string.IsNullOrWhiteSpace(projectTypeName))
                {
                    <dt class="project-facts__label">Project type</dt>
                    <dd class="project-facts__value">@projectTypeName</dd>
                }
                <dt class="project-facts__label">Repeat build</dt>
                <dd class="project-facts__value">@((project?.IsBuild ?? false) ? "Yes" : "No")</dd>
                @if (!string.IsNullOrWhiteSpace(sponsoringUnitName))
                {
                    <dt class="project-facts__label">Sponsoring unit</dt>
                    <dd class="project-facts__value">@sponsoringUnitName</dd>
                }
                @if (!string.IsNullOrWhiteSpace(sponsoringDirectorateName))
                {
                    <dt class="project-facts__label">Sponsoring line directorate</dt>
                    <dd class="project-facts__value">@sponsoringDirectorateName</dd>
                }
                <dt class="project-facts__label">Head of Department</dt>
                <dd class="project-facts__value">@FormatUser(project?.HodUser)</dd>
                <dt class="project-facts__label">Project Officer</dt>
                <dd class="project-facts__value">@FormatUser(project?.LeadPoUser)</dd>
                @if (Model.CostSummary.RdCostLakhs.HasValue)
                {
                    <dt class="project-facts__label">Initial procurement / R&amp;D cost</dt>
                    <dd class="project-facts__value">@FormatCost(Model.CostSummary.RdCostLakhs)</dd>
                }
                @if (Model.CostSummary.ApproxProductionCost.HasValue)
                {
                    <dt class="project-facts__label">Approx. production cost</dt>
                    <dd class="project-facts__value">@FormatCost(Model.CostSummary.ApproxProductionCost)</dd>
                }
            </dl>

            @if (!string.IsNullOrWhiteSpace(Model.DescriptionHtml))
            {
                <section class="project-description-block">
                    <h3 class="h6 mb-2">Project description</h3>
                    <div class="project-overview__description pm-markdown">@Html.Raw(Model.DescriptionHtml)</div>
                </section>
            }

            @if (missingDetails.Count > 0)
            {
                <div class="project-profile-missing project-profile-missing--clear" role="status">
                    <div>
                        <strong>@missingDetails.Count recommended detail@(missingDetails.Count == 1 ? string.Empty : "s") missing</strong>
                        <span>@string.Join(", ", missingDetails)</span>
                    </div>
                    @if (canEditDetails)
                    {
                        <a class="btn btn-sm btn-outline-primary" asp-page="/Projects/Meta/Edit" asp-route-id="@Model.Project!.Id">Edit details</a>
                    }
                    else if (canRequestDetails)
                    {
                        <a class="btn btn-sm btn-outline-primary" asp-page="/Projects/Meta/Request" asp-route-id="@Model.Project!.Id">Update details</a>
                    }
                </div>
            }
        </div>
    </div>
</div>

@functions {
    private static string FormatUser(ApplicationUser? user)
    {
        if (user is null) return "—";
        if (!string.IsNullOrWhiteSpace(user.FullName)) return user.FullName!;
        if (!string.IsNullOrWhiteSpace(user.UserName)) return user.UserName!;
        if (!string.IsNullOrWhiteSpace(user.Email)) return user.Email!;
        return "—";
    }

    private static string FormatCost(decimal? costLakhs) =>
        costLakhs.HasValue ? $"{costLakhs.Value:0.##} lakh" : "—";
}
