@using ProjectManagement.ViewModels
@model ProjectPortfolioPresentationVm
<section class="card pm-card project-lifecycle-summary" aria-labelledby="lifecycle-summary-title">
    <div class="card-header pm-card-header">
        <div class="pm-card-heading">
            <span class="pm-card-icon" aria-hidden="true"><i class="bi bi-signpost-split"></i></span>
            <div>
                <h3 id="lifecycle-summary-title" class="pm-card-title h5 mb-0">Lifecycle position</h3>
                <p class="pm-card-subtitle mb-0">Plan health, schedule variance and the next operational action.</p>
            </div>
        </div>
        <button class="btn btn-sm btn-outline-primary" type="button" data-scroll-target="#timeline">Open timeline</button>
    </div>
    <div class="card-body pm-card-body">
        <div class="project-lifecycle-summary__grid">
            <div>
                <span class="project-lifecycle-summary__label">Plan</span>
                <strong>@Model.PlanStatus</strong>
                <span>@Model.PlanHealth</span>
            </div>
            <div>
                <span class="project-lifecycle-summary__label">Backfill</span>
                <strong>@(Model.BackfillStageCount == 0 ? "Clear" : $"{Model.BackfillStageCount} stage{(Model.BackfillStageCount == 1 ? string.Empty : "s")}")</strong>
                <span>@(Model.BackfillStageCount == 0 ? "Completed stages have completion dates" : "Completion dates or required stage facts are missing")</span>
            </div>
            <div>
                <span class="project-lifecycle-summary__label">Schedule variance</span>
                <strong>@(Model.DelayedStageCount == 0 ? "None" : $"{Model.DelayedStageCount} stage{(Model.DelayedStageCount == 1 ? string.Empty : "s")}")</strong>
                <span>@(Model.DelayedStageCount == 0 ? "No current overdue stage or recorded late completion" : "Current stage overdue or completed after planned finish")</span>
            </div>
            <div>
                <span class="project-lifecycle-summary__label">Next action</span>
                <strong class="project-lifecycle-summary__action">@Model.NextAction</strong>
                <span>@(Model.IsWorkflowConcluded && Model.BackfillStageCount == 0 ? "Lifecycle sequence complete" : "Operational follow-up")</span>
            </div>
        </div>
        <div class="project-lifecycle-summary__progress" role="progressbar" aria-valuenow="@Model.ResolvedStages" aria-valuemin="0" aria-valuemax="@Model.ProgressMaximum">
            <span style="--project-progress:@Model.ProgressPercent%"></span>
        </div>
    </div>
</section>
