@page "{id:int}"
@model ProjectManagement.Pages.Projects.Meta.RequestModel
@{
    ViewData["Title"] = "Update Project Details";
    const int descriptionMaxLength = ProjectManagement.Models.ProjectFieldLimits.DescriptionMaxLength;
}
<div class="container-xl project-meta-update">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Projects/Index">Projects</a></li>
            <li class="breadcrumb-item"><a asp-page="/Projects/Overview" asp-route-id="@Model.Input.ProjectId">@Model.ProjectName</a></li>
            <li class="breadcrumb-item active" aria-current="page">Update details</li>
        </ol>
    </nav>

    <header class="project-meta-header">
        <a asp-page="/Projects/Overview" asp-route-id="@Model.Input.ProjectId" class="project-meta-back"><i class="bi bi-arrow-left"></i> Back to project</a>
        <h1>Update project details</h1>
        <p class="project-meta-project-name">@Model.ProjectName</p>
        <p class="text-muted mb-0">Review the complete proposed record below. Changes will be submitted to the Head of Department for approval.</p>
    </header>

    @if (Model.HasPendingRequest)
    {
        <div class="alert alert-warning project-meta-pending" role="status">
            <i class="bi bi-clock-history" aria-hidden="true"></i>
            <div><strong>A project-details update is already awaiting HoD approval.</strong><br />Saving this form will revise that pending submission; earlier proposed values have been loaded below.</div>
        </div>
    }

    <form method="post" class="project-meta-form">
        <input asp-for="Input.ProjectId" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <section class="card pm-card project-meta-section">
            <div class="card-header"><h2>Basic information</h2><p>Name, description and case reference.</p></div>
            <div class="card-body">
                <div class="mb-3"><label asp-for="Input.Name" class="form-label"></label><input asp-for="Input.Name" class="form-control" /><span asp-validation-for="Input.Name" class="text-danger"></span></div>
                <div class="mb-3"><label asp-for="Input.Description" class="form-label"></label><textarea asp-for="Input.Description" rows="5" class="form-control" maxlength="@descriptionMaxLength"></textarea><span asp-validation-for="Input.Description" class="text-danger"></span></div>
                <div><label asp-for="Input.CaseFileNumber" class="form-label">Case file number</label><input asp-for="Input.CaseFileNumber" class="form-control" placeholder="Not specified" /><span asp-validation-for="Input.CaseFileNumber" class="text-danger"></span></div>
            </div>
        </section>

        <section class="card pm-card project-meta-section">
            <div class="card-header"><h2>Classification</h2><p>Project category, technical domain and build type.</p></div>
            <div class="card-body"><div class="row g-3">
                <div class="col-md-6"><label asp-for="Input.CategoryId" class="form-label">Category</label><select asp-for="Input.CategoryId" class="form-select" asp-items="Model.CategoryOptions"></select><span asp-validation-for="Input.CategoryId" class="text-danger"></span></div>
                <div class="col-md-6"><label asp-for="Input.TechnicalCategoryId" class="form-label">Technical category</label><select asp-for="Input.TechnicalCategoryId" class="form-select" asp-items="Model.TechnicalCategoryOptions"></select><span asp-validation-for="Input.TechnicalCategoryId" class="text-danger"></span></div>
                <div class="col-md-6"><label asp-for="Input.ProjectTypeId" class="form-label">Project type</label><select asp-for="Input.ProjectTypeId" class="form-select" asp-items="Model.ProjectTypeOptions"></select><span asp-validation-for="Input.ProjectTypeId" class="text-danger"></span></div>
                <div class="col-md-6"><label asp-for="Input.IsBuild" class="form-label">Repeat build or re-manufacture</label><select asp-for="Input.IsBuild" class="form-select"><option value="false">No</option><option value="true">Yes</option></select><span asp-validation-for="Input.IsBuild" class="text-danger"></span></div>
            </div></div>
        </section>

        <section class="card pm-card project-meta-section">
            <div class="card-header"><h2>Sponsorship</h2><p>Operational sponsor and responsible line directorate.</p></div>
            <div class="card-body"><div class="row g-3">
                <div class="col-md-6"><label asp-for="Input.SponsoringUnitId" class="form-label">Sponsoring unit</label><select asp-for="Input.SponsoringUnitId" class="form-select js-async-select" asp-items="Model.SponsoringUnitOptions" data-source="/api/lookups/sponsoring-units" data-search-placeholder="Search sponsoring units"></select><span asp-validation-for="Input.SponsoringUnitId" class="text-danger"></span></div>
                <div class="col-md-6"><label asp-for="Input.SponsoringLineDirectorateId" class="form-label">Sponsoring line directorate</label><select asp-for="Input.SponsoringLineDirectorateId" class="form-select js-async-select" asp-items="Model.LineDirectorateOptions" data-source="/api/lookups/line-directorates" data-search-placeholder="Search line directorates"></select><span asp-validation-for="Input.SponsoringLineDirectorateId" class="text-danger"></span></div>
            </div></div>
        </section>

        <section class="card pm-card project-meta-section">
            <div class="card-header"><h2>Submission</h2><p>Explain why this project record is being revised.</p></div>
            <div class="card-body"><label asp-for="Input.Reason" class="form-label"></label><textarea asp-for="Input.Reason" rows="4" class="form-control" placeholder="Briefly explain the purpose of this update and any important context for the HoD."></textarea><div class="form-text">This note will be visible during approval and retained in the audit trail.</div><span asp-validation-for="Input.Reason" class="text-danger"></span></div>
        </section>

        <div class="project-meta-actions">
            <a asp-page="/Projects/Overview" asp-route-id="@Model.Input.ProjectId" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i> @(Model.HasPendingRequest ? "Update pending submission" : "Submit for approval")</button>
        </div>
    </form>
</div>
@section Styles { <link rel="stylesheet" href="~/css/pages/project-meta-request.css" asp-append-version="true" /> }
@section Scripts { <partial name="_ValidationScriptsPartial" /><script src="~/js/widgets/async-select.js" asp-append-version="true" defer></script> }
