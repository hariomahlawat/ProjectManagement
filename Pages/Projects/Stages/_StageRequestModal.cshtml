@{
    Layout = null;
}

<div class="modal fade" id="stageRequestModal" tabindex="-1" aria-labelledby="stageRequestLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable stage-update-modal-dialog">
        <div class="modal-content">
            <form method="post" class="stage-update-modal-form" data-stage-request-form novalidate>
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title" id="stageRequestLabel" data-stage-update-title>Update stage</h5>
                        <div class="small text-muted" data-stage-update-subtitle>Record the proposed project-stage update.</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="projectId" />
                    @Html.AntiForgeryToken()

                    <div class="alert alert-danger d-none" role="alert" data-stage-request-errors></div>
                    <div class="alert alert-warning d-none" role="alert" data-stage-request-conflict>
                        This stage already has an update awaiting approval. Saving will replace only that stage's pending update; pending updates for other stages remain unchanged.
                    </div>

                    <div class="stage-update-approval-note mb-3">
                        <i class="bi bi-shield-check" aria-hidden="true"></i>
                        <div>
                            <strong>HoD approval applies</strong>
                            <span>This update will be visible immediately. The official lifecycle status and progress will change only after HoD approval.</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-3">
                            <div>
                                <div class="fw-semibold">Stage update</div>
                                <div class="text-muted small">Add one or more stage updates. Existing pending updates remain active unless revised here.</div>
                            </div>
                            <button class="btn btn-sm btn-outline-secondary stage-update-add-button" type="button" data-stage-request-add>
                                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                                Add stage
                            </button>
                        </div>

                        <div class="d-flex flex-column gap-3" data-stage-request-rows></div>
                        <template data-stage-request-row-template>
                            <section class="stage-update-row" data-stage-request-row>
                                <div class="stage-update-row__header">
                                    <div>
                                        <div class="fw-semibold" data-stage-request-row-title>Stage</div>
                                        <div class="small text-muted" data-stage-request-current-state></div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-danger" type="button" data-stage-request-remove>
                                        Remove
                                    </button>
                                </div>

                                <div class="row g-3 align-items-end">
                                    <div class="col-lg-4" data-stage-request-stage-field>
                                        <label class="form-label mb-1">Stage</label>
                                        <select class="form-select" data-stage-request-stage></select>
                                    </div>
                                    <div class="col-lg-3">
                                        <label class="form-label mb-1">Update to</label>
                                        <select class="form-select" data-stage-request-target></select>
                                        <div class="form-text" data-stage-request-status-hint></div>
                                    </div>
                                    <div class="col-lg-2 d-none" data-stage-request-start-group>
                                        <label class="form-label mb-1">Start date <span class="text-muted">(optional)</span></label>
                                        <input type="date" class="form-control" data-stage-request-start-date />
                                        <div class="form-text" data-stage-request-start-hint></div>
                                    </div>
                                    <div class="col-lg-3">
                                        <label class="form-label mb-1" data-stage-request-date-label>Effective date</label>
                                        <input type="date" class="form-control" data-stage-request-date />
                                        <div class="form-text" data-stage-request-date-hint>Optional</div>
                                    </div>
                                </div>

                                <div class="stage-update-carried-start d-none" data-stage-request-carried-start>
                                    <i class="bi bi-arrow-right-circle" aria-hidden="true"></i>
                                    <span data-stage-request-carried-start-text></span>
                                </div>

                                <div class="mt-3">
                                    <label class="form-label mb-1">
                                        Note
                                        <span class="text-muted" data-stage-request-note-qualifier>(optional)</span>
                                    </label>
                                    <textarea class="form-control" rows="2" maxlength="1024" data-stage-request-note></textarea>
                                    <div class="form-text" data-stage-request-note-hint>Add context for the HoD where useful.</div>
                                </div>
                            </section>
                        </template>
                    </div>

                    <div class="stage-update-summary" data-stage-request-preview>
                        <div class="d-flex flex-wrap justify-content-between gap-2 mb-2">
                            <div class="fw-semibold">Projected lifecycle</div>
                            <div class="small text-muted">Existing pending updates are shown for context. Official progress changes after HoD approval.</div>
                        </div>
                        <ol class="mb-0 small stage-update-summary__list" data-stage-request-summary></ol>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" data-stage-request-submit>Submit update</button>
                </div>
            </form>
        </div>
    </div>
</div>
