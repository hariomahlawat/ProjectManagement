@page
@model ProjectManagement.Pages.Projects.CompletedSummary.IndexModel
@using ProjectManagement.Models
@using ProjectManagement.Models.Projects
@using ProjectManagement.Services.Projects
@using System.Globalization
@{
    ViewData["Title"] = "Completed projects";
    ViewData["UseFullWidth"] = true;

    var items = Model.Items;
    var total = items.Count;
    var currentCount = items.Count(x => string.Equals(x.TechStatus, ProjectTechStatusCodes.Current, StringComparison.OrdinalIgnoreCase));
    var outdatedCount = items.Count(x => string.Equals(x.TechStatus, ProjectTechStatusCodes.Outdated, StringComparison.OrdinalIgnoreCase));
    var techMissingCount = items.Count(x => string.IsNullOrWhiteSpace(x.TechStatus));
    var readyCount = items.Count(x =>
        string.Equals(x.TechStatus, ProjectTechStatusCodes.Current, StringComparison.OrdinalIgnoreCase)
        && x.AvailableForProliferation == true
        && (x.TotStatus == ProjectTotStatus.Completed || x.TotStatus == ProjectTotStatus.NotRequired));
    var availableCount = items.Count(x => x.AvailableForProliferation == true);
    var totCompleteCount = items.Count(x => x.TotStatus == ProjectTotStatus.Completed);
    var totPendingCount = items.Count(x => x.TotStatus == ProjectTotStatus.NotStarted || x.TotStatus == ProjectTotStatus.InProgress);
    var dataGapCount = items.Count(x => string.IsNullOrWhiteSpace(x.TechStatus)
        || !x.AvailableForProliferation.HasValue
        || !x.TotStatus.HasValue
        || !x.RdCostLakhs.HasValue);
    var recordedInvestment = items.Where(x => x.RdCostLakhs.HasValue).Sum(x => x.RdCostLakhs ?? 0m);

    static string FormatMoney(decimal? value)
    {
        if (!value.HasValue) return "—";
        return value.Value >= 100m
            ? $"₹{value.Value / 100m:0.##} Cr"
            : $"₹{value.Value:0.##} L";
    }

    static string TotLabel(ProjectTotStatus? status) => status switch
    {
        ProjectTotStatus.Completed => "Completed",
        ProjectTotStatus.InProgress => "In progress",
        ProjectTotStatus.NotStarted => "Not started",
        ProjectTotStatus.NotRequired => "Not required",
        _ => "Not assessed"
    };

    static string TotTone(ProjectTotStatus? status) => status switch
    {
        ProjectTotStatus.Completed => "positive",
        ProjectTotStatus.NotRequired => "neutral",
        ProjectTotStatus.InProgress => "info",
        ProjectTotStatus.NotStarted => "warning",
        _ => "muted"
    };

    static int MissingCount(CompletedProjectSummaryDto item)
    {
        var missing = 0;
        if (string.IsNullOrWhiteSpace(item.TechStatus)) missing++;
        if (!item.AvailableForProliferation.HasValue) missing++;
        if (!item.TotStatus.HasValue) missing++;
        if (!item.RdCostLakhs.HasValue) missing++;
        if (!item.ApproxProductionCost.HasValue) missing++;
        if (item.LatestLpp is null) missing++;
        return missing;
    }

    static string MissingFields(CompletedProjectSummaryDto item)
    {
        var fields = new List<string>();
        if (string.IsNullOrWhiteSpace(item.TechStatus)) fields.Add("Technology assessment");
        if (!item.AvailableForProliferation.HasValue) fields.Add("Proliferation decision");
        if (!item.TotStatus.HasValue) fields.Add("ToT status");
        if (!item.RdCostLakhs.HasValue) fields.Add("Development cost");
        if (!item.ApproxProductionCost.HasValue) fields.Add("Production cost");
        if (item.LatestLpp is null) fields.Add("Latest LPP");
        return string.Join(", ", fields);
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/projects-completed-summary.css" asp-append-version="true" />
}

<div class="cpw" data-default-view="portfolio">
    <header class="cpw-commandbar">
        <div class="cpw-titleblock">
            <div class="cpw-kicker">Completed project portfolio</div>
            <div class="cpw-titleline">
                <h1>Completed projects</h1>
                <span class="cpw-count">@total</span>
            </div>
            <p>Portfolio readiness, technology health, transfer-of-technology maturity and financial visibility.</p>
        </div>
        <div class="cpw-command-actions">
            <button type="button" class="cpw-btn cpw-btn-ghost" data-filter-toggle aria-expanded="false" aria-controls="cpwFilters">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16M7 12h10M10 18h4"/></svg>
                Filters
                @if (Model.HasActiveFilters)
                {
                    <span class="cpw-filter-count">@Model.ActiveFilterCount</span>
                }
            </button>
            <a asp-page="./Index"
               asp-page-handler="Export"
               asp-route-TechnicalCategoryId="@Model.TechnicalCategoryId"
               asp-route-TechStatus="@Model.TechStatus"
               asp-route-AvailableForProliferation="@Model.AvailableForProliferation"
               asp-route-TotCompleted="@Model.TotCompleted"
               asp-route-CompletedYear="@Model.CompletedYear"
               asp-route-Search="@Model.Search"
               asp-route-Build="@Model.Build"
               asp-route-Sort="@Model.Sort"
               asp-route-Dir="@Model.Dir"
               class="cpw-btn cpw-btn-primary">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12m0 0 4-4m-4 4-4-4M5 19h14"/></svg>
                Export portfolio
            </a>
        </div>
    </header>

    <section class="cpw-filter-panel @(Model.HasActiveFilters ? "is-open" : string.Empty)" id="cpwFilters" data-filter-panel>
        <form method="get" id="cpwFiltersForm" class="cpw-filter-form">
            <div class="cpw-search-field">
                <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
                <input asp-for="Search" placeholder="Search by project name…" autocomplete="off" />
            </div>
            <label class="cpw-field"><span>Technical category</span><select asp-for="TechnicalCategoryId" asp-items="Model.TechnicalCategoryOptions"></select></label>
            <label class="cpw-field"><span>Technology</span><select asp-for="TechStatus" asp-items="Model.TechStatusOptions"></select></label>
            <label class="cpw-field"><span>Completion year</span><input asp-for="CompletedYear" inputmode="numeric" placeholder="All years" /></label>
            <label class="cpw-field"><span>Proliferation</span><select asp-for="AvailableForProliferation" asp-items="Model.AvailabilityOptions"></select></label>
            <label class="cpw-field"><span>ToT</span><select asp-for="TotCompleted" asp-items="Model.TotStatusOptions"></select></label>
            <div class="cpw-build-field">
                <span>Build type</span>
                <div class="cpw-segmented">
                    <label><input type="radio" name="Build" value="" @(string.IsNullOrWhiteSpace(Model.Build) ? "checked" : null) /><span>All</span></label>
                    <label><input type="radio" name="Build" value="New" @(string.Equals(Model.Build, "New", StringComparison.OrdinalIgnoreCase) ? "checked" : null) /><span>New</span></label>
                    <label><input type="radio" name="Build" value="Rebuild" @(string.Equals(Model.Build, "Rebuild", StringComparison.OrdinalIgnoreCase) ? "checked" : null) /><span>Rebuild</span></label>
                </div>
            </div>
            <input type="hidden" asp-for="Sort" />
            <input type="hidden" asp-for="Dir" />
            <div class="cpw-filter-actions">
                @if (Model.HasActiveFilters)
                {
                    <a asp-page="./Index" class="cpw-btn cpw-btn-ghost">Clear</a>
                }
                <button type="submit" class="cpw-btn cpw-btn-primary">Apply filters</button>
            </div>
        </form>
    </section>

    <section class="cpw-lenses" aria-label="Strategic portfolio lenses">
        <button type="button" class="cpw-lens is-active" data-lens="all">
            <span class="cpw-lens-icon neutral"><svg viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="3"/><path d="M8 9h8M8 13h8M8 17h5"/></svg></span>
            <span><strong>@total</strong><small>Whole portfolio</small></span>
        </button>
        <button type="button" class="cpw-lens" data-lens="ready">
            <span class="cpw-lens-icon positive"><svg viewBox="0 0 24 24"><path d="m5 12 4 4L19 6"/></svg></span>
            <span><strong>@readyCount</strong><small>Ready for proliferation</small><em>@availableCount available overall</em></span>
        </button>
        <button type="button" class="cpw-lens" data-lens="refresh">
            <span class="cpw-lens-icon warning"><svg viewBox="0 0 24 24"><path d="M12 8v5m0 3h.01M10.3 4.5 3.7 16a2 2 0 0 0 1.7 3h13.2a2 2 0 0 0 1.7-3L13.7 4.5a2 2 0 0 0-3.4 0Z"/></svg></span>
            <span><strong>@outdatedCount</strong><small>Technology refresh</small><em>@techMissingCount not assessed</em></span>
        </button>
        <button type="button" class="cpw-lens" data-lens="tot-pending">
            <span class="cpw-lens-icon info"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
            <span><strong>@totPendingCount</strong><small>ToT action pending</small><em>@totCompleteCount completed</em></span>
        </button>
        <button type="button" class="cpw-lens" data-lens="data-gap">
            <span class="cpw-lens-icon danger"><svg viewBox="0 0 24 24"><path d="M4 5h16v14H4zM8 9h8M8 13h5"/></svg></span>
            <span><strong>@dataGapCount</strong><small>Critical data gaps</small><em>Requires record action</em></span>
        </button>
    </section>

    <section class="cpw-intelligence-grid">
        <article class="cpw-intelligence-card cpw-investment-card">
            <div class="cpw-card-label">Recorded development value</div>
            <div class="cpw-investment-value">@FormatMoney(recordedInvestment)</div>
            <div class="cpw-card-note">Across @items.Count(x => x.RdCostLakhs.HasValue) projects with recorded cost</div>
        </article>

        <article class="cpw-intelligence-card">
            <div class="cpw-card-heading"><span>Technology health</span><strong>@currentCount current</strong></div>
            <div class="cpw-stacked-bar" aria-label="Technology status distribution">
                @if (total > 0)
                {
                    <span class="is-current" style="width:@(currentCount * 100d / total)%"></span>
                    <span class="is-outdated" style="width:@(outdatedCount * 100d / total)%"></span>
                    <span class="is-unknown" style="width:@(techMissingCount * 100d / total)%"></span>
                }
            </div>
            <div class="cpw-bar-legend"><span><i class="current"></i>Current @currentCount</span><span><i class="outdated"></i>Outdated @outdatedCount</span><span><i class="unknown"></i>Not assessed @techMissingCount</span></div>
        </article>

        <article class="cpw-intelligence-card">
            <div class="cpw-card-heading"><span>Readiness conversion</span><strong>@readyCount fully ready</strong></div>
            <div class="cpw-readiness-flow">
                <div><b>@currentCount</b><span>Current</span></div><i>→</i><div><b>@availableCount</b><span>Available</span></div><i>→</i><div class="final"><b>@readyCount</b><span>Ready</span></div>
            </div>
            <div class="cpw-card-note">Current technology + proliferation available + ToT complete/not required</div>
        </article>
    </section>

    <div class="cpw-workspace-toolbar">
        <div class="cpw-view-tabs" role="tablist" aria-label="Workspace view">
            <button type="button" class="is-active" data-view="portfolio" role="tab" aria-selected="true">Portfolio</button>
            <button type="button" data-view="register" role="tab" aria-selected="false">Register</button>
            <button type="button" data-view="quality" role="tab" aria-selected="false">Data quality</button>
        </div>
        <div class="cpw-workspace-meta">
            <span data-visible-count>@total</span> projects in current lens
        </div>
    </div>

    <main class="cpw-workspace">
        <section class="cpw-view is-active" data-view-panel="portfolio">
            @if (total == 0)
            {
                <div class="cpw-empty"><h2>No completed projects found</h2><p>Adjust or clear the selected filters.</p></div>
            }
            else
            {
                <div class="cpw-portfolio-grid">
                    @foreach (var item in items)
                    {
                        var isReady = string.Equals(item.TechStatus, ProjectTechStatusCodes.Current, StringComparison.OrdinalIgnoreCase)
                            && item.AvailableForProliferation == true
                            && (item.TotStatus == ProjectTotStatus.Completed || item.TotStatus == ProjectTotStatus.NotRequired);
                        var isRefresh = string.Equals(item.TechStatus, ProjectTechStatusCodes.Outdated, StringComparison.OrdinalIgnoreCase);
                        var isTotPending = item.TotStatus == ProjectTotStatus.NotStarted || item.TotStatus == ProjectTotStatus.InProgress;
                        var hasDataGap = string.IsNullOrWhiteSpace(item.TechStatus) || !item.AvailableForProliferation.HasValue || !item.TotStatus.HasValue || !item.RdCostLakhs.HasValue;
                        var missingCount = MissingCount(item);
                        <article class="cpw-project-card"
                                 data-project
                                 data-ready="@isReady.ToString().ToLowerInvariant()"
                                 data-refresh="@isRefresh.ToString().ToLowerInvariant()"
                                 data-tot-pending="@isTotPending.ToString().ToLowerInvariant()"
                                 data-data-gap="@hasDataGap.ToString().ToLowerInvariant()"
                                 data-name="@item.Name.ToLowerInvariant()">
                            <button type="button" class="cpw-card-hit" data-open-project="@item.ProjectId" aria-label="Open @item.Name"></button>
                            <div class="cpw-project-topline">
                                <span class="cpw-year">@(item.CompletedYear?.ToString() ?? "Year not recorded")</span>
                                @if (missingCount > 0)
                                {
                                    <span class="cpw-completeness" title="@MissingFields(item)">@missingCount data gap@(missingCount == 1 ? "" : "s")</span>
                                }
                                else
                                {
                                    <span class="cpw-completeness is-complete">Record complete</span>
                                }
                            </div>
                            <h2>@item.Name</h2>
                            <div class="cpw-project-value"><span>Development value</span><strong>@FormatMoney(item.RdCostLakhs)</strong></div>
                            <div class="cpw-status-rail">
                                <div class="@(string.Equals(item.TechStatus, ProjectTechStatusCodes.Current, StringComparison.OrdinalIgnoreCase) ? "is-positive" : isRefresh ? "is-warning" : "is-muted")">
                                    <span>Technology</span><b>@(string.IsNullOrWhiteSpace(item.TechStatus) ? "Not assessed" : item.TechStatus)</b>
                                </div>
                                <div class="@(item.AvailableForProliferation == true ? "is-positive" : item.AvailableForProliferation == false ? "is-negative" : "is-muted")">
                                    <span>Proliferation</span><b>@(item.AvailableForProliferation == true ? "Available" : item.AvailableForProliferation == false ? "Not available" : "Not assessed")</b>
                                </div>
                                <div class="is-@TotTone(item.TotStatus)"><span>ToT</span><b>@TotLabel(item.TotStatus)</b></div>
                            </div>
                            <div class="cpw-project-footer">
                                <span>Latest LPP: @(item.LatestLpp is null ? "Not recorded" : FormatMoney(item.LatestLpp.Amount))</span>
                                <span class="cpw-open-label">Open record <b>→</b></span>
                            </div>
                        </article>
                    }
                </div>
                <div class="cpw-no-lens-results" hidden>No projects match this strategic lens.</div>
            }
        </section>

        <section class="cpw-view" data-view-panel="register" hidden>
            <div class="cpw-register-shell">
                <div class="cpw-register-head">
                    <div><h2>Portfolio register</h2><p>High-density comparison across lifecycle, cost and readiness.</p></div>
                    <span>@total records</span>
                </div>
                <div class="cpw-table-scroll">
                    <table class="cpw-table">
                        <thead><tr>
                            <th>Project</th><th>Completed</th><th>Development</th><th>Production</th><th>Latest LPP</th><th>Technology</th><th>Proliferation</th><th>ToT</th><th>Data quality</th><th></th>
                        </tr></thead>
                        <tbody>
                        @foreach (var item in items)
                        {
                            var isReady = string.Equals(item.TechStatus, ProjectTechStatusCodes.Current, StringComparison.OrdinalIgnoreCase)
                                && item.AvailableForProliferation == true
                                && (item.TotStatus == ProjectTotStatus.Completed || item.TotStatus == ProjectTotStatus.NotRequired);
                            var isRefresh = string.Equals(item.TechStatus, ProjectTechStatusCodes.Outdated, StringComparison.OrdinalIgnoreCase);
                            var isTotPending = item.TotStatus == ProjectTotStatus.NotStarted || item.TotStatus == ProjectTotStatus.InProgress;
                            var hasDataGap = string.IsNullOrWhiteSpace(item.TechStatus) || !item.AvailableForProliferation.HasValue || !item.TotStatus.HasValue || !item.RdCostLakhs.HasValue;
                            var missingCount = MissingCount(item);
                            <tr data-project data-ready="@isReady.ToString().ToLowerInvariant()" data-refresh="@isRefresh.ToString().ToLowerInvariant()" data-tot-pending="@isTotPending.ToString().ToLowerInvariant()" data-data-gap="@hasDataGap.ToString().ToLowerInvariant()" data-name="@item.Name.ToLowerInvariant()">
                                <td><button type="button" class="cpw-project-link" data-open-project="@item.ProjectId">@item.Name</button></td>
                                <td>@(item.CompletedYear?.ToString() ?? "—")</td>
                                <td class="cpw-num">@FormatMoney(item.RdCostLakhs)</td>
                                <td class="cpw-num">@FormatMoney(item.ApproxProductionCost)</td>
                                <td>@(item.LatestLpp is null ? "—" : FormatMoney(item.LatestLpp.Amount))</td>
                                <td><span class="cpw-inline-status @(isRefresh ? "warning" : string.Equals(item.TechStatus, ProjectTechStatusCodes.Current, StringComparison.OrdinalIgnoreCase) ? "positive" : "muted")">@(string.IsNullOrWhiteSpace(item.TechStatus) ? "Not assessed" : item.TechStatus)</span></td>
                                <td><span class="cpw-inline-status @(item.AvailableForProliferation == true ? "positive" : item.AvailableForProliferation == false ? "negative" : "muted")">@(item.AvailableForProliferation == true ? "Available" : item.AvailableForProliferation == false ? "Not available" : "Not assessed")</span></td>
                                <td><span class="cpw-inline-status @TotTone(item.TotStatus)">@TotLabel(item.TotStatus)</span></td>
                                <td><span class="cpw-quality-score @(missingCount == 0 ? "complete" : missingCount <= 2 ? "partial" : "poor")">@(missingCount == 0 ? "Complete" : $"{missingCount} missing")</span></td>
                                <td><button type="button" class="cpw-row-open" data-open-project="@item.ProjectId" aria-label="Open @item.Name">→</button></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="cpw-view" data-view-panel="quality" hidden>
            <div class="cpw-quality-layout">
                <aside class="cpw-quality-summary">
                    <div class="cpw-card-label">Portfolio completeness</div>
                    <div class="cpw-quality-donut" style="--score:@(total == 0 ? 0 : Math.Round((total - dataGapCount) * 100d / total))">
                        <strong>@(total == 0 ? 0 : Math.Round((total - dataGapCount) * 100d / total))%</strong><span>critical fields complete</span>
                    </div>
                    <p>Critical fields: technology assessment, proliferation decision, ToT status and development cost.</p>
                </aside>
                <div class="cpw-quality-list">
                    <div class="cpw-quality-list-head"><div><h2>Records requiring attention</h2><p>Prioritised by number of missing data points.</p></div></div>
                    @foreach (var item in items.OrderByDescending(x => MissingCount(x)).ThenBy(x => x.Name))
                    {
                        var missing = MissingCount(item);
                        var isReady = string.Equals(item.TechStatus, ProjectTechStatusCodes.Current, StringComparison.OrdinalIgnoreCase)
                            && item.AvailableForProliferation == true
                            && (item.TotStatus == ProjectTotStatus.Completed || item.TotStatus == ProjectTotStatus.NotRequired);
                        var isRefresh = string.Equals(item.TechStatus, ProjectTechStatusCodes.Outdated, StringComparison.OrdinalIgnoreCase);
                        var isTotPending = item.TotStatus == ProjectTotStatus.NotStarted || item.TotStatus == ProjectTotStatus.InProgress;
                        var hasDataGap = string.IsNullOrWhiteSpace(item.TechStatus) || !item.AvailableForProliferation.HasValue || !item.TotStatus.HasValue || !item.RdCostLakhs.HasValue;
                        <article class="cpw-quality-row" data-project data-ready="@isReady.ToString().ToLowerInvariant()" data-refresh="@isRefresh.ToString().ToLowerInvariant()" data-tot-pending="@isTotPending.ToString().ToLowerInvariant()" data-data-gap="@hasDataGap.ToString().ToLowerInvariant()" data-name="@item.Name.ToLowerInvariant()">
                            <div class="cpw-quality-rank @(missing == 0 ? "complete" : missing <= 2 ? "partial" : "poor")">@(missing == 0 ? "✓" : missing.ToString())</div>
                            <div class="cpw-quality-main"><button type="button" data-open-project="@item.ProjectId">@item.Name</button><span>@(missing == 0 ? "No missing portfolio fields" : MissingFields(item))</span></div>
                            <div class="cpw-quality-action">@(missing == 0 ? "Complete" : $"{missing} field{(missing == 1 ? "" : "s")}")</div>
                        </article>
                    }
                </div>
            </div>
        </section>
    </main>

    @foreach (var item in items)
    {
        var missing = MissingCount(item);
        <template id="cpw-project-@item.ProjectId">
            <div class="cpw-drawer-content">
                <div class="cpw-drawer-kicker">Completed project · @(item.CompletedYear?.ToString() ?? "Year not recorded")</div>
                <h2>@item.Name</h2>
                <div class="cpw-drawer-status-grid">
                    <div><span>Technology</span><strong>@(string.IsNullOrWhiteSpace(item.TechStatus) ? "Not assessed" : item.TechStatus)</strong></div>
                    <div><span>Proliferation</span><strong>@(item.AvailableForProliferation == true ? "Available" : item.AvailableForProliferation == false ? "Not available" : "Not assessed")</strong></div>
                    <div><span>ToT</span><strong>@TotLabel(item.TotStatus)</strong></div>
                </div>
                <div class="cpw-drawer-section"><h3>Financial picture</h3><dl><div><dt>Development / L1 cost</dt><dd>@FormatMoney(item.RdCostLakhs)</dd></div><div><dt>Approx. production cost</dt><dd>@FormatMoney(item.ApproxProductionCost)</dd></div><div><dt>Latest LPP</dt><dd>@(item.LatestLpp is null ? "Not recorded" : $"{FormatMoney(item.LatestLpp.Amount)} · {item.LatestLpp.Date:dd MMM yyyy}")</dd></div></dl></div>
                <div class="cpw-drawer-section"><h3>Data quality</h3><p>@(missing == 0 ? "All portfolio fields are recorded." : $"Missing: {MissingFields(item)}")</p></div>
                <div class="cpw-drawer-section"><h3>Remarks</h3><p class="cpw-remarks">@(string.IsNullOrWhiteSpace(item.Remarks) ? "No remarks recorded." : item.Remarks)</p></div>
                @if (Model.CanEdit)
                {
                    <a asp-page="./Edit" asp-route-id="@item.ProjectId" class="cpw-btn cpw-btn-primary cpw-drawer-edit">Edit completed-project record</a>
                }
            </div>
        </template>
    }

    <div class="cpw-drawer-backdrop" data-drawer-backdrop hidden></div>
    <aside class="cpw-drawer" data-drawer aria-hidden="true" aria-label="Project details">
        <div class="cpw-drawer-header"><span>Project intelligence</span><button type="button" data-close-drawer aria-label="Close">×</button></div>
        <div data-drawer-body></div>
    </aside>
</div>

@section Scripts {
    <script src="~/js/pages/projects-completed-summary.js" asp-append-version="true"></script>
}
