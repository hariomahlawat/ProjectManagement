@page
@model ProjectManagement.Pages.Process.IndexModel
@{
    ViewData["Title"] = "Procurement Process";
    var updatedText = Model.ProcessUpdatedOn.HasValue
        ? Model.ProcessUpdatedOn.Value.ToLocalTime().ToString("dd MMM yyyy")
        : "Not available";
}

<section class="process-page" data-process-flow-root
         data-process-version="@Model.ProcessVersion"
         data-can-edit="@(Model.CanEditChecklist ? "true" : "false")">
    <header class="process-header">
        <div class="process-header__copy">
            <div class="process-eyebrow">PROCUREMENT GOVERNANCE</div>
            <div class="process-title-row">
                <h1>Procurement process</h1>
                <span class="process-version">Version @Model.ProcessVersion</span>
            </div>
            <p>Review the complete procurement lifecycle and stage-wise processing checks.</p>
        </div>
        <div class="process-header__meta">
            <div class="process-updated">
                <span>Checklist updated</span>
                <strong>@updatedText</strong>
            </div>
            <button type="button" class="btn btn-outline-secondary process-action process-action--icon" data-action="print-process" title="Print process" aria-label="Print process">
                <i class="bi bi-printer" aria-hidden="true"></i>
            </button>
        </div>
    </header>

    <section class="process-commandbar" aria-label="Process navigation controls">
        <div class="process-search-wrap">
            <i class="bi bi-search" aria-hidden="true"></i>
            <input type="search" class="form-control" placeholder="Search stages or checklist items…" data-stage-search aria-label="Search stages and checklists" />
            <button type="button" class="btn process-search-clear" data-search-clear aria-label="Clear search" hidden>
                <i class="bi bi-x-lg" aria-hidden="true"></i>
            </button>
        </div>
        <div class="process-jump-wrap">
            <label for="processStageJump" class="visually-hidden">Jump to stage</label>
            <select id="processStageJump" class="form-select" data-stage-jump>
                <option value="">Jump to stage…</option>
            </select>
        </div>
        <div class="process-command-actions">
            <button type="button" class="btn btn-outline-secondary process-action" data-action="show-overview">
                <i class="bi bi-grid-3x3-gap" aria-hidden="true"></i>
                <span>Process overview</span>
            </button>
            <button type="button" class="btn btn-outline-secondary process-action" data-action="toggle-fullscreen">
                <i class="bi bi-arrows-fullscreen" aria-hidden="true"></i>
                <span>Full screen</span>
            </button>
        </div>
    </section>

    <div class="process-workspace" data-process-workspace>
        <main class="process-map-panel" aria-label="Procurement process map">
            <div class="process-map-toolbar">
                <div>
                    <h2>Lifecycle map</h2>
                    <p><span data-stage-count>15</span> stages · six governance phases</p>
                </div>
                <div class="process-legend" aria-label="Process map legend">
                    <span><i class="legend-dot legend-dot--mandatory"></i>Mandatory</span>
                    <span><i class="legend-dot legend-dot--optional"></i>Optional</span>
                    <span><i class="legend-dot legend-dot--selected"></i>Selected</span>
                </div>
            </div>

            <div class="process-phase-strip" data-phase-strip aria-label="Process phases"></div>

            <div class="process-map" data-flow-canvas aria-live="polite" aria-busy="true">
                <div class="process-loading" data-flow-placeholder>
                    <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
                    <span>Loading procurement workflow…</span>
                </div>
            </div>
        </main>

        <aside class="stage-inspector d-none d-xl-flex" data-stage-inspector aria-label="Stage guidance">
            <div class="stage-inspector__empty" data-stage-empty>
                <div class="stage-inspector__empty-icon"><i class="bi bi-signpost-split" aria-hidden="true"></i></div>
                <h2>Stage guidance</h2>
                <p>Select any stage in the lifecycle map to view its processing checklist, dependencies and next action.</p>
                <div class="stage-inspector__tip">
                    <i class="bi bi-lightbulb" aria-hidden="true"></i>
                    <span>Use the search or “Jump to stage” control for direct navigation.</span>
                </div>
            </div>

            <div class="stage-inspector__content" data-stage-content hidden>
                <div class="stage-inspector__topbar">
                    <button type="button" class="btn btn-sm btn-light" data-action="previous-stage" aria-label="Previous stage">
                        <i class="bi bi-arrow-left" aria-hidden="true"></i>
                    </button>
                    <span data-stage-position>Stage</span>
                    <button type="button" class="btn btn-sm btn-light" data-action="next-stage" aria-label="Next stage">
                        <i class="bi bi-arrow-right" aria-hidden="true"></i>
                    </button>
                </div>

                <div class="stage-inspector__heading">
                    <div class="stage-kicker" data-stage-phase>Phase</div>
                    <h2 data-stage-title>Select a stage</h2>
                    <div class="stage-tags">
                        <span class="stage-code" data-stage-code-label></span>
                        <span class="stage-requirement" data-stage-requirement hidden></span>
                    </div>
                    <p class="stage-purpose" data-stage-purpose></p>
                </div>

                <div class="stage-relations">
                    <div>
                        <span>Previous</span>
                        <strong data-stage-previous>—</strong>
                    </div>
                    <i class="bi bi-arrow-right" aria-hidden="true"></i>
                    <div>
                        <span>Next</span>
                        <strong data-stage-next>—</strong>
                    </div>
                </div>

                <div class="stage-checklist-header">
                    <div>
                        <h3>Processing checklist</h3>
                        <p>Reference checks for this stage</p>
                    </div>
                    <button type="button" class="btn btn-outline-primary btn-sm stage-add-button" data-action="add-item" data-checklist-actions hidden>
                        <i class="bi bi-plus-lg" aria-hidden="true"></i>
                        Add item
                    </button>
                </div>
                <ol class="stage-checklist" data-checklist-list data-checklist-primary aria-live="polite" aria-busy="false"></ol>
            </div>
        </aside>
    </div>

    <button type="button" class="mobile-stage-button d-xl-none" data-action="open-stage-panel" hidden>
        <span>
            <small>Selected stage</small>
            <strong data-mobile-stage-title>View stage guidance</strong>
        </span>
        <i class="bi bi-chevron-up" aria-hidden="true"></i>
    </button>
</section>

<div class="offcanvas offcanvas-end stage-offcanvas" tabindex="-1" id="checklistOffcanvas" aria-labelledby="checklistOffcanvasLabel">
    <div class="offcanvas-header stage-offcanvas__header">
        <div>
            <div class="stage-kicker" data-stage-phase>Phase</div>
            <h2 class="h5 mb-0" id="checklistOffcanvasLabel" data-stage-title>Stage guidance</h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close stage guidance"></button>
    </div>
    <div class="offcanvas-body stage-offcanvas__body">
        <div class="stage-tags mb-2">
            <span class="stage-code" data-stage-code-label></span>
            <span class="stage-requirement" data-stage-requirement hidden></span>
        </div>
        <p class="stage-purpose stage-purpose--mobile" data-stage-purpose></p>
        <div class="stage-relations stage-relations--mobile">
            <div><span>Previous</span><strong data-stage-previous>—</strong></div>
            <i class="bi bi-arrow-right" aria-hidden="true"></i>
            <div><span>Next</span><strong data-stage-next>—</strong></div>
        </div>
        <div class="stage-checklist-header mt-4">
            <div><h3>Processing checklist</h3><p>Reference checks for this stage</p></div>
            <button type="button" class="btn btn-outline-primary btn-sm stage-add-button" data-action="add-item" data-checklist-actions hidden>
                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                Add item
            </button>
        </div>
        <ol class="stage-checklist" data-checklist-list aria-live="polite" aria-busy="false"></ol>
    </div>
</div>

<div class="modal fade" id="checklistItemModal" tabindex="-1" aria-labelledby="checklistItemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form class="modal-content process-modal" data-checklist-form>
            <div class="modal-header">
                <div>
                    <div class="process-modal__eyebrow">PROCESSING CHECKLIST</div>
                    <h2 class="modal-title fs-5" id="checklistItemModalLabel">Checklist item</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <label for="checklistItemText" class="form-label fw-semibold">Action or verification required</label>
                <textarea class="form-control" id="checklistItemText" name="text" rows="5" maxlength="512" required></textarea>
                <div class="form-text d-flex justify-content-between"><span>Use clear, action-oriented language.</span><span data-character-count>0 / 512</span></div>
                <input type="hidden" name="itemId" />
                <input type="hidden" name="itemRowVersion" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">
                    <span data-submit-label>Add item</span>
                    <span class="spinner-border spinner-border-sm ms-2" role="status" aria-hidden="true" hidden></span>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="checklistDeleteModal" tabindex="-1" aria-labelledby="checklistDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form class="modal-content process-modal" data-checklist-delete-form>
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="checklistDeleteModalLabel">Remove checklist item?</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">This item will be permanently removed from the stage guidance.</p>
                <input type="hidden" name="itemId" />
                <input type="hidden" name="itemRowVersion" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-danger">
                    <span data-submit-label>Delete item</span>
                    <span class="spinner-border spinner-border-sm ms-2" role="status" aria-hidden="true" hidden></span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/process-flow.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/lib/sortable/1.15.2/Sortable.min.js" asp-append-version="true"></script>
    <script type="module" src="~/js/process-flow.js" asp-append-version="true"></script>
}
