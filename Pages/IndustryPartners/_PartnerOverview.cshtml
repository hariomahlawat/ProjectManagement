@model ProjectManagement.Pages.IndustryPartners.IndexModel
@{
    var partner = Model.SelectedPartner!;
    var primary = partner.PrimaryContact;
}

@if (Model.Edit && Model.CanManageOrganisation)
{
    <form method="post" asp-page-handler="UpdatePartner" class="ip-edit-form" data-update-organisation-form>
        @Html.AntiForgeryToken()
        <input type="hidden" name="partnerId" value="@partner.Id" />
        <input type="hidden" name="rowVersion" value="@partner.RowVersion" />
        <input type="hidden" name="q" value="@Model.Q" />
        <input type="hidden" name="filter" value="@Model.Filter" />
        <input type="hidden" name="p" value="@Model.PageNumber" />
        <input type="hidden" name="projectId" value="@Model.ContextProjectId" />

        <div class="ip-section-heading">
            <div>
                <h3>Edit organisation</h3>
                <p>Update the directory record, then save all changes together.</p>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label" for="partnerName">Organisation name</label>
            <input id="partnerName" name="name" class="form-control" value="@partner.Name" maxlength="200" required />
        </div>
        <div class="mb-3">
            <label class="form-label" for="partnerLocation">City / location / address</label>
            <textarea id="partnerLocation" name="location" class="form-control" rows="2" maxlength="2000">@partner.Location</textarea>
        </div>
        <div class="mb-3">
            <label class="form-label" for="partnerRemarks">Notes</label>
            <textarea id="partnerRemarks" name="remarks" class="form-control" rows="4" maxlength="4000">@partner.Remarks</textarea>
            <div class="form-text">Keep only durable information that helps future engagement with the organisation.</div>
        </div>
        <div class="ip-form-actions">
            <a href="@Model.BuildDirectoryUrl(partner.Id, "overview")" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary" data-submit-once>Save changes</button>
        </div>
    </form>
}
else
{
    @if (primary is not null)
    {
        <article class="ip-primary-contact-card">
            <div class="ip-primary-contact-icon"><i class="bi bi-person" aria-hidden="true"></i></div>
            <div class="min-w-0 flex-grow-1">
                <div class="ip-card-label">Primary contact</div>
                <h3>@primary.DisplayName</h3>
                <div class="ip-contact-links">
                    @if (!string.IsNullOrWhiteSpace(primary.Phone))
                    {
                        <a href="tel:@primary.Phone"><i class="bi bi-telephone" aria-hidden="true"></i>@primary.Phone</a>
                    }
                    @if (!string.IsNullOrWhiteSpace(primary.Email))
                    {
                        <a href="mailto:@primary.Email"><i class="bi bi-envelope" aria-hidden="true"></i>@primary.Email</a>
                    }
                </div>
            </div>
            @if (partner.Contacts.Count > 1)
            {
                <button type="button" class="ip-text-button" data-open-tab="contacts">+@(partner.Contacts.Count - 1) more</button>
            }
        </article>
    }
    else if (Model.CanAddContact)
    {
        <button type="button" class="ip-primary-contact-card ip-primary-contact-empty" data-open-tab="contacts" data-show-panel="contact-add-panel">
            <div class="ip-primary-contact-icon"><i class="bi bi-person-plus" aria-hidden="true"></i></div>
            <div>
                <div class="ip-card-label">Contact</div>
                <h3>Add the first contact</h3>
                <p>Only a phone number or email address is required.</p>
            </div>
            <i class="bi bi-chevron-right ms-auto" aria-hidden="true"></i>
        </button>
    }

    <article class="ip-info-card ip-organisation-details-card">
        <div class="ip-card-label">Organisation details</div>
        @if (string.IsNullOrWhiteSpace(partner.Location) && string.IsNullOrWhiteSpace(partner.Remarks))
        {
            <p class="ip-muted mb-0">No location or notes added.</p>
        }
        else
        {
            <dl class="ip-overview-details">
                @if (!string.IsNullOrWhiteSpace(partner.Location))
                {
                    <div>
                        <dt>Location</dt>
                        <dd class="ip-preserve-lines">@partner.Location</dd>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(partner.Remarks))
                {
                    <div class="ip-overview-notes">
                        <dt>Notes</dt>
                        <dd class="ip-preserve-lines">@partner.Remarks</dd>
                    </div>
                }
            </dl>
        }
    </article>

    <article class="ip-info-card">
        <div class="ip-card-heading-row">
            <div class="ip-card-label">Recent JDP projects</div>
            @if (partner.LinkedProjects.Count > 0)
            {
                <button type="button" class="ip-text-button" data-open-tab="projects">View all</button>
            }
        </div>
        @if (partner.LinkedProjects.Count == 0)
        {
            <div class="ip-compact-empty">
                <span>No JDP association recorded. This organisation remains available as a contact.</span>
            </div>
        }
        else
        {
            <div class="ip-project-preview-list">
                @foreach (var project in partner.LinkedProjects.Take(2))
                {
                    <div>
                        <a asp-page="/Projects/Overview" asp-route-id="@project.ProjectId" class="ip-project-preview-name">@project.ProjectName</a>
                        <span class="ip-status-badge ip-status-@(project.ProjectStatusLabel == "Ongoing" ? "current" : "past")">@project.ProjectStatusLabel</span>
                    </div>
                }
            </div>
        }
    </article>

    <div class="ip-record-meta">Last updated @partner.LastUpdatedUtc.LocalDateTime.ToString("dd MMM yyyy, HH:mm")</div>
}
