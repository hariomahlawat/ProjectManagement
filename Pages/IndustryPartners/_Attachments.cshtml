@model ProjectManagement.Pages.IndustryPartners.IndexModel
@{
    var partner = Model.SelectedPartner!;
}

<div class="ip-section-heading">
    <div>
        <h3>Files</h3>
        <p>Optional brochures, catalogues or company information. A directory record is complete without files.</p>
    </div>
    @if (Model.CanManageOrganisation)
    {
        <button type="button" class="btn btn-sm btn-outline-secondary" data-toggle-panel="file-add-panel" aria-expanded="false">
            <i class="bi bi-paperclip" aria-hidden="true"></i> Add file
        </button>
    }
</div>

@if (Model.CanManageOrganisation)
{
    <div class="ip-inline-create d-none" data-collapsible-panel="file-add-panel">
        <div class="ip-inline-create-title">
            <strong>Add company file</strong>
            <span>Use this only for material specifically related to the organisation.</span>
        </div>
        <form method="post" asp-page-handler="UploadAttachment" enctype="multipart/form-data" data-attachment-upload-form>
            @Html.AntiForgeryToken()
            <input type="hidden" name="partnerId" value="@partner.Id" />
            <input type="hidden" name="q" value="@Model.Q" />
            <input type="hidden" name="filter" value="@Model.Filter" />
            <input type="hidden" name="p" value="@Model.PageNumber" />
            <input type="hidden" name="projectId" value="@Model.ContextProjectId" />
            <label class="ip-file-drop" for="partnerFileInput" data-file-drop>
                <i class="bi bi-cloud-arrow-up" aria-hidden="true"></i>
                <span data-attachment-file-name>Choose a brochure, catalogue or company document</span>
                <small>The existing PRISM upload limits and file security checks apply.</small>
            </label>
            <input id="partnerFileInput" type="file" name="file" class="visually-hidden" required data-attachment-file />
            <div class="ip-form-actions ip-form-actions-compact">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-hide-panel="file-add-panel">Cancel</button>
                <button type="submit" class="btn btn-sm btn-primary" data-attachment-upload-submit disabled>Upload file</button>
            </div>
        </form>
    </div>
}

@if (partner.Attachments.Count == 0)
{
    <div class="ip-tab-empty ip-tab-empty-soft">
        <div class="ip-empty-icon"><i class="bi bi-file-earmark-text" aria-hidden="true"></i></div>
        <h4>No company files added</h4>
        <p>This is normal. Add a file only when a brochure, catalogue or company profile is useful.</p>
    </div>
}
else
{
    <div class="ip-file-list">
        @foreach (var attachment in partner.Attachments)
        {
            var extension = System.IO.Path.GetExtension(attachment.OriginalFileName)?.Trim('.').ToUpperInvariant();
            extension = string.IsNullOrWhiteSpace(extension) ? "FILE" : extension;
            <article class="ip-file-row">
                <div class="ip-file-type">@extension</div>
                <div class="min-w-0 flex-grow-1">
                    <a asp-page="./Index"
                       asp-page-handler="DownloadAttachment"
                       asp-route-partnerId="@partner.Id"
                       asp-route-attachmentId="@attachment.Id"
                       class="ip-file-title">@attachment.OriginalFileName</a>
                    <div class="ip-row-meta">@FormatBytes(attachment.SizeBytes) · Added @attachment.UploadedUtc.LocalDateTime.ToString("dd MMM yyyy")</div>
                </div>
                <div class="ip-file-actions">
                    <a asp-page="./Index"
                       asp-page-handler="DownloadAttachment"
                       asp-route-partnerId="@partner.Id"
                       asp-route-attachmentId="@attachment.Id"
                       class="btn btn-sm btn-light"
                       aria-label="Download @attachment.OriginalFileName">
                        <i class="bi bi-download" aria-hidden="true"></i>
                    </a>
                    @if (Model.CanManageOrganisation)
                    {
                        <form method="post" asp-page-handler="DeleteAttachment" data-confirm-form="Remove this file from the organisation record?">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="partnerId" value="@partner.Id" />
                            <input type="hidden" name="attachmentId" value="@attachment.Id" />
                            <input type="hidden" name="q" value="@Model.Q" />
                            <input type="hidden" name="filter" value="@Model.Filter" />
                            <input type="hidden" name="p" value="@Model.PageNumber" />
                            <input type="hidden" name="projectId" value="@Model.ContextProjectId" />
                            <button type="submit" class="btn btn-sm btn-light text-danger" aria-label="Delete @attachment.OriginalFileName">
                                <i class="bi bi-trash" aria-hidden="true"></i>
                            </button>
                        </form>
                    }
                </div>
            </article>
        }
    </div>
}

@functions {
    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1024L * 1024L)
        {
            return $"{bytes / (1024d * 1024d):0.0} MB";
        }

        return $"{Math.Max(1, bytes / 1024d):0.0} KB";
    }
}
