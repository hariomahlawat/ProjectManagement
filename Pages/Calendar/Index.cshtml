@page
@model ProjectManagement.Pages.Calendar.IndexModel
@{
    ViewData["Title"] = "Calendar";
    ViewData["UseFullWidth"] = true;
    ViewData["PageShell"] = "calendar";
}

@section Styles {
    <link rel="stylesheet" href="~/css/calendar.css" asp-append-version="true" />
}

<div class="calendar-page-shell" data-calendar-view="dayGridMonth">
  <header class="calendar-page-header">
    <div>
      <h1 class="calendar-page-title">Calendar</h1>
      <p class="calendar-page-subtitle">Institutional schedule, events, holidays, birthdays and anniversaries.</p>
    </div>
    @if (Model.CanManageCelebrations || Model.CanEdit)
    {
      <div class="calendar-header-actions">
        @if (Model.CanManageCelebrations)
        {
          <a asp-page="/Celebrations/Index"
             class="btn btn-outline-primary calendar-manage-celebrations"
             title="@Model.CelebrationManagementLabel">
            <i class="bi bi-balloon-heart" aria-hidden="true"></i>
            <span>@Model.CelebrationManagementLabel</span>
          </a>
        }
        @if (Model.CanEdit)
        {
          <button class="btn btn-primary calendar-new-event"
                  id="btnNewEvent"
                  type="button"
                  data-bs-toggle="offcanvas"
                  data-bs-target="#eventFormCanvas"
                  aria-controls="eventFormCanvas">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            <span>New event</span>
          </button>
        }
      </div>
    }
  </header>

  <section class="calendar-workbench" aria-label="Calendar controls">
    <div class="calendar-period-nav">
      <button class="calendar-icon-button" id="btnPrev" type="button" aria-label="Previous period" title="Previous period">
        <i class="bi bi-chevron-left" aria-hidden="true"></i>
      </button>
      <button class="calendar-today-button" id="btnToday" type="button">Today</button>
      <button class="calendar-icon-button" id="btnNext" type="button" aria-label="Next period" title="Next period">
        <i class="bi bi-chevron-right" aria-hidden="true"></i>
      </button>
      <div id="calTitle" class="calendar-period-title" aria-live="polite"></div>
    </div>

    <div class="calendar-toolbar-actions">
      <div class="calendar-view-switch" role="group" aria-label="Calendar view">
        <button type="button" data-view="dayGridMonth">Month</button>
        <button type="button" data-view="timeGridWeek">Week</button>
        <button type="button" data-view="timeGridDay">Day</button>
        <button type="button" data-view="listMonth">List</button>
      </div>

      <div class="dropdown calendar-holiday-help">
        <button class="calendar-holiday-help__button"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false"
                aria-label="Explain holiday indicators"
                title="Holiday indicators">
          <i class="bi bi-info-circle" aria-hidden="true"></i>
          <span class="calendar-holiday-help__label">Holiday indicators</span>
        </button>
        <div class="dropdown-menu dropdown-menu-end calendar-holiday-help__menu">
          <div class="calendar-holiday-help__title">Holiday indicators</div>
          <div class="calendar-holiday-help__item">
            <span class="calendar-holiday-guide__mark calendar-holiday-guide__mark--gazetted" aria-hidden="true"></span>
            <span><strong>Gazetted holiday</strong><small>Office closed; project schedules are affected.</small></span>
          </div>
          <div class="calendar-holiday-help__item">
            <span class="calendar-holiday-guide__mark calendar-holiday-guide__mark--observed" aria-hidden="true"></span>
            <span><strong>RH office holiday</strong><small>Office closed for the establishment.</small></span>
          </div>
          <div class="calendar-holiday-help__item">
            <span class="calendar-holiday-guide__mark calendar-holiday-guide__mark--info" aria-hidden="true">RH</span>
            <span><strong>Informational RH</strong><small>Office remains open; shown for information.</small></span>
          </div>
        </div>
      </div>

      <form id="calendarPreferences"
            method="post"
            class="calendar-preferences"
            data-preference-endpoint="@Url.Content("~/calendar/events/preferences/show-celebrations")">
        @Html.AntiForgeryToken()
        <div class="form-check form-switch m-0">
          <input class="form-check-input"
                 type="checkbox"
                 id="showCelebrationsToggle"
                 @(Model.ShowCelebrations ? "checked" : null)>
          <label class="form-check-label" for="showCelebrationsToggle">Birthdays &amp; anniversaries</label>
        </div>
      </form>
    </div>
  </section>

  <section class="calendar-card" aria-label="Calendar">
<div id="calendar"
     class="shadow-sm border rounded-3 bg-white"
     data-can-edit="@Model.CanEdit.ToString().ToLowerInvariant()"
     data-show-celebrations="@Model.ShowCelebrations.ToString().ToLowerInvariant()"></div>

<footer class="calendar-card-footer" aria-label="Calendar indicators">
  <div id="categoryLegend" class="calendar-legend" aria-label="Event category legend"></div>
  <div class="calendar-holiday-footer" aria-label="Holiday indicators">
    <span class="calendar-holiday-footer__label">Holiday indicators</span>
    <span class="calendar-holiday-footer__item">
      <span class="calendar-holiday-guide__mark calendar-holiday-guide__mark--gazetted" aria-hidden="true"></span>
      <span><strong>Gazetted</strong> — office closed</span>
    </span>
    <span class="calendar-holiday-footer__item">
      <span class="calendar-holiday-guide__mark calendar-holiday-guide__mark--observed" aria-hidden="true"></span>
      <span><strong>RH office holiday</strong> — office closed</span>
    </span>
    <span class="calendar-holiday-footer__item">
      <span class="calendar-holiday-guide__mark calendar-holiday-guide__mark--info" aria-hidden="true">RH</span>
      <span><strong>RH</strong> — information only</span>
    </span>
  </div>
</footer>
  </section>
</div>

@if (Model.CanEdit)
{
  <!-- Offcanvas: Create/Edit -->
  <div class="offcanvas offcanvas-end calendar-offcanvas calendar-event-editor"
       tabindex="-1"
       id="eventFormCanvas"
       aria-labelledby="eventFormLabel"
       aria-describedby="eventFormHint">
    <div class="offcanvas-header calendar-editor-header">
      <div class="calendar-editor-heading">
        <span class="calendar-editor-icon" aria-hidden="true">
          <i class="bi bi-calendar-plus"></i>
        </span>
        <div>
          <div class="calendar-editor-eyebrow">Calendar event</div>
          <h5 id="eventFormLabel" class="offcanvas-title">New event</h5>
          <p id="eventFormHint" class="calendar-editor-hint">Add the essential details now; optional fields can be completed later.</p>
        </div>
      </div>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>

    <form id="eventForm" class="calendar-event-form" novalidate>
      <div class="offcanvas-body calendar-event-form-body">
        <div id="eventFormAlert" class="alert alert-danger d-none" role="alert"></div>
        <input type="hidden" name="id" />

        <section class="calendar-form-section" aria-labelledby="eventBasicsHeading">
          <div class="calendar-form-section-header">
            <div>
              <h6 id="eventBasicsHeading">Event details</h6>
              <p>Give the event a clear name and context.</p>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label" for="eventTitle">Title <span class="calendar-required">Required</span></label>
            <input class="form-control form-control-lg"
                   id="eventTitle"
                   name="title"
                   maxlength="160"
                   placeholder="e.g. Monthly project review"
                   autocomplete="off"
                   required />
            <div class="invalid-feedback">Enter a title for the event.</div>
          </div>

          <div class="row g-3">
            <div class="col-12 col-sm-5">
              <label class="form-label" for="eventCategory">Category</label>
              <select class="form-select" id="eventCategory" name="category">
                <option>Visit</option>
                <option value="Insp">Inspection</option>
                <option>Conference</option>
                <option selected>Other</option>
              </select>
            </div>
            <div class="col-12 col-sm-7">
              <label class="form-label" for="eventLocation">Location <span class="calendar-optional">Optional</span></label>
              <input class="form-control"
                     id="eventLocation"
                     name="location"
                     maxlength="160"
                     placeholder="Venue or online link"
                     autocomplete="off" />
            </div>
          </div>
        </section>

        <section class="calendar-form-section" aria-labelledby="eventTimingHeading">
          <div class="calendar-form-section-header calendar-timing-header">
            <div>
              <h6 id="eventTimingHeading">When</h6>
              <p>Choose a timed event or switch to an all-day event.</p>
            </div>
            <div class="form-check form-switch calendar-all-day-switch">
              <input class="form-check-input" type="checkbox" id="toggleAllDay" name="isAllDay">
              <label class="form-check-label" for="toggleAllDay">All day</label>
            </div>
          </div>

          <div class="calendar-inline-hint">
            <i class="bi bi-clock-history" aria-hidden="true"></i>
            <span>All times use your local browser time.</span>
          </div>

          <div id="timedDateTimeFields" class="calendar-date-time-grid">
            <div class="calendar-date-time-row">
              <div class="calendar-date-time-heading">
                <label class="form-label" for="eventStartDateTimed">Starts</label>
              </div>
              <div class="calendar-date-time-inputs row g-2">
                <div class="col-12 col-sm-7">
                  <input type="date" class="form-control" id="eventStartDateTimed" name="startDateTimed" aria-label="Start date" required />
                  <div class="invalid-feedback">Select the start date.</div>
                </div>
                <div class="col-12 col-sm-5">
                  <input type="time" class="form-control" id="eventStartTimeTimed" name="startTimeTimed" aria-label="Start time" step="60" required />
                  <div class="invalid-feedback">Select the start time.</div>
                </div>
              </div>
            </div>

            <div class="calendar-date-time-row">
              <div class="calendar-date-time-heading">
                <label class="form-label" for="eventEndDateTimed">Ends</label>
              </div>
              <div class="calendar-date-time-inputs row g-2">
                <div class="col-12 col-sm-7">
                  <input type="date" class="form-control" id="eventEndDateTimed" name="endDateTimed" aria-label="End date" required />
                  <div class="invalid-feedback">Select the end date.</div>
                </div>
                <div class="col-12 col-sm-5">
                  <input type="time" class="form-control" id="eventEndTimeTimed" name="endTimeTimed" aria-label="End time" step="60" required />
                  <div class="invalid-feedback">Select a valid end time.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="row g-3 d-none" id="allDayDateFields">
            <div class="col-12 col-sm-6">
              <label class="form-label" for="eventStartDateAllDay">Start date</label>
              <input type="date" class="form-control" id="eventStartDateAllDay" name="startDateAllDay" aria-label="All-day start date" required disabled />
              <div class="invalid-feedback">Select the start date.</div>
            </div>
            <div class="col-12 col-sm-6">
              <label class="form-label" for="eventEndDateAllDay">End date</label>
              <input type="date" class="form-control" id="eventEndDateAllDay" name="endDateAllDay" aria-label="All-day end date" required disabled />
              <div class="invalid-feedback">Select a valid end date.</div>
            </div>
          </div>

          <div id="eventDateRangeError" class="calendar-field-error d-none" role="alert"></div>
          <div id="eventDurationHint" class="calendar-duration-hint" aria-live="polite"></div>
        </section>

        <details class="calendar-form-section calendar-advanced-options" id="eventAdvancedOptions">
          <summary class="calendar-advanced-summary">
            <div>
              <span class="calendar-advanced-title">More options</span>
              <span class="calendar-advanced-copy">Repeat and additional details</span>
            </div>
            <i class="bi bi-chevron-down" aria-hidden="true"></i>
          </summary>

          <div class="calendar-advanced-body">
            <section class="calendar-collapsible-section" aria-labelledby="eventRepeatHeading">
              <div class="calendar-form-section-header">
                <div>
                  <h6 id="eventRepeatHeading">Repeat</h6>
                  <p>Set a recurring schedule only when required.</p>
                </div>
              </div>

              <label class="form-label visually-hidden" for="repeatFreq">Repeat frequency</label>
              <select class="form-select" id="repeatFreq">
                <option value="">Does not repeat</option>
                <option value="WEEKLY">Weekly</option>
                <option value="MONTHLY">Monthly</option>
              </select>

              <div id="repeatOptions" class="calendar-repeat-options d-none">
                <div id="repeatWeekly" class="d-none">
                  <div class="calendar-field-caption">Repeat on</div>
                  <div class="calendar-weekday-picker" role="group" aria-label="Repeat on weekdays">
                    <label><input class="visually-hidden" type="checkbox" value="MO"><span>Mon</span></label>
                    <label><input class="visually-hidden" type="checkbox" value="TU"><span>Tue</span></label>
                    <label><input class="visually-hidden" type="checkbox" value="WE"><span>Wed</span></label>
                    <label><input class="visually-hidden" type="checkbox" value="TH"><span>Thu</span></label>
                    <label><input class="visually-hidden" type="checkbox" value="FR"><span>Fri</span></label>
                    <label><input class="visually-hidden" type="checkbox" value="SA"><span>Sat</span></label>
                    <label><input class="visually-hidden" type="checkbox" value="SU"><span>Sun</span></label>
                  </div>
                </div>

                <div id="repeatMonthly" class="d-none">
                  <label class="form-label" for="repeatMonthDay">Day of month</label>
                  <div class="input-group">
                    <span class="input-group-text">Day</span>
                    <input type="number"
                           min="1"
                           max="31"
                           class="form-control"
                           id="repeatMonthDay"
                           aria-label="Day of month"
                           placeholder="Uses start date" />
                    <div class="invalid-feedback">Enter a day from 1 to 31, or leave it blank to use the event start date.</div>
                  </div>
                </div>

                <div class="calendar-repeat-end">
                  <div class="calendar-field-caption">Ends</div>
                  <div class="calendar-repeat-end-options">
                    <div class="form-check calendar-radio-option">
                      <input class="form-check-input"
                             type="radio"
                             id="repeatEndNever"
                             name="repeatEnd"
                             value="never"
                             checked>
                      <label class="form-check-label" for="repeatEndNever">Never</label>
                    </div>
                    <div class="calendar-repeat-on-date">
                      <div class="form-check calendar-radio-option">
                        <input class="form-check-input"
                               type="radio"
                               id="repeatEndOn"
                               name="repeatEnd"
                               value="on">
                        <label class="form-check-label" for="repeatEndOn">On date</label>
                      </div>
                      <div class="calendar-repeat-date-field">
                        <input type="date"
                               class="form-control"
                               id="repeatUntil"
                               aria-label="Repeat end date"
                               disabled>
                        <div class="invalid-feedback">Select the repeat end date.</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <section class="calendar-collapsible-section" aria-labelledby="eventNotesHeading">
              <div class="calendar-form-section-header">
                <div>
                  <h6 id="eventNotesHeading">Additional details</h6>
                  <p>Add information that attendees may need.</p>
                </div>
              </div>
              <label class="form-label" for="eventDescription">Description <span class="calendar-optional">Optional</span></label>
              <textarea class="form-control"
                        id="eventDescription"
                        rows="4"
                        name="description"
                        maxlength="4000"
                        placeholder="Agenda, instructions, point of contact, or joining details"></textarea>
            </section>
          </div>
        </details>
      </div>

      <div class="calendar-editor-footer">
        <button class="btn btn-outline-danger d-none" id="btnDeleteEvent" type="button">
          <i class="bi bi-trash3" aria-hidden="true"></i>
          <span>Delete</span>
        </button>
        <div class="calendar-editor-footer-actions">
          <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="offcanvas">Cancel</button>
          <button class="btn btn-primary" id="btnSaveEvent" type="submit">
            <span class="spinner-border spinner-border-sm d-none" id="eventSaveSpinner" aria-hidden="true"></span>
            <i class="bi bi-check2" id="eventSaveIcon" aria-hidden="true"></i>
            <span id="eventSaveText">Save event</span>
          </button>
        </div>
      </div>
    </form>
  </div>
}

<!-- Offcanvas: View Details -->
<div class="offcanvas offcanvas-end calendar-offcanvas calendar-details-offcanvas"
     tabindex="-1"
     id="eventDetailsCanvas"
     aria-labelledby="eventDetailsLabel">
  <div class="offcanvas-header calendar-details-header">
    <div class="calendar-details-heading">
      <span class="calendar-details-icon is-event" id="eventDetailsIcon" aria-hidden="true">
        <i class="bi bi-calendar-event"></i>
      </span>
      <div class="calendar-details-title-wrap">
        <div class="calendar-details-eyebrow" id="eventDetailsEyebrow">Calendar event</div>
        <h5 id="eventDetailsLabel" class="offcanvas-title"></h5>
      </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body calendar-details-body">
    <div class="calendar-details-meta">
      <div class="calendar-details-meta-row">
        <i class="bi bi-calendar3" aria-hidden="true"></i>
        <span id="eventDetailsTime"></span>
      </div>
      <div class="calendar-details-meta-row d-none" id="eventDetailsRepeat">
        <i class="bi bi-arrow-repeat" aria-hidden="true"></i>
        <span>Repeats annually</span>
      </div>
    </div>

    <div class="calendar-details-section" id="eventDetailsCategoryRow">
      <span class="calendar-details-category" id="eventDetailsCategory"></span>
    </div>

    <div class="calendar-details-section d-none" id="eventDetailsLocationRow">
      <div class="calendar-details-section-label">
        <i class="bi bi-geo-alt" aria-hidden="true"></i>
        <span>Location</span>
      </div>
      <div id="eventDetailsLocation"></div>
    </div>

    <div class="calendar-details-section d-none" id="eventDetailsDescriptionRow">
      <div class="calendar-details-section-label">
        <i class="bi bi-text-paragraph" aria-hidden="true"></i>
        <span>Details</span>
      </div>
      <div id="eventDetailsDescription"></div>
    </div>

    <button class="btn btn-outline-primary btn-sm"
            id="btnAddToTasks"
            type="button">
      <i class="bi bi-check2-square me-1" aria-hidden="true"></i>
      Add to My Tasks
    </button>
  </div>
</div>

<!-- Undo toast -->
<div class="toast-container position-fixed bottom-0 end-0 p-3">
  <div id="undoToast" class="toast" role="status" aria-live="polite" aria-atomic="true">
    <div class="d-flex">
      <div id="undoMessage" class="toast-body"></div>
      <button id="btnUndo" type="button" class="btn btn-link btn-sm ms-auto">Undo</button>
      <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
  </div>
</div>

@section Scripts {
  <!-- Order matters: Bootstrap JS (provided by layout) → FullCalendar → page script -->

  <!-- EITHER: single bundle -->
  <script src="~/lib/fullcalendar/bundle/index.global.min.js" asp-append-version="true"></script>

  <!-- OR: individual globals (if you didn’t add the bundle):
  <script src="~/lib/fullcalendar/core/index.global.min.js"></script>
  <script src="~/lib/fullcalendar/daygrid/index.global.min.js"></script>
  <script src="~/lib/fullcalendar/timegrid/index.global.min.js"></script>
  <script src="~/lib/fullcalendar/list/index.global.min.js"></script>
  <script src="~/lib/fullcalendar/interaction/index.global.min.js"></script>
  -->

  <script src="~/js/calendar.js" asp-append-version="true"></script>
}
