@page
@model ProjectManagement.Pages.Dashboard.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Globalization
@using System.Linq
@using System.Text.Json
@using ProjectManagement.Configuration
@{
    ViewData["Title"] = "Dashboard";
    ViewData["UseFullWidth"] = true;
    ViewData["PageShell"] = "wide";

    var pulse = Model.ProjectPulse;
    ProjectManagement.Areas.Dashboard.Components.ProjectPulse.OngoingBucketSetVm? totalBucket = null;
    if (pulse is not null && !pulse.OngoingBucketsByKey.TryGetValue("total", out totalBucket))
    {
        totalBucket = pulse.OngoingBucketsByKey.Values.FirstOrDefault();
    }

    var stageOrder = new[] { "FS", "IPA", "SOW", "AON", "BID", "TEC", "BM", "COB", "PNC", "SO", "DEVP", "ATP", "PAYMENT", "TOT" };
    var stageItems = pulse?.OngoingStageDistributionTotal.Items
        .Where(x => x.Count > 0)
        .OrderBy(x => { var i = Array.IndexOf(stageOrder, x.StageCode); return i < 0 ? int.MaxValue : i; })
        .ToList() ?? new List<ProjectManagement.Services.Analytics.StageDistributionItem>();
    var projectTypes = pulse?.OngoingBucketFilters
        .Where(x => !string.Equals(x.Key, "total", StringComparison.OrdinalIgnoreCase))
        .ToList() ?? new List<ProjectManagement.Areas.Dashboard.Components.ProjectPulse.OngoingBucketFilterVm>();
    var completedCategories = pulse?.UniqueCompletedByTechnicalCategory.Take(6).ToList()
        ?? new List<ProjectManagement.Areas.Dashboard.Components.ProjectPulse.TreemapNode>();
    var completedTotal = Math.Max(1, pulse?.CompletedUniqueCount ?? 0);
    var outputTiles = Model.OpsSignals.Tiles.ToList();
    var topFfcCountries = Model.FfcSimulatorMap.Countries
        .Where(x => x.TotalUnits > 0)
        .OrderByDescending(x => x.Completed)
        .ThenByDescending(x => x.Planned)
        .ThenBy(x => x.Name)
        .Take(5)
        .ToList();
    var ffcPayload = JsonSerializer.Serialize(Model.FfcSimulatorMap.Countries, new JsonSerializerOptions(JsonSerializerDefaults.Web));
    var ffcGeoUrl = Url.Content("~/ffc/maps/world_india_view.geojson");
    var ffcFullMapUrl = Url.Page("/FFC/Map", values: new { area = "ProjectOfficeReports" }) ?? "#";
    var canOpenOcrConsole = User.IsInRole(RoleNames.Admin) || User.IsInRole(RoleNames.HoD);
    var ocrPending = Model.SearchHealth.Ocr.Pending;
    var ocrFailed = Model.SearchHealth.Ocr.Failed;
    var ocrWorkerActive = Model.SearchHealth.WorkerActive;
    var processingState = ocrFailed > 0
        ? "failed"
        : ocrPending > 0 && !ocrWorkerActive
            ? "attention"
            : ocrWorkerActive
                ? "processing"
                : "idle";
    var processingTitle = processingState switch
    {
        "failed" => "Document processing requires attention",
        "attention" => "Document processing is waiting",
        "processing" => "Document processing in progress",
        _ => "Document processing is idle"
    };
    var processingBadge = processingState switch
    {
        "failed" => "Failures detected",
        "attention" => "Queue waiting",
        "processing" => "Processing",
        _ => "Standby"
    };
    var processingDescription = processingState switch
    {
        "failed" => "One or more OCR jobs failed and should be reviewed.",
        "attention" => "Documents are pending while the OCR worker is not active.",
        "processing" => "The OCR worker is currently processing or has been active recently.",
        _ => "No documents are waiting. The OCR worker is at rest and searchable documents remain available."
    };
    string Json<T>(IEnumerable<T>? values) => JsonSerializer.Serialize(values ?? Array.Empty<T>());
    string OngoingStageUrl(string stageCode) => Url.Page("/Projects/Ongoing/Index", new { PresentStageCode = stageCode }) ?? (pulse?.OngoingUrl ?? "#");
    string StageDisplayLabel(string stageCode) => stageCode.ToUpperInvariant() switch
    {
        "PAYMENT" or "PAYMENT1" => "Payment",
        "DEVP" => "DEVP",
        _ => stageCode
    };
    string OngoingBucketUrl(string bucket) => Url.Page("/Projects/Ongoing/Index", new { StageBucket = bucket }) ?? (pulse?.OngoingUrl ?? "#");
    string OngoingCategoryUrl(string key)
    {
        if (key.StartsWith("cat-", StringComparison.OrdinalIgnoreCase) && int.TryParse(key[4..], out var categoryId))
        {
            return Url.Page("/Projects/Ongoing/Index", new { ProjectCategoryId = categoryId }) ?? (pulse?.OngoingUrl ?? "#");
        }
        return pulse?.OngoingUrl ?? "#";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/leaflet/1.9.4/leaflet.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/widgets/ffc-simulator-map.css" asp-append-version="true" />
}

@if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-warning py-2 mb-3"><i class="bi bi-exclamation-triangle-fill me-2"></i>@err</div>
}

<div class="db-page" data-dashboard>
    <header class="db-header db-reveal">
        <div>
            <h1>Dashboard</h1>
            <p class="db-header__subtitle">Portfolio, institutional outputs, engagement and innovation at a glance.</p>
        </div>
        <div class="db-header__actions">
            <span class="db-updated"><i class="bi bi-clock-history"></i> Loaded @Model.DashboardLoadedAtIst.ToString("dd MMM yyyy, HH:mm") IST</span>
            @if (pulse is not null)
            {
                <a class="btn btn-primary btn-sm db-primary-action" href="@pulse.AnalyticsUrl"><i class="bi bi-graph-up-arrow"></i><span>Open analytics</span></a>
            }
        </div>
    </header>

    <main class="db-sections">
        <div class="db-top-grid">
            <section class="db-panel db-reveal" aria-labelledby="portfolio-pulse-title">
                <div class="db-section-head">
                    <div>
                        <span class="db-section-icon db-section-icon--blue"><i class="bi bi-activity"></i></span>
                        <div><h2 id="portfolio-pulse-title">Portfolio pulse</h2><p>@(pulse?.OngoingCount ?? 0) ongoing projects across the development lifecycle</p></div>
                    </div>
                    <a href="@(pulse?.OngoingUrl ?? "#")" class="db-text-link">View ongoing projects <i class="bi bi-arrow-right"></i></a>
                </div>

                @if (pulse is not null)
                {
                    <div class="db-pulse-layout">
                        <article class="db-pulse-block db-pulse-block--lifecycle">
                            <div class="db-block-heading"><h3>Lifecycle distribution</h3><span>@pulse.OngoingCount total</span></div>
                            <div class="db-lifecycle" role="list" aria-label="Ongoing projects by lifecycle bucket">
                                @{ var bucketTotal = Math.Max(1, totalBucket?.Total ?? 0); }
                                @foreach (var item in new[]
                                {
                                    (Label: "Approval", Count: totalBucket?.Apvl ?? 0, Css: "approval", Bucket: "approval"),
                                    (Label: "AoN", Count: totalBucket?.Aon ?? 0, Css: "aon", Bucket: "aon"),
                                    (Label: "Tendering", Count: totalBucket?.Tender ?? 0, Css: "tender", Bucket: "procurement"),
                                    (Label: "Development", Count: totalBucket?.Devp ?? 0, Css: "development", Bucket: "development")
                                })
                                {
                                    var pct = (int)Math.Round(item.Count * 100d / bucketTotal);
                                    <a class="db-lifecycle__segment db-lifecycle__segment--@item.Css" href="@OngoingBucketUrl(item.Bucket)" role="listitem" aria-label="@item.Label: @item.Count projects, @pct percent">
                                        <span>@item.Label</span><strong>@item.Count</strong><small>@pct%</small>
                                    </a>
                                }
                            </div>
                        </article>

                        <article class="db-pulse-block db-pulse-block--stages">
                            <div class="db-block-heading"><h3>Stage distribution</h3><span>Active portfolio</span></div>
                            <div class="db-stage-grid" role="list">
                                @foreach (var stage in stageItems)
                                {
                                    <a href="@OngoingStageUrl(stage.StageCode)" class="db-stage" role="listitem" title="View projects at @stage.StageName"><span>@StageDisplayLabel(stage.StageCode)</span><strong>@stage.Count</strong></a>
                                }
                            </div>
                        </article>

                        <article class="db-pulse-block db-pulse-block--classification">
                            <div class="db-block-heading"><h3>Project classification</h3><span>Ongoing</span></div>
                            <div class="db-classification-list">
                                @foreach (var item in projectTypes)
                                {
                                    var width = pulse.OngoingCount > 0 ? Math.Max(6, item.Count * 100d / pulse.OngoingCount) : 0;
                                    <a class="db-classification-row" href="@OngoingCategoryUrl(item.Key)">
                                        <div><span>@item.Label</span><strong>@item.Count</strong></div>
                                        <div class="db-meter"><span style="--meter-width:@width.ToString("0.##", CultureInfo.InvariantCulture)%"></span></div>
                                    </a>
                                }
                            </div>
                        </article>
                    </div>
                }
                else
                {
                    <div class="db-empty">Portfolio data is temporarily unavailable.</div>
                }
            </section>

            <section class="db-panel db-reveal" aria-labelledby="completed-title">
                <div class="db-section-head db-section-head--compact">
                    <div>
                        <span class="db-section-icon db-section-icon--green"><i class="bi bi-check2-circle"></i></span>
                        <div><h2 id="completed-title">Completed projects</h2><p>Portfolio outcomes and technical composition</p></div>
                    </div>
                    <a href="@(pulse?.CompletedUrl ?? "#")" class="db-text-link">View all <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="db-completed-compact">
                    <div class="db-completed-summary">
                        <div class="db-summary-stat db-summary-stat--primary"><span>Total completed</span><strong>@(pulse?.CompletedCount ?? 0)</strong></div>
                        <div class="db-summary-stat"><span>Original projects</span><strong>@(pulse?.CompletedUniqueCount ?? 0)</strong></div>
                        <div class="db-summary-stat"><span>Rebuild projects</span><strong>@(pulse?.CompletedRebuildCount ?? 0)</strong></div>
                        <a href="@(pulse?.ProliferationEligibleUrl ?? "#")" class="db-summary-stat db-summary-stat--accent"><span>Ready for proliferation</span><strong>@(pulse?.ProliferationEligible ?? 0)</strong></a>
                    </div>
                    <div class="db-category-bars" aria-label="Completed projects by technical category">
                        @foreach (var category in completedCategories)
                        {
                            var share = category.Count * 100d / completedTotal;
                            var categoryUrl = string.IsNullOrWhiteSpace(category.Url) ? pulse?.CompletedUrl ?? "#" : category.Url;
                            <a class="db-category-row" href="@categoryUrl">
                                <span>@category.Label</span>
                                <div class="db-category-track"><i style="--bar-width:@share.ToString("0.##", CultureInfo.InvariantCulture)%"></i></div>
                                <strong>@category.Count <small>@share.ToString("0")%</small></strong>
                            </a>
                        }
                    </div>
                </div>
            </section>
        </div>

        <section class="db-panel db-reveal" aria-labelledby="outputs-title">
            <div class="db-section-head">
                <div>
                    <span class="db-section-icon db-section-icon--teal"><i class="bi bi-bar-chart-line"></i></span>
                    <div><h2 id="outputs-title">Institutional outputs</h2><p>Key institutional results with a 12-month activity view</p></div>
                </div>
            </div>
            <div class="db-output-grid">
                @foreach (var tile in outputTiles)
                {
                    var values = tile.Sparkline ?? Array.Empty<int>();
                    var labels = tile.SparklineLabels ?? Array.Empty<string>();
                    var hasRecentActivity = values.Any(v => v > 0);
                    <a class="db-output-card" href="@tile.LinkUrl">
                        <div class="db-output-card__head"><span class="db-output-card__icon"><i class="bi @tile.Icon"></i></span><span class="db-output-card__label">@tile.Label</span></div>
                        <div class="db-output-card__metrics @(tile.SecondaryValue.HasValue ? "has-secondary" : "")">
                            <div class="db-output-card__metric">
                                <strong>@tile.Value.ToString("N0")</strong>
                                @if (!string.IsNullOrWhiteSpace(tile.Unit))
                                {
                                    <span>@tile.Unit</span>
                                }
                            </div>
                            @if (tile.SecondaryValue.HasValue)
                            {
                                <div class="db-output-card__secondary">
                                    <strong>@tile.SecondaryValue.Value.ToString("N0")</strong>
                                    <span>@tile.SecondaryLabel</span>
                                </div>
                            }
                        </div>
                        <div class="db-output-card__chart @(hasRecentActivity ? "" : "is-empty")" data-db-spark data-values='@Html.Raw(Json(values))' data-labels='@Html.Raw(Json(labels))'>
                            <canvas role="img" aria-label="@tile.Label monthly activity over the last 12 months"></canvas>
                            @if (!hasRecentActivity)
                            {
                                <span class="db-chart-empty">No activity in the last 12 months</span>
                            }
                        </div>
                        <div class="db-output-card__foot">
                            <span>@(string.IsNullOrWhiteSpace(tile.TrendLabel) ? "Monthly activity · 12 months" : tile.TrendLabel)</span>
                            @if (tile.DeltaPct is not null)
                            {
                                var deltaUp = tile.DeltaPct >= 0;
                                <em class="@(deltaUp ? "is-up" : "is-down")"><i class="bi @(deltaUp ? "bi-arrow-up" : "bi-arrow-down")"></i>@string.Format("{0:+0;-0;0}%", Math.Round((tile.DeltaPct ?? 0) * 100))</em>
                            }
                            else if (!string.IsNullOrWhiteSpace(tile.DeltaLabel))
                            {
                                <em class="is-neutral">@tile.DeltaLabel</em>
                            }
                            else
                            {
                                <em class="is-neutral">No change</em>
                            }
                        </div>
                    </a>
                }
            </div>
        </section>

        <section class="db-dual-grid db-reveal" aria-label="Engagement and innovation">
            <article class="db-panel db-engagement-card">
                <div class="db-section-head">
                    <div><span class="db-section-icon db-section-icon--teal"><i class="bi bi-people"></i></span><div><h2>Institutional activities</h2><p>Recent engagement, monthly activity and leading activity types</p></div></div>
                    <a asp-page="/Activities/Index" class="db-text-link">View activities <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="db-activity-overview">
                    <div class="db-activity-kpis">
                        <div><span>Total activities</span><strong>@Model.ActivitySummary.TotalActivities</strong></div>
                        <div><span>Last 30 days</span><strong>@Model.ActivitySummary.Last30DaysCount</strong></div>
                    </div>
                    <div class="db-activity-trend" data-db-activity-trend data-values='@Html.Raw(Json(Model.ActivitySummary.MonthlyTrend))' data-labels='@Html.Raw(Json(Model.ActivitySummary.MonthlyLabels))'>
                        <div class="db-activity-trend__head"><span>Monthly activity</span><small>Last 12 months</small></div>
                        <canvas role="img" aria-label="Institutional activities recorded per month for the last 12 months"></canvas>
                        @if (Model.ActivitySummary.MonthlyLabels.Count > 0)
                        {
                            <div class="db-activity-trend__axis" aria-hidden="true">
                                <span>@Model.ActivitySummary.MonthlyLabels.First()</span>
                                <span>@Model.ActivitySummary.MonthlyLabels.Last()</span>
                            </div>
                        }
                    </div>
                </div>
                <div class="db-activity-detail">
                    <div class="db-top-types">
                        <h3>Top activity types</h3>
                        @if (Model.ActivitySummary.TopTypes.Count > 0)
                        {
                            var maxType = Math.Max(1, Model.ActivitySummary.TopTypes.Max(x => x.Count));
                            var totalActivities = Math.Max(1, Model.ActivitySummary.TotalActivities);
                            @foreach (var type in Model.ActivitySummary.TopTypes)
                            {
                                var width = type.Count * 100d / maxType;
                                var share = (int)Math.Round(type.Count * 100d / totalActivities);
                                <a asp-page="/Activities/Index" asp-route-ActivityTypeId="@type.ActivityTypeId" class="db-type-row"><span>@type.Name</span><div><i style="--type-width:@width.ToString("0.##", CultureInfo.InvariantCulture)%"></i></div><strong>@type.Count <small>@share%</small></strong></a>
                            }
                        }
                        else { <div class="db-empty db-empty--compact">No activity types recorded.</div> }
                    </div>
                    <div class="db-recent-activities">
                        <h3>Recent activities</h3>
                        @foreach (var activity in Model.ActivitySummary.RecentActivities)
                        {
                            var occurredIst = TimeZoneInfo.ConvertTime(activity.OccurredAtUtc, ProjectManagement.Infrastructure.IstClock.TimeZone);
                            <a asp-page="/Activities/Details" asp-route-id="@activity.Id" class="db-recent-row">
                                <div>
                                    <strong>@activity.Title</strong>
                                    <span>
                                        @activity.Type · @occurredIst.ToString("dd MMM yyyy")
                                        @if (!string.IsNullOrWhiteSpace(activity.Location))
                                        {
                                            <text> · @activity.Location</text>
                                        }
                                    </span>
                                </div>
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        }
                        @if (Model.ActivitySummary.RecentActivities.Count == 0) { <div class="db-empty db-empty--compact">No activities recorded.</div> }
                    </div>
                </div>
            </article>

            <article class="db-panel db-innovation-card">
                <div class="db-section-head">
                    <div><span class="db-section-icon db-section-icon--indigo"><i class="bi bi-lightbulb"></i></span><div><h2>Innovation pipeline</h2><p>Active and on-hold ideas progressing through refinement</p></div></div>
                    <a asp-page="/ProjectIdeas/Index" class="db-text-link">Open ideation board <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="db-idea-summary">
                    <div class="db-idea-summary__primary"><strong>@Model.IdeaSummary.ActiveCount</strong><span>Active ideas</span></div>
                    <div><strong>@Model.IdeaSummary.OnHoldCount</strong><span>On hold</span></div>
                    <div><strong>@Model.IdeaSummary.UpdatedLast30Days</strong><span>Updated in 30 days</span></div>
                    <div><strong>@Model.IdeaSummary.IdeasWithDiscussion</strong><span>With discussion</span></div>
                    <div><strong>@Model.IdeaSummary.DocumentCount</strong><span>Supporting documents</span></div>
                </div>
                <div class="db-idea-list">
                    @foreach (var idea in Model.IdeaSummary.LatestIdeas)
                    {
                        <a asp-page="/ProjectIdeas/Details" asp-route-id="@idea.Id" class="db-idea-row"><div><strong>@idea.Title</strong><span>@idea.Status · @idea.OwnerName · Updated @idea.UpdatedAt.ToString("dd MMM yyyy")</span></div><div><span><i class="bi bi-chat"></i> @idea.CommentCount</span><span><i class="bi bi-paperclip"></i> @idea.DocumentCount</span></div></a>
                    }
                    @if (Model.IdeaSummary.LatestIdeas.Count == 0) { <div class="db-empty db-empty--compact">No active or on-hold ideas recorded.</div> }
                </div>
            </article>
        </section>

        <section class="db-panel db-ffc-panel db-reveal" aria-labelledby="ffc-title">
            <div class="db-section-head">
                <div><span class="db-section-icon db-section-icon--blue"><i class="bi bi-globe-asia-australia"></i></span><div><h2 id="ffc-title">Simulator footprint across FFCs</h2><p>Completed and planned units by partner country</p></div></div>
                <a href="@ffcFullMapUrl" class="db-text-link">View full map <i class="bi bi-arrow-right"></i></a>
            </div>
            @if (Model.FfcSimulatorMap.HasData)
            {
                <div class="db-ffc-layout">
                    <div class="db-ffc-map-wrap">
                        <div class="ffc-simulator-map db-ffc-map" data-widget="ffc-simulator-map" data-countries='@Html.Raw(ffcPayload)' data-geo-url="@ffcGeoUrl" data-focus-bounds="42,-18|-38,118" data-highlight-color="var(--db-primary)">
                            <div class="ffc-simulator-map__canvas" role="img" aria-label="Map showing simulator footprint across Friendly Foreign Countries"></div>
                            <div class="ffc-simulator-map__status" data-map-status>Loading footprint…</div>
                        </div>
                        <div class="db-ffc-legend" aria-label="Map legend">
                            <span><i class="is-completed"></i>Bubble value: completed units</span>
                            <span><i class="is-planned"></i>Amber marker: planned-only location</span>
                        </div>
                    </div>
                    <aside class="db-ffc-insights">
                        <div class="db-ffc-stats">
                            <div><span>Countries covered</span><strong>@Model.FfcSimulatorMap.Countries.Count(x => x.Completed > 0)</strong></div>
                            <div><span>Completed units <i class="bi bi-info-circle" title="Installed plus delivered units recorded as completed"></i></span><strong>@Model.FfcSimulatorMap.TotalCompleted</strong></div>
                            <div><span>Installed <i class="bi bi-info-circle" title="Units installed at the partner-country location"></i></span><strong>@Model.FfcSimulatorMap.TotalInstalled</strong></div>
                            <div><span>Delivered <i class="bi bi-info-circle" title="Units delivered but not recorded as installed"></i></span><strong>@Model.FfcSimulatorMap.TotalDelivered</strong></div>
                            <div class="is-planned"><span>Planned units <i class="bi bi-info-circle" title="Approved or recorded future units not yet completed"></i></span><strong>@Model.FfcSimulatorMap.TotalPlanned</strong></div>
                        </div>
                        <div class="db-ffc-countries">
                            <h3>Top countries</h3>
                            @foreach (var country in topFfcCountries)
                            {
                                <a asp-area="ProjectOfficeReports" asp-page="/FFC/MapTableDetailed" asp-route-countryId="@country.CountryId" data-country-chip="@country.Iso3" class="db-country-row">
                                    <span>@country.Name</span>
                                    <div>
                                        <strong>@country.Completed</strong>
                                        <small>completed</small>
                                        @if (country.Planned > 0)
                                        {
                                            <em>+@country.Planned planned</em>
                                        }
                                    </div>
                                </a>
                            }
                        </div>
                    </aside>
                </div>
            }
            else { <div class="db-empty">FFC project unit data is not available right now.</div> }
        </section>

        <section class="db-processing-alert db-panel db-reveal is-@processingState" aria-labelledby="document-processing-title">
            <div class="db-processing-alert__identity">
                <span class="db-utility-card__icon" aria-hidden="true">
                    <i class="bi @(processingState == "failed" ? "bi-x-octagon" : processingState == "attention" ? "bi-hourglass-split" : processingState == "processing" ? "bi-arrow-repeat" : "bi-pause-circle")"></i>
                </span>
                <div>
                    <div class="db-processing-title-row">
                        <h2 id="document-processing-title">@processingTitle</h2>
                        <span class="db-status-badge">@processingBadge</span>
                    </div>
                    <p>@processingDescription</p>
                </div>
            </div>
            <div class="db-processing-metrics" aria-label="Document processing metrics">
                <div><span>OCR worker</span><strong class="is-@processingState">@(ocrWorkerActive ? "Active" : processingState == "idle" ? "At rest" : "Inactive")</strong></div>
                <div><span>Pending</span><strong>@ocrPending <small>documents</small></strong></div>
                <div><span>Failed</span><strong class="@(ocrFailed > 0 ? "is-failed" : "")">@ocrFailed <small>documents</small></strong></div>
                <div><span>Searchable</span><strong>@Model.SearchHealth.TotalSearchable.ToString("N0") <small>documents</small></strong></div>
            </div>
            @if (canOpenOcrConsole)
            {
                <a asp-area="DocumentRepository" asp-page="/Admin/OCRFailures/OcrFailures" class="db-processing-action">View processing status <i class="bi bi-arrow-right"></i></a>
            }
            else if (processingState is "failed" or "attention")
            {
                <span class="db-processing-note">Administrator review may be required.</span>
            }
        </section>
    </main>

    <footer class="db-footer db-footer--timezone"><span>All times shown in IST</span></footer>
</div>

@section Scripts {
    <script src="~/lib/chart.js/chart.umd.js"></script>
    <script src="~/js/pages/dashboard.js" asp-append-version="true"></script>
    <script src="~/lib/leaflet/1.9.4/leaflet.js" asp-append-version="true"></script>
    <script src="~/js/widgets/ffc-simulator-map.js" asp-append-version="true"></script>
}
