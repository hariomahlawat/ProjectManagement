@page
@model ProjectManagement.Pages.Dashboard.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Globalization
@using System.Linq
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";
    ViewData["UseFullWidth"] = true;

    var pulse = Model.ProjectPulse;
    ProjectManagement.Areas.Dashboard.Components.ProjectPulse.OngoingBucketSetVm? totalBucket = null;
    if (pulse is not null && !pulse.OngoingBucketsByKey.TryGetValue("total", out totalBucket))
    {
        totalBucket = pulse.OngoingBucketsByKey.Values.FirstOrDefault();
    }

    var stageOrder = new[] { "FS", "IPA", "SOW", "AON", "BID", "TEC", "BM", "COB", "PNC", "SO", "DEVP", "ATP", "PAYMENT", "TOT" };
    var stageItems = pulse?.OngoingStageDistributionTotal.Items
        .Where(x => x.Count > 0)
        .OrderBy(x => Array.IndexOf(stageOrder, x.StageCode))
        .ToList() ?? new List<ProjectManagement.Services.Analytics.StageDistributionItem>();
    var projectTypes = pulse?.OngoingBucketFilters
        .Where(x => !string.Equals(x.Key, "total", StringComparison.OrdinalIgnoreCase))
        .ToList() ?? new List<ProjectManagement.Areas.Dashboard.Components.ProjectPulse.OngoingBucketFilterVm>();
    var completedCategories = pulse?.UniqueCompletedByTechnicalCategory.Take(6).ToList()
        ?? new List<ProjectManagement.Areas.Dashboard.Components.ProjectPulse.TreemapNode>();
    var maxCompletedCategory = completedCategories.Count > 0 ? Math.Max(1, completedCategories.Max(x => x.Count)) : 1;
    var outputTiles = Model.OpsSignals.Tiles.ToList();
    var nowIst = TimeZoneInfo.ConvertTime(DateTimeOffset.UtcNow, ProjectManagement.Infrastructure.IstClock.TimeZone);
    var latestActivityIst = Model.ActivitySummary.LatestAtUtc is null
        ? (DateTimeOffset?)null
        : TimeZoneInfo.ConvertTime(Model.ActivitySummary.LatestAtUtc.Value, ProjectManagement.Infrastructure.IstClock.TimeZone);
    var searchHealthy = Model.SearchHealth.WorkerActive && Model.SearchHealth.Ocr.Failed == 0;
    var activityMediaRate = Model.ActivitySummary.TotalActivities > 0
        ? (int)Math.Round(Model.ActivitySummary.WithMedia * 100d / Model.ActivitySummary.TotalActivities)
        : 0;
    string Json<T>(IEnumerable<T>? values) => JsonSerializer.Serialize(values ?? Array.Empty<T>());
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/leaflet/1.9.4/leaflet.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/widgets/ffc-simulator-map.css" asp-append-version="true" />
}

@if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-warning py-2 mb-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@err
    </div>
}

<div class="db-page" data-dashboard>
    <header class="db-header db-reveal">
        <div>
            <p class="db-eyebrow">PRISM ERP</p>
            <h1>Dashboard</h1>
            <p class="db-header__subtitle">Portfolio, institutional outputs, engagement and innovation at a glance.</p>
        </div>
        <div class="db-header__actions">
            <span class="db-updated"><i class="bi bi-arrow-repeat"></i> Updated @nowIst.ToString("dd MMM yyyy, HH:mm") IST</span>
            @if (pulse is not null)
            {
                <a class="btn btn-primary btn-sm db-primary-action" href="@pulse.AnalyticsUrl">
                    <i class="bi bi-graph-up-arrow"></i><span>Open analytics</span>
                </a>
            }
        </div>
    </header>

    <main class="db-sections">
        <div class="db-top-grid">
            <section class="db-panel db-reveal" aria-labelledby="portfolio-pulse-title">
                <div class="db-section-head">
                    <div>
                        <span class="db-section-icon db-section-icon--blue"><i class="bi bi-activity"></i></span>
                        <div>
                            <h2 id="portfolio-pulse-title">Portfolio pulse</h2>
                            <p>@(pulse?.OngoingCount ?? 0) ongoing projects across the development lifecycle</p>
                        </div>
                    </div>
                    <a href="@(pulse?.OngoingUrl ?? "#")" class="db-text-link">View ongoing projects <i class="bi bi-arrow-right"></i></a>
                </div>

                @if (pulse is not null)
                {
                    <div class="db-pulse-layout">
                        <article class="db-pulse-block db-pulse-block--lifecycle">
                            <div class="db-block-heading"><h3>Lifecycle distribution</h3><span>@pulse.OngoingCount total</span></div>
                            <div class="db-lifecycle" role="list" aria-label="Ongoing projects by lifecycle bucket">
                                @{ var bucketTotal = Math.Max(1, totalBucket?.Total ?? 0); }
                                @foreach (var item in new[]
                                {
                                    (Label: "Approval", Count: totalBucket?.Apvl ?? 0, Css: "approval"),
                                    (Label: "AoN", Count: totalBucket?.Aon ?? 0, Css: "aon"),
                                    (Label: "Tendering", Count: totalBucket?.Tender ?? 0, Css: "tender"),
                                    (Label: "Development", Count: totalBucket?.Devp ?? 0, Css: "development")
                                })
                                {
                                    var pct = (int)Math.Round(item.Count * 100d / bucketTotal);
                                    <div class="db-lifecycle__segment db-lifecycle__segment--@item.Css" style="--segment-grow:@Math.Max(1, item.Count)" role="listitem">
                                        <span>@item.Label</span><strong>@item.Count</strong><small>@pct%</small>
                                    </div>
                                }
                            </div>
                        </article>

                        <article class="db-pulse-block db-pulse-block--stages">
                            <div class="db-block-heading"><h3>Stage distribution</h3><span>Active portfolio</span></div>
                            <div class="db-stage-grid" role="list">
                                @foreach (var stage in stageItems)
                                {
                                    <a href="@pulse.OngoingUrl" class="db-stage" role="listitem" title="@stage.StageName">
                                        <span>@stage.StageCode</span><strong>@stage.Count</strong>
                                    </a>
                                }
                            </div>
                        </article>

                        <article class="db-pulse-block db-pulse-block--classification">
                            <div class="db-block-heading"><h3>Project classification</h3><span>Ongoing</span></div>
                            <div class="db-classification-list">
                                @foreach (var item in projectTypes)
                                {
                                    var width = pulse.OngoingCount > 0 ? Math.Max(6, item.Count * 100d / pulse.OngoingCount) : 0;
                                    <div class="db-classification-row">
                                        <div><span>@item.Label</span><strong>@item.Count</strong></div>
                                        <div class="db-meter"><span style="--meter-width:@width.ToString("0.##", CultureInfo.InvariantCulture)%"></span></div>
                                    </div>
                                }
                            </div>
                        </article>
                    </div>
                }
                else
                {
                    <div class="db-empty">Portfolio data is temporarily unavailable.</div>
                }
            </section>

            <section class="db-panel db-reveal" aria-labelledby="completed-title">
                <div class="db-section-head db-section-head--compact">
                    <div>
                        <span class="db-section-icon db-section-icon--green"><i class="bi bi-check2-circle"></i></span>
                        <div><h2 id="completed-title">Completed projects</h2><p>Portfolio outcomes</p></div>
                    </div>
                    <a href="@(pulse?.CompletedUrl ?? "#")" class="db-text-link">View all <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="db-completed-compact">
                    <div class="db-completed-summary">
                        <div class="db-summary-stat db-summary-stat--primary"><span>Total completed</span><strong>@(pulse?.CompletedCount ?? 0)</strong></div>
                        <div class="db-summary-stat"><span>Unique projects</span><strong>@(pulse?.CompletedUniqueCount ?? 0)</strong></div>
                        <div class="db-summary-stat"><span>Rebuilds</span><strong>@(pulse?.CompletedRebuildCount ?? 0)</strong></div>
                        <div class="db-summary-stat db-summary-stat--accent"><span>Ready for proliferation</span><strong>@(pulse?.ProliferationEligible ?? 0)</strong></div>
                    </div>
                    <div class="db-category-bars">
                        @foreach (var category in completedCategories)
                        {
                            var pct = category.Count * 100d / maxCompletedCategory;
                            <div class="db-category-row">
                                <span>@category.Label</span>
                                <div class="db-category-track"><i style="--bar-width:@pct.ToString("0.##", CultureInfo.InvariantCulture)%"></i></div>
                                <strong>@category.Count</strong>
                            </div>
                        }
                    </div>
                </div>
            </section>
        </div>

        <section class="db-panel db-reveal" aria-labelledby="outputs-title">
            <div class="db-section-head">
                <div>
                    <span class="db-section-icon db-section-icon--teal"><i class="bi bi-bar-chart-line"></i></span>
                    <div><h2 id="outputs-title">Institutional outputs</h2><p>Cumulative totals with monthly activity for the last 12 months</p></div>
                </div>
            </div>
            <div class="db-output-grid">
                @foreach (var tile in outputTiles)
                {
                    var values = tile.Sparkline ?? Array.Empty<int>();
                    var labels = tile.SparklineLabels ?? Array.Empty<string>();
                    <a class="db-output-card" href="@tile.LinkUrl">
                        <div class="db-output-card__head">
                            <span class="db-output-card__icon"><i class="bi @tile.Icon"></i></span>
                            <span class="db-output-card__label">@tile.Label</span>
                        </div>
                        <div class="db-output-card__metric">
                            <strong>@tile.Value.ToString("N0")</strong>
                            @if (!string.IsNullOrWhiteSpace(tile.Unit)) { <span>@tile.Unit</span> }
                        </div>
                        <div class="db-output-card__chart" data-db-spark data-values='@Html.Raw(Json(values))' data-labels='@Html.Raw(Json(labels))' aria-label="@tile.Label monthly activity over the last 12 months">
                            <canvas></canvas>
                        </div>
                        <div class="db-output-card__foot">
                            <span>Monthly activity · 12 months</span>
                            @if (tile.DeltaPct is not null)
                            {
                                var deltaUp = tile.DeltaPct >= 0;
                                <em class="@(deltaUp ? "is-up" : "is-down")"><i class="bi @(deltaUp ? "bi-arrow-up" : "bi-arrow-down")"></i>@string.Format("{0:+0;-0;0}%", Math.Round((tile.DeltaPct ?? 0) * 100))</em>
                            }
                            else if (!string.IsNullOrWhiteSpace(tile.DeltaLabel))
                            {
                                <em class="is-neutral">@tile.DeltaLabel</em>
                            }
                        </div>
                    </a>
                }
            </div>
        </section>

        <section class="db-dual-grid db-reveal" aria-label="Engagement and innovation">
            <article class="db-panel db-engagement-card">
                <div class="db-section-head">
                    <div>
                        <span class="db-section-icon db-section-icon--teal"><i class="bi bi-people"></i></span>
                        <div><h2>Institutional activities</h2><p>Engagements, media and supporting records</p></div>
                    </div>
                    <a asp-page="/Activities/Index" class="db-text-link">View activities <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="db-mini-metrics">
                    <div><strong>@Model.ActivitySummary.TotalActivities</strong><span>Activities</span></div>
                    <div><strong>@Model.ActivitySummary.WithMedia</strong><span>With media</span></div>
                    <div><strong>@Model.ActivitySummary.PhotoCount</strong><span>Photos</span></div>
                    <div><strong>@Model.ActivitySummary.DocumentCount</strong><span>Documents</span></div>
                    <div><strong>@Model.ActivitySummary.VideoCount</strong><span>Videos</span></div>
                </div>
                <div class="db-engagement-body">
                    <div class="db-coverage">
                        <div><span>Media-backed activities</span><strong>@activityMediaRate%</strong></div>
                        <div class="db-coverage__track"><i style="--coverage-width:@activityMediaRate%"></i></div>
                        <small>@Model.ActivitySummary.WithMedia of @Model.ActivitySummary.TotalActivities activities include supporting media.</small>
                    </div>
                    <div class="db-latest-record">
                        <span class="db-latest-record__label">Latest activity</span>
                        @if (!string.IsNullOrWhiteSpace(Model.ActivitySummary.LatestTitle))
                        {
                            <strong>@Model.ActivitySummary.LatestTitle</strong>
                            <div>
                                @if (!string.IsNullOrWhiteSpace(Model.ActivitySummary.LatestType)) { <span>@Model.ActivitySummary.LatestType</span> }
                                @if (latestActivityIst is not null) { <span>@latestActivityIst.Value.ToString("dd MMM yyyy")</span> }
                                @if (!string.IsNullOrWhiteSpace(Model.ActivitySummary.LatestLocation)) { <span>@Model.ActivitySummary.LatestLocation</span> }
                            </div>
                        }
                        else { <strong>No activities recorded</strong> }
                    </div>
                </div>
            </article>

            <article class="db-panel db-innovation-card">
                <div class="db-section-head">
                    <div>
                        <span class="db-section-icon db-section-icon--indigo"><i class="bi bi-lightbulb"></i></span>
                        <div><h2>Innovation pipeline</h2><p>Ideas progressing through discussion and refinement</p></div>
                    </div>
                    <a asp-page="/ProjectIdeas/Index" class="db-text-link">Open ideation board <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="db-idea-summary">
                    <div class="db-idea-summary__primary"><strong>@Model.IdeaSummary.ActiveCount</strong><span>Active ideas</span></div>
                    <div><strong>@Model.IdeaSummary.OnHoldCount</strong><span>On hold</span></div>
                    <div><strong>@Model.IdeaSummary.UpdatedLast30Days</strong><span>Updated in 30 days</span></div>
                    <div><strong>@Model.IdeaSummary.IdeasWithDiscussion</strong><span>With discussion</span></div>
                    <div><strong>@Model.IdeaSummary.DocumentCount</strong><span>Documents</span></div>
                </div>
                <div class="db-idea-list">
                    @foreach (var idea in Model.IdeaSummary.LatestIdeas)
                    {
                        <a asp-page="/ProjectIdeas/Details" asp-route-id="@idea.Id" class="db-idea-row">
                            <div><strong>@idea.Title</strong><span>@idea.Status · Updated @idea.UpdatedAt.ToString("dd MMM yyyy")</span></div>
                            <div><span><i class="bi bi-chat"></i> @idea.CommentCount</span><span><i class="bi bi-paperclip"></i> @idea.DocumentCount</span></div>
                        </a>
                    }
                    @if (Model.IdeaSummary.LatestIdeas.Count == 0) { <div class="db-empty db-empty--compact">No active ideas recorded.</div> }
                </div>
            </article>
        </section>

        <section class="db-panel db-ffc-panel db-reveal" aria-label="FFC footprint">
            @await Html.PartialAsync("~/Areas/Dashboard/Components/FfcSimulatorMap/_Widget.cshtml", Model.FfcSimulatorMap)
        </section>

        <section class="db-utility-grid db-reveal" aria-label="Personal and system status">
            <article class="db-panel db-utility-card">
                <div class="db-utility-card__icon"><i class="bi bi-bell"></i></div>
                <div><h2>Personal reminders</h2><p><strong>@(Model.NotebookWidget?.OverdueCount ?? 0)</strong> overdue · <strong>@(Model.NotebookWidget?.DueTodayCount ?? 0)</strong> due today</p></div>
                <a asp-page="/Notebook/Index">Open notebook <i class="bi bi-arrow-right"></i></a>
            </article>
            <article class="db-panel db-utility-card @(searchHealthy ? "is-healthy" : "is-warning")">
                <div class="db-utility-card__icon"><i class="bi @(searchHealthy ? "bi-check2-circle" : "bi-exclamation-triangle")"></i></div>
                <div><h2>Document processing</h2><p>@(searchHealthy ? "All systems operational" : "OCR worker requires attention") · @Model.SearchHealth.TotalSearchable searchable documents</p></div>
                <a asp-area="DocumentRepository" asp-page="/Documents/Index">View status <i class="bi bi-arrow-right"></i></a>
            </article>
        </section>
    </main>

    <footer class="db-footer"><span>PRISM ERP · Simulator Development Division</span><span>All times shown in IST</span></footer>
</div>

@section Scripts {
    <script src="~/lib/chart.js/chart.umd.js"></script>
    <script src="~/js/pages/dashboard.js" asp-append-version="true"></script>
    <script src="~/lib/leaflet/1.9.4/leaflet.js" asp-append-version="true"></script>
    <script src="~/js/widgets/ffc-simulator-map.js" asp-append-version="true"></script>
}
