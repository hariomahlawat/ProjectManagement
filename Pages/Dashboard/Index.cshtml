@page
@model ProjectManagement.Pages.Dashboard.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Linq
@{
    ViewData["Title"] = "Dashboard";

    var pulse = Model.ProjectPulse;
    var ongoingCount = pulse?.OngoingCount ?? 0;
    var completedCount = pulse?.CompletedCount ?? 0;
    var readyCount = pulse?.ProliferationEligible ?? 0;
    var searchableCount = Model.SearchHealth?.TotalSearchable ?? 0;
    var assignedProjects = Model.MyProjectSections.SelectMany(section => section.Items).ToList();
    var currentStagesNeedingAttention = assignedProjects.Count(project =>
        project.StageSummary is null ||
        project.StageSummary.PlannedDue is null ||
        project.StageSummary.IsOverdue);

    var overdueReminders = Model.NotebookWidget?.OverdueCount ?? 0;
    var dueTodayReminders = Model.NotebookWidget?.DueTodayCount ?? 0;
    var workerHealthy = Model.SearchHealth?.WorkerActive == true;
    var searchHealthy = workerHealthy && (Model.SearchHealth?.Ocr.Failed ?? 0) == 0;

    var today = DateTime.Today;
    var fyStartYear = today.Month >= 4 ? today.Year : today.Year - 1;
    var fyLabel = $"Apr {fyStartYear} – Mar {fyStartYear + 1}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/widgets/project-pulse.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/widgets/ops-signals.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/leaflet/1.9.4/leaflet.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/widgets/ffc-simulator-map.css" asp-append-version="true" />
}

@if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-warning py-2 mb-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@err
    </div>
}

<div class="executive-dashboard">
    <header class="executive-dashboard__header">
        <div>
            <h1>Dashboard</h1>
            <p>Portfolio overview and institutional performance</p>
        </div>
        <div class="executive-dashboard__header-actions">
            <span class="executive-dashboard__updated">
                <i class="bi bi-arrow-repeat" aria-hidden="true"></i>
                Updated @DateTime.Now.ToString("dd MMM yyyy, HH:mm")
            </span>
            @if (pulse is not null)
            {
                <a class="btn btn-outline-primary btn-sm" href="@pulse.AnalyticsUrl">
                    <i class="bi bi-graph-up-arrow me-1" aria-hidden="true"></i>Open analytics
                </a>
            }
        </div>
    </header>

    <div class="executive-dashboard__layout">
        <main class="executive-dashboard__main">
            <section class="dashboard-kpis" aria-label="Portfolio summary">
                <a class="dashboard-kpi" href="@(pulse?.OngoingUrl ?? "#")">
                    <span class="dashboard-kpi__icon dashboard-kpi__icon--blue"><i class="bi bi-folder2-open"></i></span>
                    <span class="dashboard-kpi__body">
                        <span class="dashboard-kpi__label">Ongoing projects</span>
                        <strong>@ongoingCount</strong>
                        <small>Across all stages</small>
                    </span>
                    <span class="dashboard-kpi__link">View projects <i class="bi bi-arrow-right"></i></span>
                </a>

                <a class="dashboard-kpi" href="/Workspace#assigned-projects">
                    <span class="dashboard-kpi__icon dashboard-kpi__icon--amber"><i class="bi bi-exclamation-triangle"></i></span>
                    <span class="dashboard-kpi__body">
                        <span class="dashboard-kpi__label">Current stages needing attention</span>
                        <strong>@currentStagesNeedingAttention</strong>
                        <small>Overdue or incomplete current-stage timelines</small>
                    </span>
                    <span class="dashboard-kpi__link">View details <i class="bi bi-arrow-right"></i></span>
                </a>

                <a class="dashboard-kpi" href="@(pulse?.ProliferationEligibleUrl ?? "#")">
                    <span class="dashboard-kpi__icon dashboard-kpi__icon--green"><i class="bi bi-patch-check"></i></span>
                    <span class="dashboard-kpi__body">
                        <span class="dashboard-kpi__label">Ready for proliferation</span>
                        <strong>@readyCount</strong>
                        <small>Approved and suitable for proliferation</small>
                    </span>
                    <span class="dashboard-kpi__link">View list <i class="bi bi-arrow-right"></i></span>
                </a>

                <a class="dashboard-kpi" href="@(pulse?.CompletedUrl ?? "#")">
                    <span class="dashboard-kpi__icon dashboard-kpi__icon--purple"><i class="bi bi-flag"></i></span>
                    <span class="dashboard-kpi__body">
                        <span class="dashboard-kpi__label">Completed projects</span>
                        <strong>@completedCount</strong>
                        <small>Portfolio total</small>
                    </span>
                    <span class="dashboard-kpi__link">View completed <i class="bi bi-arrow-right"></i></span>
                </a>
            </section>

            <section class="dashboard-primary-panel" aria-label="Portfolio pulse">
                @if (pulse is not null)
                {
                    @await Html.PartialAsync("~/Areas/Dashboard/Components/ProjectPulse/_Widget.cshtml", pulse)
                }
                else
                {
                    <div class="dashboard-empty-state">Portfolio data is temporarily unavailable.</div>
                }
            </section>

            <section class="dashboard-primary-panel dashboard-outputs" aria-labelledby="dashboard-outputs-title">
                <div class="dashboard-panel-heading">
                    <div>
                        <h2 id="dashboard-outputs-title">Key outputs</h2>
                        <p>Current financial year · @fyLabel</p>
                    </div>
                    <a href="@(pulse?.AnalyticsUrl ?? "#")">View detailed analytics <i class="bi bi-arrow-right"></i></a>
                </div>
                @await Html.PartialAsync("~/Areas/Dashboard/Components/OpsSignals/_Widget.cshtml", Model.OpsSignals)
            </section>

            <section class="dashboard-primary-panel dashboard-ffc-compact" aria-label="FFC footprint">
                @await Html.PartialAsync("~/Areas/Dashboard/Components/FfcSimulatorMap/_Widget.cshtml", Model.FfcSimulatorMap)
            </section>
        </main>

        <aside class="executive-dashboard__rail">
            <section class="dashboard-rail-card dashboard-reminders-card" aria-labelledby="dashboard-reminders-title">
                <div class="dashboard-rail-card__head">
                    <div class="dashboard-rail-card__title">
                        <span class="dashboard-rail-card__icon"><i class="bi bi-calendar-check"></i></span>
                        <h2 id="dashboard-reminders-title">My reminders</h2>
                    </div>
                    <a asp-page="/Notebook/Index">View all</a>
                </div>

                <div class="dashboard-reminder-summary">
                    <div class="dashboard-reminder-summary__item dashboard-reminder-summary__item--danger">
                        <span>Overdue</span><strong>@overdueReminders</strong>
                    </div>
                    <div class="dashboard-reminder-summary__item">
                        <span>Due today</span><strong>@dueTodayReminders</strong>
                    </div>
                </div>

                @if (Model.NotebookWidget is not null)
                {
                    <div class="dashboard-rail-list">
                        <h3>Due / overdue</h3>
                        @await Html.PartialAsync("_NotebookWidgetList", Model.NotebookWidget.DueItems.Take(3).ToList())
                    </div>
                    <div class="dashboard-rail-list">
                        <h3>Pinned</h3>
                        @await Html.PartialAsync("_NotebookWidgetList", Model.NotebookWidget.PinnedItems.Take(2).ToList())
                    </div>
                }

                <a class="btn btn-primary btn-sm w-100 mt-3" asp-page="/Notebook/Index">Open My Notebook</a>
            </section>

            <section class="dashboard-rail-card dashboard-system-card" aria-labelledby="dashboard-system-title">
                <div class="dashboard-rail-card__head">
                    <div class="dashboard-rail-card__title">
                        <span class="dashboard-rail-card__icon"><i class="bi bi-cpu"></i></span>
                        <h2 id="dashboard-system-title">System status</h2>
                    </div>
                    <span class="dashboard-system-pill @(searchHealthy ? "is-healthy" : "is-warning")">
                        @(searchHealthy ? "Operational" : "Attention")
                    </span>
                </div>

                <div class="dashboard-system-list">
                    <div><span>OCR worker</span><strong class="@(workerHealthy ? "text-success" : "text-warning")">@(workerHealthy ? "Online" : "Offline")</strong></div>
                    <div><span>OCR failures</span><strong>@(Model.SearchHealth?.Ocr.Failed ?? 0)</strong></div>
                    <div><span>Searchable corpus</span><strong>@searchableCount documents</strong></div>
                    <div><span>Queue</span><strong>@((Model.SearchHealth?.Ocr.Pending ?? 0) == 0 ? "Clear" : $"{Model.SearchHealth!.Ocr.Pending} pending")</strong></div>
                </div>
                <a asp-area="DocumentRepository" asp-page="/Documents/Index" class="dashboard-rail-link">View document processing <i class="bi bi-arrow-right"></i></a>
            </section>

            <section class="dashboard-rail-card dashboard-quick-links" aria-labelledby="dashboard-quick-links-title">
                <div class="dashboard-rail-card__head">
                    <div class="dashboard-rail-card__title"><h2 id="dashboard-quick-links-title">Quick links</h2></div>
                </div>
                <div class="dashboard-quick-links__grid">
                    <a asp-page="/Projects/Ongoing"><i class="bi bi-folder2"></i><span>Projects</span></a>
                    <a asp-page="/Calendar/Index"><i class="bi bi-calendar3"></i><span>Calendar</span></a>
                    <a asp-area="DocumentRepository" asp-page="/Documents/Index"><i class="bi bi-file-earmark-text"></i><span>Documents</span></a>
                    <a href="@(pulse?.AnalyticsUrl ?? "#")"><i class="bi bi-bar-chart"></i><span>Analytics</span></a>
                </div>
            </section>
        </aside>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chart.js/chart.umd.js" asp-append-version="true" defer></script>
    <script type="module" src="~/js/widgets/project-pulse.js" asp-append-version="true"></script>
    <script type="module" src="~/js/widgets/ops-signals.js" asp-append-version="true"></script>
    <script src="~/lib/leaflet/1.9.4/leaflet.js" asp-append-version="true" defer></script>
    <script src="~/js/widgets/ffc-simulator-map.js" asp-append-version="true" defer></script>
}
