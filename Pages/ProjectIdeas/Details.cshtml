@page "{id:int}"
@model ProjectManagement.Pages.ProjectIdeas.DetailsModel
@using ProjectManagement.Models.ProjectIdeas
@{
    ViewData["UseFullWidth"] = true;
    ViewData["Title"] = Model.Idea.Title;
    var updatedLocal = Model.Idea.UpdatedAt.ToLocalTime();
    var updatedUtcIso = Model.Idea.UpdatedAt.ToUniversalTime().ToString("O");
}
<link rel="stylesheet" href="~/css/project-ideas.css" asp-append-version="true" />

<div class="pi-page">
    <a asp-page="Index" class="pi-back">← Back to Idea Workspace</a>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <section class="pi-detail-hero">
        <div class="pi-icon big"><span class="bi bi-lightbulb" aria-hidden="true"></span></div>

        <div class="pi-detail-title">
            <h1>@Model.Idea.Title</h1>
            <p>@Model.Idea.Description</p>

            @if (Model.CanEdit)
            {
                <span class="pi-notice"><span class="bi bi-info-circle" aria-hidden="true"></span> Assigned Project Officers may update the idea description; ownership and status remain controlled by HoD/Admin/Comdt.</span>
            }

            <div class="pi-detail-secondary-meta" aria-label="Idea record information">
                <span title="Assigned HoD">
                    <span class="bi bi-person-badge" aria-hidden="true"></span>
                    HoD: <strong>@(Model.Idea.AssignedHodUser?.FullName ?? "Unassigned")</strong>
                </span>
                <span title="Created by">
                    <span class="bi bi-person" aria-hidden="true"></span>
                    Created by <strong>@(Model.Idea.CreatedByUser?.FullName ?? "Unknown")</strong>
                </span>
                <span title="Last updated">
                    <span class="bi bi-clock-history" aria-hidden="true"></span>
                    Updated <time datetime="@updatedUtcIso">@updatedLocal.ToString("dd MMM yyyy, hh:mm tt")</time>
                </span>
            </div>
        </div>

        <div class="pi-detail-primary-meta" aria-label="Current idea ownership and status">
            <div class="pi-detail-primary-item">
                <span class="pi-detail-primary-label">Status</span>
                <b class="pi-status pi-status-@Model.Idea.Status.ToLowerInvariant()">@ProjectIdeaStatuses.ToDisplay(Model.Idea.Status)</b>
            </div>
            <div class="pi-detail-primary-item">
                <span class="pi-detail-primary-label">Assigned Project Officer</span>
                <strong>@(Model.Idea.AssignedProjectOfficerUser?.FullName ?? "Unassigned")</strong>
            </div>
        </div>

        <div class="pi-actions">
            @if (Model.CanEdit)
            {
                <a class="pi-btn" asp-page="Edit" asp-route-id="@Model.Idea.Id"><span class="bi bi-pencil" aria-hidden="true"></span> Edit idea</a>
            }
            @* SECTION: Archive action *@
            @if (Model.CanArchive && !Model.IsArchived)
            {
                <button type="button" class="pi-btn pi-btn-danger" data-bs-toggle="modal" data-bs-target="#archiveIdeaModal">
                    <span class="bi bi-archive" aria-hidden="true"></span> Archive
                </button>
            }
            @if (Model.CanRestore && Model.Idea.Status == ProjectIdeaStatuses.Archived)
            {
                <form method="post" asp-page-handler="Restore" asp-route-id="@Model.Idea.Id">
                    <button class="pi-btn pi-btn-primary" type="submit">Restore</button>
                </form>
            }
        </div>
    </section>


    @* SECTION: Archived read-only banner *@
    @if (Model.IsArchived)
    {
        <div class="alert alert-secondary d-flex align-items-start gap-2">
            <i class="bi bi-archive mt-1"></i>
            <div>
                <strong>This idea is archived.</strong>
                <div>It is retained for historical reference. Restore it to make changes.</div>
                @if (!string.IsNullOrWhiteSpace(Model.Idea.ArchiveReason))
                {
                    <div class="mt-2"><strong>Closing note:</strong> @Model.Idea.ArchiveReason</div>
                }
            </div>
        </div>
    }

    <div class="pi-workspace">
        <section class="pi-panel">
            <h2><span class="bi bi-chat-dots"></span> Discussion</h2>
            <div class="pi-feed">
                @foreach (var c in Model.Idea.Comments.OrderBy(c => c.CreatedAt))
                {
                    <article class="pi-comment">
                        <div class="pi-avatar">@DetailsModel.Initials(c.CreatedByUser?.FullName ?? c.CreatedByUser?.UserName)</div>
                        <div>
                            <b>@(c.CreatedByUser?.FullName ?? c.CreatedByUser?.UserName ?? "Unknown")</b>
                            <time>@c.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</time>
                            <p>@c.CommentText</p>
                        </div>
                    </article>
                }
            </div>
            @if (Model.CanAddComment)
            {
                <form method="post" asp-page-handler="Comment" asp-route-id="@Model.Idea.Id" class="pi-inline-form">
                    <textarea name="CommentText" placeholder="Write a comment..." maxlength="4000"></textarea>
                    <button class="pi-btn pi-btn-primary">Send</button>
                </form>
            }
        </section>

        <section class="pi-panel">
            <h2><span class="bi bi-journal-text"></span> Notes</h2>
            @foreach (var n in Model.Idea.Notes.OrderByDescending(n => n.IsPinned).ThenByDescending(n => n.UpdatedAt))
            {
                <article class="pi-note">
                    @if (n.IsPinned)
                    {
                        <span class="pi-featured">Featured</span>
                    }
                    <h3>@n.Title</h3>
                    <small>By @(n.CreatedByUser?.FullName ?? n.CreatedByUser?.UserName ?? "Unknown") · @n.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</small>
                    <p>@n.Body</p>
                </article>
            }
            @if (Model.CanAddNote)
            {
                <form method="post" asp-page-handler="Note" asp-route-id="@Model.Idea.Id" class="pi-inline-form">
                    <input name="NoteTitle" placeholder="Note title" maxlength="200" />
                    <textarea name="NoteBody" placeholder="Add a long-form note..."></textarea>
                    <label><input type="checkbox" name="IsPinned" value="true" /> Featured</label>
                    <button class="pi-btn">Add Note</button>
                </form>
            }
        </section>

        @* SECTION: Documents and images attachments panel *@
        <section class="pi-panel idea-attachments-card">
            <div class="idea-section-header">
                <div>
                    <h2><span class="bi bi-folder2-open"></span> Documents &amp; Images</h2>
                    <p>Supporting files, PDFs, screenshots and reference material.</p>
                </div>
                @if (Model.CanUpload)
                {
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#uploadDocumentModal">
                        <span class="bi bi-cloud-upload"></span> Upload
                    </button>
                }
            </div>

            @if (!Model.Documents.Any())
            {
                <div class="idea-empty-attachments">
                    <span class="bi bi-folder-plus"></span>
                    <strong>No documents or images yet</strong>
                    <span>Upload feasibility notes, sketches, PDFs, screenshots or reference files.</span>
                </div>
            }
            else
            {
                <div class="idea-attachment-list">
                    @foreach (var document in Model.Documents)
                    {
                        var isImage = DetailsModel.IsImage(document);
                        var isPdf = DetailsModel.IsPdf(document);
                        var previewUrl = Url.Page("/ProjectIdeas/Details", "Preview", new { id = Model.Idea.Id, documentId = document.Id });
                        var downloadUrl = Url.Page("/ProjectIdeas/Details", "Download", new { id = Model.Idea.Id, documentId = document.Id });

                        <div class="idea-attachment-row">
                            <div class="idea-attachment-leading">
                                @if (isImage)
                                {
                                    <button type="button" class="idea-attachment-thumb image" data-bs-toggle="modal" data-bs-target="#previewDocumentModal" data-preview-url="@previewUrl" data-download-url="@downloadUrl" data-file-name="@document.OriginalFileName" data-file-type="image" aria-label="Preview @document.OriginalFileName">
                                        <img src="@previewUrl" alt="@document.OriginalFileName" />
                                    </button>
                                }
                                else
                                {
                                    <div class="idea-attachment-icon @DetailsModel.FileTypeClass(document)" aria-hidden="true">
                                        <span class="bi @DetailsModel.FileIcon(document)"></span>
                                    </div>
                                }
                            </div>

                            <div class="idea-attachment-body">
                                <div class="idea-attachment-name" title="@document.OriginalFileName">@document.OriginalFileName</div>
                                <div class="idea-attachment-meta">
                                    <span>@DetailsModel.FileExtension(document)</span>
                                    <span>@DetailsModel.FormatFileSize(document.FileSizeBytes)</span>
                                    <span>@document.UploadedAt.ToLocalTime().ToString("dd MMM yyyy")</span>
                                    @if (document.UploadedByUser is not null)
                                    {
                                        <span title="Uploaded by @Model.DisplayUser(document.UploadedByUser)">By @Model.DisplayUser(document.UploadedByUser)</span>
                                    }
                                </div>
                            </div>

                            <div class="idea-attachment-actions">
                                @if (isImage || isPdf)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#previewDocumentModal" data-preview-url="@previewUrl" data-download-url="@downloadUrl" data-file-name="@document.OriginalFileName" data-file-type="@(isPdf ? "pdf" : "image")">
                                        <span class="bi bi-eye"></span> View
                                    </button>
                                }
                                <a class="btn btn-sm btn-outline-secondary" asp-page-handler="Download" asp-route-id="@Model.Idea.Id" asp-route-documentId="@document.Id">
                                    <span class="bi bi-download"></span> Download
                                </a>
                                @if (Model.CanDeleteDocument(document))
                                {
                                    <form method="post" asp-page-handler="DeleteDocument" asp-route-id="@Model.Idea.Id" asp-route-documentId="@document.Id" class="d-inline js-confirm-delete-attachment">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <span class="bi bi-trash"></span> Delete
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </div>
</div>

@* SECTION: Archive confirmation modal *@
@if (Model.CanArchive && !Model.IsArchived)
{
    <div class="modal fade" id="archiveIdeaModal" tabindex="-1" aria-labelledby="archiveIdeaModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="Archive" asp-route-id="@Model.Idea.Id" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="archiveIdeaModalLabel">Archive Idea</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted mb-3">
                        Please enter a closing note/reason. This idea will become read-only and retained for historical reference.
                    </p>
                    <label class="form-label" for="ArchiveReason">Closing note / reason</label>
                    <textarea id="ArchiveReason" name="ArchiveReason" class="form-control" required maxlength="1000" rows="4" placeholder="Enter reason for archiving this idea"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Archive Idea</button>
                </div>
            </form>
        </div>
    </div>
}

@* SECTION: Attachment preview modal *@
<div class="modal fade" id="previewDocumentModal" tabindex="-1" aria-labelledby="previewDocumentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content idea-preview-modal">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="previewDocumentModalLabel">Preview</h5>
                    <div class="small text-muted" id="previewDocumentFileName"></div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <a id="previewDocumentDownload" class="btn btn-sm btn-outline-primary" href="#">
                        <span class="bi bi-download"></span> Download
                    </a>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
            </div>
            <div class="modal-body">
                <div id="previewDocumentContainer" class="idea-preview-container"></div>
            </div>
        </div>
    </div>
</div>

@* SECTION: Document upload modal *@
@if (Model.CanUpload)
{
    <div class="modal fade" id="uploadDocumentModal" tabindex="-1" aria-labelledby="uploadDocumentModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" enctype="multipart/form-data" asp-page-handler="Upload" asp-route-id="@Model.Idea.Id" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="uploadDocumentModalLabel">Upload Document or Image</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <label asp-for="DocumentUpload" class="form-label">Select file</label>
                    <input asp-for="DocumentUpload" type="file" class="form-control" accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.png,.jpg,.jpeg" />
                    <div class="form-text">Allowed: PDF, Word, Excel, PowerPoint, PNG, JPG. Max size: 20 MB.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><span class="bi bi-cloud-upload"></span> Upload</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/pages/project-ideas-details.js" asp-append-version="true" defer></script>
}
