@page "{id:int}"
@model ProjectManagement.Pages.ProjectIdeas.DetailsModel
@using ProjectManagement.Models.ProjectIdeas
@{
    ViewData["UseFullWidth"] = true;
    ViewData["Title"] = Model.Idea.Title;

    var updatedLocal = Model.Idea.UpdatedAt.ToLocalTime();
    var updatedUtcIso = Model.Idea.UpdatedAt.ToUniversalTime().ToString("O");
    var comments = Model.Idea.Comments.Where(c => !c.IsDeleted).OrderBy(c => c.CreatedAt).ToList();
    var notes = Model.Idea.Notes.Where(n => !n.IsDeleted).OrderByDescending(n => n.IsPinned).ThenByDescending(n => n.UpdatedAt).ToList();
    var commentCount = comments.Count;
    var noteCount = notes.Count;
    var documentCount = Model.Documents.Count;
}
<link rel="stylesheet" href="~/css/project-ideas.css" asp-append-version="true" />

<div class="pi-page pi-detail-page">
    <a asp-page="Index" class="pi-back">
        <span class="bi bi-arrow-left" aria-hidden="true"></span>
        Back to Idea Workspace
    </a>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <section class="pi-detail-hero pi-detail-hero-compact">
        <div class="pi-icon big" aria-hidden="true"><span class="bi bi-lightbulb"></span></div>

        <div class="pi-detail-title">
            <div class="pi-detail-heading-row">
                <div>
                    <span class="pi-detail-kicker">Project idea</span>
                    <div class="pi-detail-title-line">
                        <h1>@Model.Idea.Title</h1>
                        <span class="pi-status pi-status-@Model.Idea.Status.ToLowerInvariant()">@ProjectIdeaStatuses.ToDisplay(Model.Idea.Status)</span>
                    </div>
                </div>
            </div>

            <p>@Model.Idea.Description</p>

            <div class="pi-detail-owner" aria-label="Assigned Project Officer">
                <span class="pi-detail-owner-label">Assigned Project Officer</span>
                <strong>@Model.DisplayUser(Model.Idea.AssignedProjectOfficerUser, "Unassigned")</strong>
            </div>

            @if (Model.ShowRestrictedEditNotice)
            {
                <div class="pi-permission-note" role="note">
                    <span class="bi bi-info-circle" aria-hidden="true"></span>
                    You may update the description. Ownership and status remain controlled by HoD, Admin and Comdt.
                </div>
            }

            <div class="pi-detail-secondary-meta" aria-label="Idea record information">
                <span title="Assigned HoD">
                    <span class="bi bi-person-badge" aria-hidden="true"></span>
                    HoD: <strong>@Model.DisplayUser(Model.Idea.AssignedHodUser, "Unassigned")</strong>
                </span>
                <span title="Created by">
                    <span class="bi bi-person" aria-hidden="true"></span>
                    Created by <strong>@Model.DisplayUser(Model.Idea.CreatedByUser)</strong>
                </span>
                <span title="Last updated">
                    <span class="bi bi-clock-history" aria-hidden="true"></span>
                    Updated <time datetime="@updatedUtcIso">@updatedLocal.ToString("dd MMM yyyy, hh:mm tt")</time>
                </span>
            </div>
        </div>

        <div class="pi-actions pi-detail-actions">
            @if (Model.CanEdit)
            {
                <a class="pi-btn" asp-page="Edit" asp-route-id="@Model.Idea.Id">
                    <span class="bi bi-pencil" aria-hidden="true"></span>
                    Edit idea
                </a>
            }
            @if (Model.CanArchive && !Model.IsArchived)
            {
                <button type="button" class="pi-btn pi-btn-danger" data-bs-toggle="modal" data-bs-target="#archiveIdeaModal">
                    <span class="bi bi-archive" aria-hidden="true"></span>
                    Archive
                </button>
            }
            @if (Model.CanRestore && Model.Idea.Status == ProjectIdeaStatuses.Archived)
            {
                <form method="post" asp-page-handler="Restore" asp-route-id="@Model.Idea.Id">
                    <button class="pi-btn pi-btn-primary" type="submit">
                        <span class="bi bi-arrow-counterclockwise" aria-hidden="true"></span>
                        Restore
                    </button>
                </form>
            }
        </div>
    </section>

    @* SECTION: Archived read-only banner *@
    @if (Model.IsArchived)
    {
        <div class="alert alert-secondary d-flex align-items-start gap-2">
            <i class="bi bi-archive mt-1" aria-hidden="true"></i>
            <div>
                <strong>This idea is archived.</strong>
                <div>It is retained for historical reference. Restore it to make changes.</div>
                @if (!string.IsNullOrWhiteSpace(Model.Idea.ArchiveReason))
                {
                    <div class="mt-2"><strong>Closing note:</strong> @Model.Idea.ArchiveReason</div>
                }
            </div>
        </div>
    }

    <div class="pi-workspace">
        @* SECTION: Discussion *@
        <section class="pi-panel" id="discussion">
            <div class="pi-panel-header">
                <div>
                    <h2>
                        <span class="bi bi-chat-dots" aria-hidden="true"></span>
                        Discussion
                        <span class="pi-section-count">@commentCount</span>
                    </h2>
                    <p>Questions, observations, progress updates and conference directions.</p>
                </div>
            </div>

            <div class="pi-feed">
                @if (comments.Count == 0)
                {
                    <div class="pi-section-empty">
                        <span class="bi bi-chat-square-text" aria-hidden="true"></span>
                        <strong>No comments yet</strong>
                        <span>Start the discussion with the first comment.</span>
                    </div>
                }
                else
                {
                    @foreach (var comment in comments)
                    {
                        var commentUtcIso = comment.CreatedAt.ToUniversalTime().ToString("O");
                        var isConferenceComment = string.Equals(comment.CommentType, ProjectIdeaCommentTypes.Conference, StringComparison.OrdinalIgnoreCase);
                        var roleLabel = DetailsModel.DisplayRole(comment.CreatedByRole);
                        <article class="pi-comment@(isConferenceComment ? " pi-comment-conference" : string.Empty)">
                            <div class="pi-avatar">@DetailsModel.Initials(comment.CreatedByUser?.FullName ?? comment.CreatedByUser?.UserName)</div>
                            <div class="pi-comment-content">
                                <div class="pi-comment-heading">
                                    <b>@(comment.CreatedByUser?.FullName ?? comment.CreatedByUser?.UserName ?? "Unknown")</b>
                                    <span class="pi-comment-type@(isConferenceComment ? " is-conference" : string.Empty)">@DetailsModel.DisplayCommentType(comment.CommentType)</span>
                                    @if (!string.IsNullOrWhiteSpace(roleLabel))
                                    {
                                        <span class="pi-comment-role">@roleLabel</span>
                                    }
                                </div>
                                <time datetime="@commentUtcIso">@comment.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</time>
                                <p>@comment.CommentText</p>
                                @if (isConferenceComment && !string.IsNullOrWhiteSpace(comment.StatusSnapshot))
                                {
                                    <div class="pi-comment-context">Status when issued: @ProjectIdeaStatuses.ToDisplay(comment.StatusSnapshot)</div>
                                }
                            </div>
                        </article>
                    }
                }
            </div>

            @if (Model.CanAddComment)
            {
                <form method="post" asp-page-handler="Comment" asp-route-id="@Model.Idea.Id" class="pi-inline-form pi-comment-composer" data-pi-comment-composer>
                    <input type="hidden" name="CommentType" value="@ProjectIdeaCommentTypes.General" data-pi-comment-type />
                    @if (Model.CanAddConferenceComment)
                    {
                        <div class="pi-comment-type-selector" role="group" aria-label="Comment type">
                            <button type="button" class="is-active" data-pi-comment-type-option="@ProjectIdeaCommentTypes.General" aria-pressed="true">General</button>
                            <button type="button" data-pi-comment-type-option="@ProjectIdeaCommentTypes.Conference" aria-pressed="false">Conference</button>
                        </div>
                    }
                    <label class="visually-hidden" for="CommentText">Write a comment</label>
                    <textarea id="CommentText" name="CommentText" placeholder="Write a comment..." maxlength="4000" required data-pi-comment-body></textarea>
                    <div class="pi-composer-actions">
                        <span data-pi-comment-guidance>Share a concise update or question.</span>
                        <button class="pi-btn pi-btn-primary" type="submit" data-pi-comment-submit>
                            <span class="bi bi-send" aria-hidden="true"></span>
                            <span data-pi-comment-submit-label>Send</span>
                        </button>
                    </div>
                </form>
            }
        </section>

        @* SECTION: Notes *@
        <section class="pi-panel" id="notes">
            <div class="pi-panel-header">
                <div>
                    <h2>
                        <span class="bi bi-journal-text" aria-hidden="true"></span>
                        Notes
                        <span class="pi-section-count">@noteCount</span>
                    </h2>
                    <p>Long-form working notes and important reference points.</p>
                </div>
                @if (Model.CanAddNote)
                {
                    <button type="button"
                            class="pi-section-action"
                            data-bs-toggle="collapse"
                            data-bs-target="#noteComposer"
                            aria-expanded="@Model.OpenNoteComposer.ToString().ToLowerInvariant()"
                            aria-controls="noteComposer">
                        <span class="bi bi-plus-lg" aria-hidden="true"></span>
                        Add note
                    </button>
                }
            </div>

            <div class="pi-note-list">
                @if (notes.Count == 0)
                {
                    <div class="pi-section-empty">
                        <span class="bi bi-journal-plus" aria-hidden="true"></span>
                        <strong>No notes yet</strong>
                        <span>Capture detailed thinking, assumptions or reference information.</span>
                    </div>
                }
                else
                {
                    @foreach (var note in notes)
                    {
                        <article class="pi-note">
                            @if (note.IsPinned)
                            {
                                <span class="pi-featured"><span class="bi bi-pin-angle-fill" aria-hidden="true"></span> Featured</span>
                            }
                            <h3>@note.Title</h3>
                            <small>By @(note.CreatedByUser?.FullName ?? note.CreatedByUser?.UserName ?? "Unknown") · @note.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</small>
                            <p>@note.Body</p>
                        </article>
                    }
                }
            </div>

            @if (Model.CanAddNote)
            {
                <div class="collapse pi-note-composer @(Model.OpenNoteComposer ? "show" : null)" id="noteComposer">
                    <form method="post" asp-page-handler="Note" asp-route-id="@Model.Idea.Id" class="pi-inline-form pi-note-composer-form">
                        <div class="pi-composer-heading">
                            <div>
                                <strong>Add a note</strong>
                                <span>Notes remain attached to this idea for future reference.</span>
                            </div>
                            <button type="button" class="btn-close" data-bs-toggle="collapse" data-bs-target="#noteComposer" aria-label="Close note composer"></button>
                        </div>

                        <label for="NoteTitle">Title</label>
                        <input id="NoteTitle" name="NoteTitle" placeholder="Note title" maxlength="200" required />

                        <label for="NoteBody">Note</label>
                        <textarea id="NoteBody" name="NoteBody" placeholder="Add a long-form note..." required></textarea>

                        <div class="pi-note-form-footer">
                            <label class="pi-checkbox-option">
                                <input type="checkbox" name="IsPinned" value="true" />
                                <span>Feature this note</span>
                            </label>
                            <button class="pi-btn pi-btn-primary" type="submit">
                                <span class="bi bi-plus-lg" aria-hidden="true"></span>
                                Add Note
                            </button>
                        </div>
                    </form>
                </div>
            }
        </section>

        @* SECTION: Documents and images attachments panel *@
        <section class="pi-panel idea-attachments-card" id="documents">
            <div class="pi-panel-header idea-section-header">
                <div>
                    <h2>
                        <span class="bi bi-folder2-open" aria-hidden="true"></span>
                        Documents &amp; Images
                        <span class="pi-section-count">@documentCount</span>
                    </h2>
                    <p>Supporting files, PDFs, screenshots and reference material.</p>
                </div>
                @if (Model.CanUpload)
                {
                    <button type="button" class="pi-section-action pi-section-action-primary" data-bs-toggle="modal" data-bs-target="#uploadDocumentModal">
                        <span class="bi bi-cloud-upload" aria-hidden="true"></span>
                        Upload
                    </button>
                }
            </div>

            @if (!Model.Documents.Any())
            {
                <div class="idea-empty-attachments">
                    <span class="bi bi-folder-plus" aria-hidden="true"></span>
                    <strong>No documents or images yet</strong>
                    <span>Upload feasibility notes, sketches, PDFs, screenshots or reference files.</span>
                </div>
            }
            else
            {
                <div class="idea-attachment-list">
                    @foreach (var document in Model.Documents)
                    {
                        var isImage = DetailsModel.IsImage(document);
                        var isPdf = DetailsModel.IsPdf(document);
                        var canPreview = isImage || isPdf;
                        var canDelete = Model.CanDeleteDocument(document);
                        var previewUrl = Url.Page("/ProjectIdeas/Details", "Preview", new { id = Model.Idea.Id, documentId = document.Id });
                        var downloadUrl = Url.Page("/ProjectIdeas/Details", "Download", new { id = Model.Idea.Id, documentId = document.Id });

                        <article class="idea-attachment-row">
                            <div class="idea-attachment-leading">
                                @if (isImage)
                                {
                                    <button type="button"
                                            class="idea-attachment-thumb image"
                                            data-bs-toggle="modal"
                                            data-bs-target="#previewDocumentModal"
                                            data-preview-url="@previewUrl"
                                            data-download-url="@downloadUrl"
                                            data-file-name="@document.OriginalFileName"
                                            data-file-type="image"
                                            aria-label="Preview @document.OriginalFileName">
                                        <img src="@previewUrl" alt="" />
                                    </button>
                                }
                                else
                                {
                                    <div class="idea-attachment-icon @DetailsModel.FileTypeClass(document)" aria-hidden="true">
                                        <span class="bi @DetailsModel.FileIcon(document)"></span>
                                    </div>
                                }
                            </div>

                            <div class="idea-attachment-body">
                                <div class="idea-attachment-name" title="@document.OriginalFileName">@document.OriginalFileName</div>
                                <div class="idea-attachment-meta">
                                    <span>@DetailsModel.FileExtension(document)</span>
                                    <span>@DetailsModel.FormatFileSize(document.FileSizeBytes)</span>
                                    <span>@document.UploadedAt.ToLocalTime().ToString("dd MMM yyyy")</span>
                                    @if (document.UploadedByUser is not null)
                                    {
                                        <span title="Uploaded by @Model.DisplayUser(document.UploadedByUser)">By @Model.DisplayUser(document.UploadedByUser)</span>
                                    }
                                </div>
                            </div>

                            <div class="idea-attachment-actions">
                                @if (canPreview)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#previewDocumentModal"
                                            data-preview-url="@previewUrl"
                                            data-download-url="@downloadUrl"
                                            data-file-name="@document.OriginalFileName"
                                            data-file-type="@(isPdf ? "pdf" : "image")">
                                        <span class="bi bi-eye" aria-hidden="true"></span>
                                        View
                                    </button>
                                    <a class="btn btn-sm btn-outline-secondary idea-icon-button"
                                       asp-page-handler="Download"
                                       asp-route-id="@Model.Idea.Id"
                                       asp-route-documentId="@document.Id"
                                       title="Download @document.OriginalFileName"
                                       aria-label="Download @document.OriginalFileName">
                                        <span class="bi bi-download" aria-hidden="true"></span>
                                    </a>
                                }
                                else
                                {
                                    <a class="btn btn-sm btn-outline-primary"
                                       asp-page-handler="Download"
                                       asp-route-id="@Model.Idea.Id"
                                       asp-route-documentId="@document.Id">
                                        <span class="bi bi-download" aria-hidden="true"></span>
                                        Download
                                    </a>
                                }

                                @if (canDelete)
                                {
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary idea-icon-button"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                aria-expanded="false"
                                                aria-label="More actions for @document.OriginalFileName"
                                                title="More actions">
                                            <span class="bi bi-three-dots" aria-hidden="true"></span>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <form method="post"
                                                      asp-page-handler="DeleteDocument"
                                                      asp-route-id="@Model.Idea.Id"
                                                      asp-route-documentId="@document.Id"
                                                      data-file-name="@document.OriginalFileName"
                                                      class="js-confirm-delete-attachment">
                                                    <button type="submit" class="dropdown-item text-danger">
                                                        <span class="bi bi-trash me-2" aria-hidden="true"></span>
                                                        Delete
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    </div>
</div>

@* SECTION: Archive confirmation modal *@
@if (Model.CanArchive && !Model.IsArchived)
{
    <div class="modal fade" id="archiveIdeaModal" tabindex="-1" aria-labelledby="archiveIdeaModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" asp-page-handler="Archive" asp-route-id="@Model.Idea.Id" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="archiveIdeaModalLabel">Archive Idea</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted mb-3">
                        Please enter a closing note or reason. This idea will become read-only and retained for historical reference.
                    </p>
                    <label class="form-label" for="ArchiveReason">Closing note / reason</label>
                    <textarea id="ArchiveReason" name="ArchiveReason" class="form-control" required maxlength="1000" rows="4" placeholder="Enter reason for archiving this idea"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Archive Idea</button>
                </div>
            </form>
        </div>
    </div>
}

@* SECTION: Attachment preview modal *@
<div class="modal fade" id="previewDocumentModal" tabindex="-1" aria-labelledby="previewDocumentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content idea-preview-modal">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="previewDocumentModalLabel">Preview</h5>
                    <div class="small text-muted" id="previewDocumentFileName"></div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <a id="previewDocumentDownload" class="btn btn-sm btn-outline-primary" href="#">
                        <span class="bi bi-download" aria-hidden="true"></span> Download
                    </a>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
            </div>
            <div class="modal-body">
                <div id="previewDocumentContainer" class="idea-preview-container"></div>
            </div>
        </div>
    </div>
</div>

@* SECTION: Document upload modal *@
@if (Model.CanUpload)
{
    <div class="modal fade" id="uploadDocumentModal" tabindex="-1" aria-labelledby="uploadDocumentModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <form method="post" enctype="multipart/form-data" asp-page-handler="Upload" asp-route-id="@Model.Idea.Id" class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="uploadDocumentModalLabel">Upload Document or Image</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <label asp-for="DocumentUpload" class="form-label">Select file</label>
                    <input asp-for="DocumentUpload" type="file" class="form-control" accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.png,.jpg,.jpeg" />
                    <div class="form-text">Allowed: PDF, Word, Excel, PowerPoint, PNG, JPG. Max size: 20 MB.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><span class="bi bi-cloud-upload" aria-hidden="true"></span> Upload</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/pages/project-ideas-details.js" asp-append-version="true" defer></script>
}
