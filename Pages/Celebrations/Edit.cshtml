@page "{id?}"
@model ProjectManagement.Pages.Celebrations.EditModel
@using ProjectManagement.Areas.Admin.Models
@{
    ViewData["Title"] = Model.PageTitle;
    var header = new AdminPageHeaderModel { Eyebrow = "Master data · Celebrations", Title = Model.PageTitle, Description = "Maintain an annual calendar record. This does not modify a user account profile.", Icon = Model.Input.EventType == ProjectManagement.Models.CelebrationType.Anniversary ? "bi-hearts" : "bi-cake2", Actions = new[] { new AdminPageActionModel { Text = "Back to celebrations", Href = Url.Page("./Index"), Icon = "bi-arrow-left" } } };
}
<partial name="~/Areas/Admin/Pages/Shared/_AdminPageHeader.cshtml" model="header" />
<div class="admin-form-layout"><form method="post" class="admin-panel admin-form-panel" novalidate><input asp-for="Input.Id" type="hidden" /><header class="admin-form-section__header"><span>01</span><div><h2>Celebration record</h2><p>The entry recurs annually on the selected date.</p></div></header><div class="admin-form-section__body"><div asp-validation-summary="ModelOnly" class="admin-validation-summary" role="alert"></div>@if(Model.IsRestrictedEditor){<div class="admin-operation-notice"><i class="bi bi-info-circle"></i><div><strong>Permission scope</strong><span>@Model.PermissionNotice</span></div></div>}<div class="admin-form-grid admin-form-grid--two"><div class="admin-field"><label asp-for="Input.EventType"></label>@if(Model.CanManageBothTypes){<select asp-for="Input.EventType" class="form-select"><option value="Birthday">Birthday</option><option value="Anniversary">Anniversary</option></select>}else{<input asp-for="Input.EventType" type="hidden" /><input class="form-control" value="@Model.RestrictedTypeLabel" readonly />}<span asp-validation-for="Input.EventType" class="text-danger"></span></div><div class="admin-field"><label asp-for="Input.Name"></label><input asp-for="Input.Name" class="form-control" maxlength="120" autocomplete="off" /><span asp-validation-for="Input.Name" class="text-danger"></span></div><div class="admin-field"><label asp-for="Input.SpouseName"></label><input asp-for="Input.SpouseName" class="form-control" maxlength="120" autocomplete="off" /><span asp-validation-for="Input.SpouseName" class="text-danger"></span></div></div><fieldset class="admin-date-fieldset"><legend>Annual date</legend><div class="admin-form-grid admin-form-grid--three"><div class="admin-field"><label asp-for="Input.Day"></label><input asp-for="Input.Day" class="form-control" type="number" min="1" max="31" /><span asp-validation-for="Input.Day" class="text-danger"></span></div><div class="admin-field"><label asp-for="Input.Month"></label><select asp-for="Input.Month" class="form-select"><option value="0">Select</option>@for(var month=1;month<=12;month++){<option value="@month">@System.Globalization.CultureInfo.InvariantCulture.DateTimeFormat.GetMonthName(month)</option>}</select><span asp-validation-for="Input.Month" class="text-danger"></span></div><div class="admin-field"><label asp-for="Input.Year"></label><input asp-for="Input.Year" class="form-control" type="number" min="1" max="9999" placeholder="Optional" /><span asp-validation-for="Input.Year" class="text-danger"></span><small>Optional; used only for historical context.</small></div></div></fieldset></div><footer class="admin-form-actions"><a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a><button class="btn btn-primary" type="submit"><i class="bi bi-check-lg"></i>Save celebration</button></footer></form><aside class="admin-guidance-card"><span class="admin-guidance-card__icon"><i class="bi bi-calendar-heart"></i></span><h2>Calendar behaviour</h2><ul><li>The entry appears annually.</li><li>Visibility follows each user's calendar preference.</li><li>User account profile data is not changed.</li></ul></aside></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
