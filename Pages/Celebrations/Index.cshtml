@page
@model ProjectManagement.Pages.Celebrations.IndexModel
@{
    ViewData["Title"] = "Birthdays & anniversaries";
}

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
    <div>
        <h1 class="h4 fw-semibold mb-1">Birthdays &amp; anniversaries</h1>
        <p class="text-muted mb-0">Maintain the recurring celebrations shown on the institutional calendar.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="/Calendar/Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-calendar3 me-1" aria-hidden="true"></i>Calendar
        </a>
        @if (Model.CanEdit)
        {
            <a asp-page="Edit" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1" aria-hidden="true"></i>@Model.AddButtonLabel
            </a>
        }
    </div>
</div>

@if (Model.CanManageBirthdays && !Model.CanManageAnniversaries)
{
    <div class="alert alert-info py-2 small" role="status">
        Main Office access is limited to adding, editing and deleting birthdays. Anniversaries remain view-only.
    </div>
}

<form method="get" class="card card-body border-0 shadow-sm mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-sm-3 col-lg-2">
            <label class="form-label small text-muted" for="celebrationTypeFilter">Type</label>
            <select id="celebrationTypeFilter" asp-for="Type" class="form-select form-select-sm">
                <option value="all">All</option>
                <option value="birthday">Birthday</option>
                <option value="anniversary">Anniversary</option>
            </select>
        </div>
        <div class="col-sm-3 col-lg-2">
            <label class="form-label small text-muted" for="celebrationWindowFilter">Window</label>
            <select id="celebrationWindowFilter" asp-for="Window" class="form-select form-select-sm">
                <option value="all">All</option>
                <option value="today">Today</option>
                <option value="7">Next 7 days</option>
                <option value="15">Next 15 days</option>
                <option value="30">Next 30 days</option>
            </select>
        </div>
        <div class="col-sm-4 col-lg-5">
            <label class="form-label small text-muted" for="celebrationSearch">Search</label>
            <input id="celebrationSearch"
                   type="search"
                   asp-for="Q"
                   class="form-control form-control-sm"
                   placeholder="Search by name" />
        </div>
        <div class="col-sm-2 col-lg-1">
            <button type="submit" class="btn btn-sm btn-outline-primary w-100">Filter</button>
        </div>
        <div class="col-lg-2 text-lg-end">
            <a asp-page="Index" class="btn btn-sm btn-link text-decoration-none">Clear</a>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Type</th>
                    <th scope="col">Next occurrence</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Items.Length == 0)
            {
                <tr>
                    <td colspan="4" class="text-center text-muted py-5">No matching birthdays or anniversaries.</td>
                </tr>
            }
            else
            {
                @foreach (var row in Model.Items)
                {
                    <tr>
                        <td class="fw-medium">@row.Name</td>
                        <td>
                            <span class="badge rounded-pill @(row.EventType == ProjectManagement.Models.CelebrationType.Birthday ? "text-bg-primary" : "text-bg-warning")">
                                @row.EventType
                            </span>
                        </td>
                        <td>
                            @row.NextOccurrence.ToString("dd MMM yyyy")
                            <span class="text-muted small ms-1">
                                @(row.DaysAway == 0 ? "Today" : $"in {row.DaysAway} days")
                            </span>
                        </td>
                        <td class="text-end text-nowrap">
                            @if (Model.CanManage(row.EventType))
                            {
                                <a asp-page="Edit"
                                   asp-route-id="@row.Id"
                                   class="btn btn-sm btn-link text-decoration-none">Edit</a>
                                <form method="post"
                                      asp-page-handler="Delete"
                                      asp-route-id="@row.Id"
                                      class="d-inline"
                                      onsubmit="return confirm('Delete this entry?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Type" value="@Model.Type" />
                                    <input type="hidden" name="Window" value="@Model.Window" />
                                    <input type="hidden" name="Q" value="@Model.Q" />
                                    <button type="submit" class="btn btn-sm btn-link text-danger text-decoration-none">Delete</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">View only</span>
                            }
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
