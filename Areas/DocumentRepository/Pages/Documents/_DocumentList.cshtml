@model ProjectManagement.Areas.DocumentRepository.Models.DocumentListItemVm
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Http.Extensions
@using Microsoft.AspNetCore.WebUtilities
@using System
@using System.Collections.Generic
@using System.Linq
@inject IAuthorizationService AuthorizationService

@{
    var canEdit = await AuthorizationService.AuthorizeAsync(User, "DocRepo.EditMetadata");
    var canSoftDelete = await AuthorizationService.AuthorizeAsync(User, "DocRepo.SoftDelete");
    // SECTION: Return URL
    var queryParams = QueryHelpers.ParseQuery(Context.Request.QueryString.Value);
    var filteredQuery = new QueryBuilder(
        queryParams
            .Where(kvp => !string.Equals(kvp.Key, "partial", StringComparison.OrdinalIgnoreCase))
            .SelectMany(kvp => kvp.Value, (kvp, value) => new KeyValuePair<string, string>(kvp.Key, value ?? string.Empty))
    );
    var returnUrl = $"{Context.Request.Path}{filteredQuery}";
    var readerUrl = Model.IsActive ? Url.Page("./Reader", new { id = Model.Id, returnUrl }) : string.Empty;
}

<tr class="docrepo-row @(Model.IsActive ? string.Empty : "docrepo-row--inactive")"
    data-href="@readerUrl"
    tabindex="0"
    role="link"
    aria-label="Open document @Model.Subject">
    <!-- SECTION: Subject -->
    <td>
        <div class="docrepo-subjectcell">
            <div class="docrepo-subjectcell__flags" data-no-row-nav>
                <authorize policy="DocRepo.View">
                    <button type="button"
                            class="docrepo-star"
                            data-docid="@Model.Id"
                            data-fav="@(Model.IsFavourite ? "true" : "false")"
                            title="@(Model.IsFavourite ? "Remove from favourites" : "Add to favourites")"
                            aria-label="@(Model.IsFavourite ? "Remove from favourites" : "Add to favourites")"
                            data-no-row-nav>
                        <i class="bi @(Model.IsFavourite ? "bi-star-fill" : "bi-star")"></i>
                    </button>
                </authorize>
                @if (Model.IsAots)
                {
                    <span class="docrepo-aots-badge" title="All officers to see">
                        <i class="bi bi-broadcast"></i>
                        <span>AOTS</span>
                    </span>
                }
                @if (Model.IsAotsUnread)
                {
                    <span class="docrepo-aots-dot" aria-label="Unread AOTS document" title="Unread AOTS document"></span>
                }
            </div>
            <div class="docrepo-subjectcell__content">
                @if (Model.IsActive)
                {
                    <a asp-page="./Reader" asp-route-id="@Model.Id" asp-route-returnUrl="@returnUrl" class="docrepo-subject-link" title="@Model.Subject">
                        @Model.Subject
                    </a>
                }
                else
                {
                    <span class="docrepo-subject-link text-muted" title="Inactive documents cannot be viewed. Download is available.">
                        @Model.Subject
                    </span>
                }
                @if (!Model.IsActive)
                {
                    <span class="badge rounded-pill bg-light text-muted">Inactive</span>
                }
            </div>
        </div>
    </td>

    <!-- SECTION: Document category -->
    <td>@Model.DocumentCategoryName</td>

    <!-- SECTION: Office -->
    <td>@Model.OfficeName</td>

    <!-- SECTION: Document date -->
    <td>@(Model.DocumentDate.HasValue ? Model.DocumentDate.Value.ToString("dd MMM yyyy") : string.Empty)</td>

    <!-- SECTION: OCR status -->
    <td>
        <span class="docrepo-ocr @(Model.OcrStatus switch
              {
                  ProjectManagement.Data.DocRepo.DocOcrStatus.Succeeded => "docrepo-ocr--ok",
                  ProjectManagement.Data.DocRepo.DocOcrStatus.Failed => "docrepo-ocr--fail",
                  ProjectManagement.Data.DocRepo.DocOcrStatus.Pending => "docrepo-ocr--pending",
                  _ => "docrepo-ocr--none"
              })"
              title="OCR: @Model.OcrStatus"
              aria-label="OCR status: @Model.OcrStatus">
            <i class="bi @(Model.OcrStatus switch
                 {
                     ProjectManagement.Data.DocRepo.DocOcrStatus.Succeeded => "bi-check-circle-fill",
                     ProjectManagement.Data.DocRepo.DocOcrStatus.Failed => "bi-exclamation-circle-fill",
                     ProjectManagement.Data.DocRepo.DocOcrStatus.Pending => "bi-clock-fill",
                     _ => "bi-dash-circle"
                 })"></i>
            @if (Model.OcrStatus != ProjectManagement.Data.DocRepo.DocOcrStatus.Succeeded)
            {
                <span>@Model.OcrStatus</span>
            }
        </span>
    </td>

    <!-- SECTION: Actions -->
    <td class="docrepo-actions text-end" data-no-row-nav>
        <!-- SECTION: Actions menu -->
        <div class="dropdown docrepo-actions__dropdown" data-no-row-nav>
            <button class="btn btn-sm btn-light"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    title="More actions"
                    data-no-row-nav>
                <i class="bi bi-three-dots-vertical"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end" data-no-row-nav>
                <!-- SECTION: Primary actions -->
                @if (Model.IsActive)
                {
                    <li>
                        <a class="dropdown-item"
                           asp-page="./Reader" asp-route-id="@Model.Id" asp-route-returnUrl="@returnUrl">
                            <i class="bi bi-eye me-2"></i>Open
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item"
                           asp-page="./View" asp-route-id="@Model.Id"
                           target="_blank"
                           rel="noopener">
                            <i class="bi bi-box-arrow-up-right me-2"></i>Open in new tab
                        </a>
                    </li>
                }
                else
                {
                    <li>
                        <span class="dropdown-item text-muted"
                              title="Inactive documents cannot be viewed. Download is available.">
                            <i class="bi bi-eye me-2"></i>Open
                        </span>
                    </li>
                    <li>
                        <span class="dropdown-item text-muted"
                              title="Inactive documents cannot be viewed. Download is available.">
                            <i class="bi bi-box-arrow-up-right me-2"></i>Open in new tab
                        </span>
                    </li>
                }
                <li>
                    <a class="dropdown-item"
                       asp-page="./Download" asp-route-id="@Model.Id">
                        <i class="bi bi-download me-2"></i>Download
                    </a>
                </li>
                <li><hr class="dropdown-divider" /></li>

                <!-- SECTION: Manage actions -->
                @if (canEdit.Succeeded)
                {
                    <li>
                        <a class="dropdown-item"
                           asp-page="./Edit" asp-route-id="@Model.Id">
                            <i class="bi bi-pencil-square me-2"></i>Edit metadata
                        </a>
                    </li>
                }
                else
                {
                    <li><span class="dropdown-item text-muted small">No editable fields</span></li>
                }

                @if (canSoftDelete.Succeeded)
                {
                    <li><hr class="dropdown-divider" /></li>
                    @if (Model.IsActive)
                    {
                        <li>
                            <form method="post" asp-page="./Manage" asp-page-handler="Deactivate" asp-route-id="@Model.Id" class="px-3 py-1">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-link p-0 text-warning">
                                    <i class="bi bi-slash-circle me-2"></i>Deactivate
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li>
                            <form method="post" asp-page="./Manage" asp-page-handler="Activate" asp-route-id="@Model.Id" class="px-3 py-1">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-link p-0 text-success">
                                    <i class="bi bi-check2-circle me-2"></i>Activate
                                </button>
                            </form>
                        </li>
                    }
                    <li>
                        <form method="post" asp-page="./Manage" asp-page-handler="RequestDelete" asp-route-id="@Model.Id" class="px-3 py-1">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-link p-0 text-danger">
                                <i class="bi bi-trash me-2"></i>Request delete
                            </button>
                        </form>
                    </li>
                }
            </ul>
        </div>
    </td>
</tr>
