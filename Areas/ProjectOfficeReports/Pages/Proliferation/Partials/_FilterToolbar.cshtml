@model ProjectManagement.Areas.ProjectOfficeReports.Proliferation.ViewModels.ProliferationFilterToolbarModel

<div class="pf-filter-toolbar" id="pf-filter-toolbar" data-filter-context="@Model.Context">
    <div class="d-flex flex-wrap align-items-center gap-2 w-100">
        <div class="flex-grow-1 flex-md-grow-0 pf-filter-project-picker">
            <partial name="~/Areas/ProjectOfficeReports/Pages/Proliferation/Partials/_ProjectSearchPicker.cshtml"
                     model="@(new ProjectManagement.Areas.ProjectOfficeReports.Proliferation.ViewModels.ProliferationProjectPickerModel(
                         InputId: "pf-filter-project-search",
                         ValueInputId: "pf-filter-project",
                         SuggestionsId: "pf-filter-project-suggestions",
                         Label: "Project",
                         Projects: Model.Projects.Select(project => new ProjectManagement.Areas.ProjectOfficeReports.Proliferation.ViewModels.ProliferationCompletedProjectOption(int.Parse(project.Value), project.Label)).ToList(),
                         Placeholder: "All projects",
                         EligibilityText: string.Empty,
                         Compact: true,
                         ShowLabel: false,
                         ShowEligibilityText: false,
                         ShowRecent: true,
                         AriaLabel: "Filter by project",
                         RecentStorageKey: "prism-proliferation-filter-recent-projects"))" />
        </div>
        <div class="flex-grow-1 flex-md-grow-0 pf-min-w-140">
            <label class="visually-hidden" for="pf-filter-source">Source</label>
            <select class="form-select form-select-sm" id="pf-filter-source" aria-label="Filter by source">
                <option value="">All sources</option>
                @foreach (var source in Model.Sources)
                {
                    <option value="@source.Value">@source.Label</option>
                }
            </select>
        </div>
        <div class="flex-grow-1 flex-md-grow-0 pf-min-w-140">
            <label class="visually-hidden" for="pf-filter-type">Type</label>
            <select class="form-select form-select-sm" id="pf-filter-type" aria-label="Filter by type">
                @foreach (var type in Model.Types)
                {
                    <option value="@type.Value">@type.Label</option>
                }
            </select>
        </div>
        @* SECTION: Approval status filter (manage context) *@
        @if (Model.Context == "manage")
        {
            <div class="flex-grow-1 flex-md-grow-0 pf-min-w-160">
                <label class="visually-hidden" for="pf-filter-status">Approval status</label>
                <select class="form-select form-select-sm" id="pf-filter-status" aria-label="Filter by approval status">
                    <option value="">All statuses</option>
                    <option value="pending">Pending</option>
                    <option value="approved">Approved</option>
                    <option value="rejected">Rejected</option>
                </select>
            </div>
        }
        <div class="flex-grow-1 flex-md-grow-0 pf-min-w-120">
            <label class="visually-hidden" for="pf-filter-year">Year</label>
            <input class="form-control form-control-sm" id="pf-filter-year" type="number" inputmode="numeric" min="2000" max="3000" placeholder="Year" aria-label="Filter by year" />
        </div>
        <div class="flex-grow-1 pf-min-w-200">
            <label class="visually-hidden" for="pf-filter-search">Search</label>
            <input class="form-control form-control-sm" id="pf-filter-search" type="search" placeholder="@Model.SearchPlaceholder" aria-label="Search proliferation records" />
        </div>
        <div class="ms-auto">
            <button class="btn btn-link btn-sm text-decoration-none" type="button" id="pf-filter-reset">Reset filters</button>
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-2" id="pf-filter-chips" aria-live="polite" aria-label="Active filters"></div>
</div>
