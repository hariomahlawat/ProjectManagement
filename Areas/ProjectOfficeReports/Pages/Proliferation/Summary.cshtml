@page
@model ProjectManagement.Areas.ProjectOfficeReports.Pages.Proliferation.SummaryModel
@using System
@using System.Linq
@using System.Text.Json
@{
    ViewData["Title"] = "Proliferation overview";
    ViewData["UseFullWidth"] = true;

    var projects = Model.Summary.ByProject
        .OrderByDescending(x => x.Totals.Total)
        .ThenBy(x => x.ProjectName, StringComparer.OrdinalIgnoreCase)
        .ToList();

    var years = Model.Summary.ByYear
        .OrderBy(x => x.Year)
        .ToList();

    var recentYears = years
        .Where(x => x.Year is >= 2000 and <= 3000)
        .OrderByDescending(x => x.Year)
        .Take(6)
        .ToList();

    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
}

<div class="container-xxl py-3 pf-shell" data-page="proliferation-summary">
    <nav aria-label="Breadcrumb" class="mb-2">
        <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item"><a asp-area="" asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Proliferation</li>
        </ol>
    </nav>

    <partial name="_ProliferationNav" model="Model.CanManageRecords" />

    <header class="pf-page-header pf-page-header--compact">
        <div>
            <h1 class="pf-page-title">Overview</h1>
            <p class="pf-page-subtitle mb-0">@Model.Lede</p>
        </div>
        <div class="pf-page-actions">
            @if (Model.CanManageRecords)
            {
                <a class="btn btn-primary"
                   asp-area="ProjectOfficeReports"
                   asp-page="/Proliferation/Manage">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i>
                    Add proliferation
                </a>
            }
        </div>
    </header>

    @if (Model.DataQualityIssueCount > 0)
    {
        <div class="alert alert-warning pf-quality-alert" role="alert">
            <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
            <div class="pf-quality-alert__copy">
                <strong>Data review required.</strong>
                <span>@Model.DataQualityIssueCount.ToString("N0") @(Model.DataQualityIssueCount == 1 ? "record has" : "records have") an invalid year. @(Model.DataQualityIssueCount == 1 ? "It is" : "They are") excluded from chronological analysis until corrected.</span>
                <span class="visually-hidden">Affected years: @string.Join(", ", Model.InvalidYears). Quantities remain included in the overall total.</span>
            </div>
            @if (Model.CanReviewDataQuality)
            {
                <a class="alert-link pf-quality-alert__action" asp-area="ProjectOfficeReports" asp-page="/Proliferation/Manage" asp-route-workspace="data-quality">Review @Model.DataQualityIssueCount.ToString("N0") @(Model.DataQualityIssueCount == 1 ? "record" : "records")</a>
            }
        </div>
    }

    <section class="pf-project-finder pf-project-finder--compact" aria-labelledby="find-project-heading">
        <div class="pf-project-finder__copy">
            <h2 id="find-project-heading">Find a project total</h2>
            <p>Open a project for its source split, year-wise calculation and detailed records.</p>
        </div>
        <div class="pf-project-finder__control">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search" aria-hidden="true"></i></span>
                <input type="text"
                       id="pf-project-search"
                       class="form-control"
                       placeholder="Search project name, acronym or code"
                       autocomplete="off" />
                <button type="button" class="btn btn-outline-secondary d-none pf-project-finder__clear" id="pf-project-search-clear" aria-label="Clear selected project">
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </button>
                <button type="button" class="btn btn-primary" id="pf-project-search-open" disabled>View total</button>
            </div>
            <input type="hidden" id="pf-project-search-id" />
            <div class="pf-suggestions d-none" id="pf-project-search-suggestions" role="listbox"></div>
            <div class="form-text" id="pf-project-search-status" aria-live="polite"></div>
        </div>
    </section>

    <section class="pf-kpi-grid" aria-label="Proliferation totals">
        <article class="pf-kpi pf-kpi--primary">
            <span>Total proliferation</span>
            <strong>@Model.GrandTotal.ToString("N0")</strong>
            <small>Approved reported total</small>
        </article>
        <article class="pf-kpi">
            <span>Projects</span>
            <strong>@Model.ProjectsTotal.ToString("N0")</strong>
            <small>With reported proliferation</small>
        </article>
        <article class="pf-kpi">
            <span>SDD</span>
            <strong>@Model.GrandSdd.ToString("N0")</strong>
            <small>@(Model.GrandTotal > 0 ? ((decimal)Model.GrandSdd / Model.GrandTotal).ToString("P1") : "0%") of total</small>
        </article>
        <article class="pf-kpi">
            <span>515 ABW</span>
            <strong>@Model.GrandAbw.ToString("N0")</strong>
            <small>@(Model.GrandTotal > 0 ? ((decimal)Model.GrandAbw / Model.GrandTotal).ToString("P1") : "0%") of total</small>
        </article>
    </section>

    <section class="pf-card mt-3" aria-labelledby="project-totals-heading">
        <div class="pf-card__header">
            <div>
                <h2 class="pf-card__title" id="project-totals-heading">Project totals</h2>
                <p class="pf-card__subtitle">The reported proliferation count is shown first. Open a project for the underlying calculation.</p>
            </div>
            <a class="btn btn-sm btn-outline-secondary"
               asp-page-handler="ExportProjects"
               title="Export project totals to Excel">
                <i class="bi bi-download" aria-hidden="true"></i>
                Export project totals
            </a>
        </div>

        @if (projects.Count == 0)
        {
            <div class="pf-empty-state">
                <i class="bi bi-inbox" aria-hidden="true"></i>
                <h3>No approved proliferation recorded</h3>
                <p>Approved project totals will appear here.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0 pf-project-table" id="pf-project-table">
                    <thead>
                        <tr>
                            <th scope="col">Project</th>
                            <th scope="col" class="text-end">SDD</th>
                            <th scope="col" class="text-end">515 ABW</th>
                            <th scope="col" class="text-end">Total proliferation</th>
                            <th scope="col" class="pf-table-action"><span class="visually-hidden">Open</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var projectIndex = 0; projectIndex < projects.Count; projectIndex++)
                        {
                            var project = projects[projectIndex];
                            <tr data-project-row data-project-rank="@(projectIndex + 1)" class="@(projectIndex >= 15 ? "pf-project-row--collapsed" : string.Empty)">
                                <td>
                                    <a class="pf-project-link"
                                       asp-area="ProjectOfficeReports"
                                       asp-page="/Proliferation/Project"
                                       asp-route-id="@project.ProjectId">
                                        <span>@project.ProjectName</span>
                                        @if (!string.IsNullOrWhiteSpace(project.ProjectCode))
                                        {
                                            <small>@project.ProjectCode</small>
                                        }
                                    </a>
                                </td>
                                <td class="text-end pf-number">@project.Totals.Sdd.ToString("N0")</td>
                                <td class="text-end pf-number">@project.Totals.Abw515.ToString("N0")</td>
                                <td class="text-end"><strong class="pf-total-pill">@project.Totals.Total.ToString("N0")</strong></td>
                                <td class="text-end">
                                    <a class="pf-row-open"
                                       asp-area="ProjectOfficeReports"
                                       asp-page="/Proliferation/Project"
                                       asp-route-id="@project.ProjectId"
                                       aria-label="Open @project.ProjectName proliferation details">
                                        <i class="bi bi-chevron-right" aria-hidden="true"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="pf-table-empty d-none" id="pf-project-no-results">
                No project matches the current search.
            </div>
            <div class="pf-card__footer">
                <span id="pf-project-count">Showing @Math.Min(15, projects.Count).ToString("N0") of @projects.Count.ToString("N0") projects</span>
                <div class="d-flex flex-wrap gap-3 align-items-center">
                    @if (projects.Count > 15)
                    {
                        <button type="button" class="btn btn-sm btn-link p-0" id="pf-project-show-all">View all @projects.Count.ToString("N0") projects</button>
                    }
                    <a asp-area="ProjectOfficeReports" asp-page="/Proliferation/Index">Browse grouped records</a>
                </div>
            </div>
        }
    </section>

    <section class="pf-card mt-3" id="proliferation-analytics" aria-labelledby="analytics-heading">
        <div class="pf-card__header pf-analytics-header">
            <div>
                <h2 class="pf-card__title" id="analytics-heading">Analytics</h2>
                <p class="pf-card__subtitle" id="pf-analytics-description">Year-wise reported proliferation with the SDD and 515 ABW split.</p>
            </div>
            <div class="pf-analytics-actions">
                <div class="btn-group btn-group-sm" role="tablist" aria-label="Analytics view">
                    <button type="button" class="btn btn-outline-secondary active" role="tab" aria-selected="true" data-analytics-tab="trend">Year-wise</button>
                    @if (Model.TechnicalCategoryBreakdown.Count > 0)
                    {
                        <button type="button" class="btn btn-outline-secondary" role="tab" aria-selected="false" data-analytics-tab="category">Technical category</button>
                    }
                </div>
                <div class="btn-group btn-group-sm" role="group" aria-label="Trend period" data-analytics-trend-controls>
                    <button type="button" class="btn btn-outline-secondary active" data-trend-range="10">Last 10 years</button>
                    <button type="button" class="btn btn-outline-secondary" data-trend-range="all">All years</button>
                </div>
            </div>
        </div>

        <div class="pf-analytics-panel" data-analytics-panel="trend">
            <div class="row g-0">
                <div class="col-12 col-xl-8 pf-analytics-chart-column">
                    <div id="proliferation-yearly-chart"
                         class="pf-chart-host"
                         data-yearly='@JsonSerializer.Serialize(years, jsonOptions)'>
                        <canvas id="proliferation-yearly-chart-canvas" aria-label="Year-wise proliferation chart" role="img"></canvas>
                    </div>
                    <div class="pf-chart-fallback">
                        <span class="text-muted d-none" id="proliferation-yearly-chart-message" role="status"></span>
                        <a asp-page-handler="ExportYearBreakdown">Export year-wise data</a>
                    </div>
                </div>
                <div class="col-12 col-xl-4 pf-recent-years-column" aria-labelledby="recent-years-heading">
                    <div class="pf-analytics-subheader">
                        <h3 id="recent-years-heading">Recent years</h3>
                        <span>Exact reported totals</span>
                    </div>
                    <div class="pf-recent-years">
                        @foreach (var year in recentYears)
                        {
                            <div class="pf-recent-year">
                                <div>
                                    <strong>@year.Year</strong>
                                    <small>SDD @year.Totals.Sdd.ToString("N0") · 515 ABW @year.Totals.Abw515.ToString("N0")</small>
                                </div>
                                <span>@year.Totals.Total.ToString("N0")</span>
                            </div>
                        }
                        @if (recentYears.Count == 0)
                        {
                            <p class="text-muted mb-0">No year-wise data is available.</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (Model.TechnicalCategoryBreakdown.Count > 0)
        {
            <div class="pf-analytics-panel d-none" data-analytics-panel="category" hidden>
                <div id="proliferation-techcat-chart"
                     class="pf-chart-host pf-chart-host--category"
                     data-categories='@JsonSerializer.Serialize(Model.TechnicalCategoryBreakdown, jsonOptions)'>
                    <canvas id="proliferation-techcat-chart-canvas" aria-label="Proliferation by technical category chart" role="img"></canvas>
                </div>
                <p class="text-muted small d-none px-3 pb-3 mb-0" id="proliferation-techcat-chart-message" role="status"></p>
            </div>
        }
    </section>

</div>

<link rel="stylesheet" href="~/css/proliferation.css" asp-append-version="true" />
<script src="~/lib/chartjs/chart.umd.js" asp-append-version="true" defer></script>
<script src="~/js/components/proliferation-project-picker.js" asp-append-version="true" defer></script>
<script src="~/js/pages/project-office-reports/proliferation-summary-charts.js" asp-append-version="true" defer></script>
