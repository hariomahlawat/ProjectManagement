@page
@model ProjectManagement.Areas.ProjectOfficeReports.Pages.Proliferation.ManageModel
@{
    ViewData["Title"] = "Manage proliferation";
    ViewData["UseFullWidth"] = true;
}

<div class="container-xxl py-3 pf-shell"
     data-page="proliferation-manage"
     data-can-approve="@(Model.CanApproveRecords ? "true" : "false")"
     data-initial-workspace="@Model.InitialWorkspace">
    <nav aria-label="Breadcrumb" class="mb-2">
        <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item"><a asp-area="" asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-area="ProjectOfficeReports" asp-page="/Proliferation/Summary">Proliferation</a></li>
            <li class="breadcrumb-item active" aria-current="page">Manage</li>
        </ol>
    </nav>

    <partial name="_ProliferationNav" model="true" />

    <header class="pf-page-header pf-page-header--compact">
        <div>
            <h1 class="pf-page-title">Manage proliferation</h1>
            <p class="pf-page-subtitle mb-0">Add and review records, approve submissions and manage exceptional counting rules.</p>
        </div>
    </header>

    <nav class="pf-workspace-tabs" aria-label="Manage proliferation workspaces" role="tablist">
        <button type="button" class="pf-workspace-tab active" data-workspace="records" data-workspace-panel="records" role="tab" aria-selected="true" aria-controls="pf-workspace-records">
            <i class="bi bi-pencil-square" aria-hidden="true"></i>
            <span>Records</span>
        </button>
        @if (Model.CanApproveRecords)
        {
            <button type="button" class="pf-workspace-tab" data-workspace="approvals" data-workspace-panel="records" role="tab" aria-selected="false" aria-controls="pf-workspace-records">
                <i class="bi bi-check2-square" aria-hidden="true"></i>
                <span>Pending approval</span>
                <span class="badge rounded-pill text-bg-warning d-none" id="pf-pending-badge"></span>
            </button>
        }
        @if (Model.CanManagePreferences)
        {
            <button type="button" class="pf-workspace-tab" data-workspace="counting-rules" data-workspace-panel="counting-rules" role="tab" aria-selected="false" aria-controls="pf-workspace-counting-rules">
                <i class="bi bi-sliders" aria-hidden="true"></i>
                <span>Counting rules</span>
            </button>
        }
        @if (Model.CanReviewDataQuality)
        {
            <button type="button" class="pf-workspace-tab" data-workspace="data-quality" data-workspace-panel="data-quality" role="tab" aria-selected="false" aria-controls="pf-workspace-data-quality">
                <i class="bi bi-shield-check" aria-hidden="true"></i>
                <span>Data quality</span>
                <span class="badge rounded-pill text-bg-danger d-none" id="pf-quality-badge"></span>
            </button>
        }
    </nav>

    <section data-workspace-panel="records" class="pf-workspace-panel" id="pf-workspace-records" role="tabpanel">
        <div class="pf-manage-layout" id="pf-manage-layout">
            <section class="pf-manage-column pf-manage-column--list" id="pf-list-panel" aria-label="Existing records">
                <partial name="_ProliferationList" model="Model.ListBoot" />
            </section>
            <section class="pf-manage-column pf-manage-column--detail" id="pf-detail-panel" aria-label="Record editor">
                <div class="pf-entry-type-switch pf-manage-new-actions" aria-label="New proliferation record type">
                    <span class="pf-entry-type-switch__label">New record</span>
                    <div class="btn-group btn-group-sm" role="group" aria-label="Choose entry type">
                        <button type="button" class="btn btn-outline-primary" data-new-proliferation="granular">
                            <i class="bi bi-list-check" aria-hidden="true"></i> Detailed entry
                        </button>
                        <button type="button" class="btn btn-outline-primary" data-new-proliferation="yearly">
                            <i class="bi bi-calendar3" aria-hidden="true"></i> Annual quantity
                        </button>
                    </div>
                    <span class="pf-entry-type-switch__help">Use detailed when date and unit are known; otherwise record the annual aggregate.</span>
                </div>

                <div class="pf-command-bar pf-command-bar--integrated" data-command-bar aria-label="Record actions">
                    <div class="pf-command-bar__actions">
                        @if (Model.CanApproveRecords)
                        {
                            <button class="btn btn-sm btn-success d-none" id="pf-approve" type="button">
                                <i class="bi bi-check-lg" aria-hidden="true"></i> Approve
                            </button>
                            <button class="btn btn-sm btn-outline-danger d-none" id="pf-reject" type="button">
                                <i class="bi bi-x-lg" aria-hidden="true"></i> Reject
                            </button>
                        }
                        <button class="btn btn-sm btn-primary" id="pf-save" type="submit" form="pf-form" disabled aria-disabled="true">
                            <i class="bi bi-check2" aria-hidden="true"></i> <span data-save-label>Save</span>
                        </button>
                        <button class="btn btn-sm btn-outline-danger d-none" id="pf-delete" type="button">Delete</button>
                    </div>
                </div>

                <partial name="_ProliferationEditor" model="Model.EditorBoot" />
            </section>
        </div>
    </section>

    @if (Model.CanManagePreferences)
    {
        <section data-workspace-panel="counting-rules" class="pf-workspace-panel d-none" id="pf-workspace-counting-rules" role="tabpanel" hidden>
            <partial name="_PreferenceOverrides" model="Model.OverridesBoot" />
        </section>
    }

    @if (Model.CanReviewDataQuality)
    {
        <section data-workspace-panel="data-quality" class="pf-workspace-panel d-none" id="pf-workspace-data-quality" role="tabpanel" hidden>
            <partial name="_DataQualityPanel" />
        </section>
    }

</div>

<div class="modal fade" id="pf-delete-modal" tabindex="-1" aria-labelledby="pf-delete-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h2 class="modal-title fs-5" id="pf-delete-modal-label">Delete proliferation record</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cancel deletion"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">Delete the <span data-confirm-type>selected record</span> for <strong data-confirm-project>this project</strong>?</p>
                <dl class="row small mb-2">
                    <dt class="col-4">Source</dt><dd class="col-8" data-confirm-source>—</dd>
                    <dt class="col-4">Date / year</dt><dd class="col-8" data-confirm-date>—</dd>
                    <dt class="col-4">Quantity</dt><dd class="col-8" data-confirm-quantity>—</dd>
                    <dt class="col-4">Status</dt><dd class="col-8" data-confirm-status>—</dd>
                </dl>
                <p class="text-danger small mb-0">This action cannot be undone. Approved records can be deleted only by Admin or HoD.</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" data-confirm-cancel>Cancel</button>
                <button type="button" class="btn btn-danger" data-confirm-accept>Delete record</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="pf-reject-modal" tabindex="-1" aria-labelledby="pf-reject-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="pf-reject-modal-label">Reject proliferation record</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cancel rejection"></button>
            </div>
            <div class="modal-body">
                <label class="form-label" for="pf-reject-reason">Reason for rejection</label>
                <textarea class="form-control" id="pf-reject-reason" rows="4" maxlength="500" required></textarea>
                <div class="form-text">The reason will be retained in the audit trail and should clearly state the correction required.</div>
                <div class="text-danger small mt-2 d-none" id="pf-reject-reason-error">Enter a reason for rejection.</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="pf-reject-confirm">Reject record</button>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed top-0 end-0 p-3" id="toastHost" aria-live="polite" aria-atomic="true"></div>

@section Scripts {
    <script src="~/js/pages/proliferation-manage.js" asp-append-version="true"></script>
    <script src="~/js/pages/proliferation-manage-workspaces.js" asp-append-version="true"></script>
    @if (Model.CanReviewDataQuality)
    {
        <script src="~/js/pages/proliferation-data-quality.js" asp-append-version="true"></script>
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/proliferation.css" asp-append-version="true" />
}
