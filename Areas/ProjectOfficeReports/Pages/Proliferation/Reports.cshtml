@page
@model ProjectManagement.Areas.ProjectOfficeReports.Pages.Proliferation.ReportsModel
@{
    ViewData["Title"] = "Proliferation reports";
    ViewData["UseFullWidth"] = true;
}

<div class="container-xxl py-3 pf-shell pf-analysis-page"
     data-page="proliferation-analysis"
     data-analysis-endpoint="/api/proliferation/reports/analysis"
     data-export-endpoint="/api/proliferation/reports/analysis/export"
     data-projects-endpoint="/api/proliferation/projects"
     data-lookups-endpoint="/api/proliferation/lookups"
     data-project-page-base="/ProjectOfficeReports/Proliferation/Project/"
     data-minimum-year="@Model.MinimumYear"
     data-maximum-year="@Model.MaximumYear"
     data-current-year="@Model.CurrentYear">

    <div class="d-none" id="pf-analysis-antiforgery">
        @Html.AntiForgeryToken()
    </div>

    <nav aria-label="Breadcrumb" class="mb-2">
        <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item"><a asp-area="" asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-area="ProjectOfficeReports" asp-page="/Proliferation/Summary">Proliferation</a></li>
            <li class="breadcrumb-item active" aria-current="page">Reports</li>
        </ol>
    </nav>

    <partial name="_ProliferationNav" model="Model.CanManageRecords" />

    <header class="pf-page-header pf-page-header--compact pf-analysis-header">
        <div>
            <h1 class="pf-page-title">Reports</h1>
            <p class="pf-page-subtitle mb-0">Analyse proliferation by period, technical category or selected simulators.</p>
        </div>
        <div class="pf-page-actions">
            <button class="btn btn-outline-success" id="pf-analysis-export" type="button" disabled>
                <i class="bi bi-download" aria-hidden="true"></i>
                Export Excel
            </button>
        </div>
    </header>

    <section class="pf-card pf-analysis-setup" aria-labelledby="pf-analysis-setup-heading">
        <div class="pf-card__header">
            <div>
                <h2 class="pf-card__title" id="pf-analysis-setup-heading">Build report</h2>
                <p class="pf-card__subtitle">Select what to analyse and the period. Results begin with the total and allow unit-wise detail when required.</p>
            </div>
        </div>

        <div class="pf-analysis-setup__body">
            <fieldset class="pf-analysis-step">
                <legend>
                    <span class="pf-analysis-step__number">1</span>
                    What do you want to analyse?
                </legend>

                <div class="pf-analysis-scope-grid" role="radiogroup" aria-label="Analysis scope">
                    <label class="pf-analysis-choice is-selected">
                        <input class="visually-hidden" type="radio" name="analysisScope" value="1" checked />
                        <span class="pf-analysis-choice__icon"><i class="bi bi-bar-chart-line" aria-hidden="true"></i></span>
                        <span>
                            <strong>All proliferation</strong>
                            <small>Total proliferation across all eligible simulators.</small>
                        </span>
                    </label>

                    <label class="pf-analysis-choice">
                        <input class="visually-hidden" type="radio" name="analysisScope" value="2" />
                        <span class="pf-analysis-choice__icon"><i class="bi bi-diagram-3" aria-hidden="true"></i></span>
                        <span>
                            <strong>Technical category</strong>
                            <small>Total for one technical category and its simulators.</small>
                        </span>
                    </label>

                    <label class="pf-analysis-choice">
                        <input class="visually-hidden" type="radio" name="analysisScope" value="3" />
                        <span class="pf-analysis-choice__icon"><i class="bi bi-ui-checks-grid" aria-hidden="true"></i></span>
                        <span>
                            <strong>Selected simulators</strong>
                            <small>Compare one or more selected simulators.</small>
                        </span>
                    </label>
                </div>
            </fieldset>

            <fieldset class="pf-analysis-step">
                <legend>
                    <span class="pf-analysis-step__number">2</span>
                    Select period
                </legend>

                <div class="row g-3 align-items-end">
                    <div class="col-12 col-md-4 col-xl-3">
                        <label class="form-label" for="pf-analysis-period-mode">Period</label>
                        <select class="form-select" id="pf-analysis-period-mode">
                            <option value="1">All time</option>
                            <option value="2">Single year</option>
                            <option value="3">Year range</option>
                            <option value="4">Custom dates</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-4 col-xl-3 d-none" id="pf-analysis-single-year-wrap">
                        <label class="form-label" for="pf-analysis-year">Year</label>
                        <select class="form-select" id="pf-analysis-year"></select>
                    </div>

                    <div class="col-6 col-md-4 col-xl-3 d-none" id="pf-analysis-from-year-wrap">
                        <label class="form-label" for="pf-analysis-from-year">From year</label>
                        <select class="form-select" id="pf-analysis-from-year"></select>
                    </div>

                    <div class="col-6 col-md-4 col-xl-3 d-none" id="pf-analysis-to-year-wrap">
                        <label class="form-label" for="pf-analysis-to-year">To year</label>
                        <select class="form-select" id="pf-analysis-to-year"></select>
                    </div>

                    <div class="col-12 col-md-4 col-xl-3 d-none" id="pf-analysis-from-date-wrap">
                        <label class="form-label" for="pf-analysis-from-date">From date</label>
                        <input class="form-control" type="date" id="pf-analysis-from-date" />
                    </div>

                    <div class="col-12 col-md-4 col-xl-3 d-none" id="pf-analysis-to-date-wrap">
                        <label class="form-label" for="pf-analysis-to-date">To date</label>
                        <input class="form-control" type="date" id="pf-analysis-to-date" />
                    </div>
                </div>

                <div class="pf-analysis-date-note d-none" id="pf-analysis-date-note" role="note">
                    <i class="bi bi-info-circle" aria-hidden="true"></i>
                    <span>Exact-date reports use approved detailed entries only. Annual quantities cannot be assigned to a specific date within the year.</span>
                </div>
            </fieldset>

            <fieldset class="pf-analysis-step d-none" id="pf-analysis-scope-options">
                <legend>
                    <span class="pf-analysis-step__number">3</span>
                    Select scope
                </legend>

                <div class="d-none" id="pf-analysis-category-wrap">
                    <label class="form-label" for="pf-analysis-category">Technical category</label>
                    <select class="form-select pf-analysis-category-select" id="pf-analysis-category">
                        <option value="">Select technical category</option>
                    </select>
                    <div class="form-text">Only completed simulators in the selected category are included.</div>
                </div>

                <div class="d-none" id="pf-analysis-projects-wrap">
                    <label class="form-label" for="pf-analysis-project-search">Simulators</label>
                    <div class="pf-analysis-project-picker">
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search" aria-hidden="true"></i></span>
                            <input class="form-control"
                                   id="pf-analysis-project-search"
                                   autocomplete="off"
                                   placeholder="Search project name, acronym or code"
                                   aria-autocomplete="list"
                                   aria-haspopup="listbox"
                                   aria-expanded="false"
                                   aria-controls="pf-analysis-project-suggestions" />
                        </div>
                        <div class="pf-analysis-project-suggestions d-none"
                             id="pf-analysis-project-suggestions"
                             role="listbox"></div>
                    </div>
                    <div class="pf-analysis-project-chips" id="pf-analysis-project-chips" aria-live="polite"></div>
                    <div class="form-text" id="pf-analysis-project-status">Select one or more simulators.</div>
                </div>
            </fieldset>

            <details class="pf-analysis-more">
                <summary>More options</summary>
                <div class="pf-analysis-more__body">
                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="pf-analysis-source">Source</label>
                            <select class="form-select" id="pf-analysis-source">
                                <option value="">All sources</option>
                                <option value="1">SDD</option>
                                <option value="2">515 ABW</option>
                            </select>
                        </div>
                    </div>
                </div>
            </details>

            <div class="pf-analysis-actions">
                <button class="btn btn-primary" id="pf-analysis-run" type="button">
                    <i class="bi bi-play-fill" aria-hidden="true"></i>
                    Generate report
                </button>
                <button class="btn btn-link" id="pf-analysis-clear" type="button">Clear</button>
                <div class="pf-analysis-status" id="pf-analysis-status" role="status" aria-live="polite"></div>
            </div>
        </div>
    </section>

    <section class="pf-analysis-results d-none" id="pf-analysis-results" aria-labelledby="pf-analysis-results-heading">
        <div class="pf-analysis-results__heading">
            <div>
                <span class="pf-analysis-eyebrow">Generated report</span>
                <h2 id="pf-analysis-results-heading">Proliferation analysis</h2>
                <p id="pf-analysis-result-context"></p>
            </div>
            <button class="btn btn-sm btn-outline-secondary" id="pf-analysis-edit" type="button">
                <i class="bi bi-sliders" aria-hidden="true"></i>
                Edit report
            </button>
        </div>

        <div class="pf-analysis-summary-grid">
            <article class="pf-analysis-total-card">
                <span>Total proliferation</span>
                <strong id="pf-analysis-total">0</strong>
                <small id="pf-analysis-basis"></small>
            </article>

            <article class="pf-analysis-metric-card">
                <span>SDD</span>
                <strong id="pf-analysis-sdd">0</strong>
            </article>

            <article class="pf-analysis-metric-card">
                <span>515 ABW</span>
                <strong id="pf-analysis-abw">0</strong>
            </article>

            <article class="pf-analysis-metric-card">
                <span>Simulators covered</span>
                <strong id="pf-analysis-project-count">0</strong>
            </article>

            <article class="pf-analysis-metric-card">
                <span>Receiving units</span>
                <strong id="pf-analysis-unit-count">—</strong>
                <small id="pf-analysis-unit-count-note">Loaded on request</small>
            </article>
        </div>

        <div class="pf-analysis-coverage" id="pf-analysis-coverage" role="note"></div>

        <section class="pf-card pf-analysis-breakdown" aria-labelledby="pf-analysis-project-breakdown-heading">
            <div class="pf-card__header">
                <div>
                    <h3 class="pf-card__title" id="pf-analysis-project-breakdown-heading">Simulator breakdown</h3>
                    <p class="pf-card__subtitle">Reported proliferation by simulator and source.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Simulator</th>
                            <th scope="col">Technical category</th>
                            <th scope="col" class="text-end">SDD</th>
                            <th scope="col" class="text-end">515 ABW</th>
                            <th scope="col" class="text-end">Total proliferation</th>
                        </tr>
                    </thead>
                    <tbody id="pf-analysis-project-body"></tbody>
                </table>
            </div>
        </section>

        <section class="pf-card pf-analysis-breakdown" aria-labelledby="pf-analysis-unit-breakdown-heading">
            <div class="pf-card__header pf-analysis-unit-header">
                <div>
                    <h3 class="pf-card__title" id="pf-analysis-unit-breakdown-heading">Unit-wise breakdown</h3>
                    <p class="pf-card__subtitle">Receiving-unit names and quantities are available from approved detailed entries.</p>
                </div>
                <button class="btn btn-sm btn-outline-primary" id="pf-analysis-load-units" type="button">
                    Show unit-wise breakdown
                </button>
            </div>

            <div class="pf-analysis-unit-placeholder" id="pf-analysis-unit-placeholder">
                Unit-wise data is loaded only when required.
            </div>

            <div class="table-responsive d-none" id="pf-analysis-unit-table-wrap">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Receiving unit</th>
                            <th scope="col">Simulator</th>
                            <th scope="col">Source</th>
                            <th scope="col">Period</th>
                            <th scope="col" class="text-end">Quantity</th>
                        </tr>
                    </thead>
                    <tbody id="pf-analysis-unit-body"></tbody>
                </table>
            </div>
        </section>
    </section>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/proliferation.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/proliferation-reports.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/pages/proliferation-reports.js" asp-append-version="true"></script>
}
