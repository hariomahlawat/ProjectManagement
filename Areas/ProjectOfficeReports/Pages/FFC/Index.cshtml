@page
@using System
@model ProjectManagement.Areas.ProjectOfficeReports.Pages.FFC.IndexModel
@{
    ViewData["Title"] = "FFC Proposals";
    ViewData["UseFullWidth"] = true;
    var request = ViewContext.HttpContext.Request;
    var currentReturnUrl = $"{request.PathBase}{request.Path}{request.QueryString}";
}

@section Styles {
    <link rel="stylesheet"
          href="~/css/project-office-reports/ffc-portfolio.css"
          asp-append-version="true" />
}

<div class="container-fluid px-3 px-lg-4 py-1 ffc-portfolio">
    <header class="ffc-portfolio-header">
        <div class="ffc-portfolio-header__copy">
            <div class="ffc-portfolio-header__eyebrow">FFC Proposals</div>
            <div class="ffc-portfolio-header__title-line">
                <h1>FFC Portfolio Overview</h1>
                @if (Model.TotalCount > 0)
                {
                    <span class="ffc-portfolio-header__result-count" role="status" aria-live="polite">
                        Showing @Model.Portfolio.FirstItemNumber–@Model.Portfolio.LastItemNumber of @Model.TotalCount
                    </span>
                }
            </div>
            <p>Monitor milestones, project-unit delivery and installation progress across the complete FFC portfolio.</p>
        </div>

        <div class="ffc-portfolio-header__actions">
            <a asp-area="ProjectOfficeReports"
               asp-page="/FFC/MapTableDetailed"
               class="btn btn-primary btn-sm d-inline-flex align-items-center gap-2">
                <span class="bi bi-table" aria-hidden="true"></span>
                <span>Detailed table</span>
            </a>

            @if (Model.CanManageRecords)
            {
                <a asp-area="ProjectOfficeReports"
                   asp-page="/FFC/Records/Create"
                   asp-route-returnUrl="@currentReturnUrl"
                   class="btn btn-outline-primary btn-sm d-inline-flex align-items-center gap-2">
                    <span class="bi bi-plus-lg" aria-hidden="true"></span>
                    <span>New record</span>
                </a>
            }

            <div class="dropdown">
                <button type="button"
                        class="btn btn-light btn-sm d-inline-flex align-items-center gap-2"
                        data-bs-toggle="dropdown"
                        aria-expanded="false">
                    <span>More</span>
                    <span class="bi bi-chevron-down" aria-hidden="true"></span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                        <a asp-area="ProjectOfficeReports"
                           asp-page="/FFC/Map"
                           class="dropdown-item">
                            <span class="bi bi-geo-alt" aria-hidden="true"></span>
                            World footprint
                        </a>
                    </li>
                    <li>
                        <a asp-area="ProjectOfficeReports"
                           asp-page="/FFC/MapBoard"
                           class="dropdown-item">
                            <span class="bi bi-grid" aria-hidden="true"></span>
                            Country board
                        </a>
                    </li>
                    @if (Model.CanManageRecords)
                    {
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <a asp-area="ProjectOfficeReports"
                               asp-page="/FFC/Records/Create"
                               asp-route-returnUrl="@currentReturnUrl"
                               class="dropdown-item">
                                <span class="bi bi-plus-circle" aria-hidden="true"></span>
                                Create record
                            </a>
                        </li>
                        <li>
                            <a asp-area="ProjectOfficeReports"
                               asp-page="/FFC/Records/Archived"
                               asp-route-returnUrl="@currentReturnUrl"
                               class="dropdown-item">
                                <span class="bi bi-archive" aria-hidden="true"></span>
                                Archived records
                            </a>
                        </li>
                        <li>
                            <a asp-area="ProjectOfficeReports"
                               asp-page="/FFC/Countries/Manage"
                               class="dropdown-item">
                                <span class="bi bi-globe2" aria-hidden="true"></span>
                                Country settings
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </header>

    <partial name="~/Areas/ProjectOfficeReports/Pages/FFC/Partials/_PortfolioSummary.cshtml"
             model="Model.Summary" />

    <partial name="~/Areas/ProjectOfficeReports/Pages/FFC/Partials/_PortfolioFilters.cshtml"
             model="Model" />

    <partial name="~/Areas/ProjectOfficeReports/Pages/Shared/_StatusMessage.cshtml" />

    <section class="ffc-portfolio-results" aria-labelledby="ffc-portfolio-results-title">
        <div class="ffc-portfolio-results__header">
            <div>
                <h2 id="ffc-portfolio-results-title">Country-year records</h2>
                <p>Select a record to review its project roll-up without leaving the page.</p>
            </div>
            @if (Model.TotalCount > 0)
            {
                <span class="ffc-portfolio-results__count">
                    @Model.TotalCount record@(Model.TotalCount == 1 ? string.Empty : "s")
                </span>
            }
        </div>

        @if (Model.Records.Count == 0)
        {
            <div class="ffc-portfolio-empty" role="status">
                <span class="bi bi-search" aria-hidden="true"></span>
                <div>
                    <h3>No matching FFC records</h3>
                    <p>Adjust the search or filters to broaden the portfolio view.</p>
                </div>
                @if (Model.HasActiveFilters)
                {
                    <a asp-page="./Index" class="btn btn-outline-primary btn-sm">Clear filters</a>
                }
            </div>
        }
        else
        {
            <div class="ffc-portfolio-list">
                @foreach (var record in Model.Records)
                {
                    <partial name="~/Areas/ProjectOfficeReports/Pages/FFC/Partials/_PortfolioRow.cshtml"
                             model="record" />
                }
            </div>
        }
    </section>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="FFC records pagination" class="ffc-portfolio-pagination">
            <div class="ffc-portfolio-pagination__summary">
                Page @Model.PageNumber of @Model.TotalPages
            </div>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : string.Empty)">
                    <a class="page-link"
                       asp-page="./Index"
                       asp-all-route-data='Model.BuildRoute(page: Math.Max(1, Model.PageNumber - 1))'
                       aria-label="Previous page"
                       tabindex="@(Model.PageNumber <= 1 ? -1 : 0)">
                        <span class="bi bi-chevron-left" aria-hidden="true"></span>
                    </a>
                </li>

                @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                {
                    <li class="page-item @(pageNumber == Model.PageNumber ? "active" : string.Empty)">
                        <a class="page-link"
                           asp-page="./Index"
                           asp-all-route-data='Model.BuildRoute(page: pageNumber)'
                           aria-current="@(pageNumber == Model.PageNumber ? "page" : null)">
                            @pageNumber
                        </a>
                    </li>
                }

                <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : string.Empty)">
                    <a class="page-link"
                       asp-page="./Index"
                       asp-all-route-data='Model.BuildRoute(page: Math.Min(Model.TotalPages, Model.PageNumber + 1))'
                       aria-label="Next page"
                       tabindex="@(Model.PageNumber >= Model.TotalPages ? -1 : 0)">
                        <span class="bi bi-chevron-right" aria-hidden="true"></span>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script src="~/js/pages/project-office-reports/ffc/ffc-portfolio.js"
            asp-append-version="true"
            defer></script>
}
