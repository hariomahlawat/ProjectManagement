@page "{id:guid}"
@model ProjectManagement.Areas.ProjectOfficeReports.Pages.SocialMedia.DeleteModel
@{
    ViewData["Title"] = "Delete social media activity";
}

<div class="social-page-shell social-delete-page">
    <nav aria-label="Breadcrumb" class="social-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-area="" asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-page="Index">Social media</a></li>
            <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@Model.Event?.Id">Activity</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>

    <section class="social-delete-card">
        <div class="social-delete-card__icon"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i></div>
        <span class="social-page-kicker">Permanent action</span>
        <h1>Delete this activity?</h1>
        <p><strong>@Model.Event?.Title</strong> will be permanently removed from the social media register.</p>
        <dl class="social-delete-summary">
            <div><dt>Date</dt><dd>@Model.Event?.DateOfEvent.ToString("dd MMM yyyy")</dd></div>
            <div><dt>Event type</dt><dd>@Model.EventType?.Name</dd></div>
            <div><dt>Photographs</dt><dd>@Model.PhotoCount</dd></div>
        </dl>
        @if (Model.PhotoCount > 0)
        {
            <div class="alert alert-warning">All associated photographs will also be deleted.</div>
        }
        <form method="post" data-social-disable-on-submit class="social-delete-actions">
            <input type="hidden" asp-for="RowVersion" />
            <a asp-page="Details" asp-route-id="@Model.Event?.Id" class="btn btn-outline-secondary">Keep activity</a>
            <button type="submit" class="btn btn-danger" data-social-busy-label="Deleting…"><i class="bi bi-trash" aria-hidden="true"></i>Delete permanently</button>
        </form>
    </section>
</div>

@section Scripts {
    <script type="module" src="~/js/pages/project-office-reports/social-media.js" asp-append-version="true"></script>
}
