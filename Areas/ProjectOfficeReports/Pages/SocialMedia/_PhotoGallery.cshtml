@using Microsoft.AspNetCore.WebUtilities
@model ProjectManagement.Areas.ProjectOfficeReports.SocialMedia.ViewModels.SocialMediaEventPhotoGalleryModel

@if (Model.Photos.Count == 0)
{
    <div class="social-gallery-empty">
        <div class="social-empty-state__icon"><i class="bi bi-images" aria-hidden="true"></i></div>
        <h3>No photographs added</h3>
        <p>@(Model.CanManage ? "Use the upload area below to add activity photographs." : "No photographs are available for this activity.")</p>
    </div>
}
else
{
    <div class="social-gallery" data-social-gallery>
        @foreach (var photo in Model.Photos)
        {
            var thumbnail = Url.Page("./ViewPhoto", new { id = Model.EventId, photoId = photo.Id, size = "thumb" });
            var full = Url.Page("./ViewPhoto", new { id = Model.EventId, photoId = photo.Id, size = "feed" });
            var versionedThumbnail = string.IsNullOrWhiteSpace(photo.VersionStamp)
                ? thumbnail ?? string.Empty
                : (thumbnail is null ? string.Empty : QueryHelpers.AddQueryString(thumbnail, "v", photo.VersionStamp));
            var versionedFull = string.IsNullOrWhiteSpace(photo.VersionStamp)
                ? full ?? string.Empty
                : (full is null ? string.Empty : QueryHelpers.AddQueryString(full, "v", photo.VersionStamp));
            var altText = string.IsNullOrWhiteSpace(photo.Caption) ? "Activity photograph" : photo.Caption;

            <article class="social-gallery-card">
                <a href="@versionedFull" target="_blank" rel="noopener" class="social-gallery-card__image">
                    <span class="visually-hidden">Open full-size photograph in a new tab</span>
                    <div class="social-gallery-card__frame">
                        <img src="@versionedThumbnail" alt="" loading="lazy" data-social-photo />
                        <div class="social-photo-fallback" hidden data-social-photo-fallback>
                            <i class="bi bi-image" aria-hidden="true"></i>
                            <strong>Photograph unavailable</strong>
                            <span>The stored image could not be loaded.</span>
                        </div>
                        @if (photo.IsCover)
                        {
                            <span class="social-gallery-card__badge"><i class="bi bi-star-fill" aria-hidden="true"></i>Cover</span>
                        }
                    </div>
                </a>
                <div class="social-gallery-card__info">
                    <p class="social-gallery-card__caption @(string.IsNullOrWhiteSpace(photo.Caption) ? "social-gallery-card__caption--muted" : string.Empty)">
                        @(string.IsNullOrWhiteSpace(photo.Caption) ? "No caption" : photo.Caption)
                    </p>
                    @if (Model.CanManage)
                    {
                        <div class="social-gallery-card__actions">
                            @if (!photo.IsCover)
                            {
                                <form method="post" asp-page-handler="SetCover" asp-route-id="@Model.EventId" data-social-disable-on-submit>
                                    <input type="hidden" name="photoId" value="@photo.Id" />
                                    <input type="hidden" name="rowVersion" value="@photo.RowVersion" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary" data-social-busy-label="Setting…"><i class="bi bi-star" aria-hidden="true"></i>Set cover</button>
                                </form>
                            }
                            <form method="post" asp-page-handler="DeletePhoto" asp-route-id="@Model.EventId" data-social-disable-on-submit data-confirm="Delete this photograph?">
                                <input type="hidden" name="photoId" value="@photo.Id" />
                                <input type="hidden" name="rowVersion" value="@photo.RowVersion" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" data-social-busy-label="Deleting…"><i class="bi bi-trash" aria-hidden="true"></i>Remove</button>
                            </form>
                        </div>
                    }
                </div>
            </article>
        }
    </div>
}
