@page
@model ProjectManagement.Areas.ProjectOfficeReports.Pages.SocialMedia.IndexModel
@using ProjectManagement.Areas.ProjectOfficeReports.SocialMedia.ViewModels
@{
    ViewData["Title"] = "Social media activities";

    string GetPlatformIcon(string? platformName)
    {
        var value = platformName?.Trim().ToLowerInvariant() ?? string.Empty;
        if (value.Contains("twitter") || value == "x" || value.StartsWith("x ")) return "bi-twitter";
        if (value.Contains("instagram")) return "bi-instagram";
        if (value.Contains("facebook")) return "bi-facebook";
        if (value.Contains("youtube")) return "bi-youtube";
        if (value.Contains("linkedin")) return "bi-linkedin";
        return "bi-share";
    }

    string GetPlatformLabel(string? platformName)
    {
        var value = platformName?.Trim() ?? string.Empty;
        return value.Contains("formerly twitter", StringComparison.OrdinalIgnoreCase) ? "X" : (string.IsNullOrWhiteSpace(value) ? "Unspecified" : value);
    }

    var hasFilters = Model.Filter.EventTypeId.HasValue
        || Model.Filter.PlatformId.HasValue
        || !string.IsNullOrWhiteSpace(Model.Filter.SearchQuery)
        || Model.Filter.StartDate.HasValue
        || Model.Filter.EndDate.HasValue
        || Model.Filter.OnlyActiveEventTypes;

    var toastMessages = new List<SocialMediaToastMessage>();
    if (TempData.TryGetValue("ToastMessage", out var toastMsg) && toastMsg is string okMsg && !string.IsNullOrWhiteSpace(okMsg))
    {
        toastMessages.Add(new SocialMediaToastMessage(okMsg, "success"));
    }
    if (TempData.TryGetValue("ToastError", out var toastErr) && toastErr is string errMsg && !string.IsNullOrWhiteSpace(errMsg))
    {
        toastMessages.Add(new SocialMediaToastMessage(errMsg, "danger"));
    }
}

<partial name="_ToastMessages" model="toastMessages" />

<div class="social-page-shell social-index-page">
    <nav aria-label="Breadcrumb" class="social-breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-area="" asp-page="/Dashboard/Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Social media</li>
        </ol>
    </nav>

    <header class="social-page-header">
        <div>
            <span class="social-page-kicker">Project office reports</span>
            <h1>Social media activities</h1>
            <p>Maintain a clear record of institutional posts, news coverage and communication activities.</p>
        </div>
        <div class="social-page-actions">
            @if (Model.TotalCount > 0)
            {
                <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#exportSocialModal">
                    <i class="bi bi-download" aria-hidden="true"></i>
                    Export
                </button>
            }
            @if (Model.CanManage)
            {
                <a asp-page="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i>
                    Add activity
                </a>
            }
        </div>
    </header>

    <section class="social-summary-grid" aria-label="Social media summary">
        <article class="social-summary-card">
            <div class="social-summary-card__icon"><i class="bi bi-megaphone" aria-hidden="true"></i></div>
            <div><span>Activities</span><strong>@Model.TotalCount</strong></div>
        </article>
        <article class="social-summary-card">
            <div class="social-summary-card__icon"><i class="bi bi-images" aria-hidden="true"></i></div>
            <div><span>Photographs</span><strong>@Model.TotalPhotos</strong></div>
        </article>
        <article class="social-summary-card social-summary-card--wide">
            <div class="social-summary-card__icon"><i class="bi bi-clock-history" aria-hidden="true"></i></div>
            <div>
                <span>Latest activity</span>
                @if (Model.LatestEvent is null)
                {
                    <strong>None recorded</strong>
                }
                else
                {
                    <strong>@Model.LatestEvent.DateOfEvent.ToString("dd MMM yyyy")</strong>
                    <small>@Model.LatestEvent.Title</small>
                }
            </div>
        </article>
    </section>

    @if (Model.PlatformBreakdown.Count > 0)
    {
        <div class="social-platform-strip" aria-label="Platform distribution">
            <span class="social-platform-strip__label">Platforms</span>
            @foreach (var platform in Model.PlatformBreakdown)
            {
                <span class="social-platform-chip">
                    <i class="bi @GetPlatformIcon(platform.Name)" aria-hidden="true"></i>
                    @GetPlatformLabel(platform.Name)
                    <strong>@platform.Count</strong>
                </span>
            }
        </div>
    }

    <form method="get" class="social-filter-bar" data-social-filter-form>
        <div class="social-filter-search">
            <i class="bi bi-search" aria-hidden="true"></i>
            <label class="visually-hidden" for="social-search">Search activities</label>
            <input id="social-search" name="Q" value="@Model.Filter.SearchQuery" class="form-control" placeholder="Search title or description" />
        </div>
        <div>
            <label class="visually-hidden" for="social-event-type">Event type</label>
            <select id="social-event-type" asp-for="EventTypeId" asp-items="Model.Filter.EventTypeOptions" class="form-select" data-social-auto-submit></select>
        </div>
        <div>
            <label class="visually-hidden" for="social-platform">Platform</label>
            <select id="social-platform" asp-for="PlatformId" asp-items="Model.Filter.PlatformOptions" class="form-select" data-social-auto-submit></select>
        </div>
        <button class="btn btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#social-date-filters" aria-expanded="@(Model.Filter.StartDate.HasValue || Model.Filter.EndDate.HasValue ? "true" : "false")" aria-controls="social-date-filters">
            <i class="bi bi-calendar3" aria-hidden="true"></i>
            Date
        </button>
        <button class="btn btn-primary" type="submit">Apply</button>
        @if (hasFilters)
        {
            <a asp-page="Index" class="btn btn-link">Clear</a>
        }
        <div id="social-date-filters" class="collapse social-date-filters @(Model.Filter.StartDate.HasValue || Model.Filter.EndDate.HasValue ? "show" : string.Empty)">
            <div>
                <label for="social-from">From</label>
                <input id="social-from" name="From" type="date" value="@Model.Filter.StartDateValue" class="form-control" />
            </div>
            <div>
                <label for="social-to">To</label>
                <input id="social-to" name="To" type="date" value="@Model.Filter.EndDateValue" class="form-control" />
            </div>
            <label class="form-check social-active-toggle">
                <input class="form-check-input" type="checkbox" value="true" name="OnlyActiveEventTypes" @(Model.Filter.OnlyActiveEventTypes ? "checked" : string.Empty) />
                <span class="form-check-label">Active event types only</span>
            </label>
        </div>
    </form>

    <section class="social-records-section">
        <div class="social-records-header">
            <div>
                <h2>Activity register</h2>
                <p>@Model.TotalCount result@(Model.TotalCount == 1 ? string.Empty : "s")</p>
            </div>
        </div>

        @if (Model.TotalCount == 0)
        {
            <div class="social-empty-state">
                <div class="social-empty-state__icon"><i class="bi bi-journal-text" aria-hidden="true"></i></div>
                <h2>No activities found</h2>
                <p>Adjust the filters or add the first social media activity.</p>
                @if (Model.CanManage)
                {
                    <a asp-page="Create" class="btn btn-primary">Add activity</a>
                }
            </div>
        }
        else
        {
            <div class="social-table-card d-none d-lg-block">
                <div class="table-responsive">
                    <table class="table social-activity-table mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Activity</th>
                                <th>Type</th>
                                <th>Platform</th>
                                <th class="text-center">Photos</th>
                                <th class="text-end"><span class="visually-hidden">Actions</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Events)
                            {
                                <tr data-social-row-url="@Url.Page("Details", new { id = item.Id })">
                                    <td class="social-date-cell"><strong>@item.DateOfEvent.ToString("dd MMM")</strong><span>@item.DateOfEvent.Year</span></td>
                                    <td>
                                        <a asp-page="Details" asp-route-id="@item.Id" class="social-activity-title">@item.Title</a>
                                        <div class="social-row-meta">Updated @((item.LastModifiedAtUtc ?? item.CreatedAtUtc).ToLocalTime().ToString("dd MMM yyyy"))</div>
                                    </td>
                                    <td><span class="social-type-badge">@item.EventTypeName</span></td>
                                    <td><span class="social-platform-value"><i class="bi @GetPlatformIcon(item.PlatformName)" aria-hidden="true"></i>@GetPlatformLabel(item.PlatformName)</span></td>
                                    <td class="text-center"><span class="social-photo-count"><i class="bi bi-image" aria-hidden="true"></i>@item.PhotoCount</span></td>
                                    <td class="text-end">
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-light social-row-menu" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Actions for @item.Title">
                                                <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li><a class="dropdown-item" asp-page="Details" asp-route-id="@item.Id"><i class="bi bi-eye" aria-hidden="true"></i>View</a></li>
                                                @if (Model.CanManage)
                                                {
                                                    <li><a class="dropdown-item" asp-page="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil" aria-hidden="true"></i>Edit</a></li>
                                                    <li><hr class="dropdown-divider" /></li>
                                                    <li><a class="dropdown-item text-danger" asp-page="Delete" asp-route-id="@item.Id"><i class="bi bi-trash" aria-hidden="true"></i>Delete</a></li>
                                                }
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="social-mobile-list d-lg-none">
                @foreach (var item in Model.Events)
                {
                    <article class="social-mobile-card">
                        <div class="social-mobile-card__top">
                            <span class="social-mobile-card__date">@item.DateOfEvent.ToString("dd MMM yyyy")</span>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light" type="button" data-bs-toggle="dropdown" aria-label="Actions for @item.Title"><i class="bi bi-three-dots-vertical"></i></button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-page="Details" asp-route-id="@item.Id">View</a></li>
                                    @if (Model.CanManage)
                                    {
                                        <li><a class="dropdown-item" asp-page="Edit" asp-route-id="@item.Id">Edit</a></li>
                                        <li><a class="dropdown-item text-danger" asp-page="Delete" asp-route-id="@item.Id">Delete</a></li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <a asp-page="Details" asp-route-id="@item.Id" class="social-mobile-card__title">@item.Title</a>
                        <div class="social-mobile-card__meta">
                            <span>@item.EventTypeName</span>
                            <span><i class="bi @GetPlatformIcon(item.PlatformName)"></i>@GetPlatformLabel(item.PlatformName)</span>
                            <span><i class="bi bi-image"></i>@item.PhotoCount</span>
                        </div>
                    </article>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="social-pagination" aria-label="Social media activity pages">
                    <a class="btn btn-outline-secondary @(Model.PageNumber <= 1 ? "disabled" : string.Empty)"
                       asp-page="Index" asp-route-PageNumber="@(Model.PageNumber - 1)" asp-route-Q="@Model.Q" asp-route-EventTypeId="@Model.EventTypeId" asp-route-PlatformId="@Model.PlatformId" asp-route-From="@Model.From" asp-route-To="@Model.To" asp-route-OnlyActiveEventTypes="@Model.OnlyActiveEventTypes">Previous</a>
                    <span>Page @Model.PageNumber of @Model.TotalPages</span>
                    <a class="btn btn-outline-secondary @(Model.PageNumber >= Model.TotalPages ? "disabled" : string.Empty)"
                       asp-page="Index" asp-route-PageNumber="@(Model.PageNumber + 1)" asp-route-Q="@Model.Q" asp-route-EventTypeId="@Model.EventTypeId" asp-route-PlatformId="@Model.PlatformId" asp-route-From="@Model.From" asp-route-To="@Model.To" asp-route-OnlyActiveEventTypes="@Model.OnlyActiveEventTypes">Next</a>
                </nav>
            }
        }
    </section>
</div>

<div class="modal fade" id="exportSocialModal" tabindex="-1" aria-labelledby="exportSocialModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content social-modal-content">
            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Q" value="@Model.Q" />
                <input type="hidden" name="EventTypeId" value="@Model.EventTypeId" />
                <input type="hidden" name="PlatformId" value="@Model.PlatformId" />
                <input type="hidden" name="From" value="@Model.From" />
                <input type="hidden" name="To" value="@Model.To" />
                <input type="hidden" name="OnlyActiveEventTypes" value="@Model.OnlyActiveEventTypes" />
                <div class="modal-header">
                    <div>
                        <h2 class="modal-title fs-5" id="exportSocialModalLabel">Export activities</h2>
                        <p class="text-muted small mb-0">The current filters will be applied.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="social-export-options">
                        <button type="submit" class="social-export-option" asp-page-handler="ExportPdf">
                            <i class="bi bi-filetype-pdf" aria-hidden="true"></i>
                            <span><strong>PDF report</strong><small>Presentation-ready summary</small></span>
                        </button>
                        <button type="submit" class="social-export-option" asp-page-handler="Export">
                            <i class="bi bi-file-earmark-spreadsheet" aria-hidden="true"></i>
                            <span><strong>Excel workbook</strong><small>Structured data for analysis</small></span>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/pages/project-office-reports/social-media.js" asp-append-version="true"></script>
}
