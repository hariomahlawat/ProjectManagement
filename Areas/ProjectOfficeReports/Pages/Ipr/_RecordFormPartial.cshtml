@model ProjectManagement.Areas.ProjectOfficeReports.Pages.Ipr.IndexModel
@{
    var isCreateMode = string.Equals(Model.Mode, "create", StringComparison.OrdinalIgnoreCase);
    var isEditMode = string.Equals(Model.Mode, "edit", StringComparison.OrdinalIgnoreCase);
    var handler = isCreateMode ? "Create" : "Edit";
    var formId = isCreateMode ? "iprCreateForm" : "iprEditForm";
    var formRoutes = Model.GetRouteValuesForLinks(
        isCreateMode
            ? new { mode = "create" }
            : new { mode = "edit", id = Model.Input.Id },
        includeModeAndId: false);
    var closeRoutes = Model.GetRouteValuesForLinks(includeModeAndId: false);
    var isGranted = Model.Input.Status == ProjectManagement.Infrastructure.Data.IprStatus.Granted;
}

@if (isCreateMode || isEditMode)
{
    <form method="post"
          asp-page-handler="@handler"
          asp-all-route-data="formRoutes"
          class="ipr-drawer-form"
          id="@formId"
          data-ipr-record-form>
        @if (isEditMode)
        {
            <input type="hidden" asp-for="Input.Id" />
            <input type="hidden" asp-for="Input.RowVersion" />
        }

        <div asp-validation-summary="ModelOnly" class="ipr-form-summary text-danger" role="alert"></div>

        <section class="ipr-form-section" aria-labelledby="iprRecordDetailsHeading">
            <header class="ipr-form-section__header">
                <span>Record details</span>
                <small>Fields marked required must be completed.</small>
            </header>
            <div class="ipr-form-grid">
                <div class="ipr-form-field">
                    <label asp-for="Input.FilingNumber" class="form-label"></label>
                    <input asp-for="Input.FilingNumber"
                           class="form-control"
                           autocomplete="off"
                           maxlength="128"
                           required />
                    <span asp-validation-for="Input.FilingNumber" class="text-danger"></span>
                </div>

                <div class="ipr-form-field">
                    <label asp-for="Input.Type" class="form-label"></label>
                    <select asp-for="Input.Type" asp-items="Model.TypeFormOptions" class="form-select" required>
                        <option value="" disabled selected="@(Model.Input.Type is null ? "selected" : null)">Select type</option>
                    </select>
                    <span asp-validation-for="Input.Type" class="text-danger"></span>
                </div>

                <div class="ipr-form-field ipr-form-field--wide">
                    <label asp-for="Input.Title" class="form-label"></label>
                    <input asp-for="Input.Title"
                           class="form-control"
                           maxlength="256"
                           required />
                    <span asp-validation-for="Input.Title" class="text-danger"></span>
                </div>

                <div class="ipr-form-field ipr-form-field--wide">
                    <label asp-for="Input.FiledBy" class="form-label"></label>
                    <input asp-for="Input.FiledBy" class="form-control" maxlength="128" />
                    <span asp-validation-for="Input.FiledBy" class="text-danger"></span>
                </div>
            </div>
        </section>

        <section class="ipr-form-section" aria-labelledby="iprStatusDatesHeading">
            <header class="ipr-form-section__header">
                <span>Status and dates</span>
                <small>Dates are recorded as Indian calendar dates.</small>
            </header>
            <div class="ipr-form-grid">
                <div class="ipr-form-field">
                    <label asp-for="Input.Status" class="form-label"></label>
                    <select asp-for="Input.Status"
                            asp-items="Model.StatusFormOptions"
                            class="form-select"
                            required
                            data-ipr-status-select>
                        <option value="" disabled selected="@(Model.Input.Status is null ? "selected" : null)">Select status</option>
                    </select>
                    <span asp-validation-for="Input.Status" class="text-danger"></span>
                </div>

                <div class="ipr-form-field">
                    <label asp-for="Input.FiledOn" class="form-label"></label>
                    <input asp-for="Input.FiledOn" class="form-control" type="date" required />
                    <span asp-validation-for="Input.FiledOn" class="text-danger"></span>
                </div>

                <div class="ipr-form-field @(isGranted ? string.Empty : "is-hidden")"
                     data-ipr-granted-date-field
                     aria-hidden="@(isGranted ? "false" : "true")">
                    <label asp-for="Input.GrantedOn" class="form-label"></label>
                    @if (isGranted)
                    {
                        <input asp-for="Input.GrantedOn"
                               class="form-control"
                               type="date"
                               required
                               data-ipr-granted-date />
                    }
                    else
                    {
                        <input asp-for="Input.GrantedOn"
                               class="form-control"
                               type="date"
                               disabled
                               data-ipr-granted-date />
                    }
                    <span asp-validation-for="Input.GrantedOn" class="text-danger"></span>
                </div>

                <div class="ipr-form-field">
                    <label asp-for="Input.ProjectId" class="form-label"></label>
                    <select asp-for="Input.ProjectId" asp-items="Model.ProjectFormOptions" class="form-select"></select>
                    <span asp-validation-for="Input.ProjectId" class="text-danger"></span>
                </div>
            </div>
        </section>

        <section class="ipr-form-section" aria-labelledby="iprAdditionalInformationHeading">
            <header class="ipr-form-section__header">
                <span>Additional information</span>
            </header>
            <div class="ipr-form-grid">
                <div class="ipr-form-field ipr-form-field--wide">
                    <label asp-for="Input.Notes" class="form-label"></label>
                    <textarea asp-for="Input.Notes"
                              class="form-control"
                              rows="4"
                              maxlength="2000"
                              placeholder="Add relevant filing, examination or grant notes."></textarea>
                    <span asp-validation-for="Input.Notes" class="text-danger"></span>
                </div>
            </div>
        </section>

        <footer class="ipr-drawer-form__actions">
            <a class="btn btn-outline-secondary"
               asp-page="./Index"
               asp-all-route-data="closeRoutes">Cancel</a>
            <button type="submit" class="btn btn-primary">
                @(isCreateMode ? "Create record" : "Save changes")
            </button>
        </footer>
    </form>

    @if (isEditMode && Model.Input.Id.HasValue)
    {
        <section class="ipr-attachment-section" aria-labelledby="iprAttachmentsHeading">
            <header class="ipr-attachment-section__header">
                <div>
                    <h3 id="iprAttachmentsHeading">Attachments</h3>
                    <p>Supporting documents linked to this IPR record.</p>
                </div>
                <span class="ipr-file-policy">@Model.AttachmentUploadHint</span>
            </header>

            @if (Model.Attachments.Count == 0)
            {
                <div class="ipr-attachment-empty">
                    <i class="bi bi-file-earmark-pdf" aria-hidden="true"></i>
                    <span>No attachments uploaded.</span>
                </div>
            }
            else
            {
                <ul class="ipr-attachment-list">
                    @foreach (var attachment in Model.Attachments)
                    {
                        <li class="ipr-attachment-row">
                            <a class="ipr-attachment-row__main"
                               asp-page="Download"
                               asp-route-iprRecordId="@Model.Input.Id"
                               asp-route-attachmentId="@attachment.Id"
                               target="_blank"
                               rel="noopener noreferrer"
                               title="Open @attachment.FileName">
                                <span class="ipr-attachment-row__icon"><i class="bi bi-file-earmark-pdf"></i></span>
                                <span class="ipr-attachment-row__content">
                                    <strong>@attachment.FileName</strong>
                                    <small>@Model.FormatFileSize(attachment.FileSize) · @Model.FormatAttachmentTimestamp(attachment.UploadedAtUtc)</small>
                                    <small>Uploaded by @attachment.UploadedBy</small>
                                </span>
                            </a>
                            <form method="post"
                                  asp-page-handler="RemoveAttachment"
                                  asp-all-route-data="@Model.GetRouteValuesForLinks(new { mode = "edit", id = Model.Input.Id }, includeModeAndId: false)"
                                  data-ipr-confirm="Remove this attachment?">
                                <input type="hidden" name="RemoveAttachment.AttachmentId" value="@attachment.Id" />
                                <input type="hidden" name="RemoveAttachment.RecordId" value="@Model.Input.Id" />
                                <input type="hidden" name="RemoveAttachment.RowVersion" value="@attachment.RowVersion" />
                                <button type="submit"
                                        class="btn btn-sm btn-outline-danger ipr-attachment-row__remove"
                                        aria-label="Remove @attachment.FileName"
                                        title="Remove attachment">
                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                </button>
                            </form>
                        </li>
                    }
                </ul>
            }

            <form method="post"
                  asp-page-handler="Attach"
                  asp-all-route-data="@Model.GetRouteValuesForLinks(new { mode = "edit", id = Model.Input.Id }, includeModeAndId: false)"
                  enctype="multipart/form-data"
                  class="ipr-attachment-upload"
                  id="iprAttachmentForm">
                <input type="hidden" asp-for="UploadInput.RecordId" />
                <div class="ipr-form-field">
                    <label asp-for="UploadInput.File" class="form-label">Add PDF attachment</label>
                    <input asp-for="UploadInput.File"
                           class="form-control"
                           type="file"
                           accept=".pdf,application/pdf"
                           required />
                    <span class="form-text">@Model.AttachmentUploadHint</span>
                    <span asp-validation-for="UploadInput.File" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-upload" aria-hidden="true"></i>
                    Upload
                </button>
            </form>
        </section>

        <section class="ipr-danger-zone" aria-labelledby="iprDangerZoneHeading">
            <div>
                <h3 id="iprDangerZoneHeading">Delete record</h3>
                <p>Permanently removes this IPR record and all its attachments.</p>
            </div>
            <form method="post"
                  asp-page-handler="Delete"
                  asp-all-route-data="closeRoutes"
                  id="iprDeleteForm"
                  data-ipr-confirm="This will permanently delete the IPR record and all its attachments. Continue?">
                <input type="hidden" asp-for="DeleteRequest.Id" />
                <input type="hidden" asp-for="DeleteRequest.RowVersion" />
                <button type="submit" class="btn btn-outline-danger">Delete record</button>
            </form>
        </section>
    }
}
