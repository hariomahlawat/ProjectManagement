@page
@model ProjectManagement.Areas.ProjectOfficeReports.Pages.Ipr.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "IPR Register";
    ViewData["UseFullWidth"] = true;

    var toastMessage = TempData["ToastMessage"] as string;
    var toastError = TempData["ToastError"] as string;
    var isCreateMode = string.Equals(Model.Mode, "create", StringComparison.OrdinalIgnoreCase);
    var isEditMode = string.Equals(Model.Mode, "edit", StringComparison.OrdinalIgnoreCase);
    var exportRouteValues = Model.GetRouteValuesForLinks(includeModeAndId: false);
    var hasRecords = Model.TotalCount > 0;
    var firstItem = hasRecords ? ((Model.PageNumber - 1) * Model.PageSize) + 1 : 0;
    var lastItem = hasRecords ? Math.Min(Model.TotalCount, Model.PageNumber * Model.PageSize) : 0;
    var yearlyJson = JsonSerializer.Serialize(Model.YearlyStats);
    var recordsRoutes = Model.GetRouteValuesForLinks(new { tab = "records", page = 1 }, includePage: false, includeModeAndId: false);
    var projectRoutes = Model.GetRouteValuesForLinks(new { tab = "project", page = 1 }, includePage: false, includeModeAndId: false);
    var analyticsRoutes = Model.GetRouteValuesForLinks(new { tab = "analytics", page = 1 }, includePage: false, includeModeAndId: false);
}

@section Styles {
    <link rel="stylesheet" href="~/css/site-ipr.css" asp-append-version="true" />
}

<div class="ipr-register-page">
    <header class="ipr-register-header">
        <div class="ipr-register-title-block">
            <span class="ipr-register-icon"><i class="bi bi-file-earmark-text"></i></span>
            <div>
                <h1>IPR Register</h1>
                <p>Track filed and granted patents and copyrights by project.</p>
            </div>
        </div>
        <div class="ipr-register-actions">
            <a asp-page="./Index" asp-page-handler="Export" asp-all-route-data="exportRouteValues" class="btn btn-outline-primary">
                <i class="bi bi-download"></i> Export
            </a>
            @if (Model.CanEdit)
            {
                <a asp-page="./Index" asp-all-route-data="@Model.GetRouteValuesForLinks(new { mode = "create" }, includeModeAndId: false)" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Add IPR record
                </a>
            }
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(toastMessage) || !string.IsNullOrWhiteSpace(toastError))
    {
        <div class="toast-container position-fixed top-0 end-0 p-3 pm-util-z-1100" aria-live="polite" aria-atomic="true">
            @if (!string.IsNullOrWhiteSpace(toastMessage))
            {
                <div class="toast align-items-center text-bg-success border-0 show" role="status"><div class="d-flex"><div class="toast-body">@toastMessage</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>
            }
            @if (!string.IsNullOrWhiteSpace(toastError))
            {
                <div class="toast align-items-center text-bg-danger border-0 show" role="alert"><div class="d-flex"><div class="toast-body">@toastError</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>
            }
        </div>
    }

    <section class="ipr-summary-grid" aria-label="IPR summary">
        <a asp-page="./Index" asp-route-tab="records" class="ipr-summary-card ipr-summary-card--filed">
            <div><span>Total filed</span><strong>@Model.Kpis.Total</strong><small>All patents and copyrights</small></div>
            <i class="bi bi-file-earmark-check"></i>
        </a>
        <a asp-page="./Index" asp-route-tab="records" asp-route-Statuses="Granted" class="ipr-summary-card ipr-summary-card--granted">
            <div><span>Granted</span><strong>@Model.Kpis.Granted</strong><small>@Model.Kpis.Granted filings have received grant</small></div>
            <i class="bi bi-patch-check"></i>
        </a>
        <a asp-page="./Index" asp-route-tab="records" asp-route-Statuses="Filed" class="ipr-summary-card ipr-summary-card--awaiting">
            <div><span>Awaiting grant</span><strong>@Model.Kpis.Filed</strong><small>Filed records not yet granted</small></div>
            <i class="bi bi-clock-history"></i>
        </a>
        <a asp-page="./Index" asp-route-tab="project" class="ipr-summary-card ipr-summary-card--projects">
            <div><span>Projects with IPR</span><strong>@Model.ProjectsWithIpr</strong><small>Distinct projects linked to @Model.Kpis.Total filings</small></div>
            <i class="bi bi-buildings"></i>
        </a>
        <div class="ipr-type-summary">
            <div class="ipr-type-summary__head"><strong>Position by type</strong></div>
            <div class="ipr-type-summary__columns" aria-hidden="true">
                <span>Type</span><span>Filed</span><span>Granted</span><span>Awaiting</span>
            </div>
            @foreach (var item in Model.TypeBreakdown)
            {
                <div class="ipr-type-summary__row">
                    <span>@item.Type</span>
                    <strong>@item.Filed</strong>
                    <strong class="text-success">@item.Granted</strong>
                    <strong class="ipr-awaiting-value">@item.AwaitingGrant</strong>
                </div>
            }
        </div>
    </section>

    <nav class="ipr-tabs" aria-label="IPR views">
        <a asp-page="./Index" asp-all-route-data="recordsRoutes" class="@(Model.Tab == "records" ? "active" : "")"><i class="bi bi-card-list"></i> Records</a>
        <a asp-page="./Index" asp-all-route-data="projectRoutes" class="@(Model.Tab == "project" ? "active" : "")"><i class="bi bi-building"></i> Projects &amp; IPR</a>
        <a asp-page="./Index" asp-all-route-data="analyticsRoutes" class="@(Model.Tab == "analytics" ? "active" : "")"><i class="bi bi-bar-chart-line"></i> Analytics</a>
    </nav>

    @if (Model.Tab == "records")
    {
        <section class="ipr-panel">
            <form method="get" class="ipr-filter-bar" data-ipr-loading-form>
                <input type="hidden" name="Tab" value="records" />
                <div class="ipr-search-field"><i class="bi bi-search"></i><input asp-for="Query" type="search" placeholder="Search title, filing number or project" /></div>
                <select name="Types" class="form-select" data-ipr-auto-submit><option value="">All types</option>@foreach (var option in Model.TypeOptions)
                {
                    if (option.Selected) { <option value="@option.Value" selected>@option.Text</option> }
                    else { <option value="@option.Value">@option.Text</option> }
                }</select>
                <select name="Statuses" class="form-select" data-ipr-auto-submit><option value="">All positions</option>@foreach (var option in Model.StatusOptions)
                {
                    if (option.Selected) { <option value="@option.Value" selected>@option.Text</option> }
                    else { <option value="@option.Value">@option.Text</option> }
                }</select>
                <select asp-for="ProjectId" asp-items="Model.ProjectOptions" class="form-select" data-ipr-auto-submit></select>
                <select asp-for="Year" asp-items="Model.YearOptions" class="form-select" data-ipr-auto-submit></select>
                <button type="submit" class="btn btn-primary">Apply</button>
                @if (Model.HasAnyFilter)
                {
                    <a asp-page="./Index" asp-route-tab="records" class="btn btn-outline-secondary">Clear</a>
                }
            </form>

            <div class="ipr-panel-header">
                <div><h2>IPR records</h2><p>@(hasRecords ? $"Showing {firstItem}–{lastItem} of {Model.TotalCount}" : "No records found")</p></div>
                <span class="ipr-result-count">@Model.TotalCount total</span>
            </div>

            @if (!hasRecords)
            {
                <div class="ipr-empty-state"><i class="bi bi-inboxes"></i><h3>No IPR records found</h3><p>Adjust the filters or add the first record.</p></div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table ipr-register-table align-middle mb-0">
                        <thead><tr><th>IPR title</th><th>Type</th><th>Project</th><th>Filing no.</th><th>Filed on</th><th>Status</th><th>Granted on</th><th class="text-center">Files</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var row in Model.Records)
                        {
                            <tr>
                                <td><a asp-page="./Index" asp-route-tab="records" asp-route-mode="edit" asp-route-id="@row.Id" class="ipr-title-link">@row.Title</a></td>
                                <td><span class="ipr-type-badge ipr-type-badge--@row.IprType.ToLowerInvariant()">@row.IprType</span></td>
                                <td>
                                    @if (row.ProjectId.HasValue)
                                    {
                                        <a asp-area="" asp-page="/Projects/Overview" asp-route-id="@row.ProjectId" class="ipr-project-link">@row.ProjectName</a>
                                    }
                                    else
                                    {
                                        <span class="ipr-project-name">@row.ProjectName</span>
                                    }
                                </td>
                                <td><span class="font-monospace small ipr-filing-number">@row.ApplicationNumber</span></td>
                                <td>@(row.FiledOn?.ToString("dd MMM yyyy") ?? "—")</td>
                                <td><span class="ipr-status-badge @(row.Status == "Granted" ? "ipr-status-badge--granted" : "ipr-status-badge--filed")">@row.Status</span></td>
                                <td>@(row.GrantedOn?.ToString("dd MMM yyyy") ?? "—")</td>
                                <td class="text-center"><i class="bi bi-paperclip"></i> @row.AttachmentCount</td>
                                <td class="text-end"><a asp-page="./Index" asp-route-tab="records" asp-route-mode="edit" asp-route-id="@row.Id" class="btn btn-sm btn-outline-secondary" aria-label="Edit @row.Title" title="Edit record"><i class="bi bi-pencil"></i></a></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPages > 1)
                {
                    var baseRoutes = Model.GetRouteValuesForLinks(new { pageSize = Model.PageSize, tab = "records" }, includePage: false, includeModeAndId: false);
                    <div class="ipr-pagination-bar">
                        <span>Showing @firstItem–@lastItem of @Model.TotalCount records</span>
                        <nav><ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")"><a class="page-link" asp-page="./Index" asp-all-route-data="baseRoutes" asp-route-page="@(Model.PageNumber - 1)">‹</a></li>
                            @for (var pageNo = Math.Max(1, Model.PageNumber - 2); pageNo <= Math.Min(Model.TotalPages, Model.PageNumber + 2); pageNo++)
                            {<li class="page-item @(pageNo == Model.PageNumber ? "active" : "")"><a class="page-link" asp-page="./Index" asp-all-route-data="baseRoutes" asp-route-page="@pageNo">@pageNo</a></li>}
                            <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")"><a class="page-link" asp-page="./Index" asp-all-route-data="baseRoutes" asp-route-page="@(Model.PageNumber + 1)">›</a></li>
                        </ul></nav>
                    </div>
                }
            }
        </section>
    }
    else if (Model.Tab == "project")
    {
        <section class="ipr-panel">
            <div class="ipr-panel-header">
                <div>
                    <h2>Projects &amp; IPR</h2>
                    <p>See which patent or copyright is linked to each project and its current position.</p>
                </div>
                <span class="ipr-result-count">@Model.ProjectsWithIpr projects · @Model.Kpis.Total filings</span>
            </div>
            <div class="table-responsive">
                <table class="table ipr-project-table align-middle mb-0">
                    <thead><tr><th>Project</th><th>IPR title</th><th>Type</th><th>Current position</th><th>Filed on</th><th>Granted on</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var item in Model.ProjectIprLinks)
                    {
                        <tr>
                            <td>
                                <div class="ipr-project-cell">
                                    @if (item.ProjectId.HasValue)
                                    {
                                        <a asp-area="" asp-page="/Projects/Overview" asp-route-id="@item.ProjectId" class="ipr-project-link">@item.ProjectName</a>
                                    }
                                    else
                                    {
                                        <span>@item.ProjectName</span>
                                    }
                                    @if (item.ProjectIprCount > 1)
                                    {
                                        <span class="ipr-multi-badge">@item.ProjectIprCount IPR</span>
                                    }
                                </div>
                            </td>
                            <td><a asp-page="./Index" asp-route-tab="project" asp-route-mode="edit" asp-route-id="@item.Id" class="ipr-title-link">@item.Title</a></td>
                            <td><span class="ipr-type-badge ipr-type-badge--@item.Type.ToLowerInvariant()">@item.Type</span></td>
                            <td><span class="ipr-status-badge @(item.Position == "Granted" ? "ipr-status-badge--granted" : "ipr-status-badge--filed")">@item.Position</span></td>
                            <td>@(item.FiledOn?.ToString("dd MMM yyyy") ?? "—")</td>
                            <td>@(item.GrantedOn?.ToString("dd MMM yyyy") ?? "—")</td>
                            <td class="text-end"><a asp-page="./Index" asp-route-tab="project" asp-route-mode="edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Edit record" aria-label="Edit @item.Title"><i class="bi bi-pencil"></i></a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
    else
    {
        <section class="ipr-analytics-grid">
            <article class="ipr-panel ipr-chart-panel">
                <div class="ipr-panel-header"><div><h2>Filings and grants by year</h2><p>A filing and its later grant are counted as separate events.</p></div></div>
                <div class="ipr-chart-canvas"><canvas id="iprEventTrend" data-yearly='@Html.Raw(yearlyJson)' role="img" aria-label="IPR filings and grants by year"></canvas></div>
            </article>
            <aside class="ipr-analytics-side">
                <article class="ipr-panel ipr-type-position-panel">
                    <div class="ipr-panel-header"><div><h2>Position by type</h2><p>Absolute filed, granted and awaiting-grant counts.</p></div></div>
                    <div class="ipr-type-matrix">
                        <div class="ipr-type-matrix__head"><span>Type</span><span>Filed</span><span>Granted</span><span>Awaiting</span></div>
                        @foreach (var item in Model.TypeBreakdown)
                        {
                            <div class="ipr-type-matrix__row">
                                <strong>@item.Type</strong>
                                <span>@item.Filed</span>
                                <span class="text-success fw-semibold">@item.Granted</span>
                                <span class="ipr-awaiting-value fw-semibold">@item.AwaitingGrant</span>
                            </div>
                        }
                    </div>
                </article>
                <article class="ipr-panel ipr-pending-panel">
                    <div class="ipr-panel-header"><div><h2>Oldest filings awaiting grant</h2><p>Records that may require follow-up.</p></div></div>
                    @if (Model.OldestAwaitingGrant.Count == 0)
                    {
                        <div class="ipr-compact-empty"><i class="bi bi-check-circle"></i><span>No filings are awaiting grant.</span></div>
                    }
                    else
                    {
                        <div class="ipr-pending-list">
                            @foreach (var item in Model.OldestAwaitingGrant)
                            {
                                <a asp-page="./Index" asp-route-tab="analytics" asp-route-mode="edit" asp-route-id="@item.Id" class="ipr-pending-row">
                                    <div><strong>@item.Title</strong><span>@item.ProjectName · @item.Type</span></div>
                                    <div class="text-end"><strong>@item.WaitingDays d</strong><span>@(item.FiledOn?.ToString("dd MMM yyyy") ?? "Date unavailable")</span></div>
                                </a>
                            }
                        </div>
                    }
                </article>
            </aside>
        </section>
    }

    @if (Model.CanEdit)
    {
        <div class="offcanvas offcanvas-end ipr-record-drawer" tabindex="-1" id="iprRecordOffcanvas" aria-labelledby="iprRecordOffcanvasLabel" data-ipr-mode="@(Model.Mode ?? string.Empty)" data-ipr-has-form="@(isCreateMode || isEditMode ? "true" : "false")">
            <div class="offcanvas-header"><div><h2 class="offcanvas-title h5" id="iprRecordOffcanvasLabel">@(isCreateMode ? "Add IPR record" : "Edit IPR record")</h2><p class="text-muted small mb-0">Capture filing, grant and project details.</p></div><a class="btn-close" asp-page="./Index" asp-all-route-data="@Model.GetRouteValuesForLinks(includeModeAndId: false)"></a></div>
            <div class="offcanvas-body"><partial name="_RecordFormPartial" model="Model" /></div>
        </div>
    }
</div>

@section Scripts {
    <partial name="~/Pages/Shared/_ValidationScriptsPartial.cshtml" />
    <script src="~/lib/chartjs/chart.umd.js" defer asp-append-version="true"></script>
    <script src="~/js/project-office-reports/ipr/ipr-register.js" defer asp-append-version="true"></script>
    <script src="~/js/project-office-reports/ipr/index.js" defer asp-append-version="true"></script>
}
