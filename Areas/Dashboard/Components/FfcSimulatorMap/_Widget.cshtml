@* SECTION: FFC simulator map widget markup *@
@using System.Text.Json
@using System.Linq
@model ProjectManagement.Areas.Dashboard.Components.FfcSimulatorMap.FfcSimulatorMapVm
@{
    var jsonOptions = new JsonSerializerOptions(JsonSerializerDefaults.Web);
    var payload = JsonSerializer.Serialize(
        Model.Countries.Select(country => new
        {
            country.CountryId,
            country.Iso3,
            country.Name,
            country.Installed,
            country.Delivered,
            country.Planned,
            country.TotalUnits,
            DetailsUrl = Url.Page(
                "/FFC/MapTableDetailed",
                values: new { area = "ProjectOfficeReports", countryId = country.CountryId }) ?? "#"
        }),
        jsonOptions);
    var geoUrl = Url.Content("~/ffc/maps/world_india_view.geojson");
    var focusBounds = "42,-18|-38,118";
    var fullMapUrl = Url.Page("/FFC/Map", values: new { area = "ProjectOfficeReports" });
    var detailTableUrl = Url.Page("/FFC/MapTableDetailed", values: new { area = "ProjectOfficeReports" });

    // Show all countries, sorted by completed units then by name.
    var countriesToShow = Model.Countries
        .OrderByDescending(country => country.Completed)
        .ThenBy(country => country.Name)
        .ToList();
}

<section class="ffc-simulator-map-widget pm-card pm-shadow" aria-labelledby="ffc-simulator-map-title" data-ffc-map-scope>
    <div class="pm-card-body">
        <div class="ffc-simulator-map-widget__header">
            <div>
                <p class="ffc-simulator-map-widget__eyebrow text-uppercase mb-1">
                    Simulators for Friendly Foreign Countries
                </p>
                <h2 id="ffc-simulator-map-title" class="h5 mb-1">Simulator footprint across FFCs</h2>
            </div>

            <div class="ffc-simulator-map-widget__stats" aria-label="FFC project unit totals">
                <div class="ffc-simulator-map-widget__stat">
                    <span class="label">Installed units</span>
                    <strong>@Model.TotalInstalled</strong>
                </div>
                <div class="ffc-simulator-map-widget__stat">
                    <span class="label">Delivered, awaiting installation</span>
                    <strong>@Model.TotalDelivered</strong>
                </div>
                <div class="ffc-simulator-map-widget__stat ffc-simulator-map-widget__stat--emphasis">
                    <span class="label">Completed units</span>
                    <strong>@Model.TotalCompleted</strong>
                    @if (Model.TotalPlanned > 0)
                    {
                        <span class="ffc-simulator-map-widget__stat-note">
                            @Model.TotalPlanned planned units
                        </span>
                    }
                </div>
            </div>

            <a href="@fullMapUrl" class="btn btn-outline-primary btn-sm">View full map</a>
        </div>

        @if (Model.HasData)
        {
            <div class="ffc-simulator-map"
                 data-widget="ffc-simulator-map"
                 data-countries="@payload"
                 data-geo-url="@geoUrl"
                 data-focus-bounds="@focusBounds"
                 data-auto-fit="true"
                 data-auto-fit-max-zoom="4"
                 data-deconflict-markers="true"
                 data-highlight-color="var(--pm-accent-ffc)"
                 aria-live="polite">
                <div class="ffc-simulator-map__canvas"
                     role="region"
                     aria-label="Interactive map showing completed and planned simulator units across Friendly Foreign Countries">
                </div>
                <div class="ffc-simulator-map__status" data-map-status>
                    Loading delivery footprint…
                </div>
            </div>

            <div class="dashboard-ffc-footnotes">
                @* SECTION: Below-map country chip strip *@
                <div class="ffc-simulator-map__country-strip" aria-label="FFC project unit activity by country">
                    <div class="ffc-country-strip" role="list">
                        @foreach (var country in countriesToShow)
                        {
                            <a asp-area="ProjectOfficeReports"
                               asp-page="/FFC/MapTableDetailed"
                               asp-route-countryId="@country.CountryId"
                               class="ffc-country-chip"
                               data-country-chip="@country.Iso3"
                               title="Open FFC projects for @country.Name"
                               role="listitem">
                                <span class="ffc-country-chip__name">@country.Name</span>
                                <span class="ffc-country-chip__total">
                                    (<strong>@country.Completed</strong> completed
                                    @if (country.Planned > 0)
                                    {
                                        <span class="ffc-country-chip__planned">
                                            +@country.Planned planned
                                        </span>
                                    }
                                    )
                                </span>
                            </a>
                        }
                    </div>
                </div>

                <div class="mt-2">
                    <a href="@detailTableUrl"
                       class="btn btn-link btn-sm px-0">
                        View detailed table →
                    </a>
                </div>
            </div>
        }
        else
        {
            <p class="text-secondary small mb-0 mt-3">
                FFC project unit data is not available right now.
            </p>
        }
    </div>
</section>
@* END SECTION *@
