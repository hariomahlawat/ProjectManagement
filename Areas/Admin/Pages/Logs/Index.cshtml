@page
@model ProjectManagement.Areas.Admin.Pages.Logs.IndexModel
@using System.Text.Json
@using ProjectManagement.Services.Admin
@{
    ViewData["Title"] = "Audit logs";
    var series = Model.Result.SeriesLabels.Select((label, index) => new
    {
        label,
        count = index < Model.Result.SeriesCounts.Count ? Model.Result.SeriesCounts[index] : 0
    });
}

<partial name="~/Areas/Admin/Pages/Shared/_AdminPageHeader.cshtml" model="Model.Header" />

<section class="admin-monitoring-metric-grid" aria-label="Audit log summary">
    @foreach (var metric in Model.Metrics)
    {
        <partial name="~/Areas/Admin/Pages/Shared/_AdminMonitoringMetric.cshtml" model="metric" />
    }
</section>

<section class="admin-panel admin-monitoring-filter-panel" aria-labelledby="audit-filter-title">
    <header class="admin-panel__header admin-panel__header--compact">
        <div>
            <div class="admin-panel__eyebrow">Audit scope</div>
            <h2 id="audit-filter-title">Search and filters</h2>
        </div>
        <span class="admin-panel__meta">Showing @Model.FirstRow–@Model.LastRow of @Model.Result.Total.ToString("N0")</span>
    </header>

    <form method="get" class="admin-audit-filter" data-admin-audit-filter>
        <input type="hidden" name="PageNo" value="1" />
        <input type="hidden" asp-for="Sort" />
        <input type="hidden" asp-for="Dir" />
        @if (!string.IsNullOrWhiteSpace(Model.UserId))
        {
            <input type="hidden" asp-for="UserId" />
        }

        <div class="admin-audit-filter__primary">
            <div class="admin-filter-toolbar__field admin-filter-toolbar__field--search">
                <label asp-for="Contains">Search</label>
                <div class="admin-input-with-icon">
                    <i class="bi bi-search" aria-hidden="true"></i>
                    <input asp-for="Contains" class="form-control" placeholder="Event, message or record reference" />
                </div>
            </div>

            <div class="admin-filter-toolbar__field">
                <label asp-for="Level">Severity</label>
                <select asp-for="Level" class="form-select" data-admin-audit-submit>
                    <option value="">All severities</option>
                    <option value="Info">Information</option>
                    <option value="Warning">Warning</option>
                    <option value="Error">Error</option>
                </select>
            </div>

            <div class="admin-filter-toolbar__field">
                <label asp-for="Category">Category</label>
                <select asp-for="Category" class="form-select" data-admin-audit-submit>
                    <option value="">All categories</option>
                    <option value="authentication">Authentication</option>
                    <option value="access-security">Access &amp; security</option>
                    <option value="projects">Projects</option>
                    <option value="documents">Documents</option>
                    <option value="calendar">Calendar</option>
                    <option value="recovery">Recovery</option>
                    <option value="master-data">Master data</option>
                </select>
            </div>

            <div class="admin-filter-toolbar__field admin-filter-toolbar__field--page-size">
                <label asp-for="PageSize">Rows</label>
                <select asp-for="PageSize" class="form-select" data-admin-audit-submit>
                    @foreach (var size in new[] { 25, 50, 100, 200 })
                    {
                        <option value="@size">@size</option>
                    }
                </select>
            </div>

            <div class="admin-filter-toolbar__actions">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-funnel" aria-hidden="true"></i>
                    Apply
                </button>
                @if (Model.HasFilters)
                {
                    <a class="btn btn-outline-secondary" asp-page="./Index">Clear</a>
                }
            </div>
        </div>

        <details class="admin-advanced-filters" @(string.IsNullOrWhiteSpace(Model.Action) && string.IsNullOrWhiteSpace(Model.EntityType) && string.IsNullOrWhiteSpace(Model.UserName) && string.IsNullOrWhiteSpace(Model.Ip) && !Model.From.HasValue && !Model.To.HasValue ? null : "open")>
            <summary><i class="bi bi-sliders" aria-hidden="true"></i> More filters</summary>
            <div class="admin-advanced-filters__grid">
                <div class="admin-filter-toolbar__field">
                    <label asp-for="Action">Exact action</label>
                    <input asp-for="Action" class="form-control" list="audit-action-options" placeholder="Select or enter an action" />
                    <datalist id="audit-action-options">
                        @foreach (var action in Model.Result.ActionOptions)
                        {
                            <option value="@action"></option>
                        }
                    </datalist>
                </div>

                <div class="admin-filter-toolbar__field">
                    <label asp-for="EntityType">Affected record type</label>
                    <select asp-for="EntityType" class="form-select">
                        <option value="">All record types</option>
                        <option value="ApplicationUser">User account</option>
                        <option value="Project">Project</option>
                        <option value="Document">Document</option>
                        <option value="Event">Calendar event</option>
                    </select>
                </div>

                <div class="admin-filter-toolbar__field">
                    <label asp-for="UserName">Actor</label>
                    <input asp-for="UserName" class="form-control" placeholder="Name or username" disabled="@(string.IsNullOrWhiteSpace(Model.UserId) ? null : "disabled")" />
                    @if (!string.IsNullOrWhiteSpace(Model.UserId))
                    {
                        <small>Exact user filter is active.</small>
                    }
                </div>

                <div class="admin-filter-toolbar__field">
                    <label asp-for="Ip">Source IP</label>
                    <input asp-for="Ip" class="form-control" placeholder="IP address" />
                </div>

                <div class="admin-filter-toolbar__field">
                    <label asp-for="From">From</label>
                    <input asp-for="From" type="date" class="form-control" />
                </div>

                <div class="admin-filter-toolbar__field">
                    <label asp-for="To">To</label>
                    <input asp-for="To" type="date" class="form-control" />
                </div>
            </div>
        </details>

        @if (Model.HasFilters)
        {
            <div class="admin-active-filters" aria-label="Active filters">
                <span class="admin-active-filters__label">Active filters</span>
                @if (!string.IsNullOrWhiteSpace(Model.Level)) { <span class="admin-filter-chip">Severity: @Model.Level</span> }
                @if (!string.IsNullOrWhiteSpace(Model.Category)) { <span class="admin-filter-chip">Category: @Model.Category.Replace('-', ' ')</span> }
                @if (!string.IsNullOrWhiteSpace(Model.Action)) { <span class="admin-filter-chip">Action: @Model.Action</span> }
                @if (!string.IsNullOrWhiteSpace(Model.EntityType)) { <span class="admin-filter-chip">Record: @Model.EntityType</span> }
                @if (!string.IsNullOrWhiteSpace(Model.UserName)) { <span class="admin-filter-chip">Actor: @Model.UserName</span> }
                @if (!string.IsNullOrWhiteSpace(Model.UserId)) { <span class="admin-filter-chip">Exact user account</span> }
                @if (!string.IsNullOrWhiteSpace(Model.Ip)) { <span class="admin-filter-chip">IP: @Model.Ip</span> }
                @if (!string.IsNullOrWhiteSpace(Model.Contains)) { <span class="admin-filter-chip">Search: @Model.Contains</span> }
                @if (Model.From.HasValue) { <span class="admin-filter-chip">From: @Model.From.Value.ToString("dd MMM yyyy")</span> }
                @if (Model.To.HasValue) { <span class="admin-filter-chip">To: @Model.To.Value.ToString("dd MMM yyyy")</span> }
            </div>
        }
    </form>
</section>

@if (Model.Result.SeriesLabels.Count > 0)
{
    <section class="admin-panel" aria-labelledby="audit-trend-title">
        <header class="admin-panel__header">
            <div>
                <div class="admin-panel__eyebrow">Event volume</div>
                <h2 id="audit-trend-title">Events over time</h2>
            </div>
            <span class="admin-panel__meta">Grouped by IST calendar day</span>
        </header>
        <div class="admin-chart-frame admin-chart-frame--audit">
            <canvas id="adminAuditTrend" data-series="@JsonSerializer.Serialize(series)" aria-label="Audit events grouped by day" role="img"></canvas>
        </div>
    </section>
}

<section class="admin-panel admin-audit-directory" aria-labelledby="audit-directory-title">
    <header class="admin-panel__header">
        <div>
            <div class="admin-panel__eyebrow">Event directory</div>
            <h2 id="audit-directory-title">Audit events</h2>
        </div>
        <span class="admin-panel__meta">@Model.Result.Total.ToString("N0") result@(Model.Result.Total == 1 ? string.Empty : "s")</span>
    </header>

    @if (Model.Result.Rows.Count == 0)
    {
        <partial name="~/Areas/Admin/Pages/Shared/_AdminEmptyState.cshtml"
                 model="@(new ProjectManagement.Areas.Admin.Models.AdminEmptyStateModel
                 {
                     Icon = "bi-journal-check",
                     Title = "No audit events found",
                     Description = "Adjust the filters or date range to review a different audit scope."
                 })" />
    }
    else
    {
        <div class="admin-data-table-wrap">
            <table class="admin-data-table admin-audit-table">
                <thead>
                    <tr>
                        <th scope="col"><a class="admin-sort-link" href="@Model.SortUrl("Action")">Event <i class="bi bi-arrow-down-up" aria-hidden="true"></i></a></th>
                        <th scope="col"><a class="admin-sort-link" href="@Model.SortUrl("User")">Actor <i class="bi bi-arrow-down-up" aria-hidden="true"></i></a></th>
                        <th scope="col">Affected record</th>
                        <th scope="col"><a class="admin-sort-link" href="@Model.SortUrl("Time")">Time <i class="bi bi-arrow-down-up" aria-hidden="true"></i></a></th>
                        <th scope="col"><a class="admin-sort-link" href="@Model.SortUrl("Level")">Severity <i class="bi bi-arrow-down-up" aria-hidden="true"></i></a></th>
                        <th scope="col" class="admin-data-table__actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Result.Rows)
                    {
                        var presentation = Model.Presentation(row);
                        var client = Model.Client(row);
                        var payload = row.Payload;
                        var entityLink = Model.EntityLink(row);
                        <tr>
                            <td>
                                <div class="admin-audit-event-cell">
                                    <span class="admin-audit-event-cell__icon admin-audit-event-cell__icon--@presentation.Tone" aria-hidden="true"><i class="bi @presentation.Icon"></i></span>
                                    <span class="admin-audit-event-cell__copy">
                                        <strong>@presentation.Label</strong>
                                        <span>@(string.IsNullOrWhiteSpace(row.Message) ? presentation.Category : row.Message)</span>
                                        <code>@row.Action</code>
                                    </span>
                                </div>
                            </td>
                            <td>
                                <div class="admin-activity-value">
                                    <strong>@(payload?.ActorName ?? row.UserName ?? "System")</strong>
                                    <span>@(string.IsNullOrWhiteSpace(payload?.ActorRoles) ? presentation.Category : payload.ActorRoles)</span>
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(payload?.AffectedRecord))
                                {
                                    <div class="admin-affected-record">
                                        <strong>@payload.EntityType</strong>
                                        <span>@payload.EntityId</span>
                                        @if (entityLink is not null)
                                        {
                                            <a href="@entityLink.Href">@entityLink.Text <i class="bi bi-arrow-up-right" aria-hidden="true"></i></a>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="admin-muted-value">Not recorded</span>
                                }
                            </td>
                            <td>
                                <div class="admin-activity-value">
                                    <strong>@Model.FormatIst(row.TimeUtc)</strong>
                                    <span title="@client.RawUserAgent">@(string.IsNullOrWhiteSpace(row.Ip) ? client.Summary : row.Ip)</span>
                                </div>
                            </td>
                            <td><span class="admin-status-pill admin-status-pill--@presentation.Tone">@row.Level</span></td>
                            <td class="admin-data-table__actions">
                                <button class="btn btn-sm btn-icon" type="button" data-admin-audit-detail="audit-detail-@row.Id" aria-label="View details for @presentation.Label">
                                    <i class="bi bi-eye" aria-hidden="true"></i>
                                </button>
                                <script type="application/json" id="audit-detail-@row.Id">@Html.Raw(Model.DetailJson(row))</script>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Result.TotalPages > 1)
        {
            var firstPage = Math.Max(1, Model.Result.Page - 2);
            var lastPage = Math.Min(Model.Result.TotalPages, Model.Result.Page + 2);
            <nav class="admin-pagination" aria-label="Audit log pages">
                <span>Page @Model.Result.Page of @Model.Result.TotalPages</span>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.Result.Page <= 1 ? "disabled" : string.Empty)"><a class="page-link" href="@Model.PageUrl(Model.Result.Page - 1)">Previous</a></li>
                    @for (var pageNumber = firstPage; pageNumber <= lastPage; pageNumber++)
                    {
                        <li class="page-item @(pageNumber == Model.Result.Page ? "active" : string.Empty)"><a class="page-link" href="@Model.PageUrl(pageNumber)">@pageNumber</a></li>
                    }
                    <li class="page-item @(Model.Result.Page >= Model.Result.TotalPages ? "disabled" : string.Empty)"><a class="page-link" href="@Model.PageUrl(Model.Result.Page + 1)">Next</a></li>
                </ul>
            </nav>
        }
    }
</section>

<div class="offcanvas offcanvas-end admin-audit-drawer" tabindex="-1" id="adminAuditDrawer" aria-labelledby="adminAuditDrawerTitle">
    <div class="offcanvas-header">
        <div>
            <div class="admin-panel__eyebrow" data-audit-category>Audit event</div>
            <h2 class="offcanvas-title" id="adminAuditDrawerTitle" data-audit-title>Event details</h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <div class="admin-audit-drawer__status">
            <span class="admin-status-pill" data-audit-severity>Information</span>
            <time data-audit-time></time>
        </div>

        <dl class="admin-audit-detail-list">
            <div><dt>Actor</dt><dd data-audit-actor>—</dd></div>
            <div><dt>Affected record</dt><dd data-audit-record>—</dd></div>
            <div><dt>Source</dt><dd data-audit-source>—</dd></div>
            <div><dt>Client</dt><dd data-audit-client>—</dd></div>
            <div><dt>Outcome</dt><dd data-audit-outcome>—</dd></div>
            <div><dt>Reason</dt><dd data-audit-reason>—</dd></div>
            <div><dt>Trace/reference</dt><dd data-audit-trace>—</dd></div>
        </dl>

        <div class="admin-audit-message" data-audit-message-wrap hidden>
            <h3>Event summary</h3>
            <p data-audit-message></p>
        </div>

        <a class="btn btn-outline-primary admin-audit-drawer__entity-link" data-audit-entity-link hidden></a>

        <details class="admin-technical-details" data-audit-before-wrap hidden>
            <summary>Values before the change</summary>
            <pre><code data-audit-before></code></pre>
        </details>
        <details class="admin-technical-details" data-audit-after-wrap hidden>
            <summary>Values after the change</summary>
            <pre><code data-audit-after></code></pre>
        </details>
        <details class="admin-technical-details" data-audit-raw-wrap hidden>
            <summary>Raw technical data</summary>
            <div class="admin-technical-details__actions"><button class="btn btn-sm btn-outline-secondary" type="button" data-audit-copy><i class="bi bi-clipboard" aria-hidden="true"></i> Copy</button></div>
            <pre><code data-audit-raw></code></pre>
        </details>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chart.js/chart.umd.js" asp-append-version="true"></script>
    <script type="module" src="~/js/admin/admin-audit-logs.js" asp-append-version="true"></script>
}
