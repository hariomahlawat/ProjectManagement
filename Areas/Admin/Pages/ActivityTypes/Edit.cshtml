@page "{id:int}"
@model ProjectManagement.Areas.Admin.Pages.ActivityTypes.EditModel
@using ProjectManagement.Areas.Admin.Models
@{
    ViewData["Title"] = "Edit activity type";
    var header = new AdminPageHeaderModel
    {
        Eyebrow = "Master data · Activity types",
        Title = $"Edit {Model.Input.Name}",
        Description = "Update the classification purpose or availability while preserving existing activities.",
        Icon = "bi-pencil-square",
        Actions = new[] { new AdminPageActionModel { Text = "Back to activity types", Href = Url.Page("./Index"), Icon = "bi-arrow-left" } }
    };
}
<partial name="~/Areas/Admin/Pages/Shared/_AdminPageHeader.cshtml" model="header" />
<div class="admin-form-layout">
    <form method="post" class="admin-panel admin-form-panel" novalidate>
        <input asp-for="Input.RowVersion" type="hidden" />
        <header class="admin-form-section__header"><span>01</span><div><h2>Activity classification</h2><p>Changes apply to all places where this type is displayed.</p></div></header>
        <div class="admin-form-section__body">
            <div asp-validation-summary="ModelOnly" class="admin-validation-summary" role="alert"></div>
            <div class="admin-form-grid">
                <div class="admin-field"><label asp-for="Input.Name"></label><input asp-for="Input.Name" class="form-control" maxlength="120" autocomplete="off" /><span asp-validation-for="Input.Name" class="text-danger"></span></div>
                <div class="admin-field"><label asp-for="Input.Description"></label><textarea asp-for="Input.Description" class="form-control" rows="4" maxlength="512"></textarea><span asp-validation-for="Input.Description" class="text-danger"></span></div>
            </div>
            <label class="admin-switch-row"><input asp-for="Input.IsActive" type="checkbox" /><span><strong>Active</strong><small>Inactive types remain visible on historical activities but cannot be selected for new records.</small></span></label>
        </div>
        <footer class="admin-form-actions"><a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a><button class="btn btn-primary" type="submit"><i class="bi bi-check-lg"></i>Save changes</button></footer>
    </form>
    <aside class="admin-guidance-card"><span class="admin-guidance-card__icon"><i class="bi bi-shield-check"></i></span><h2>Change control</h2><p>Duplicate names, invalid descriptions and stale concurrent edits are rejected without changing the record.</p></aside>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
