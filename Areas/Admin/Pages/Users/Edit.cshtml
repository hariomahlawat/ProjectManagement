@page "{id}"
@model ProjectManagement.Areas.Admin.Pages.Users.EditModel
@{
    ViewData["Title"] = "Edit user";
    var roleGrid = new AdminRoleSelectionGridModel
    {
        Roles = Model.RoleOptions,
        SelectedRoles = Model.Input.Roles,
        InputName = "Input.Roles",
        IdPrefix = "edit-role"
    };
}

<partial name="~/Areas/Admin/Pages/Shared/_AdminPageHeader.cshtml" model="Model.Header" />
<partial name="~/Areas/Admin/Pages/Shared/_AdminFlashMessages.cshtml" />

@if (Model.Account is not null)
{
    <section class="admin-panel admin-user-form-context" aria-label="Account being edited">
        <partial name="~/Areas/Admin/Pages/Shared/_AdminUserIdentity.cshtml" model="Model.Account" />
    </section>
}

<form method="post" class="admin-user-form" novalidate>
    <input type="hidden" asp-for="Input.Id" />
    <div asp-validation-summary="ModelOnly" class="admin-validation-summary" role="alert"></div>

    <section class="admin-form-section" aria-labelledby="edit-user-identity-title">
        <header class="admin-form-section__header">
            <span class="admin-form-section__step">01</span>
            <div>
                <h2 id="edit-user-identity-title">Identity</h2>
                <p>Update the official name and rank displayed in PRISM. The username remains permanent.</p>
            </div>
        </header>
        <div class="admin-form-section__body">
            <div class="admin-form-grid admin-form-grid--three">
                <div class="admin-field">
                    <label>Username</label>
                    <input class="form-control" value="@Model.Account?.UserName" disabled aria-describedby="username-immutable-note" />
                    <span id="username-immutable-note" class="admin-field__hint">The sign-in name cannot be changed from this workflow.</span>
                </div>
                <div class="admin-field">
                    <label asp-for="Input.Rank"></label>
                    <input asp-for="Input.Rank" class="form-control" maxlength="32" autocomplete="organization-title" />
                    <span asp-validation-for="Input.Rank" class="text-danger"></span>
                </div>
                <div class="admin-field">
                    <label asp-for="Input.FullName"></label>
                    <input asp-for="Input.FullName" class="form-control" maxlength="100" autocomplete="name" />
                    <span asp-validation-for="Input.FullName" class="text-danger"></span>
                </div>
            </div>
        </div>
    </section>

    <section class="admin-form-section" aria-labelledby="edit-user-roles-title">
        <header class="admin-form-section__header">
            <span class="admin-form-section__step">02</span>
            <div>
                <h2 id="edit-user-roles-title">Roles and access</h2>
                <p>Review the complete role set. Removing or adding roles refreshes the account security state.</p>
            </div>
        </header>
        <div class="admin-form-section__body">
            <partial name="~/Areas/Admin/Pages/Shared/_AdminRoleSelectionGrid.cshtml" model="roleGrid" />
            <span asp-validation-for="Input.Roles" class="text-danger"></span>
        </div>
    </section>

    <section class="admin-form-section admin-form-section--compact" aria-labelledby="edit-user-state-title">
        <header class="admin-form-section__header">
            <span class="admin-form-section__step">03</span>
            <div>
                <h2 id="edit-user-state-title">Account state</h2>
                <p>Lifecycle controls are separated from profile editing to prevent accidental access changes.</p>
            </div>
        </header>
        <div class="admin-form-section__body admin-form-section__body--state">
            @if (Model.Account is not null)
            {
                <partial name="~/Areas/Admin/Pages/Shared/_AdminUserStateBadge.cshtml" model="Model.Account.AccountState" />
                <a asp-page="./Details" asp-route-id="@Model.Account.Id" class="btn btn-sm btn-outline-secondary">
                    Review lifecycle actions
                </a>
            }
        </div>
    </section>

    <footer class="admin-form-actions">
        <a asp-page="./Details" asp-route-id="@Model.Input.Id" class="btn btn-outline-secondary">Cancel</a>
        <button class="btn btn-primary" type="submit">
            <i class="bi bi-check2" aria-hidden="true"></i>
            Save changes
        </button>
    </footer>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="module" src="~/js/admin/admin-users.js" asp-append-version="true"></script>
}
