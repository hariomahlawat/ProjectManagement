@using ProjectManagement.Services.Admin
@{
    var successKeys = new[]
    {
        FlashMessageKeys.AdminUsersSuccess,
        FlashMessageKeys.AdminMasterDataSuccess,
        FlashMessageKeys.AdminCalendarRecoverySuccess,
        FlashMessageKeys.AdminHolidaysSuccess,
        FlashMessageKeys.AdminPdfIngestionSuccess,
        FlashMessageKeys.AdminRecoverySuccess,
        FlashMessageKeys.AdminMaintenanceSuccess,
        FlashMessageKeys.CelebrationsSuccess,
        FlashMessageKeys.IdentitySuccess
    };
    var errorKeys = new[]
    {
        FlashMessageKeys.AdminUsersError,
        FlashMessageKeys.AdminMasterDataError,
        FlashMessageKeys.AdminCalendarRecoveryError,
        FlashMessageKeys.AdminHolidaysError,
        FlashMessageKeys.AdminPdfIngestionError,
        FlashMessageKeys.AdminRecoveryError,
        FlashMessageKeys.AdminMaintenanceError,
        FlashMessageKeys.CelebrationsError,
        FlashMessageKeys.IdentityError
    };
    var successMessage = successKeys.Select(key => TempData[key] as string).FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));
    var errorMessage = errorKeys.Select(key => TempData[key] as string).FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));
}
@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="admin-flash admin-flash--success" role="status" data-admin-flash>
        <span class="admin-flash__icon" aria-hidden="true"><i class="bi bi-check-circle"></i></span>
        <div class="admin-flash__copy"><strong>Completed</strong><span>@successMessage</span></div>
        <button type="button" class="admin-flash__dismiss" data-admin-flash-dismiss aria-label="Dismiss notification"><i class="bi bi-x-lg" aria-hidden="true"></i></button>
    </div>
}
@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="admin-flash admin-flash--danger" role="alert" data-admin-flash>
        <span class="admin-flash__icon" aria-hidden="true"><i class="bi bi-exclamation-octagon"></i></span>
        <div class="admin-flash__copy"><strong>Action not completed</strong><span>@errorMessage</span></div>
        <button type="button" class="admin-flash__dismiss" data-admin-flash-dismiss aria-label="Dismiss notification"><i class="bi bi-x-lg" aria-hidden="true"></i></button>
    </div>
}
