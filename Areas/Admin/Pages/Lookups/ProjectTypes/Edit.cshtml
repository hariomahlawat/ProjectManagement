@page "{id:int}"
@model ProjectManagement.Areas.Admin.Pages.Lookups.ProjectTypes.EditModel
@using ProjectManagement.Areas.Admin.Models
@{
    ViewData["Title"] = "Edit project type";
    var header = new AdminPageHeaderModel { Eyebrow = "Master data · Project types", Title = $"Edit {Model.Input.Name}", Description = "Update the reference name or display order.", Icon = "bi-pencil-square", Actions = new[] { new AdminPageActionModel { Text = "Back to project types", Href = Url.Page("./Index"), Icon = "bi-arrow-left" } } };
}
<partial name="~/Areas/Admin/Pages/Shared/_AdminPageHeader.cshtml" model="header" />
<div class="admin-form-layout">
<form method="post" class="admin-panel admin-form-panel" novalidate><input asp-for="Input.Id" type="hidden" /><input asp-for="Input.RowVersion" type="hidden" />
<header class="admin-form-section__header"><span>01</span><div><h2>Reference details</h2><p>Existing project references remain linked after a rename.</p></div></header>
<div class="admin-form-section__body"><div asp-validation-summary="ModelOnly" class="admin-validation-summary" role="alert"></div><div class="admin-form-grid admin-form-grid--two"><div class="admin-field admin-field--wide"><label asp-for="Input.Name"></label><input asp-for="Input.Name" class="form-control" maxlength="200" autocomplete="off" /><span asp-validation-for="Input.Name" class="text-danger"></span></div><div class="admin-field"><label asp-for="Input.SortOrder">Display order</label><input asp-for="Input.SortOrder" class="form-control" type="number" min="0" max="1000" /><span asp-validation-for="Input.SortOrder" class="text-danger"></span><small>Use directory move controls for routine reordering.</small></div></div></div>
<footer class="admin-form-actions"><a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a><button class="btn btn-primary" type="submit"><i class="bi bi-check-lg"></i>Save changes</button></footer>
</form>
<aside class="admin-guidance-card"><span class="admin-guidance-card__icon"><i class="bi bi-shield-check"></i></span><h2>Change control</h2><p>Duplicate names and stale concurrent edits are rejected without changing the record.</p></aside>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
