@page
@model ProjectManagement.Areas.Admin.Pages.Lookups.LineDirectorates.CreateModel
@using ProjectManagement.Areas.Admin.Models
@{
    ViewData["Title"] = "Add line directorate";
    var header = new AdminPageHeaderModel { Eyebrow = "Master data · Line directorates", Title = "Add line directorate", Description = "Create a controlled reference value for use in project records.", Icon = "bi-plus-circle", Actions = new[] { new AdminPageActionModel { Text = "Back to line directorates", Href = Url.Page("./Index"), Icon = "bi-arrow-left" } } };
}
<partial name="~/Areas/Admin/Pages/Shared/_AdminPageHeader.cshtml" model="header" />
<div class="admin-form-layout">
<form method="post" class="admin-panel admin-form-panel" novalidate>
<header class="admin-form-section__header"><span>01</span><div><h2>Reference details</h2><p>Use a clear name that can remain stable across reporting periods.</p></div></header>
<div class="admin-form-section__body"><div asp-validation-summary="ModelOnly" class="admin-validation-summary" role="alert"></div><div class="admin-form-grid admin-form-grid--two"><div class="admin-field admin-field--wide"><label asp-for="Input.Name"></label><input asp-for="Input.Name" class="form-control" maxlength="200" autocomplete="off" autofocus /><span asp-validation-for="Input.Name" class="text-danger"></span></div><div class="admin-field"><label asp-for="Input.SortOrder">Initial display order</label><input asp-for="Input.SortOrder" class="form-control" type="number" min="0" max="1000" /><span asp-validation-for="Input.SortOrder" class="text-danger"></span><small>Items can be reordered later from the directory.</small></div></div></div>
<footer class="admin-form-actions"><a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a><button class="btn btn-primary" type="submit"><i class="bi bi-plus-lg"></i>Create line directorate</button></footer>
</form>
<aside class="admin-guidance-card"><span class="admin-guidance-card__icon"><i class="bi bi-diagram-2"></i></span><h2>Reference-list governance</h2><p>Names must be unique. Once referenced by a project, deactivate the value instead of removing its historical meaning.</p></aside>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
