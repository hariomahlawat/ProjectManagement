@page "{id:int}"
@model ProjectManagement.Areas.Admin.Pages.Categories.EditModel
@using ProjectManagement.Areas.Admin.Models
@{
    ViewData["Title"] = "Edit project category";
    var header = new AdminPageHeaderModel
    {
        Eyebrow = "Master data · Project categories",
        Title = $"Edit {Model.Input.Name}",
        Description = "Update the category name, hierarchy position or availability.",
        Icon = "bi-pencil-square",
        Actions = new[] { new AdminPageActionModel { Text = "Back to categories", Href = Url.Page("./Index"), Icon = "bi-arrow-left" } }
    };
}
<partial name="~/Areas/Admin/Pages/Shared/_AdminPageHeader.cshtml" model="header" />
<div class="admin-form-layout">
    <form method="post" class="admin-panel admin-form-panel" novalidate>
        <input asp-for="Input.Id" type="hidden" /><input asp-for="Input.RowVersion" type="hidden" />
        <header class="admin-form-section__header"><span>01</span><div><h2>Category details</h2><p>Moving a category preserves existing project references and child categories.</p></div></header>
        <div class="admin-form-section__body">
            <div asp-validation-summary="ModelOnly" class="admin-validation-summary" role="alert"></div>
            <div class="admin-form-grid admin-form-grid--two">
                <div class="admin-field admin-field--wide"><label asp-for="Input.Name"></label><input asp-for="Input.Name" class="form-control" maxlength="120" autocomplete="off" /><span asp-validation-for="Input.Name" class="text-danger"></span></div>
                <div class="admin-field"><label asp-for="Input.ParentId">Parent category</label><select asp-for="Input.ParentId" asp-items="Model.ParentOptions" class="form-select"></select><span asp-validation-for="Input.ParentId" class="text-danger"></span><small>A category cannot be moved below one of its descendants.</small></div>
            </div>
            <label class="admin-switch-row"><input asp-for="Input.IsActive" type="checkbox" /><span><strong>Active</strong><small>Inactive values remain on existing project records but are unavailable for new selection.</small></span></label>
        </div>
        <footer class="admin-form-actions"><a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a><button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i>Save changes</button></footer>
    </form>
    <aside class="admin-guidance-card"><span class="admin-guidance-card__icon"><i class="bi bi-shield-check"></i></span><h2>Change control</h2><p>Hierarchy cycles and duplicate sibling names are blocked. Concurrent edits require the page to be reloaded.</p></aside>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
