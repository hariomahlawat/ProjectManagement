@page
@model ProjectManagement.Areas.Admin.Pages.AdminIndexModel
@using ProjectManagement.Areas.Admin.Models
@using ProjectManagement.Services.Navigation.ModuleNav
@{
    ViewData["Title"] = "Administration";
}

<partial name="~/Areas/Admin/Pages/Shared/_AdminPageHeader.cshtml" model="Model.Header" />

<section class="admin-operational-status admin-operational-status--@Model.OperationalTone"
         aria-labelledby="admin-operational-status-title">
    <div class="admin-operational-status__indicator" aria-hidden="true">
        <i class="bi @Model.OperationalIcon"></i>
    </div>
    <div class="admin-operational-status__copy">
        <div class="admin-operational-status__eyebrow">Operational oversight</div>
        <div class="admin-operational-status__title-row">
            <h2 id="admin-operational-status-title">@Model.OperationalLabel</h2>
            <span class="admin-status-pill admin-status-pill--@Model.OperationalTone">Current</span>
        </div>
        <p>@Model.OperationalSummary</p>
    </div>
    <a class="admin-operational-status__action"
       href="@Model.NavigationHref(AdminNavigationKeys.DatabaseHealth)">
        View system health
        <i class="bi bi-arrow-right" aria-hidden="true"></i>
    </a>
</section>

<section aria-labelledby="admin-overview-title" class="admin-dashboard-section">
    <div class="admin-section-heading">
        <div>
            <h2 id="admin-overview-title">Overview</h2>
            <p>Current access, authentication, audit and recovery indicators.</p>
        </div>
    </div>

    <div class="admin-metrics-grid">
        @foreach (var metric in Model.MetricCards)
        {
            <partial name="~/Areas/Admin/Pages/Shared/_AdminMetricCard.cshtml" model="metric" />
        }
    </div>
</section>

<div class="admin-dashboard-primary-grid">
    <section class="admin-panel" aria-labelledby="admin-attention-title">
        <header class="admin-panel__header">
            <div>
                <div class="admin-panel__eyebrow">Prioritised queue</div>
                <h2 id="admin-attention-title">Needs attention</h2>
            </div>
            @if (Model.AttentionItems.Count > 0)
            {
                <span class="admin-panel__count">@Model.AttentionItems.Count</span>
            }
        </header>

        @if (Model.AttentionItems.Count > 0)
        {
            <div class="admin-attention-list">
                @foreach (var item in Model.AttentionItems)
                {
                    <article class="admin-attention-item admin-attention-item--@item.Tone">
                        <span class="admin-attention-item__icon" aria-hidden="true">
                            <i class="bi @item.Icon"></i>
                        </span>
                        <div class="admin-attention-item__copy">
                            <h3>@item.Title</h3>
                            <p>@item.Detail</p>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(item.Href))
                        {
                            <a class="admin-attention-item__action" href="@item.Href">
                                @item.LinkText
                                <i class="bi bi-chevron-right" aria-hidden="true"></i>
                            </a>
                        }
                    </article>
                }
            </div>
        }
        else
        {
            <partial name="~/Areas/Admin/Pages/Shared/_AdminEmptyState.cshtml"
                     model="Model.NoAttentionEmptyState" />
        }
    </section>

    <section class="admin-panel" aria-labelledby="admin-recent-actions-title">
        <header class="admin-panel__header">
            <div>
                <div class="admin-panel__eyebrow">Audit trail</div>
                <h2 id="admin-recent-actions-title">Recent activity</h2>
            </div>
            <a class="admin-panel__header-link" href="@Model.NavigationHref(AdminNavigationKeys.Logs)">
                View all
            </a>
        </header>

        @if (Model.RecentAdminActions.Count > 0)
        {
            <div class="admin-activity-list">
                @foreach (var action in Model.RecentAdminActions)
                {
                    <article class="admin-activity-item">
                        <span class="admin-activity-item__level admin-activity-item__level--@Model.LevelCss(action.Level)"
                              aria-label="@action.Level">
                            <i class="bi @(Model.LevelCss(action.Level) == "danger" ? "bi-x-octagon" : Model.LevelCss(action.Level) == "warning" ? "bi-exclamation-triangle" : "bi-check2")"
                               aria-hidden="true"></i>
                        </span>
                        <div class="admin-activity-item__copy">
                            <h3>@Model.HumaniseAction(action.Action)</h3>
                            <p>@action.Message</p>
                            <div class="admin-activity-item__meta">
                                <span><i class="bi bi-person" aria-hidden="true"></i>@action.Actor</span>
                                <time>@action.WhenLocal</time>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <partial name="~/Areas/Admin/Pages/Shared/_AdminEmptyState.cshtml"
                     model="Model.NoRecentActivityEmptyState" />
        }
    </section>
</div>

<section class="admin-dashboard-section" aria-labelledby="admin-areas-title">
    <div class="admin-section-heading">
        <div>
            <h2 id="admin-areas-title">Administrative areas</h2>
            <p>Direct access to monitoring, recovery, maintenance and controlled master data.</p>
        </div>
    </div>

    <div class="admin-link-group-grid">
        @foreach (var group in Model.LinkGroups)
        {
            <article class="admin-link-group">
                <header class="admin-link-group__header">
                    <span class="admin-link-group__icon" aria-hidden="true">
                        <i class="bi @group.Icon"></i>
                    </span>
                    <div>
                        <h3>@group.Title</h3>
                        <p>@group.Description</p>
                    </div>
                </header>

                <div class="admin-link-group__links">
                    @foreach (var link in group.Links)
                    {
                        <a href="@link.Href" class="admin-link-tile">
                            <span class="admin-link-tile__icon" aria-hidden="true">
                                <i class="bi @(link.Icon ?? "bi-arrow-right-circle")"></i>
                            </span>
                            <span>@link.Text</span>
                            <i class="bi bi-chevron-right admin-link-tile__arrow" aria-hidden="true"></i>
                        </a>
                    }
                </div>
            </article>
        }
    </div>
</section>
