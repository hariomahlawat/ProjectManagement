@page
@model ProjectManagement.Areas.Admin.Pages.Calendar.DeletedModel
@using ProjectManagement.Services.Admin
@{
    ViewData["Title"] = "Deleted calendar events";
}

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a asp-area="Admin" asp-page="/Index">Admin</a></li>
                <li class="breadcrumb-item active" aria-current="page">Deleted events</li>
            </ol>
        </nav>
        <h1 class="h4 mb-1">Deleted calendar events</h1>
        <p class="text-muted mb-0">Review and restore events removed from the shared calendar.</p>
    </div>
</div>

@if (TempData[FlashMessageKeys.AdminCalendarRecoverySuccess] is string successMessage)
{
    <div class="alert alert-success" role="status">@successMessage</div>
}
@if (TempData[FlashMessageKeys.AdminCalendarRecoveryError] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<form method="get" class="card card-body mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-lg-7">
            <label asp-for="Search" class="form-label">Search</label>
            <input asp-for="Search" class="form-control" placeholder="Event title or location" />
        </div>
        <div class="col-lg-3">
            <label asp-for="Category" class="form-label">Category</label>
            <select asp-for="Category" class="form-select">
                <option value="">All categories</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category">@category</option>
                }
            </select>
        </div>
        <div class="col-lg-2 d-grid gap-2">
            <button type="submit" class="btn btn-primary">Apply filters</button>
            <a asp-page="./Deleted" class="btn btn-outline-secondary">Reset</a>
        </div>
    </div>
</form>

<div class="d-flex justify-content-between align-items-center mb-2">
    <span class="text-muted">@Model.Result.TotalCount deleted event(s)</span>
    @if (Model.Result.TotalPages > 1)
    {
        <span class="text-muted">Page @Model.Result.Page of @Model.Result.TotalPages</span>
    }
</div>

@if (Model.Result.Items.Count == 0)
{
    <div class="card card-body text-center py-5">
        <i class="bi bi-calendar-check fs-2 text-muted" aria-hidden="true"></i>
        <h2 class="h6 mt-3">No deleted events found</h2>
        <p class="text-muted mb-0">There are no deleted calendar events matching the current filters.</p>
    </div>
}
else
{
    <div class="card overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Event</th>
                        <th scope="col">Original schedule</th>
                        <th scope="col">Deletion record</th>
                        <th scope="col" class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Result.Items)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@item.Title</div>
                            <div class="d-flex flex-wrap gap-2 mt-1">
                                <span class="badge text-bg-light border">@item.Category</span>
                                @if (item.IsRecurring)
                                {
                                    <span class="badge text-bg-light border"><i class="bi bi-arrow-repeat" aria-hidden="true"></i> Recurring</span>
                                }
                                @if (item.IsAllDay)
                                {
                                    <span class="badge text-bg-light border">All day</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.Location))
                            {
                                <div class="small text-muted mt-1"><i class="bi bi-geo-alt" aria-hidden="true"></i> @item.Location</div>
                            }
                        </td>
                        <td>@Model.FormatSchedule(item)</td>
                        <td>
                            <div>@Model.FormatDeletedAt(item.DeletedAtUtc)</div>
                            <div class="small text-muted">@(item.DeletedByName ?? "User unavailable")</div>
                        </td>
                        <td class="text-end">
                            <form method="post" asp-page-handler="Restore" asp-route-id="@item.Id" class="d-inline"
                                  onsubmit="return confirm('Restore this calendar event?');">
                                <input type="hidden" name="search" value="@Model.Search" />
                                <input type="hidden" name="category" value="@Model.Category" />
                                <input type="hidden" name="pageNumber" value="@Model.Result.Page" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i> Restore
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.Result.TotalPages > 1)
    {
        <nav aria-label="Deleted event pages" class="mt-3">
            <ul class="pagination pagination-sm justify-content-end mb-0">
                <li class="page-item @(Model.Result.Page <= 1 ? "disabled" : null)">
                    <a class="page-link" asp-route-Search="@Model.Search" asp-route-Category="@Model.Category" asp-route-PageNumber="@(Model.Result.Page - 1)">Previous</a>
                </li>
                <li class="page-item disabled"><span class="page-link">@Model.Result.Page / @Model.Result.TotalPages</span></li>
                <li class="page-item @(Model.Result.Page >= Model.Result.TotalPages ? "disabled" : null)">
                    <a class="page-link" asp-route-Search="@Model.Search" asp-route-Category="@Model.Category" asp-route-PageNumber="@(Model.Result.Page + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
}
